        "kind": "platform_capabilities",
        "platform_is": "windows",
        "ui_multi_window_is": true,
        "ui_window_tear_off_is": true
      }
    }
  ],
  "tags": ["imui", "docking", "multiwindow", "windows", "placement", "real-host", "editor-grade"]
