{
  "schema_version": 2,
  "meta": {
    "name": "UI gallery: carousel demo dnd long-press arbitration gate",
    "tags": ["ui-gallery", "carousel", "dnd", "gate"],
    "required_capabilities": ["diag.script_v2"],
    "target_hints": [
      "Navigate to the Carousel page and long-press the DnD region inside the demo slide.",
      "Expected behavior: DnD becomes active and the gesture does not fall back to carousel swipe."
    ]
  },
  "steps": [
    { "type": "reset_diagnostics" },
    { "type": "press_key", "key": "escape" },
    { "type": "wait_frames", "n": 2 },

    {
      "type": "wait_until",
      "predicate": { "kind": "exists", "target": { "kind": "test_id", "id": "ui-gallery-nav-search" } },
      "timeout_frames": 240
    },

    { "type": "set_window_inner_size", "width_px": 1280.0, "height_px": 720.0 },
    { "type": "wait_frames", "n": 10 },

    { "type": "click", "target": { "kind": "test_id", "id": "ui-gallery-nav-search" } },
    { "type": "press_key", "key": "a", "modifiers": { "ctrl": true } },
    { "type": "press_key", "key": "backspace" },
    { "type": "type_text", "text": "carousel" },
    { "type": "wait_frames", "n": 2 },

    {
      "type": "wait_until",
      "predicate": {
        "kind": "bounds_within_window",
        "target": { "kind": "test_id", "id": "ui-gallery-nav-carousel" },
        "padding_px": 8.0,
        "eps_px": 1.0
      },
      "timeout_frames": 240
    },
    { "type": "click", "target": { "kind": "test_id", "id": "ui-gallery-nav-carousel" } },

    {
      "type": "wait_until",
      "predicate": { "kind": "exists", "target": { "kind": "test_id", "id": "ui-gallery-page-carousel" } },
      "timeout_frames": 240
    },
    {
      "type": "scroll_into_view",
      "container": { "kind": "test_id", "id": "ui-gallery-content-scroll" },
      "target": { "kind": "test_id", "id": "ui-gallery-carousel-demo" },
      "delta_y": -120.0,
      "require_fully_within_container": true,
      "require_fully_within_window": true,
      "padding_px": 16.0,
      "timeout_frames": 600
    },

    {
      "type": "wait_until",
      "predicate": { "kind": "exists", "target": { "kind": "test_id", "id": "ui-gallery-carousel-demo-dnd-long-press" } },
      "timeout_frames": 240
    },
    {
      "type": "wait_until",
      "predicate": { "kind": "visible_in_window", "target": { "kind": "test_id", "id": "ui-gallery-carousel-demo-item-1" } },
      "timeout_frames": 240
    },

    { "type": "pointer_down", "pointer_kind": "touch", "target": { "kind": "test_id", "id": "ui-gallery-carousel-demo-dnd-long-press" } },
    { "type": "wait_frames", "n": 20 },
    { "type": "pointer_move", "pointer_kind": "touch", "delta_x": -8.0, "delta_y": 0.0, "steps": 8 },
    {
      "type": "wait_until",
      "predicate": { "kind": "exists", "target": { "kind": "test_id", "id": "ui-gallery-carousel-demo-dnd-active" } },
      "timeout_frames": 240
    },
    { "type": "pointer_up", "pointer_kind": "touch" },
    { "type": "wait_frames", "n": 6 },
    {
      "type": "assert",
      "predicate": { "kind": "visible_in_window", "target": { "kind": "test_id", "id": "ui-gallery-carousel-demo-item-1" } }
    },
    {
      "type": "assert",
      "predicate": { "kind": "not_exists", "target": { "kind": "test_id", "id": "ui-gallery-carousel-demo-dnd-active" } }
    },

    { "type": "capture_bundle", "label": "ui-gallery-carousel-demo-dnd-long-press" }
  ]
}
