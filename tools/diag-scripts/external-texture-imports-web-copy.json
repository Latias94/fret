{
  "schema_version": 2,
  "steps": [
    { "type": "set_window_inner_size", "width_px": 1280.0, "height_px": 720.0 },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "external-texture-imports-web-root" }
      },
      "timeout_frames": 240
    },

    { "type": "wait_frames", "n": 10 },
    { "type": "capture_bundle", "label": "external-texture-imports-web-initial" },
    { "type": "capture_screenshot", "label": "external-texture-imports-web-initial" },

    { "type": "set_window_inner_size", "width_px": 800.0, "height_px": 600.0 },
    { "type": "wait_frames", "n": 12 },
    { "type": "capture_bundle", "label": "external-texture-imports-web-resized" },
    { "type": "capture_screenshot", "label": "external-texture-imports-web-resized" },

    { "type": "press_key", "key": "v" },
    { "type": "wait_frames", "n": 8 },
    { "type": "capture_bundle", "label": "external-texture-imports-web-hidden" },
    { "type": "capture_screenshot", "label": "external-texture-imports-web-hidden" },

    { "type": "press_key", "key": "v" },
    { "type": "wait_frames", "n": 8 },
    { "type": "capture_bundle", "label": "external-texture-imports-web-restored" },
    { "type": "capture_screenshot", "label": "external-texture-imports-web-restored" }
  ]
}

