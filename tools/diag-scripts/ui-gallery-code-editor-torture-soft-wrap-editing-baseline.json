{
  "schema_version": 2,
  "steps": [
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-nav-search" }
      },
      "timeout_frames": 240
    },
    { "type": "click", "target": { "kind": "test_id", "id": "ui-gallery-nav-search" } },
    { "type": "press_key", "key": "a", "modifiers": { "ctrl": true } },
    { "type": "press_key", "key": "backspace" },
    { "type": "type_text", "text": "code_editor_torture" },
    { "type": "wait_frames", "n": 2 },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "bounds_within_window",
        "target": { "kind": "test_id", "id": "ui-gallery-nav-code-editor-torture" },
        "padding_px": 8.0,
        "eps_px": 1.0
      },
      "timeout_frames": 240
    },
    {
      "type": "click",
      "target": { "kind": "test_id", "id": "ui-gallery-nav-code-editor-torture" }
    },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-page-code-editor-torture" }
      },
      "timeout_frames": 240
    },
    { "type": "wait_frames", "n": 30 },
    {
      "type": "click",
      "target": { "kind": "test_id", "id": "ui-gallery-code-editor-torture-soft-wrap" }
    },
    { "type": "wait_frames", "n": 5 },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-code-editor-torture-root" }
      },
      "timeout_frames": 240
    },
    {
      "type": "click",
      "target": { "kind": "test_id", "id": "ui-gallery-code-editor-torture-root" }
    },
    { "type": "wait_frames", "n": 2 },
    {
      "type": "capture_bundle",
      "label": "ui-gallery-code-editor-torture-soft-wrap-editing-before"
    },
    {
      "type": "capture_screenshot",
      "label": "ui-gallery-code-editor-torture-soft-wrap-editing-before"
    },
    {
      "type": "type_text_into",
      "target": {
        "kind": "role_and_name",
        "role": "text_field",
        "name": "Code editor"
      },
      "text": " abc",
      "timeout_frames": 240
    },
    { "type": "wait_frames", "n": 2 },
    { "type": "press_key", "key": "backspace" },
    { "type": "press_key", "key": "backspace" },
    { "type": "press_key", "key": "backspace" },
    { "type": "wait_frames", "n": 2 },
    {
      "type": "type_text_into",
      "target": {
        "kind": "role_and_name",
        "role": "text_field",
        "name": "Code editor"
      },
      "text": " hello_soft_wrap_marker",
      "timeout_frames": 240
    },
    { "type": "wait_frames", "n": 5 },
    {
      "type": "capture_bundle",
      "label": "ui-gallery-code-editor-torture-soft-wrap-editing-after-insert"
    },
    {
      "type": "capture_screenshot",
      "label": "ui-gallery-code-editor-torture-soft-wrap-editing-after-insert"
    },
    { "type": "press_key", "key": "z", "modifiers": { "ctrl": true } },
    { "type": "wait_frames", "n": 8 },
    {
      "type": "capture_bundle",
      "label": "ui-gallery-code-editor-torture-soft-wrap-editing-after-undo"
    },
    {
      "type": "capture_screenshot",
      "label": "ui-gallery-code-editor-torture-soft-wrap-editing-after-undo"
    },
    { "type": "press_key", "key": "z", "modifiers": { "ctrl": true, "shift": true } },
    { "type": "press_key", "key": "y", "modifiers": { "ctrl": true } },
    { "type": "wait_frames", "n": 8 },
    {
      "type": "capture_bundle",
      "label": "ui-gallery-code-editor-torture-soft-wrap-editing-after-redo"
    },
    {
      "type": "capture_screenshot",
      "label": "ui-gallery-code-editor-torture-soft-wrap-editing-after-redo"
    },
    {
      "type": "move_pointer",
      "target": { "kind": "test_id", "id": "ui-gallery-code-editor-torture-viewport" }
    },
    {
      "type": "wheel",
      "target": { "kind": "test_id", "id": "ui-gallery-code-editor-torture-viewport" },
      "delta_y": -480.0
    },
    { "type": "wait_frames", "n": 5 },
    {
      "type": "wheel",
      "target": { "kind": "test_id", "id": "ui-gallery-code-editor-torture-viewport" },
      "delta_y": 480.0
    },
    { "type": "wait_frames", "n": 15 },
    {
      "type": "capture_bundle",
      "label": "ui-gallery-code-editor-torture-soft-wrap-editing-after"
    },
    {
      "type": "capture_screenshot",
      "label": "ui-gallery-code-editor-torture-soft-wrap-editing-after"
    }
  ]
}
