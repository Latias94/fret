{
  "meta": {
    "name": "ui-gallery-control-chrome-tabs-flex1-trigger-fill",
    "required_capabilities": ["diag.script_v2"]
  },
  "schema_version": 2,
  "steps": [
    { "type": "reset_diagnostics" },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-nav-search" }
      },
      "timeout_frames": 600
    },
    { "type": "press_key", "key": "escape" },
    { "type": "wait_frames", "n": 2 },
    { "type": "set_window_inner_size", "width_px": 1280.0, "height_px": 720.0 },
    { "type": "wait_frames", "n": 15 },
    { "type": "click", "target": { "kind": "test_id", "id": "ui-gallery-nav-search" } },
    { "type": "press_key", "key": "a", "modifiers": { "ctrl": true } },
    { "type": "press_key", "key": "backspace" },
    { "type": "type_text", "text": "tabs" },
    { "type": "wait_frames", "n": 2 },
    { "type": "click", "target": { "kind": "test_id", "id": "ui-gallery-nav-tabs" } },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-page-tabs" }
      },
      "timeout_frames": 600
    },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-tabs-flex1" }
      },
      "timeout_frames": 600
    },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "bounds_min_size",
        "target": { "kind": "test_id", "id": "ui-gallery-tabs-flex1-trigger-overview" },
        "min_w_px": 120.0,
        "min_h_px": 0.0,
        "eps_px": 1.0
      },
      "timeout_frames": 240
    },
    {
      "type": "assert",
      "predicate": {
        "kind": "bounds_approx_equal",
        "a": { "kind": "test_id", "id": "ui-gallery-tabs-flex1-trigger-overview" },
        "b": { "kind": "test_id", "id": "ui-gallery-tabs-flex1-trigger-overview.chrome" },
        "eps_px": 1.0
      }
    },
    {
      "type": "assert",
      "predicate": {
        "kind": "bounds_approx_equal",
        "a": { "kind": "test_id", "id": "ui-gallery-tabs-flex1-trigger-analytics" },
        "b": { "kind": "test_id", "id": "ui-gallery-tabs-flex1-trigger-analytics.chrome" },
        "eps_px": 1.0
      }
    },
    {
      "type": "assert",
      "predicate": {
        "kind": "bounds_approx_equal",
        "a": { "kind": "test_id", "id": "ui-gallery-tabs-flex1-trigger-reports" },
        "b": { "kind": "test_id", "id": "ui-gallery-tabs-flex1-trigger-reports.chrome" },
        "eps_px": 1.0
      }
    },
    { "type": "capture_bundle", "label": "ui-gallery-control-chrome-tabs-flex1-trigger-fill" }
  ]
}
