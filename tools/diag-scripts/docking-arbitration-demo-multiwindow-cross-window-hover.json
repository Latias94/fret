{
  "schema_version": 2,
  "meta": {
    "name": "Docking arbitration demo: cross-window hover (scripted helper)",
    "tags": ["docking", "multiwindow", "hover"],
    "required_capabilities": ["diag.script_v2"],
    "target_hints": [
      "This script is a multi-window routing helper (not a strict CI gate yet).",
      "It tears off a tab to create a DockFloating OS window, overlaps the windows, then uses a cursor screen-position override to assert that the dock drag current window can switch to the other OS window.",
      "Note: cursor overrides are expressed in window-client physical pixels."
    ]
  },
  "steps": [
    { "type": "press_key", "key": "escape" },
    { "type": "wait_frames", "n": 2 },

    { "type": "set_window_outer_position", "x_px": 120.0, "y_px": 120.0 },
    { "type": "set_window_inner_size", "width_px": 1600.0, "height_px": 900.0 },
    { "type": "wait_frames", "n": 2 },

    {
      "type": "wait_until",
      "predicate": { "kind": "exists", "target": { "kind": "test_id", "id": "dock-arb-tab-drag-anchor-right" } },
      "timeout_frames": 240
    },

    {
      "type": "drag_pointer",
      "target": { "kind": "test_id", "id": "dock-arb-tab-drag-anchor-right" },
      "delta_x": 2400.0,
      "delta_y": 0.0,
      "steps": 140
    },

    {
      "type": "wait_until",
      "predicate": { "kind": "known_window_count_ge", "n": 2 },
      "timeout_frames": 240
    },
    { "type": "wait_frames", "n": 30 },

    { "type": "raise_window", "window": { "kind": "last_seen_other" } },
    {
      "type": "set_window_outer_position",
      "window": { "kind": "last_seen_other" },
      "x_px": 180.0,
      "y_px": 180.0
    },
    { "type": "wait_frames", "n": 10 },

    { "type": "set_cursor_in_window", "window": { "kind": "last_seen_other" }, "x_px": 200.0, "y_px": 200.0 },

    {
      "type": "drag_pointer_until",
      "target": { "kind": "test_id", "id": "dock-arb-tab-drag-anchor-left" },
      "delta_x": 40.0,
      "delta_y": 0.0,
      "steps": 12,
      "predicate": { "kind": "dock_drag_current_window_is", "window": { "kind": "last_seen_other" } },
      "timeout_frames": 240
    },

    { "type": "capture_bundle", "label": "docking-arbitration-demo-multiwindow-cross-window-hover" },
    { "type": "wait_frames", "n": 2 }
  ]
}
