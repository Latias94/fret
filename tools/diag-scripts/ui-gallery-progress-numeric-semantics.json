{
  "schema_version": 2,
  "steps": [
    {
      "type": "wait_until",
      "predicate": { "kind": "exists", "target": { "kind": "test_id", "id": "ui-gallery-nav-search" } },
      "timeout_frames": 600
    },
    {
      "type": "scroll_into_view",
      "container": { "kind": "test_id", "id": "ui-gallery-nav-scroll" },
      "target": { "kind": "test_id", "id": "ui-gallery-nav-progress" },
      "delta_x": 0.0,
      "delta_y": -120.0,
      "require_fully_within_window": true,
      "padding_px": 2.0,
      "timeout_frames": 600
    },
    { "type": "click", "target": { "kind": "test_id", "id": "ui-gallery-nav-progress" } },
    {
      "type": "ensure_visible",
      "target": { "kind": "test_id", "id": "ui-gallery-progress-demo-bar" },
      "within_window": true,
      "padding_px": 2.0,
      "timeout_frames": 600
    },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "semantics_numeric_approx_eq",
        "target": { "kind": "test_id", "id": "ui-gallery-progress-demo-bar" },
        "field": "value",
        "value": 66.0,
        "eps": 0.5
      },
      "timeout_frames": 600
    },
    {
      "type": "assert",
      "predicate": {
        "kind": "semantics_numeric_approx_eq",
        "target": { "kind": "test_id", "id": "ui-gallery-progress-demo-bar" },
        "field": "min",
        "value": 0.0,
        "eps": 0.0
      }
    },
    {
      "type": "assert",
      "predicate": {
        "kind": "semantics_numeric_approx_eq",
        "target": { "kind": "test_id", "id": "ui-gallery-progress-demo-bar" },
        "field": "max",
        "value": 100.0,
        "eps": 0.0
      }
    },
    { "type": "capture_bundle", "label": "progress-numeric-semantics" }
  ]
}
