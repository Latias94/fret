{
  "schema_version": 2,
  "meta": {
    "name": "UI Gallery: Popover doc page opens on click (shadcn parity)",
    "tags": ["ui-gallery", "shadcn", "popover", "overlay", "interaction"],
    "required_capabilities": ["diag.script_v2"]
  },
  "steps": [
    { "type": "reset_diagnostics" },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-nav-search" }
      },
      "timeout_frames": 600
    },
    { "type": "press_key", "key": "escape" },
    { "type": "wait_frames", "n": 2 },
    { "type": "set_window_inner_size", "width_px": 1280.0, "height_px": 720.0 },
    { "type": "wait_frames", "n": 15 },
    {
      "type": "type_text_into",
      "target": { "kind": "role_and_name", "role": "text_field", "name": "Search components" },
      "text": "popover"
    },
    { "type": "wait_frames", "n": 2 },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-nav-popover" }
      },
      "timeout_frames": 600
    },
    { "type": "click", "target": { "kind": "test_id", "id": "ui-gallery-nav-popover" } },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-popover" }
      },
      "timeout_frames": 600
    },
    {
      "type": "scroll_into_view",
      "container": { "kind": "test_id", "id": "ui-gallery-content-viewport" },
      "target": { "kind": "test_id", "id": "ui-gallery-popover-demo-trigger" },
      "delta_y": 240.0,
      "require_fully_within_container": false,
      "require_fully_within_window": false,
      "padding_px": 24.0,
      "timeout_frames": 600
    },
    { "type": "wait_frames", "n": 10 },
    { "type": "click", "target": { "kind": "test_id", "id": "ui-gallery-popover-demo-trigger" } },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-popover-demo-content" }
      },
      "timeout_frames": 240
    },
    { "type": "wait_frames", "n": 10 },
    { "type": "capture_bundle", "label": "ui-gallery-popover-doc-page-opens" }
  ]
}

