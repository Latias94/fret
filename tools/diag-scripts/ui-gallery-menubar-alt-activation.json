{
  "schema_version": 1,
  "steps": [
    {
      "type": "click",
      "target": { "kind": "test_id", "id": "ui-gallery-command-palette" }
    },
    { "type": "wait_frames", "n": 3 },
    { "type": "type_text", "text": "Settings" },
    { "type": "wait_frames", "n": 2 },
    { "type": "press_key", "key": "enter" },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-settings-in-window-menubar" }
      },
      "timeout_frames": 120
    },
    {
      "type": "click",
      "target": { "kind": "test_id", "id": "ui-gallery-settings-in-window-menubar" }
    },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-settings-in-window-menubar-on" }
      },
      "timeout_frames": 120
    },
    {
      "type": "click",
      "target": { "kind": "test_id", "id": "ui-gallery-settings-in-window-menubar-on" }
    },
    {
      "type": "click",
      "target": { "kind": "test_id", "id": "ui-gallery-settings-apply" }
    },
    { "type": "wait_frames", "n": 10 },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "menubar-trigger-file" }
      },
      "timeout_frames": 240
    },
    { "type": "press_key", "key": "alt", "modifiers": { "alt": true } },
    { "type": "wait_frames", "n": 2 },
    {
      "type": "assert",
      "predicate": {
        "kind": "focus_is",
        "target": { "kind": "test_id", "id": "menubar-trigger-file" }
      }
    },
    { "type": "capture_bundle", "label": "ui-gallery-menubar-alt-activation" }
  ]
}

