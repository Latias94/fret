{
  "schema_version": 2,
  "steps": [
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-nav-search" }
      },
      "timeout_frames": 600
    },
    {
      "type": "click",
      "target": { "kind": "test_id", "id": "ui-gallery-nav-search" }
    },
    {
      "type": "press_key",
      "key": "a",
      "modifiers": { "ctrl": true }
    },
    { "type": "press_key", "key": "backspace" },
    { "type": "type_text", "text": "chart torture" },
    { "type": "wait_frames", "n": 2 },
    {
      "type": "ensure_visible",
      "target": { "kind": "test_id", "id": "ui-gallery-nav-chart-torture" },
      "within_window": true,
      "padding_px": 8.0,
      "timeout_frames": 600
    },
    {
      "type": "click",
      "target": { "kind": "test_id", "id": "ui-gallery-nav-chart-torture" }
    },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-chart-torture-root" }
      },
      "timeout_frames": 600
    },
    { "type": "wait_frames", "n": 30 },
    {
      "type": "capture_bundle",
      "label": "ui-gallery-chart-torture-pan-zoom-before"
    },
    {
      "type": "capture_screenshot",
      "label": "ui-gallery-chart-torture-pan-zoom-before"
    },
    {
      "type": "move_pointer",
      "target": { "kind": "test_id", "id": "ui-gallery-chart-torture-root" }
    },
    {
      "type": "drag_pointer",
      "target": { "kind": "test_id", "id": "ui-gallery-chart-torture-root" },
      "delta_x": 180.0,
      "delta_y": 0.0,
      "steps": 12
    },
    {
      "type": "wheel",
      "target": { "kind": "test_id", "id": "ui-gallery-chart-torture-root" },
      "delta_y": -240.0
    },
    { "type": "wait_frames", "n": 5 },
    {
      "type": "drag_pointer",
      "target": { "kind": "test_id", "id": "ui-gallery-chart-torture-root" },
      "delta_x": -360.0,
      "delta_y": 0.0,
      "steps": 18
    },
    { "type": "wait_frames", "n": 5 },
    {
      "type": "capture_bundle",
      "label": "ui-gallery-chart-torture-pan-zoom-after"
    },
    {
      "type": "capture_screenshot",
      "label": "ui-gallery-chart-torture-pan-zoom-after"
    },
    { "type": "capture_bundle", "label": "ui-gallery-chart-torture-pan-zoom" }
  ]
}
