{
  "schema_version": 2,
  "steps": [
    { "type": "reset_diagnostics" },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-nav-search" }
      },
      "timeout_frames": 600
    },
    { "type": "press_key", "key": "escape" },
    { "type": "wait_frames", "n": 2 },
    { "type": "click", "target": { "kind": "test_id", "id": "ui-gallery-nav-search" } },
    { "type": "press_key", "key": "a", "modifiers": { "ctrl": true } },
    { "type": "press_key", "key": "backspace" },
    { "type": "type_text", "text": "carousel" },
    { "type": "wait_frames", "n": 2 },
    { "type": "click", "target": { "kind": "test_id", "id": "ui-gallery-nav-carousel" } },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-page-carousel" }
      },
      "timeout_frames": 600
    },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-carousel-expandable" }
      },
      "timeout_frames": 600
    },
    {
      "type": "scroll_into_view",
      "container": { "kind": "test_id", "id": "ui-gallery-content-scroll" },
      "target": { "kind": "test_id", "id": "ui-gallery-carousel-expandable" },
      "delta_y": -120.0,
      "require_fully_within_container": true,
      "require_fully_within_window": true,
      "padding_px": 16.0,
      "timeout_frames": 600
    },

    { "type": "wait_frames", "n": 10 },
    { "type": "capture_bundle", "label": "ui-gallery-carousel-expandable-before" },

    {
      "type": "click_stable",
      "target": { "kind": "test_id", "id": "ui-gallery-carousel-expandable-item-3" }
    },
    { "type": "wait_frames", "n": 30 },
    {
      "type": "click",
      "target": { "kind": "test_id", "id": "ui-gallery-carousel-expandable-item-4" }
    },

    { "type": "wait_frames", "n": 30 },
    { "type": "capture_bundle", "label": "ui-gallery-carousel-expandable-after" },
    { "type": "capture_bundle", "label": "ui-gallery-carousel-expandable-fixed-frame-delta" }
  ]
}
