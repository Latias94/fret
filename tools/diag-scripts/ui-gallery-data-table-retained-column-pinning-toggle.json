{
  "schema_version": 2,
  "steps": [
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-nav-search" }
      },
      "timeout_frames": 240
    },
    { "type": "click", "target": { "kind": "test_id", "id": "ui-gallery-nav-search" } },
    { "type": "type_text", "text": "datatable (torture)" },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-nav-data-table-torture" }
      },
      "timeout_frames": 240
    },
    { "type": "click", "target": { "kind": "test_id", "id": "ui-gallery-nav-data-table-torture" } },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-data-table-torture-root" }
      },
      "timeout_frames": 240
    },

    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": {
          "kind": "role_and_name",
          "role": "text",
          "name": "Pinning: <none>"
        }
      },
      "timeout_frames": 240
    },

    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "role_and_name", "role": "button", "name": "Pin" }
      },
      "timeout_frames": 240
    },
    { "type": "click", "target": { "kind": "role_and_name", "role": "button", "name": "Pin" } },
    { "type": "wait_frames", "n": 2 },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": {
          "kind": "role_and_name",
          "role": "menu_item_radio",
          "name": "Pin mem_mb right"
        }
      },
      "timeout_frames": 240
    },
    {
      "type": "click",
      "target": { "kind": "role_and_name", "role": "menu_item_radio", "name": "Pin mem_mb right" }
    },
    { "type": "wait_frames", "n": 2 },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": {
          "kind": "role_and_name",
          "role": "text",
          "name": "Pinning: left=[] right=[mem_mb]"
        }
      },
      "timeout_frames": 240
    },

    { "type": "click", "target": { "kind": "role_and_name", "role": "button", "name": "Pin" } },
    { "type": "wait_frames", "n": 2 },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": {
          "kind": "role_and_name",
          "role": "menu_item_radio",
          "name": "Pin mem_mb unpinned"
        }
      },
      "timeout_frames": 240
    },
    {
      "type": "click",
      "target": { "kind": "role_and_name", "role": "menu_item_radio", "name": "Pin mem_mb unpinned" }
    },
    { "type": "wait_frames", "n": 2 },
    {
      "type": "assert",
      "predicate": {
        "kind": "exists",
        "target": {
          "kind": "role_and_name",
          "role": "text",
          "name": "Pinning: <none>"
        }
      }
    },

    {
      "type": "capture_bundle",
      "label": "ui-gallery-data-table-retained-column-pinning-toggle"
    }
  ]
}

