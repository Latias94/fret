{
  "schema_version": 2,
  "steps": [
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-nav-search" }
      },
      "timeout_frames": 240
    },
    { "type": "click", "target": { "kind": "test_id", "id": "ui-gallery-nav-search" } },
    { "type": "press_key", "key": "a", "modifiers": { "ctrl": true } },
    { "type": "press_key", "key": "backspace" },
    { "type": "type_text", "text": "dock" },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-nav-magic-dock" }
      },
      "timeout_frames": 240
    },
    { "type": "click", "target": { "kind": "test_id", "id": "ui-gallery-nav-magic-dock" } },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-magic-dock" }
      },
      "timeout_frames": 360
    },
    { "type": "set_window_inner_size", "width_px": 1280.0, "height_px": 720.0 },
    { "type": "wait_frames", "n": 4 },
    { "type": "reset_diagnostics" },
    { "type": "wait_frames", "n": 10 },

    { "type": "move_pointer", "target": { "kind": "test_id", "id": "ui-gallery-magic-dock-target-left" } },
    { "type": "wait_frames", "n": 12 },
    { "type": "move_pointer", "target": { "kind": "test_id", "id": "ui-gallery-magic-dock-target-middle" } },
    { "type": "wait_frames", "n": 12 },
    { "type": "move_pointer", "target": { "kind": "test_id", "id": "ui-gallery-magic-dock-target-right" } },
    { "type": "wait_frames", "n": 12 },
    { "type": "move_pointer", "target": { "kind": "test_id", "id": "ui-gallery-magic-dock-target-middle" } },
    { "type": "wait_frames", "n": 12 },
    { "type": "move_pointer", "target": { "kind": "test_id", "id": "ui-gallery-magic-dock-target-left" } },
    { "type": "wait_frames", "n": 12 },

    { "type": "wait_frames", "n": 120 },
    { "type": "capture_bundle", "label": "ui-gallery-magic-dock-perf-steady" },
    { "type": "wait_frames", "n": 2 }
  ]
}
