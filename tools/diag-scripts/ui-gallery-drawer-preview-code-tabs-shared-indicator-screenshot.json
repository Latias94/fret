{
  "schema_version": 2,
  "meta": {
    "name": "ui-gallery-drawer-preview-code-tabs-shared-indicator-screenshot",
    "required_capabilities": ["diag.script_v2", "diag.screenshot_png"]
  },
  "steps": [
    { "type": "reset_diagnostics" },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-nav-search" }
      },
      "timeout_frames": 240
    },
    { "type": "click", "target": { "kind": "test_id", "id": "ui-gallery-nav-search" } },
    { "type": "press_key", "key": "a", "modifiers": { "ctrl": true } },
    { "type": "press_key", "key": "backspace" },
    { "type": "type_text", "text": "drawer" },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-nav-drawer" }
      },
      "timeout_frames": 240
    },
    { "type": "click", "target": { "kind": "test_id", "id": "ui-gallery-nav-drawer" } },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-drawer-tabs-trigger-code" }
      },
      "timeout_frames": 240
    },
    { "type": "wait_frames", "n": 8 },
    {
      "type": "click_stable",
      "target": { "kind": "test_id", "id": "ui-gallery-drawer-tabs-trigger-code" },
      "stable_frames": 4,
      "max_move_px": 0.5,
      "timeout_frames": 240
    },
    { "type": "wait_frames", "n": 12 },
    { "type": "capture_bundle", "label": "ui-gallery-drawer-preview-code-tabs" },
    { "type": "capture_screenshot", "label": "ui-gallery-drawer-preview-code-tabs" }
  ]
}
