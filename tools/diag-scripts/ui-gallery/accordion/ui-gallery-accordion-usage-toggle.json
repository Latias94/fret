{
  "schema_version": 2,
  "meta": {
    "name": "ui-gallery-accordion-usage-toggle",
    "required_capabilities": ["diag.script_v2"],
    "tags": ["ui-gallery", "shadcn", "accordion", "usage", "interaction"]
  },
  "steps": [
    { "type": "reset_diagnostics" },
    { "type": "press_key", "key": "escape" },
    { "type": "wait_frames", "n": 2 },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-nav-search" }
      },
      "timeout_frames": 600
    },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-nav-scroll" }
      },
      "timeout_frames": 600
    },
    { "type": "click", "target": { "kind": "test_id", "id": "ui-gallery-nav-search" } },
    { "type": "press_key", "key": "a", "modifiers": { "ctrl": true } },
    { "type": "press_key", "key": "backspace" },
    { "type": "type_text", "text": "accordion" },
    { "type": "wait_frames", "n": 2 },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-nav-accordion" }
      },
      "timeout_frames": 600
    },
    {
      "type": "click_stable",
      "target": { "kind": "test_id", "id": "ui-gallery-nav-accordion" },
      "stable_frames": 3,
      "max_move_px": 2.0,
      "timeout_frames": 600
    },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-page-accordion" }
      },
      "timeout_frames": 600
    },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-accordion-usage-trigger" }
      },
      "timeout_frames": 600
    },
    {
      "type": "scroll_into_view",
      "container": { "kind": "test_id", "id": "ui-gallery-content-viewport" },
      "target": { "kind": "test_id", "id": "ui-gallery-accordion-usage-trigger" },
      "delta_y": -220.0,
      "require_fully_within_container": true,
      "require_fully_within_window": true,
      "padding_px": 16.0,
      "timeout_frames": 600
    },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-accordion-usage-panel" }
      },
      "timeout_frames": 120
    },
    {
      "type": "wait_bounds_stable",
      "target": { "kind": "test_id", "id": "ui-gallery-accordion-usage-trigger" },
      "stable_frames": 4,
      "max_move_px": 0.75,
      "timeout_frames": 240
    },
    { "type": "wait_frames", "n": 4 },
    {
      "type": "click_stable",
      "target": { "kind": "test_id", "id": "ui-gallery-accordion-usage-trigger" },
      "stable_frames": 4,
      "max_move_px": 0.75,
      "timeout_frames": 240
    },
    { "type": "wait_frames", "n": 20 },
    {
      "type": "wait_until",
        "predicate": {
        "kind": "not_exists",
        "target": { "kind": "test_id", "id": "ui-gallery-accordion-usage-panel" }
      },
      "timeout_frames": 240
    },
    { "type": "capture_bundle", "label": "ui-gallery-accordion-usage-toggle-closed" },
    {
      "type": "click_stable",
      "target": { "kind": "test_id", "id": "ui-gallery-accordion-usage-trigger" },
      "stable_frames": 4,
      "max_move_px": 0.75,
      "timeout_frames": 240
    },
    { "type": "wait_frames", "n": 10 },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-accordion-usage-panel" }
      },
      "timeout_frames": 240
    },
    { "type": "capture_bundle", "label": "ui-gallery-accordion-usage-toggle-open" }
  ]
}
