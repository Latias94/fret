{
  "schema_version": 2,
  "meta": {
    "name": "ui-gallery-scroll-area-toggle-code-tabs",
    "required_capabilities": ["diag.script_v2"],
    "tags": ["scroll", "ui_gallery", "regression_pack"]
  },
  "steps": [
    { "type": "press_key", "key": "escape" },
    { "type": "wait_frames", "n": 2 },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-nav-search" }
      },
      "timeout_frames": 600
    },
    { "type": "click", "target": { "kind": "test_id", "id": "ui-gallery-nav-search" } },
    { "type": "press_key", "key": "a", "modifiers": { "ctrl": true } },
    { "type": "press_key", "key": "backspace" },
    { "type": "type_text", "text": "scroll area" },
    { "type": "wait_frames", "n": 2 },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-nav-scroll-area" }
      },
      "timeout_frames": 600
    },
    {
      "type": "scroll_into_view",
      "container": { "kind": "test_id", "id": "ui-gallery-nav-scroll" },
      "target": { "kind": "test_id", "id": "ui-gallery-nav-scroll-area" },
      "delta_y": -240.0,
      "timeout_frames": 600
    },
    { "type": "click", "target": { "kind": "test_id", "id": "ui-gallery-nav-scroll-area" } },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-page-scroll-area" }
      },
      "timeout_frames": 600
    },

    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": {
          "kind": "test_id",
          "id": "docsec-scrollbar-drag-baseline-tabs-trigger-code"
        }
      },
      "timeout_frames": 600
    },
    {
      "type": "scroll_into_view",
      "container": { "kind": "test_id", "id": "ui-gallery-content-scroll" },
      "target": {
        "kind": "test_id",
        "id": "docsec-scrollbar-drag-baseline-tabs-trigger-code"
      },
      "delta_y": -240.0,
      "timeout_frames": 600,
      "require_fully_within_container": true,
      "require_fully_within_window": true,
      "padding_px": 4.0
    },
    {
      "type": "click_stable",
      "target": {
        "kind": "test_id",
        "id": "docsec-scrollbar-drag-baseline-tabs-trigger-code"
      },
      "stable_frames": 2,
      "max_move_px": 2.0,
      "timeout_frames": 600
    },
    {
      "type": "wait_semantics_scroll_stable",
      "target": { "kind": "test_id", "id": "ui-gallery-content-viewport" },
      "field": "y_max",
      "stable_frames": 3,
      "max_delta": 1.0,
      "timeout_frames": 600
    },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": {
          "kind": "test_id",
          "id": "docsec-scrollbar-drag-baseline-tabs-trigger-preview"
        }
      },
      "timeout_frames": 600
    },
    {
      "type": "click_stable",
      "target": {
        "kind": "test_id",
        "id": "docsec-scrollbar-drag-baseline-tabs-trigger-preview"
      },
      "stable_frames": 2,
      "max_move_px": 2.0,
      "timeout_frames": 600
    },
    {
      "type": "wait_semantics_scroll_stable",
      "target": { "kind": "test_id", "id": "ui-gallery-content-viewport" },
      "field": "y_max",
      "stable_frames": 3,
      "max_delta": 1.0,
      "timeout_frames": 600
    },
    { "type": "capture_bundle", "label": "scroll-area-toggle-code-tabs" }
  ]
}

