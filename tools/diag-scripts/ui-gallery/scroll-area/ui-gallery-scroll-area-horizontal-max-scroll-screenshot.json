{
  "schema_version": 2,
  "meta": {
    "name": "UI gallery: scroll area horizontal max scroll screenshot",
    "required_capabilities": ["diag.script_v2", "diag.screenshot_png"],
    "tags": ["scroll", "scroll-area", "horizontal", "screenshot", "ui-gallery"]
  },
  "steps": [
    { "type": "reset_diagnostics" },
    { "type": "press_key", "key": "escape" },
    { "type": "wait_frames", "n": 2 },
    { "type": "set_window_inner_size", "width_px": 1120.0, "height_px": 760.0 },
    { "type": "wait_frames", "n": 10 },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-nav-search" }
      },
      "timeout_frames": 240
    },
    { "type": "click", "target": { "kind": "test_id", "id": "ui-gallery-nav-search" } },
    { "type": "press_key", "key": "a", "modifiers": { "ctrl": true } },
    { "type": "press_key", "key": "backspace" },
    { "type": "type_text", "text": "scroll area" },
    { "type": "wait_frames", "n": 2 },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "bounds_within_window",
        "target": { "kind": "test_id", "id": "ui-gallery-nav-scroll-area" },
        "padding_px": 8.0,
        "eps_px": 1.0
      },
      "timeout_frames": 300
    },
    { "type": "click", "target": { "kind": "test_id", "id": "ui-gallery-nav-scroll-area" } },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-page-scroll-area" }
      },
      "timeout_frames": 240
    },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": {
          "kind": "test_id",
          "id": "ui-gallery-scroll-area-horizontal-viewport"
        }
      },
      "timeout_frames": 600
    },
    {
      "type": "scroll_into_view",
      "container": { "kind": "test_id", "id": "ui-gallery-content-scroll" },
      "target": { "kind": "test_id", "id": "ui-gallery-scroll-area-horizontal-viewport" },
      "delta_y": -240.0,
      "timeout_frames": 600,
      "require_fully_within_container": true,
      "require_fully_within_window": true,
      "padding_px": 24.0
    },
    {
      "type": "assert",
      "predicate": {
        "kind": "semantics_scroll_is_finite",
        "target": { "kind": "test_id", "id": "ui-gallery-scroll-area-horizontal-viewport" },
        "field": "x_max"
      }
    },
    {
      "type": "assert",
      "predicate": {
        "kind": "semantics_scroll_not_approx_eq",
        "target": { "kind": "test_id", "id": "ui-gallery-scroll-area-horizontal-viewport" },
        "field": "x_max",
        "value": 0.0,
        "eps": 0.01
      }
    },
    { "type": "wheel", "target": { "kind": "test_id", "id": "ui-gallery-scroll-area-horizontal-viewport" }, "delta_x": -1200.0 },
    { "type": "wheel", "target": { "kind": "test_id", "id": "ui-gallery-scroll-area-horizontal-viewport" }, "delta_x": -1200.0 },
    { "type": "wheel", "target": { "kind": "test_id", "id": "ui-gallery-scroll-area-horizontal-viewport" }, "delta_x": -1200.0 },
    {
      "type": "wait_semantics_scroll_stable",
      "target": { "kind": "test_id", "id": "ui-gallery-scroll-area-horizontal-viewport" },
      "field": "x",
      "stable_frames": 3,
      "max_delta": 1.0,
      "timeout_frames": 600
    },
    {
      "type": "wait_semantics_scroll_stable",
      "target": { "kind": "test_id", "id": "ui-gallery-scroll-area-horizontal-viewport" },
      "field": "x_max",
      "stable_frames": 3,
      "max_delta": 1.0,
      "timeout_frames": 600
    },
    { "type": "capture_bundle", "label": "scroll-area-horizontal-max-scroll" },
    { "type": "capture_screenshot", "label": "ui-gallery-scroll-area-horizontal-max-scroll" }
  ]
}

