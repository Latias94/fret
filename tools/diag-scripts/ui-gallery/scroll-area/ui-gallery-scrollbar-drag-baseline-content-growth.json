    {
      "type": "pointer_move",
      "delta_x": 0.0,
      "delta_y": 40.0,
      "steps": 12
    },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-scroll-area-drag-baseline-grown" }
      },
      "timeout_frames": 600
    },
    {
      "type": "pointer_move",
      "delta_x": 0.0,
      "delta_y": 40.0,
      "steps": 12
    },
    {
      "type": "assert",
      "predicate": {
        "kind": "semantics_scroll_approx_eq",
        "target": {
          "kind": "test_id",
          "id": "ui-gallery-scroll-area-drag-baseline-y-scrollbar"
        },
        "field": "y",
        "value": 20.0,
        "eps": 0.75
      }
    },
    { "type": "pointer_up" },
    { "type": "capture_bundle", "label": "scrollbar-drag-baseline-content-growth" }
