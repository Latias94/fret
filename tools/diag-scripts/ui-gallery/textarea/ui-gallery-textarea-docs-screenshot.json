{
  "schema_version": 2,
  "meta": {
    "name": "ui-gallery-textarea-docs-screenshot",
    "required_capabilities": ["diag.screenshot_png"],
    "tags": ["ui_gallery", "shadcn", "textarea", "docs_parity", "screenshot"]
  },
  "steps": [
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-nav-search" }
      },
      "timeout_frames": 240
    },
    { "type": "click", "target": { "kind": "test_id", "id": "ui-gallery-nav-search" } },
    { "type": "press_key", "key": "a", "modifiers": { "ctrl": true } },
    { "type": "press_key", "key": "backspace" },
    { "type": "type_text", "text": "textarea" },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-nav-textarea" }
      },
      "timeout_frames": 240
    },
    { "type": "click", "target": { "kind": "test_id", "id": "ui-gallery-nav-textarea" } },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-textarea-demo" }
      },
      "timeout_frames": 240
    },
    {
      "type": "scroll_into_view",
      "container": { "kind": "test_id", "id": "ui-gallery-content-viewport" },
      "target": { "kind": "test_id", "id": "ui-gallery-textarea-demo" },
      "delta_y": -180.0,
      "require_fully_within_window": true,
      "padding_px": 16.0,
      "timeout_frames": 1200
    },
    { "type": "wait_frames", "n": 2 },
    { "type": "capture_screenshot", "label": "demo", "timeout_frames": 60 },

    {
      "type": "scroll_into_view",
      "container": { "kind": "test_id", "id": "ui-gallery-content-viewport" },
      "target": { "kind": "test_id", "id": "ui-gallery-textarea-field" },
      "delta_y": -180.0,
      "require_fully_within_window": true,
      "padding_px": 16.0,
      "timeout_frames": 1200
    },
    { "type": "wait_frames", "n": 2 },
    { "type": "capture_screenshot", "label": "with-label", "timeout_frames": 60 },

    {
      "type": "scroll_into_view",
      "container": { "kind": "test_id", "id": "ui-gallery-content-viewport" },
      "target": { "kind": "test_id", "id": "ui-gallery-textarea-disabled" },
      "delta_y": -180.0,
      "require_fully_within_window": true,
      "padding_px": 16.0,
      "timeout_frames": 1200
    },
    { "type": "wait_frames", "n": 2 },
    { "type": "capture_screenshot", "label": "disabled", "timeout_frames": 60 },

    {
      "type": "scroll_into_view",
      "container": { "kind": "test_id", "id": "ui-gallery-content-viewport" },
      "target": { "kind": "test_id", "id": "ui-gallery-textarea-with-text" },
      "delta_y": -180.0,
      "require_fully_within_window": true,
      "padding_px": 16.0,
      "timeout_frames": 1200
    },
    { "type": "wait_frames", "n": 2 },
    { "type": "capture_screenshot", "label": "with-text", "timeout_frames": 60 },

    {
      "type": "scroll_into_view",
      "container": { "kind": "test_id", "id": "ui-gallery-content-viewport" },
      "target": { "kind": "test_id", "id": "ui-gallery-textarea-button" },
      "delta_y": -180.0,
      "require_fully_within_window": true,
      "padding_px": 16.0,
      "timeout_frames": 1200
    },
    { "type": "wait_frames", "n": 2 },
    { "type": "capture_screenshot", "label": "with-button", "timeout_frames": 60 },

    { "type": "capture_bundle", "label": "ui-gallery-textarea-docs-screenshot" }
  ]
}

