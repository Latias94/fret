{
  "schema_version": 2,
  "meta": {
    "name": "UI Gallery: Calendar custom cell size screenshot",
    "tags": ["ui-gallery", "calendar", "shadcn", "cell-size", "screenshots"],
    "required_capabilities": ["diag.script_v2", "diag.screenshot_png"],
    "env_defaults": {
      "FRET_UI_GALLERY_FIXED_TODAY": "2026-05-15"
    }
  },
  "steps": [
    { "type": "reset_diagnostics" },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-nav-search" }
      },
      "timeout_frames": 1800
    },
    { "type": "press_key", "key": "escape" },
    { "type": "wait_frames", "n": 2 },
    { "type": "set_window_inner_size", "width_px": 1280.0, "height_px": 900.0 },
    { "type": "wait_frames", "n": 15 },

    { "type": "click", "target": { "kind": "test_id", "id": "ui-gallery-nav-search" } },
    { "type": "press_key", "key": "a", "modifiers": { "ctrl": true } },
    { "type": "press_key", "key": "backspace" },
    { "type": "type_text", "text": "calendar" },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-nav-calendar" }
      },
      "timeout_frames": 1800
    },
    { "type": "click", "target": { "kind": "test_id", "id": "ui-gallery-nav-calendar" } },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-page-calendar" }
      },
      "timeout_frames": 1800
    },

    {
      "type": "scroll_into_view",
      "container": { "kind": "test_id", "id": "ui-gallery-content-scroll" },
      "target": { "kind": "test_id", "id": "ui-gallery.calendar.custom-cell:2026-12-12" },
      "delta_y": -240.0,
      "require_fully_within_window": true,
      "padding_px": 16.0,
      "timeout_frames": 1800
    },
    {
      "type": "assert",
      "predicate": {
        "kind": "bounds_min_size",
        "target": { "kind": "test_id", "id": "ui-gallery.calendar.custom-cell:2026-12-12" },
        "min_w_px": 47.0,
        "min_h_px": 47.0,
        "eps_px": 1.0
      }
    },
    {
      "type": "assert",
      "predicate": {
        "kind": "bounds_max_size",
        "target": { "kind": "test_id", "id": "ui-gallery.calendar.custom-cell:2026-12-12" },
        "max_w_px": 49.0,
        "max_h_px": 49.0,
        "eps_px": 1.0
      }
    },
    {
      "type": "assert",
      "predicate": {
        "kind": "exists",
        "target": {
          "kind": "test_id",
          "id": "ui-gallery.calendar.custom-cell:2026-12-12:supporting-text"
        }
      }
    },
    {
      "type": "assert",
      "predicate": {
        "kind": "not_exists",
        "target": {
          "kind": "test_id",
          "id": "ui-gallery.calendar.custom-cell:2026-11-29:outside:supporting-text"
        }
      }
    },

    { "type": "wait_frames", "n": 10 },
    { "type": "capture_bundle", "label": "ui-gallery-calendar-custom-cell-size-screenshot" },
    { "type": "capture_screenshot", "label": "ui-gallery-calendar-custom-cell-size-screenshot" }
  ]
}
