{
  "schema_version": 2,
  "meta": {
    "name": "UI Gallery: Calendar presets footer buttons match shadcn",
    "tags": ["ui-gallery", "calendar", "shadcn"],
    "required_capabilities": ["diag.script_v2", "diag.screenshot_png"],
    "env_defaults": {
      "FRET_UI_GALLERY_FIXED_TODAY": "2026-05-15"
    }
  },
  "steps": [
    { "type": "reset_diagnostics" },
    {
      "type": "wait_until",
      "timeout_frames": 1800,
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-nav-search" }
      }
    },
    { "type": "press_key", "key": "escape" },
    { "type": "wait_frames", "n": 2 },
    { "type": "set_window_inner_size", "width_px": 1280.0, "height_px": 900.0 },
    { "type": "wait_frames", "n": 15 },

    { "type": "click", "target": { "kind": "test_id", "id": "ui-gallery-nav-search" } },
    { "type": "press_key", "key": "a", "modifiers": { "ctrl": true } },
    { "type": "press_key", "key": "backspace" },
    { "type": "type_text", "text": "calendar" },
    {
      "type": "wait_until",
      "timeout_frames": 1800,
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-nav-calendar" }
      }
    },
    { "type": "click", "target": { "kind": "test_id", "id": "ui-gallery-nav-calendar" } },
    {
      "type": "wait_until",
      "timeout_frames": 1800,
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-page-calendar" }
      }
    },
    {
      "type": "scroll_into_view",
      "container": { "kind": "test_id", "id": "ui-gallery-content-scroll" },
      "target": {
        "kind": "test_id",
        "id": "ui-gallery-calendar-presets-card"
      },
      "delta_y": -240.0,
      "require_fully_within_container": false,
      "require_fully_within_window": false,
      "padding_px": 16.0,
      "padding_insets_px": {
        "left_px": 16.0,
        "top_px": 16.0,
        "right_px": 16.0,
        "bottom_px": 40.0
      },
      "timeout_frames": 1800
    },
    {
      "type": "wait_until",
      "timeout_frames": 240,
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-calendar-presets-card" }
      }
    },
    {
      "type": "wait_until",
      "timeout_frames": 240,
      "predicate": {
        "kind": "exists",
        "target": {
          "kind": "test_id",
          "id": "ui-gallery-calendar-presets-button-in-2-weeks"
        }
      }
    },
    {
      "type": "wait_until",
      "timeout_frames": 240,
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-calendar-presets-button-today" }
      }
    },
    {
      "type": "scroll_into_view",
      "container": { "kind": "test_id", "id": "ui-gallery-content-scroll" },
      "target": {
        "kind": "test_id",
        "id": "ui-gallery-calendar-presets-button-in-2-weeks"
      },
      "delta_y": -240.0,
      "require_fully_within_container": true,
      "require_fully_within_window": false,
      "padding_px": 16.0,
      "padding_insets_px": {
        "left_px": 16.0,
        "top_px": 40.0,
        "right_px": 16.0,
        "bottom_px": 200.0
      },
      "timeout_frames": 900
    },
    {
      "type": "wait_bounds_stable",
      "target": {
        "kind": "test_id",
        "id": "ui-gallery-calendar-presets-button-in-2-weeks"
      },
      "stable_frames": 4,
      "max_move_px": 0.5,
      "timeout_frames": 240
    },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "bounds_min_size",
        "target": {
          "kind": "test_id",
          "id": "ui-gallery-calendar-presets-button-in-2-weeks"
        },
        "min_w_px": 72.0,
        "min_h_px": 0.0,
        "eps_px": 1.0
      },
      "timeout_frames": 240
    },
    {
      "type": "scroll_into_view",
      "container": { "kind": "test_id", "id": "ui-gallery-content-scroll" },
      "target": { "kind": "test_id", "id": "ui-gallery-calendar-presets-button-tomorrow" },
      "delta_y": -240.0,
      "require_fully_within_container": true,
      "require_fully_within_window": false,
      "padding_px": 16.0,
      "padding_insets_px": {
        "left_px": 16.0,
        "top_px": 40.0,
        "right_px": 16.0,
        "bottom_px": 200.0
      },
      "timeout_frames": 900
    },
    {
      "type": "wait_bounds_stable",
      "target": { "kind": "test_id", "id": "ui-gallery-calendar-presets-button-tomorrow" },
      "stable_frames": 4,
      "max_move_px": 0.5,
      "timeout_frames": 240
    },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "bounds_min_size",
        "target": { "kind": "test_id", "id": "ui-gallery-calendar-presets-button-tomorrow" },
        "min_w_px": 72.0,
        "min_h_px": 0.0,
        "eps_px": 1.0
      },
      "timeout_frames": 240
    },
    {
      "type": "assert",
      "predicate": {
        "kind": "bounds_overlapping_y",
        "a": { "kind": "test_id", "id": "ui-gallery-calendar-presets-button-today" },
        "b": { "kind": "test_id", "id": "ui-gallery-calendar-presets-button-tomorrow" },
        "eps_px": 1.0
      }
    },
    {
      "type": "assert",
      "predicate": {
        "kind": "bounds_non_overlapping",
        "a": { "kind": "test_id", "id": "ui-gallery-calendar-presets-button-today" },
        "b": { "kind": "test_id", "id": "ui-gallery-calendar-presets-button-tomorrow" },
        "eps_px": 1.0
      }
    },
    { "type": "capture_bundle", "label": "ui-gallery-calendar-presets-buttons" },
    {
      "type": "capture_screenshot",
      "label": "ui-gallery-calendar-presets-buttons",
      "timeout_frames": 600
    },
    { "type": "wait_frames", "n": 30 }
  ]
}
