{
  "schema_version": 2,
  "meta": {
    "name": "ui-gallery-typography-demo-joke-tax-clip-screenshot",
    "required_capabilities": ["diag.script_v2", "diag.screenshot_png"],
    "tags": ["ui_gallery", "shadcn", "typography", "scroll", "clip", "screenshot", "regression"]
  },
  "steps": [
    { "type": "reset_diagnostics" },
    { "type": "press_key", "key": "escape" },
    { "type": "wait_frames", "n": 2 },
    { "type": "set_window_inner_size", "width_px": 1280.0, "height_px": 980.0 },
    { "type": "wait_frames", "n": 20 },

    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-nav-search" }
      },
      "timeout_frames": 600
    },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-nav-scroll" }
      },
      "timeout_frames": 600
    },
    { "type": "click", "target": { "kind": "test_id", "id": "ui-gallery-nav-search" } },
    { "type": "press_key", "key": "a", "modifiers": { "ctrl": true } },
    { "type": "press_key", "key": "backspace" },
    { "type": "type_text", "text": "typography" },
    { "type": "wait_frames", "n": 2 },

    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-nav-typography" }
      },
      "timeout_frames": 600
    },
    {
      "type": "scroll_into_view",
      "container": { "kind": "test_id", "id": "ui-gallery-nav-scroll" },
      "target": { "kind": "test_id", "id": "ui-gallery-nav-typography" },
      "delta_y": -240.0,
      "timeout_frames": 600
    },
    { "type": "click", "target": { "kind": "test_id", "id": "ui-gallery-nav-typography" } },

    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-page-typography" }
      },
      "timeout_frames": 600
    },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-content-viewport" }
      },
      "timeout_frames": 600
    },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-typography-demo-h3-joke-tax" }
      },
      "timeout_frames": 600
    },

    {
      "type": "scroll_into_view",
      "container": { "kind": "test_id", "id": "ui-gallery-content-viewport" },
      "target": { "kind": "test_id", "id": "ui-gallery-typography-demo-h3-joke-tax" },
      "delta_y": -120.0,
      "require_fully_within_window": true,
      "padding_px": 24.0,
      "timeout_frames": 900
    },

    {
      "type": "move_pointer",
      "target": { "kind": "test_id", "id": "ui-gallery-content-viewport" }
    },
    {
      "type": "wheel",
      "target": { "kind": "test_id", "id": "ui-gallery-content-viewport" },
      "delta_y": -360.0
    },
    { "type": "wait_frames", "n": 10 },

    {
      "type": "assert",
      "predicate": {
        "kind": "bounds_non_overlapping",
        "a": { "kind": "test_id", "id": "ui-gallery-typography-demo-h3-joke-tax" },
        "b": { "kind": "test_id", "id": "ui-gallery-typography-demo-list-joke-tax" },
        "eps_px": 0.5
      }
    },

    { "type": "capture_screenshot", "label": "ui-gallery-typography-demo-joke-tax-clip" },
    { "type": "capture_bundle", "label": "ui-gallery-typography-demo-joke-tax-clip" }
  ]
}
