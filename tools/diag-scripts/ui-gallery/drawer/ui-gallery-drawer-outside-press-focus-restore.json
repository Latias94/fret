{
  "schema_version": 2,
  "meta": {
    "name": "ui-gallery-drawer-outside-press-focus-restore",
    "tags": ["ui_gallery", "shadcn", "drawer", "outside_press", "focus"],
    "required_capabilities": ["diag.script_v2"],
    "target_hints": [
      "Navigate to the UI Gallery Drawer page and scroll to the gallery-only outside-press follow-up.",
      "Click the dedicated underlay probe while the modal drawer is open.",
      "Assert the drawer closes and focus returns to the trigger instead of leaking the click into the probe."
    ]
  },
  "steps": [
    { "type": "reset_diagnostics" },
    { "type": "press_key", "key": "escape" },
    { "type": "wait_frames", "n": 2 },
    { "type": "set_window_inner_size", "width_px": 1280.0, "height_px": 900.0 },
    { "type": "wait_frames", "n": 8 },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-nav-search" }
      },
      "timeout_frames": 600
    },
    {
      "type": "type_text_into",
      "target": { "kind": "test_id", "id": "ui-gallery-nav-search" },
      "text": "drawer",
      "clear_before_type": true,
      "timeout_frames": 600
    },
    { "type": "wait_frames", "n": 4 },
    {
      "type": "ensure_visible",
      "target": { "kind": "test_id", "id": "ui-gallery-nav-drawer" },
      "within_window": true,
      "padding_px": 8.0,
      "timeout_frames": 600
    },
    {
      "type": "click_stable",
      "target": { "kind": "test_id", "id": "ui-gallery-nav-drawer" }
    },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-page-drawer" }
      },
      "timeout_frames": 600
    },
    { "type": "wait_frames", "n": 20 },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "bounds_within_window",
        "target": { "kind": "test_id", "id": "ui-gallery-content-scroll" },
        "padding_px": 8.0,
        "eps_px": 1.0
      },
      "timeout_frames": 600
    },
    {
      "type": "scroll_into_view",
      "container": { "kind": "test_id", "id": "ui-gallery-content-scroll" },
      "target": {
        "kind": "test_id",
        "id": "ui-gallery-drawer-outside-press-trigger"
      },
      "delta_y": -120.0,
      "padding_px": 16.0,
      "require_fully_within_container": true,
      "require_fully_within_window": true,
      "timeout_frames": 600
    },
    {
      "type": "wheel",
      "target": { "kind": "test_id", "id": "ui-gallery-content-scroll" },
      "delta_y": -240.0
    },
    { "type": "wait_frames", "n": 2 },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "bounds_within_window",
        "target": {
          "kind": "test_id",
          "id": "ui-gallery-drawer-outside-press-trigger"
        },
        "padding_insets_px": { "left_px": 16.0, "top_px": 16.0, "right_px": 16.0, "bottom_px": 220.0 },
        "eps_px": 1.0
      },
      "timeout_frames": 600
    },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "bounds_within_window",
        "target": {
          "kind": "test_id",
          "id": "ui-gallery-drawer-outside-press-underlay-probe"
        },
        "padding_insets_px": { "left_px": 16.0, "top_px": 16.0, "right_px": 16.0, "bottom_px": 180.0 },
        "eps_px": 1.0
      },
      "timeout_frames": 600
    },
    {
      "type": "click_stable",
      "target": {
        "kind": "test_id",
        "id": "ui-gallery-drawer-outside-press-trigger"
      }
    },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": {
          "kind": "test_id",
          "id": "ui-gallery-drawer-outside-press-content"
        }
      },
      "timeout_frames": 600
    },
    { "type": "wait_frames", "n": 8 },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "bounds_within_window",
        "target": {
          "kind": "test_id",
          "id": "ui-gallery-drawer-outside-press-underlay-probe"
        },
        "padding_px": 8.0,
        "eps_px": 1.0
      },
      "timeout_frames": 600
    },
    {
      "type": "click",
      "target": {
        "kind": "test_id",
        "id": "ui-gallery-drawer-outside-press-underlay-probe"
      }
    },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "not_exists",
        "target": {
          "kind": "test_id",
          "id": "ui-gallery-drawer-outside-press-content"
        }
      },
      "timeout_frames": 600
    },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "focus_is",
        "target": {
          "kind": "test_id",
          "id": "ui-gallery-drawer-outside-press-trigger"
        }
      },
      "timeout_frames": 600
    },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "label_contains",
        "target": {
          "kind": "test_id",
          "id": "ui-gallery-drawer-outside-press-underlay-status"
        },
        "text": "Underlay activations: 0"
      },
      "timeout_frames": 600
    },
    {
      "type": "capture_bundle",
      "label": "ui-gallery-drawer-outside-press-focus-restore"
    }
  ]
}
