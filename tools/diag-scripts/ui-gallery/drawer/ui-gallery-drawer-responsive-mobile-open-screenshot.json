{
  "schema_version": 2,
  "meta": {
    "name": "ui-gallery-drawer-responsive-mobile-open-screenshot",
    "required_capabilities": ["diag.script_v2", "diag.screenshot_png"]
  },
  "steps": [
    { "type": "reset_diagnostics" },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-nav-search" }
      },
      "timeout_frames": 600
    },
    { "type": "press_key", "key": "escape" },
    { "type": "wait_frames", "n": 2 },
    { "type": "set_window_outer_position", "x_px": 120.0, "y_px": 120.0 },
    { "type": "set_window_inner_size", "width_px": 1280.0, "height_px": 900.0 },
    { "type": "wait_frames", "n": 8 },

    {
      "type": "type_text_into",
      "target": { "kind": "test_id", "id": "ui-gallery-nav-search" },
      "text": "drawer",
      "clear_before_type": true,
      "timeout_frames": 600
    },
    { "type": "wait_frames", "n": 4 },
    {
      "type": "ensure_visible",
      "target": { "kind": "test_id", "id": "ui-gallery-nav-drawer" },
      "within_window": true,
      "padding_px": 8.0,
      "timeout_frames": 600
    },
    {
      "type": "click_stable",
      "target": { "kind": "test_id", "id": "ui-gallery-nav-drawer" }
    },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-page-drawer" }
      },
      "timeout_frames": 600
    },
    { "type": "wait_frames", "n": 20 },

    { "type": "set_window_inner_size", "width_px": 520.0, "height_px": 900.0 },
    { "type": "wait_frames", "n": 15 },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-content-scroll" }
      },
      "timeout_frames": 600
    },
    {
      "type": "scroll_into_view",
      "container": { "kind": "test_id", "id": "ui-gallery-content-scroll" },
      "target": { "kind": "test_id", "id": "ui-gallery-drawer-responsive-mobile-trigger" },
      "delta_y": -120.0,
      "require_fully_within_container": true,
      "require_fully_within_window": true,
      "padding_px": 16.0,
      "timeout_frames": 600
    },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "bounds_within_window",
        "target": { "kind": "test_id", "id": "ui-gallery-drawer-responsive-mobile-trigger" },
        "padding_px": 2.0,
        "eps_px": 1.0
      },
      "timeout_frames": 600
    },

    {
      "type": "click_stable",
      "target": { "kind": "test_id", "id": "ui-gallery-drawer-responsive-mobile-trigger" }
    },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-drawer-responsive-mobile-content" }
      },
      "timeout_frames": 600
    },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "bounds_within_window",
        "target": { "kind": "test_id", "id": "ui-gallery-drawer-responsive-mobile-content" },
        "padding_px": 0.0,
        "eps_px": 1.0
      },
      "timeout_frames": 600
    },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-drawer-responsive-mobile-form" }
      },
      "timeout_frames": 600
    },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-drawer-responsive-mobile-email" }
      },
      "timeout_frames": 600
    },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-drawer-responsive-mobile-username" }
      },
      "timeout_frames": 600
    },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-drawer-responsive-mobile-save" }
      },
      "timeout_frames": 600
    },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-drawer-responsive-mobile-cancel" }
      },
      "timeout_frames": 600
    },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "value_contains",
        "target": { "kind": "test_id", "id": "ui-gallery-drawer-responsive-mobile-email" },
        "text": "shadcn@example.com"
      },
      "timeout_frames": 600
    },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "value_contains",
        "target": { "kind": "test_id", "id": "ui-gallery-drawer-responsive-mobile-username" },
        "text": "@shadcn"
      },
      "timeout_frames": 600
    },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "bounds_within_window",
        "target": { "kind": "test_id", "id": "ui-gallery-drawer-responsive-mobile-save" },
        "padding_px": 8.0,
        "eps_px": 1.0
      },
      "timeout_frames": 600
    },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "bounds_within_window",
        "target": { "kind": "test_id", "id": "ui-gallery-drawer-responsive-mobile-cancel" },
        "padding_px": 8.0,
        "eps_px": 1.0
      },
      "timeout_frames": 600
    },
    { "type": "wait_frames", "n": 6 },
    {
      "type": "capture_screenshot",
      "label": "ui-gallery-drawer-responsive-mobile-open"
    },
    {
      "type": "capture_bundle",
      "label": "ui-gallery-drawer-responsive-mobile-open"
    }
  ]
}
