{
  "schema_version": 2,
  "meta": {
    "name": "ui-gallery-collapsible-rtl-code-tab-scroll-range",
    "required_capabilities": ["diag.script_v2", "diag.screenshot_png"],
    "tags": ["ui_gallery", "shadcn", "collapsible", "tabs", "scroll", "regression"]
  },
  "steps": [
    { "type": "reset_diagnostics" },
    { "type": "press_key", "key": "escape" },
    { "type": "wait_frames", "n": 2 },
    { "type": "set_window_inner_size", "width_px": 1280.0, "height_px": 720.0 },
    { "type": "wait_frames", "n": 20 },

    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-nav-search" }
      },
      "timeout_frames": 600
    },
    {
      "type": "type_text_into",
      "target": { "kind": "test_id", "id": "ui-gallery-nav-search" },
      "text": "collapsible",
      "clear_before_type": true,
      "timeout_frames": 600
    },
    { "type": "wait_frames", "n": 4 },

    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-nav-collapsible" }
      },
      "timeout_frames": 600
    },
    {
      "type": "ensure_visible",
      "target": { "kind": "test_id", "id": "ui-gallery-nav-collapsible" },
      "within_window": true,
      "padding_px": 8.0,
      "timeout_frames": 600
    },
    {
      "type": "click_stable",
      "target": { "kind": "test_id", "id": "ui-gallery-nav-collapsible" }
    },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-page-collapsible" }
      },
      "timeout_frames": 600
    },

    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-collapsible-notes" }
      },
      "timeout_frames": 600
    },
    {
      "type": "scroll_into_view",
      "container": { "kind": "test_id", "id": "ui-gallery-content-scroll" },
      "target": { "kind": "test_id", "id": "ui-gallery-collapsible-notes" },
      "delta_y": -160.0,
      "require_fully_within_container": true,
      "require_fully_within_window": true,
      "padding_px": 24.0,
      "timeout_frames": 900
    },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "bounds_within_window",
        "target": { "kind": "test_id", "id": "ui-gallery-collapsible-notes" },
        "padding_px": 24.0,
        "eps_px": 1.0
      },
      "timeout_frames": 300
    },
    { "type": "capture_bundle", "label": "ui-gallery-collapsible-rtl-code-tab-scroll-range.at_bottom_before_tab_switch" },

    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "docsec-rtl-tabs-trigger-code" }
      },
      "timeout_frames": 600
    },
    {
      "type": "scroll_into_view",
      "container": { "kind": "test_id", "id": "ui-gallery-content-scroll" },
      "target": { "kind": "test_id", "id": "docsec-rtl-tabs-trigger-code" },
      "delta_y": -120.0,
      "require_fully_within_container": true,
      "require_fully_within_window": true,
      "padding_px": 24.0,
      "timeout_frames": 900
    },
    {
      "type": "click_stable",
      "target": { "kind": "test_id", "id": "docsec-rtl-tabs-trigger-code" },
      "stable_frames": 2,
      "max_move_px": 2.0,
      "timeout_frames": 900
    },
    { "type": "wait_frames", "n": 12 },
    { "type": "capture_bundle", "label": "ui-gallery-collapsible-rtl-code-tab-scroll-range.after_tab_switch" },

    {
      "type": "assert",
      "predicate": {
        "kind": "semantics_scroll_is_finite",
        "target": { "kind": "test_id", "id": "ui-gallery-content-scroll" },
        "field": "y_max"
      }
    },

    {
      "type": "scroll_into_view",
      "container": { "kind": "test_id", "id": "ui-gallery-content-scroll" },
      "target": { "kind": "test_id", "id": "ui-gallery-collapsible-notes" },
      "delta_y": -160.0,
      "require_fully_within_container": true,
      "require_fully_within_window": true,
      "padding_px": 24.0,
      "timeout_frames": 1800
    },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "bounds_within_window",
        "target": { "kind": "test_id", "id": "ui-gallery-collapsible-notes" },
        "padding_px": 24.0,
        "eps_px": 1.0
      },
      "timeout_frames": 300
    },
    { "type": "capture_screenshot", "label": "ui-gallery-collapsible-rtl-code-tab-scroll-range.notes_visible_after_tab_switch" },
    { "type": "capture_bundle", "label": "ui-gallery-collapsible-rtl-code-tab-scroll-range" }
  ]
}
