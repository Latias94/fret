{
  "meta": {
    "name": "ui-gallery-table-demo-hover-row-inv003-screenshot",
    "required_capabilities": ["diag.script_v2", "diag.screenshot_png"]
  },
  "schema_version": 2,
  "steps": [
    { "type": "reset_diagnostics" },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-nav-search" }
      },
      "timeout_frames": 600
    },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-nav-scroll" }
      },
      "timeout_frames": 600
    },
    { "type": "click", "target": { "kind": "test_id", "id": "ui-gallery-nav-search" } },
    { "type": "press_shortcut", "shortcut": "primary+a" },
    { "type": "press_key", "key": "backspace" },
    { "type": "type_text", "text": "table" },
    { "type": "wait_frames", "n": 2 },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "bounds_within_window",
        "target": { "kind": "test_id", "id": "ui-gallery-nav-table" },
        "padding_px": 8.0
      },
      "timeout_frames": 600
    },
    { "type": "click", "target": { "kind": "test_id", "id": "ui-gallery-nav-table" } },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-table-demo-row-inv003" }
      },
      "timeout_frames": 600
    },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "bounds_within_window",
        "target": { "kind": "test_id", "id": "ui-gallery-table-demo-row-inv003" },
        "padding_px": 6.0
      },
      "timeout_frames": 600
    },
    { "type": "move_pointer", "target": { "kind": "test_id", "id": "ui-gallery-table-demo-row-inv003" } },
    { "type": "wait_frames", "n": 6 },
    { "type": "capture_screenshot", "label": "ui-gallery-table-demo-hover-row-inv003" },
    { "type": "capture_bundle", "label": "ui-gallery-table-demo-hover-row-inv003" }
  ]
}

