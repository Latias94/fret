{
  "schema_version": 2,
  "meta": {
    "name": "UI gallery: Node graph marquee selection screenshot (zinc dark)",
    "tags": ["ui-gallery", "node-graph", "selection", "marquee", "zinc-dark", "screenshots"],
    "required_capabilities": ["diag.script_v2", "diag.screenshot_png"],
    "target_hints": [
      "Sets theme preset to zinc/dark.",
      "Navigates to the Node graph cull torture page.",
      "Creates a marquee selection to gate viewport selection fill/stroke tokens."
    ]
  },
  "steps": [
    { "type": "reset_diagnostics" },
    {
      "type": "wait_until",
      "predicate": { "kind": "exists", "target": { "kind": "test_id", "id": "ui-gallery-theme-preset-trigger" } },
      "timeout_frames": 600
    },
    { "type": "set_window_inner_size", "width_px": 1280.0, "height_px": 900.0 },
    { "type": "wait_frames", "n": 20 },

    { "type": "click", "target": { "kind": "test_id", "id": "ui-gallery-theme-preset-trigger" } },
    { "type": "click_stable", "target": { "kind": "test_id", "id": "ui-gallery-theme-preset-item-zinc-dark" } },
    { "type": "wait_frames", "n": 10 },
    { "type": "press_key", "key": "escape" },
    { "type": "wait_frames", "n": 2 },

    {
      "type": "type_text_into",
      "target": { "kind": "test_id", "id": "ui-gallery-nav-search" },
      "text": "node graph cull",
      "clear_before_type": true,
      "timeout_frames": 600
    },
    { "type": "wait_frames", "n": 2 },
    {
      "type": "ensure_visible",
      "target": { "kind": "test_id", "id": "ui-gallery-nav-node-graph-cull-torture" },
      "within_window": true,
      "padding_px": 8.0,
      "timeout_frames": 600
    },
    { "type": "click_stable", "target": { "kind": "test_id", "id": "ui-gallery-nav-node-graph-cull-torture" } },
    {
      "type": "wait_until",
      "predicate": { "kind": "exists", "target": { "kind": "test_id", "id": "ui-gallery-node-graph-cull-root" } },
      "timeout_frames": 600
    },
    { "type": "wait_frames", "n": 30 },

    {
      "type": "drag_pointer",
      "target": { "kind": "test_id", "id": "ui-gallery-node-graph-cull-root" },
      "button": "left",
      "delta_x": 240.0,
      "delta_y": 160.0,
      "steps": 18
    },
    { "type": "wait_frames", "n": 6 },

    { "type": "capture_screenshot", "label": "ui-gallery-node-graph-marquee-selection-zinc-dark" },
    { "type": "capture_bundle", "label": "ui-gallery-node-graph-marquee-selection-zinc-dark" }
  ]
}

