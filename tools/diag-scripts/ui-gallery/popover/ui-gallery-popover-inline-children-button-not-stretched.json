{
  "schema_version": 2,
  "meta": {
    "name": "UI gallery: Popover inline children button keeps intrinsic width",
    "tags": ["ui-gallery", "shadcn", "popover", "layout", "geometry"],
    "required_capabilities": ["diag.script_v2"],
    "target_hints": [
      "Navigates to the Popover page.",
      "Opens the Fret-only inline-children regression example.",
      "Asserts the inline action button does not stretch to the full popover width."
    ]
  },
  "steps": [
    { "type": "reset_diagnostics" },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-nav-search" }
      },
      "timeout_frames": 600
    },
    { "type": "press_key", "key": "escape" },
    { "type": "wait_frames", "n": 2 },
    { "type": "set_window_inner_size", "width_px": 1280.0, "height_px": 720.0 },
    { "type": "wait_frames", "n": 20 },

    { "type": "click", "target": { "kind": "test_id", "id": "ui-gallery-nav-search" } },
    { "type": "press_key", "key": "a", "modifiers": { "ctrl": true } },
    { "type": "press_key", "key": "backspace" },
    { "type": "type_text", "text": "popover" },
    { "type": "wait_frames", "n": 2 },
    {
      "type": "scroll_into_view",
      "container": { "kind": "test_id", "id": "ui-gallery-nav-scroll" },
      "target": { "kind": "test_id", "id": "ui-gallery-nav-popover" },
      "delta_y": -240.0,
      "timeout_frames": 600
    },
    {
      "type": "click_stable",
      "target": { "kind": "test_id", "id": "ui-gallery-nav-popover" },
      "stable_frames": 2,
      "max_move_px": 2.0,
      "timeout_frames": 600
    },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-page-popover" }
      },
      "timeout_frames": 600
    },

    {
      "type": "scroll_into_view",
      "container": { "kind": "test_id", "id": "ui-gallery-content-scroll" },
      "target": {
        "kind": "test_id",
        "id": "ui-gallery-popover-inline-children-tabs-trigger-preview"
      },
      "delta_y": -180.0,
      "require_fully_within_container": true,
      "require_fully_within_window": true,
      "padding_px": 16.0,
      "padding_insets_px": {
        "left_px": 16.0,
        "top_px": 16.0,
        "right_px": 16.0,
        "bottom_px": 40.0
      },
      "timeout_frames": 900
    },
    {
      "type": "click_stable",
      "target": {
        "kind": "test_id",
        "id": "ui-gallery-popover-inline-children-tabs-trigger-preview"
      },
      "stable_frames": 2,
      "max_move_px": 2.0,
      "timeout_frames": 600
    },
    { "type": "wait_frames", "n": 4 },
    {
      "type": "click_stable",
      "target": {
        "kind": "test_id",
        "id": "ui-gallery-popover-inline-children-trigger"
      },
      "stable_frames": 2,
      "max_move_px": 2.0,
      "timeout_frames": 600
    },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": {
          "kind": "test_id",
          "id": "ui-gallery-popover-inline-children-panel"
        }
      },
      "timeout_frames": 600
    },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": {
          "kind": "test_id",
          "id": "ui-gallery-popover-inline-children-button"
        }
      },
      "timeout_frames": 600
    },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "bounds_max_size",
        "target": {
          "kind": "test_id",
          "id": "ui-gallery-popover-inline-children-button"
        },
        "max_w_px": 220.0,
        "max_h_px": 10000.0,
        "eps_px": 0.5
      },
      "timeout_frames": 240
    },
    {
      "type": "capture_screenshot",
      "label": "ui-gallery-popover-inline-children-button-not-stretched"
    },
    {
      "type": "capture_bundle",
      "label": "ui-gallery-popover-inline-children-button-not-stretched"
    }
  ]
}
