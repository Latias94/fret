      "timeout_frames": 600
    },
    { "type": "wait_frames", "n": 10 },
    { "type": "capture_screenshot", "label": "m3-select-floor-30-off-open" },

    { "type": "capture_bundle", "label": "ui-gallery-material3-select-menu-width-floor-screenshots" }
  ]
}
