{
  "schema_version": 2,
  "steps": [
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-nav-search" }
      },
      "timeout_frames": 600
    },
    { "type": "click", "target": { "kind": "test_id", "id": "ui-gallery-nav-search" } },
    { "type": "press_key", "key": "a", "modifiers": { "ctrl": true } },
    { "type": "press_key", "key": "backspace" },
    { "type": "type_text", "text": "select" },
    { "type": "wait_frames", "n": 2 },
    {
      "type": "ensure_visible",
      "target": { "kind": "test_id", "id": "ui-gallery-nav-material3-select" },
      "within_window": true,
      "padding_px": 8.0,
      "timeout_frames": 600
    },
    { "type": "click", "target": { "kind": "test_id", "id": "ui-gallery-nav-material3-select" } },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-page-material3-select" }
      },
      "timeout_frames": 600
    },
    { "type": "wait_frames", "n": 30 },

    {
      "type": "ensure_visible",
      "target": { "kind": "test_id", "id": "ui-gallery-material3-select-unclamped" },
      "within_window": true,
      "padding_px": 8.0,
      "timeout_frames": 600
    },
    { "type": "capture_screenshot", "label": "m3-select-floor-00-page" },

    { "type": "move_pointer", "target": { "kind": "test_id", "id": "ui-gallery-material3-select-unclamped" } },
    { "type": "click", "target": { "kind": "test_id", "id": "ui-gallery-material3-select-unclamped" } },
    { "type": "wait_frames", "n": 2 },
    { "type": "press_key", "key": "arrow_down" },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-material3-select-unclamped-listbox" }
      },
      "timeout_frames": 600
    },
    { "type": "wait_frames", "n": 10 },
    { "type": "capture_screenshot", "label": "m3-select-floor-10-on-open" },
    { "type": "press_key", "key": "escape" },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "not_exists",
        "target": { "kind": "test_id", "id": "ui-gallery-material3-select-unclamped-listbox" }
      },
      "timeout_frames": 600
    },

    { "type": "ensure_visible", "target": { "kind": "test_id", "id": "ui-gallery-material3-select-menu-width-floor-toggle" }, "within_window": true, "padding_px": 8.0, "timeout_frames": 600 },
    { "type": "click", "target": { "kind": "test_id", "id": "ui-gallery-material3-select-menu-width-floor-toggle" } },
    { "type": "wait_frames", "n": 10 },
    { "type": "press_key", "key": "escape" },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "not_exists",
        "target": { "kind": "test_id", "id": "ui-gallery-material3-select-unclamped-listbox" }
      },
      "timeout_frames": 600
    },
    { "type": "capture_screenshot", "label": "m3-select-floor-20-off" },

    { "type": "move_pointer", "target": { "kind": "test_id", "id": "ui-gallery-material3-select-unclamped" } },
    { "type": "click", "target": { "kind": "test_id", "id": "ui-gallery-material3-select-unclamped" } },
    { "type": "wait_frames", "n": 2 },
    { "type": "press_key", "key": "arrow_down" },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-material3-select-unclamped-listbox" }
