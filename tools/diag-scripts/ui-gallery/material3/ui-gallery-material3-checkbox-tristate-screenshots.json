{
  "schema_version": 2,
  "meta": {
    "name": "ui-gallery-material3-checkbox-tristate-screenshots",
    "required_capabilities": ["diag.script_v2", "diag.screenshot_png"],
    "tags": ["ui_gallery", "material3", "checkbox", "tristate", "expressive", "screenshots"]
  },
  "steps": [
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-nav-search" }
      },
      "timeout_frames": 600
    },
    { "type": "click", "target": { "kind": "test_id", "id": "ui-gallery-nav-search" } },
    { "type": "press_key", "key": "a", "modifiers": { "ctrl": true } },
    { "type": "press_key", "key": "backspace" },
    { "type": "type_text", "text": "checkbox" },
    { "type": "wait_frames", "n": 2 },
    {
      "type": "ensure_visible",
      "target": { "kind": "test_id", "id": "ui-gallery-nav-material3-checkbox" },
      "within_window": true,
      "padding_px": 8.0,
      "timeout_frames": 600
    },
    {
      "type": "click",
      "target": { "kind": "test_id", "id": "ui-gallery-nav-material3-checkbox" }
    },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-page-material3-checkbox" }
      },
      "timeout_frames": 600
    },
    { "type": "wait_frames", "n": 20 },

    {
      "type": "wait_until",
      "predicate": {
        "kind": "role_is",
        "target": { "kind": "test_id", "id": "ui-gallery-material3-checkbox-tristate" },
        "role": "checkbox"
      },
      "timeout_frames": 600
    },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "checked_is_none",
        "target": { "kind": "test_id", "id": "ui-gallery-material3-checkbox-tristate" }
      },
      "timeout_frames": 600
    },
    { "type": "capture_bundle", "label": "m3-checkbox-tristate-00-standard-indeterminate" },
    { "type": "capture_screenshot", "label": "m3-checkbox-tristate-00-standard-indeterminate" },

    {
      "type": "click",
      "target": {
        "kind": "test_id",
        "id": "ui-gallery-material3-design-variant-toggle"
      }
    },
    { "type": "wait_frames", "n": 10 },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "checked_is_none",
        "target": { "kind": "test_id", "id": "ui-gallery-material3-checkbox-tristate" }
      },
      "timeout_frames": 600
    },
    { "type": "capture_bundle", "label": "m3-checkbox-tristate-10-expressive-indeterminate" },
    { "type": "capture_screenshot", "label": "m3-checkbox-tristate-10-expressive-indeterminate" },

    {
      "type": "click",
      "target": { "kind": "test_id", "id": "ui-gallery-material3-checkbox-tristate" }
    },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "checked_is",
        "target": { "kind": "test_id", "id": "ui-gallery-material3-checkbox-tristate" },
        "checked": true
      },
      "timeout_frames": 600
    },
    { "type": "capture_bundle", "label": "m3-checkbox-tristate-20-click-checked-true" },
    { "type": "capture_screenshot", "label": "m3-checkbox-tristate-20-click-checked-true" },

    {
      "type": "click",
      "target": { "kind": "test_id", "id": "ui-gallery-material3-checkbox-tristate" }
    },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "checked_is",
        "target": { "kind": "test_id", "id": "ui-gallery-material3-checkbox-tristate" },
        "checked": false
      },
      "timeout_frames": 600
    },
    { "type": "capture_bundle", "label": "m3-checkbox-tristate-30-click-checked-false" },
    { "type": "capture_screenshot", "label": "m3-checkbox-tristate-30-click-checked-false" },

    { "type": "capture_bundle", "label": "ui-gallery-material3-checkbox-tristate" }
  ]
}

