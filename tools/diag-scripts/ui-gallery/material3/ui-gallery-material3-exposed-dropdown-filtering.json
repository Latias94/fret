{
  "schema_version": 2,
  "steps": [
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-page-material3-autocomplete" }
      },
      "timeout_frames": 600
    },
    { "type": "wait_frames", "n": 30 },

    {
      "type": "ensure_visible",
      "target": { "kind": "test_id", "id": "ui-gallery-material3-exposed-dropdown" },
      "within_window": true,
      "padding_px": 8.0,
      "timeout_frames": 600
    },
    {
      "type": "click",
      "target": {
        "kind": "test_id",
        "id": "ui-gallery-material3-exposed-dropdown-trailing-icon"
      }
    },
    { "type": "press_key", "key": "a", "modifiers": { "ctrl": true } },
    { "type": "press_key", "key": "backspace" },
    { "type": "type_text", "text": "ga" },
    { "type": "wait_frames", "n": 4 },

    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": {
          "kind": "test_id",
          "id": "ui-gallery-material3-exposed-dropdown-listbox"
        }
      },
      "timeout_frames": 600
    },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": {
          "kind": "test_id",
          "id": "ui-gallery-material3-exposed-dropdown-option-gamma"
        }
      },
      "timeout_frames": 600
    },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "not_exists",
        "target": {
          "kind": "test_id",
          "id": "ui-gallery-material3-exposed-dropdown-option-alpha"
        }
      },
      "timeout_frames": 600
    },

    {
      "type": "assert",
      "predicate": {
        "kind": "bounds_within_window",
        "target": {
          "kind": "test_id",
          "id": "ui-gallery-material3-exposed-dropdown-listbox"
        },
        "padding_px": 8.0
      }
    },

    { "type": "capture_bundle", "label": "ui-gallery-material3-exposed-dropdown-filtering" },
    {
      "type": "capture_screenshot",
      "label": "ui-gallery-material3-exposed-dropdown-filtering-open"
    },

    {
      "type": "click",
      "target": {
        "kind": "test_id",
        "id": "ui-gallery-material3-exposed-dropdown-trailing-icon"
      }
    },
    { "type": "wait_frames", "n": 4 },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "not_exists",
        "target": {
          "kind": "test_id",
          "id": "ui-gallery-material3-exposed-dropdown-listbox"
        }
      },
      "timeout_frames": 600
    },
    {
      "type": "capture_screenshot",
      "label": "ui-gallery-material3-exposed-dropdown-filtering-closed"
    }
  ]
}
