{
  "schema_version": 2,
  "meta": {
    "name": "ui-gallery-material3-switch-focus-visible-screenshots",
    "required_capabilities": ["diag.script_v2", "diag.screenshot_png"],
    "tags": ["ui_gallery", "material3", "switch", "focus_visible", "screenshots"]
  },
  "steps": [
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-nav-search" }
      },
      "timeout_frames": 600
    },
    { "type": "click", "target": { "kind": "test_id", "id": "ui-gallery-nav-search" } },
    { "type": "press_key", "key": "a", "modifiers": { "ctrl": true } },
    { "type": "press_key", "key": "backspace" },
    { "type": "type_text", "text": "switch" },
    { "type": "wait_frames", "n": 2 },
    {
      "type": "ensure_visible",
      "target": { "kind": "test_id", "id": "ui-gallery-nav-material3-switch" },
      "within_window": true,
      "padding_px": 8.0,
      "timeout_frames": 600
    },
    { "type": "click", "target": { "kind": "test_id", "id": "ui-gallery-nav-material3-switch" } },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-page-material3-switch" }
      },
      "timeout_frames": 600
    },
    { "type": "wait_frames", "n": 20 },

    {
      "type": "wait_until",
      "predicate": {
        "kind": "checked_is",
        "target": { "kind": "test_id", "id": "ui-gallery-material3-switch" },
        "checked": false
      },
      "timeout_frames": 600
    },

    { "type": "click", "target": { "kind": "test_id", "id": "ui-gallery-material3-switch" } },
    { "type": "wait_frames", "n": 6 },
    { "type": "click", "target": { "kind": "test_id", "id": "ui-gallery-material3-switch" } },
    { "type": "wait_frames", "n": 8 },

    {
      "type": "wait_until",
      "predicate": {
        "kind": "checked_is",
        "target": { "kind": "test_id", "id": "ui-gallery-material3-switch" },
        "checked": false
      },
      "timeout_frames": 240
    },

    {
      "type": "wait_until",
      "predicate": {
        "kind": "focus_is",
        "target": { "kind": "test_id", "id": "ui-gallery-material3-switch" }
      },
      "timeout_frames": 240
    },

    { "type": "capture_bundle", "label": "m3-switch-10-focused-pointer" },
    { "type": "capture_screenshot", "label": "m3-switch-10-focused-pointer" },

    { "type": "press_key", "key": "arrow_right" },
    { "type": "wait_frames", "n": 4 },

    { "type": "capture_bundle", "label": "m3-switch-20-focused-focus-visible" },
    { "type": "capture_screenshot", "label": "m3-switch-20-focused-focus-visible" },

    {
      "type": "assert",
      "predicate": {
        "kind": "checked_is",
        "target": { "kind": "test_id", "id": "ui-gallery-material3-switch" },
        "checked": false
      }
    },

    { "type": "capture_bundle", "label": "ui-gallery-material3-switch-focus-visible-screenshots" }
  ]
}
