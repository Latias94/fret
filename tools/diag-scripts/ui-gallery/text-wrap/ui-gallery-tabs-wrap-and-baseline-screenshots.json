{
  "schema_version": 2,
  "meta": {
    "name": "ui-gallery-tabs-wrap-and-baseline-screenshots",
    "required_capabilities": ["diag.script_v2", "diag.screenshot_png"],
    "tags": ["ui_gallery", "shadcn", "tabs", "text", "wrap", "baseline", "screenshots"]
  },
  "steps": [
    { "type": "reset_diagnostics" },
    { "type": "press_key", "key": "escape" },
    { "type": "wait_frames", "n": 2 },

    {
      "type": "wait_until",
      "predicate": { "kind": "exists", "target": { "kind": "test_id", "id": "ui-gallery-nav-search" } },
      "timeout_frames": 600
    },
    {
      "type": "wait_until",
      "predicate": { "kind": "exists", "target": { "kind": "test_id", "id": "ui-gallery-nav-scroll" } },
      "timeout_frames": 600
    },

    { "type": "set_window_inner_size", "width_px": 1280.0, "height_px": 720.0 },
    { "type": "wait_frames", "n": 10 },

    { "type": "click", "target": { "kind": "test_id", "id": "ui-gallery-nav-search" } },
    { "type": "press_key", "key": "a", "modifiers": { "ctrl": true } },
    { "type": "press_key", "key": "backspace" },
    { "type": "type_text", "text": "tabs" },
    { "type": "wait_frames", "n": 2 },

    {
      "type": "scroll_into_view",
      "container": { "kind": "test_id", "id": "ui-gallery-nav-scroll" },
      "target": { "kind": "test_id", "id": "ui-gallery-nav-tabs" },
      "delta_y": -240.0,
      "timeout_frames": 600
    },
    { "type": "click", "target": { "kind": "test_id", "id": "ui-gallery-nav-tabs" } },
    {
      "type": "wait_until",
      "predicate": { "kind": "exists", "target": { "kind": "test_id", "id": "ui-gallery-page-tabs" } },
      "timeout_frames": 600
    },

    { "type": "wait_until", "predicate": { "kind": "font_catalog_populated" }, "timeout_frames": 1800 },
    { "type": "wait_until", "predicate": { "kind": "system_font_rescan_idle" }, "timeout_frames": 1800 },
    {
      "type": "wait_until",
      "predicate": { "kind": "text_font_stack_key_stable", "stable_frames": 120 },
      "timeout_frames": 900
    },

    { "type": "wait_frames", "n": 10 },
    { "type": "capture_screenshot", "label": "tabs-wide-1280", "timeout_frames": 240 },

    { "type": "set_window_inner_size", "width_px": 420.0, "height_px": 720.0 },
    { "type": "wait_frames", "n": 20 },
    { "type": "capture_screenshot", "label": "tabs-narrow-420", "timeout_frames": 240 },

    { "type": "set_window_inner_size", "width_px": 320.0, "height_px": 720.0 },
    { "type": "wait_frames", "n": 20 },
    { "type": "capture_screenshot", "label": "tabs-narrow-320", "timeout_frames": 240 },

    { "type": "capture_bundle", "label": "ui-gallery-tabs-wrap-and-baseline-screenshots" },
    { "type": "wait_frames", "n": 2 }
  ]
}

