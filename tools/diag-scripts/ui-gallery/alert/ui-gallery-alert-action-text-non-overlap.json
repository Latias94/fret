{
  "schema_version": 2,
  "meta": {
    "name": "ui-gallery-alert-action-text-non-overlap",
    "required_capabilities": ["diag.script_v2"],
    "tags": ["ui-gallery", "shadcn", "alert"]
  },
  "steps": [
    { "type": "reset_diagnostics" },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-nav-search" }
      },
      "timeout_frames": 600
    },
    { "type": "press_key", "key": "escape" },
    { "type": "wait_frames", "n": 2 },

    { "type": "set_window_inner_size", "width_px": 860.0, "height_px": 900.0 },
    { "type": "wait_frames", "n": 15 },

    { "type": "click", "target": { "kind": "test_id", "id": "ui-gallery-nav-search" } },
    { "type": "press_key", "key": "a", "modifiers": { "ctrl": true } },
    { "type": "press_key", "key": "backspace" },
    { "type": "type_text", "text": "alert" },
    { "type": "wait_frames", "n": 2 },

    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-nav-alert" }
      },
      "timeout_frames": 600
    },
    { "type": "click", "target": { "kind": "test_id", "id": "ui-gallery-nav-alert" } },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-page-alert" }
      },
      "timeout_frames": 600
    },

    {
      "type": "scroll_into_view",
      "container": { "kind": "test_id", "id": "ui-gallery-content-scroll" },
      "target": { "kind": "test_id", "id": "ui-gallery-alert-action" },
      "delta_y": -200.0,
      "require_fully_within_container": false,
      "require_fully_within_window": false,
      "padding_px": 16.0,
      "timeout_frames": 1200
    },
    { "type": "wait_frames", "n": 10 },

    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-alert-action-title" }
      },
      "timeout_frames": 600
    },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-alert-action-undo" }
      },
      "timeout_frames": 600
    },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-alert-action-badge-title" }
      },
      "timeout_frames": 600
    },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-alert-action-badge-description" }
      },
      "timeout_frames": 600
    },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-alert-action-badge-chip" }
      },
      "timeout_frames": 600
    },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "bounds_min_size",
        "target": { "kind": "test_id", "id": "ui-gallery-alert-action" },
        "min_w_px": 500.0,
        "min_h_px": 36.0,
        "eps_px": 1.0
      },
      "timeout_frames": 240
    },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "bounds_non_overlapping",
        "a": { "kind": "test_id", "id": "ui-gallery-alert-action-title" },
        "b": { "kind": "test_id", "id": "ui-gallery-alert-action-undo" },
        "eps_px": 0.5
      },
      "timeout_frames": 240
    },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "bounds_non_overlapping",
        "a": { "kind": "test_id", "id": "ui-gallery-alert-action-badge-title" },
        "b": { "kind": "test_id", "id": "ui-gallery-alert-action-badge-chip" },
        "eps_px": 0.5
      },
      "timeout_frames": 240
    },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "bounds_non_overlapping",
        "a": { "kind": "test_id", "id": "ui-gallery-alert-action-badge-description" },
        "b": { "kind": "test_id", "id": "ui-gallery-alert-action-badge-chip" },
        "eps_px": 0.5
      },
      "timeout_frames": 240
    },
    {
      "type": "capture_screenshot",
      "label": "ui-gallery-alert-action-text-non-overlap"
    },
    { "type": "capture_bundle", "label": "ui-gallery-alert-action-text-non-overlap" }
  ]
}
