{
  "schema_version": 2,
  "meta": {
    "name": "ui-gallery-alert-rich-description-layout",
    "required_capabilities": ["diag.script_v2", "diag.screenshot_png"],
    "tags": ["ui-gallery", "shadcn", "alert", "layout"]
  },
  "steps": [
    { "type": "reset_diagnostics" },
    { "type": "press_key", "key": "escape" },
    { "type": "wait_frames", "n": 2 },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-nav-search" }
      },
      "timeout_frames": 600
    },
    { "type": "click", "target": { "kind": "test_id", "id": "ui-gallery-nav-search" } },
    { "type": "press_key", "key": "a", "modifiers": { "ctrl": true } },
    { "type": "press_key", "key": "backspace" },
    { "type": "type_text", "text": "alert" },
    { "type": "wait_frames", "n": 2 },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-nav-alert" }
      },
      "timeout_frames": 600
    },
    { "type": "click", "target": { "kind": "test_id", "id": "ui-gallery-nav-alert" } },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-alert-component" }
      },
      "timeout_frames": 600
    },
    {
      "type": "scroll_into_view",
      "container": { "kind": "test_id", "id": "ui-gallery-content-scroll" },
      "target": {
        "kind": "test_id",
        "id": "ui-gallery-alert-rich-description-card"
      },
      "delta_y": -320.0,
      "require_fully_within_container": false,
      "require_fully_within_window": false,
      "padding_px": 16.0,
      "padding_insets_px": {
        "left_px": 16.0,
        "top_px": 16.0,
        "right_px": 16.0,
        "bottom_px": 40.0
      },
      "timeout_frames": 1800
    },
    { "type": "wait_frames", "n": 10 },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": {
          "kind": "test_id",
          "id": "ui-gallery-alert-rich-description-card-title"
        }
      },
      "timeout_frames": 600
    },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": {
          "kind": "test_id",
          "id": "ui-gallery-alert-rich-description-card-paragraph"
        }
      },
      "timeout_frames": 600
    },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": {
          "kind": "test_id",
          "id": "ui-gallery-alert-rich-description-card-list"
        }
      },
      "timeout_frames": 600
    },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "bounds_non_overlapping",
        "a": {
          "kind": "test_id",
          "id": "ui-gallery-alert-rich-description-card-title"
        },
        "b": {
          "kind": "test_id",
          "id": "ui-gallery-alert-rich-description-card-paragraph"
        },
        "eps_px": 0.5
      },
      "timeout_frames": 240
    },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "bounds_non_overlapping",
        "a": {
          "kind": "test_id",
          "id": "ui-gallery-alert-rich-description-card-paragraph"
        },
        "b": {
          "kind": "test_id",
          "id": "ui-gallery-alert-rich-description-card-list"
        },
        "eps_px": 0.5
      },
      "timeout_frames": 240
    },
    {
      "type": "capture_screenshot",
      "label": "ui-gallery-alert-rich-description-layout"
    },
    {
      "type": "capture_bundle",
      "label": "ui-gallery-alert-rich-description-layout"
    }
  ]
}
