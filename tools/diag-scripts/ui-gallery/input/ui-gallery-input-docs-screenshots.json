{
  "schema_version": 2,
  "meta": {
    "name": "UI gallery: Input docs screenshots (preview + code)",
    "tags": ["ui-gallery", "shadcn", "input", "docs", "screenshots"],
    "required_capabilities": ["diag.script_v2", "diag.screenshot_png"],
    "target_hints": [
      "Navigates to the Input page via the left nav search.",
      "Captures representative screenshots for the docs-aligned demo + example sections and the Fret-only label association follow-up."
    ]
  },
  "steps": [
    { "type": "reset_diagnostics" },
    {
      "type": "wait_until",
      "predicate": { "kind": "exists", "target": { "kind": "test_id", "id": "ui-gallery-nav-search" } },
      "timeout_frames": 600
    },
    {
      "type": "type_text_into",
      "target": { "kind": "test_id", "id": "ui-gallery-nav-search" },
      "text": "input",
      "clear_before_type": true,
      "timeout_frames": 600
    },
    { "type": "wait_frames", "n": 2 },
    {
      "type": "scroll_into_view",
      "container": { "kind": "test_id", "id": "ui-gallery-nav-scroll" },
      "target": { "kind": "test_id", "id": "ui-gallery-nav-input" },
      "delta_y": -240.0,
      "timeout_frames": 600
    },
    { "type": "click_stable", "target": { "kind": "test_id", "id": "ui-gallery-nav-input" } },
    {
      "type": "wait_until",
      "predicate": { "kind": "exists", "target": { "kind": "test_id", "id": "ui-gallery-input" } },
      "timeout_frames": 600
    },

    {
      "type": "scroll_into_view",
      "container": { "kind": "test_id", "id": "ui-gallery-content-scroll" },
      "target": { "kind": "test_id", "id": "ui-gallery-input-demo-content" },
      "delta_y": -120.0,
      "require_fully_within_container": true,
      "require_fully_within_window": true,
      "padding_px": 16.0,
      "timeout_frames": 600
    },
    { "type": "wait_frames", "n": 2 },
    { "type": "capture_screenshot", "label": "ui-gallery-input-docs.01-demo" },

    {
      "type": "scroll_into_view",
      "container": { "kind": "test_id", "id": "ui-gallery-content-scroll" },
      "target": { "kind": "test_id", "id": "ui-gallery-input-usage-content" },
      "delta_y": -120.0,
      "require_fully_within_container": true,
      "require_fully_within_window": true,
      "padding_px": 16.0,
      "timeout_frames": 600
    },
    { "type": "wait_frames", "n": 2 },
    { "type": "capture_screenshot", "label": "ui-gallery-input-docs.02-usage" },
    { "type": "click", "target": { "kind": "test_id", "id": "ui-gallery-input-usage-tabs-trigger-code" } },
    { "type": "wait_frames", "n": 2 },
    { "type": "capture_screenshot", "label": "ui-gallery-input-docs.03-usage-code" },

    {
      "type": "scroll_into_view",
      "container": { "kind": "test_id", "id": "ui-gallery-content-scroll" },
      "target": { "kind": "test_id", "id": "ui-gallery-input-field-group-content" },
      "delta_y": -120.0,
      "require_fully_within_container": true,
      "require_fully_within_window": true,
      "padding_px": 16.0,
      "timeout_frames": 600
    },
    { "type": "wait_frames", "n": 2 },
    { "type": "capture_screenshot", "label": "ui-gallery-input-docs.04-field-group" },

    {
      "type": "scroll_into_view",
      "container": { "kind": "test_id", "id": "ui-gallery-content-scroll" },
      "target": { "kind": "test_id", "id": "ui-gallery-input-file-section-content" },
      "delta_y": -120.0,
      "require_fully_within_container": true,
      "require_fully_within_window": true,
      "padding_px": 16.0,
      "timeout_frames": 600
    },
    { "type": "wait_frames", "n": 2 },
    { "type": "capture_screenshot", "label": "ui-gallery-input-docs.05-file" },

    {
      "type": "scroll_into_view",
      "container": { "kind": "test_id", "id": "ui-gallery-content-scroll" },
      "target": { "kind": "test_id", "id": "ui-gallery-input-form-content" },
      "delta_y": -120.0,
      "padding_px": 16.0,
      "timeout_frames": 600
    },
    { "type": "wait_frames", "n": 2 },
    { "type": "capture_screenshot", "label": "ui-gallery-input-docs.06-form" },

    {
      "type": "scroll_into_view",
      "container": { "kind": "test_id", "id": "ui-gallery-content-scroll" },
      "target": { "kind": "test_id", "id": "ui-gallery-input-label-content" },
      "delta_y": -120.0,
      "require_fully_within_container": true,
      "require_fully_within_window": true,
      "padding_px": 16.0,
      "timeout_frames": 600
    },
    { "type": "wait_frames", "n": 2 },
    { "type": "capture_screenshot", "label": "ui-gallery-input-docs.07-label-association" },

    {
      "type": "scroll_into_view",
      "container": { "kind": "test_id", "id": "ui-gallery-content-scroll" },
      "target": { "kind": "test_id", "id": "ui-gallery-input-api-reference-content" },
      "delta_y": -120.0,
      "require_fully_within_container": true,
      "require_fully_within_window": true,
      "padding_px": 16.0,
      "timeout_frames": 600
    },
    { "type": "wait_frames", "n": 2 },
    { "type": "capture_screenshot", "label": "ui-gallery-input-docs.08-api-reference" },
    { "type": "capture_bundle", "label": "ui-gallery-input-docs" }
  ]
}
