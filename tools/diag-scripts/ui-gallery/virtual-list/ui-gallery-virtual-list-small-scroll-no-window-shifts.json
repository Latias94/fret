{
  "schema_version": 1,
  "steps": [
    {
      "type": "click",
      "target": { "kind": "test_id", "id": "ui-gallery-nav-virtual-list-torture" }
    },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "focus_is",
        "target": { "kind": "test_id", "id": "ui-gallery-nav-virtual-list-torture" }
      },
      "timeout_frames": 60
    },
    { "type": "press_key", "key": "enter" },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-virtual-list-root" }
      },
      "timeout_frames": 240
    },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "visible_in_window",
        "target": { "kind": "test_id", "id": "ui-gallery-virtual-list-row-0-label" }
      },
      "timeout_frames": 240
    },
    {
      "type": "move_pointer",
      "target": { "kind": "test_id", "id": "ui-gallery-virtual-list-row-0-label" }
    },
    { "type": "wait_frames", "n": 40 },

    { "type": "capture_bundle", "label": "ui-gallery-virtual-list-small-scroll-no-window-shifts-before" },

    { "type": "wheel", "target": { "kind": "test_id", "id": "ui-gallery-virtual-list-root" }, "delta_y": 60.0 },
    { "type": "wait_frames", "n": 10 },

    { "type": "wheel", "target": { "kind": "test_id", "id": "ui-gallery-virtual-list-root" }, "delta_y": -60.0 },
    { "type": "wait_frames", "n": 12 },

    { "type": "capture_bundle", "label": "ui-gallery-virtual-list-small-scroll-no-window-shifts-after" },
    { "type": "capture_bundle", "label": "ui-gallery-virtual-list-small-scroll-no-window-shifts" }
  ]
}
