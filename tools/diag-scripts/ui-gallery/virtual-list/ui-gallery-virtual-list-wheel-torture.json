{
  "schema_version": 2,
  "meta": {
    "name": "ui-gallery-virtual-list-wheel-torture",
    "required_capabilities": ["diag.script_v2"],
    "tags": ["scroll", "wheel", "virtual_list", "ui_gallery", "perf"]
  },
  "steps": [
    { "type": "press_key", "key": "escape" },
    { "type": "wait_frames", "n": 2 },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-nav-search" }
      },
      "timeout_frames": 600
    },
    { "type": "click", "target": { "kind": "test_id", "id": "ui-gallery-nav-search" } },
    { "type": "press_key", "key": "a", "modifiers": { "ctrl": true } },
    { "type": "press_key", "key": "backspace" },
    { "type": "type_text", "text": "virtual list torture" },
    { "type": "wait_frames", "n": 2 },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-nav-virtual-list-torture" }
      },
      "timeout_frames": 600
    },
    {
      "type": "scroll_into_view",
      "container": { "kind": "test_id", "id": "ui-gallery-nav-scroll" },
      "target": { "kind": "test_id", "id": "ui-gallery-nav-virtual-list-torture" },
      "delta_y": -240.0,
      "timeout_frames": 600
    },
    { "type": "click", "target": { "kind": "test_id", "id": "ui-gallery-nav-virtual-list-torture" } },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-virtual-list-root" }
      },
      "timeout_frames": 600
    },

    { "type": "wheel", "target": { "kind": "test_id", "id": "ui-gallery-virtual-list-root" }, "delta_y": -120.0 },
    { "type": "wheel", "target": { "kind": "test_id", "id": "ui-gallery-virtual-list-root" }, "delta_y": -120.0 },
    { "type": "wheel", "target": { "kind": "test_id", "id": "ui-gallery-virtual-list-root" }, "delta_y": -120.0 },
    { "type": "wheel", "target": { "kind": "test_id", "id": "ui-gallery-virtual-list-root" }, "delta_y": -120.0 },
    { "type": "wheel", "target": { "kind": "test_id", "id": "ui-gallery-virtual-list-root" }, "delta_y": -120.0 },
    { "type": "wheel", "target": { "kind": "test_id", "id": "ui-gallery-virtual-list-root" }, "delta_y": -120.0 },
    { "type": "wheel", "target": { "kind": "test_id", "id": "ui-gallery-virtual-list-root" }, "delta_y": -120.0 },
    { "type": "wheel", "target": { "kind": "test_id", "id": "ui-gallery-virtual-list-root" }, "delta_y": -120.0 },
    { "type": "wheel", "target": { "kind": "test_id", "id": "ui-gallery-virtual-list-root" }, "delta_y": -120.0 },
    { "type": "wheel", "target": { "kind": "test_id", "id": "ui-gallery-virtual-list-root" }, "delta_y": -120.0 },

    { "type": "wait_frames", "n": 2 },
    { "type": "capture_bundle", "label": "virtual-list-wheel-torture" }
  ]
}

