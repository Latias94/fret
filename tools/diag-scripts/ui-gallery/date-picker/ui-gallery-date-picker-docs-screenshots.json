{
  "schema_version": 2,
  "meta": {
    "name": "ui-gallery-date-picker-docs-screenshots",
    "required_capabilities": ["diag.script_v2", "diag.screenshot_png"],
    "tags": ["ui_gallery", "shadcn", "date_picker", "screenshots", "docs"]
  },
  "steps": [
    { "type": "reset_diagnostics" },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-nav-date-picker" }
      },
      "timeout_frames": 600
    },
    { "type": "press_key", "key": "escape" },
    { "type": "wait_frames", "n": 2 },
    { "type": "set_window_inner_size", "width_px": 1280.0, "height_px": 720.0 },
    { "type": "wait_frames", "n": 20 },

    {
      "type": "scroll_into_view",
      "container": { "kind": "test_id", "id": "ui-gallery-nav-scroll" },
      "target": { "kind": "test_id", "id": "ui-gallery-nav-date-picker" },
      "delta_y": 240.0,
      "padding_px": 8.0,
      "timeout_frames": 600
    },
    {
      "type": "click_stable",
      "target": { "kind": "test_id", "id": "ui-gallery-nav-date-picker.chrome" },
      "stable_frames": 2,
      "max_move_px": 1.0,
      "timeout_frames": 240
    },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-page-date-picker" }
      },
      "timeout_frames": 600
    },
    { "type": "wait_frames", "n": 20 },

    {
      "type": "scroll_into_view",
      "container": { "kind": "test_id", "id": "ui-gallery-content-scroll" },
      "target": { "kind": "test_id", "id": "ui-gallery-date-picker-demo" },
      "delta_y": -200.0,
      "require_fully_within_container": true,
      "padding_px": 16.0,
      "timeout_frames": 1800
    },
    { "type": "wait_frames", "n": 10 },
    { "type": "capture_screenshot", "label": "ui-gallery-date-picker-demo" },
    {
      "type": "click_stable",
      "target": { "kind": "test_id", "id": "ui-gallery-date-picker-demo-trigger.chrome" }
    },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-date-picker-demo-content" }
      },
      "timeout_frames": 600
    },
    { "type": "wait_frames", "n": 10 },
    { "type": "capture_screenshot", "label": "ui-gallery-date-picker-demo-open" },
    { "type": "press_key", "key": "escape" },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "not_exists",
        "target": { "kind": "test_id", "id": "ui-gallery-date-picker-demo-content" }
      },
      "timeout_frames": 600
    },

    {
      "type": "scroll_into_view",
      "container": { "kind": "test_id", "id": "ui-gallery-content-scroll" },
      "target": { "kind": "test_id", "id": "ui-gallery-date-picker-basic-trigger" },
      "delta_y": -200.0,
      "require_fully_within_container": true,
      "padding_px": 16.0,
      "timeout_frames": 1800
    },
    { "type": "wait_frames", "n": 10 },
    { "type": "capture_screenshot", "label": "ui-gallery-date-picker-basic" },
    {
      "type": "click_stable",
      "target": { "kind": "test_id", "id": "ui-gallery-date-picker-basic-trigger" }
    },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-date-picker-basic-content" }
      },
      "timeout_frames": 600
    },
    { "type": "wait_frames", "n": 10 },
    { "type": "capture_screenshot", "label": "ui-gallery-date-picker-basic-open" },
    { "type": "press_key", "key": "escape" },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "not_exists",
        "target": { "kind": "test_id", "id": "ui-gallery-date-picker-basic-content" }
      },
      "timeout_frames": 600
    },

    {
      "type": "scroll_into_view",
      "container": { "kind": "test_id", "id": "ui-gallery-content-scroll" },
      "target": { "kind": "test_id", "id": "ui-gallery-date-picker-dob-trigger" },
      "delta_y": 240.0,
      "require_fully_within_container": true,
      "padding_px": 16.0,
      "timeout_frames": 1800
    },
    {
      "type": "wait_bounds_stable",
      "target": { "kind": "test_id", "id": "ui-gallery-date-picker-dob-trigger" },
      "stable_frames": 4,
      "max_move_px": 0.75,
      "timeout_frames": 600
    },
    {
      "type": "activate",
      "target": { "kind": "test_id", "id": "ui-gallery-date-picker-dob-trigger" }
    },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-date-picker-dob-content" }
      },
      "timeout_frames": 600
    },
    { "type": "wait_frames", "n": 10 },
    { "type": "capture_screenshot", "label": "ui-gallery-date-picker-dob-open" },

    {
      "type": "click_stable",
      "target": {
        "kind": "test_id",
        "id": "ui-gallery-date-picker-dob-calendar.caption-year-trigger"
      },
      "stable_frames": 2,
      "max_move_px": 1.0,
      "timeout_frames": 240
    },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "select-scroll-viewport" }
      },
      "timeout_frames": 240
    },
    { "type": "wait_frames", "n": 10 },
    { "type": "capture_screenshot", "label": "ui-gallery-date-picker-dob-year-open" },

    { "type": "capture_bundle", "label": "ui-gallery-date-picker-docs-screenshots" }
  ]
}
