{
  "schema_version": 2,
  "meta": {
    "name": "UI Gallery: Date Picker docs screenshots",
    "tags": ["ui-gallery", "date-picker", "shadcn", "screenshots"],
    "required_capabilities": ["diag.script_v2", "diag.screenshot_png"]
  },
  "steps": [
    { "type": "reset_diagnostics" },
    {
      "type": "wait_until",
      "timeout_frames": 1800,
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-date-picker-simple" }
      }
    },

    {
      "type": "scroll_into_view",
      "container": { "kind": "test_id", "id": "ui-gallery-content-scroll" },
      "target": { "kind": "test_id", "id": "ui-gallery-date-picker-simple" },
      "delta_x": 0.0,
      "delta_y": -120.0,
      "require_fully_within_container": true,
      "require_fully_within_window": true,
      "padding_px": 4.0,
      "timeout_frames": 600
    },
    { "type": "capture_bundle", "label": "ui-gallery-date-picker-docs-00-basic" },
    { "type": "capture_screenshot", "label": "ui-gallery-date-picker-docs-00-basic" },

    {
      "type": "click",
      "target": { "kind": "test_id", "id": "ui-gallery-date-picker-simple" }
    },
    {
      "type": "wait_until",
      "timeout_frames": 1800,
      "predicate": { "kind": "exists", "target": { "kind": "test_id", "id": "2024-02-01" } }
    },
    { "type": "capture_bundle", "label": "ui-gallery-date-picker-docs-01-basic-open" },
    { "type": "capture_screenshot", "label": "ui-gallery-date-picker-docs-01-basic-open" },
