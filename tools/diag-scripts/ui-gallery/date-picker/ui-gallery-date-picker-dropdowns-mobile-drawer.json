{
  "schema_version": 2,
  "meta": {
    "name": "ui-gallery-date-picker-dropdowns-mobile-drawer",
    "required_capabilities": ["diag.script_v2"],
    "tags": ["ui_gallery", "shadcn", "date_picker", "drawer", "responsive"]
  },
  "steps": [
    { "type": "reset_diagnostics" },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-nav-search" }
      },
      "timeout_frames": 600
    },
    { "type": "press_key", "key": "escape" },
    { "type": "wait_frames", "n": 2 },
    { "type": "set_window_inner_size", "width_px": 480.0, "height_px": 820.0 },
    { "type": "wait_frames", "n": 20 },

    { "type": "click", "target": { "kind": "test_id", "id": "ui-gallery-nav-search" } },
    { "type": "press_key", "key": "a", "modifiers": { "ctrl": true } },
    { "type": "press_key", "key": "backspace" },
    { "type": "type_text", "text": "date picker" },
    { "type": "wait_frames", "n": 2 },
    { "type": "click", "target": { "kind": "test_id", "id": "ui-gallery-nav-date-picker" } },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-date-picker-demo" }
      },
      "timeout_frames": 600
    },
    { "type": "wait_frames", "n": 20 },

    {
      "type": "scroll_into_view",
      "container": { "kind": "test_id", "id": "ui-gallery-content-scroll" },
      "target": { "kind": "test_id", "id": "ui-gallery-date-picker-dropdowns-trigger.chrome" },
      "delta_y": -420.0,
      "padding_px": 16.0,
      "timeout_frames": 1800
    },

    {
      "type": "click_stable",
      "target": { "kind": "test_id", "id": "ui-gallery-date-picker-dropdowns-trigger.chrome" }
    },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": {
          "kind": "test_id",
          "id": "ui-gallery-date-picker-dropdowns-drawer-content"
        }
      },
      "timeout_frames": 600
    },
    {
      "type": "assert",
      "predicate": {
        "kind": "not_exists",
        "target": {
          "kind": "test_id",
          "id": "ui-gallery-date-picker-dropdowns-popover-content"
        }
      }
    },

    { "type": "click", "target": { "kind": "test_id", "id": "ui-gallery-date-picker-dropdowns-done" } },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "not_exists",
        "target": {
          "kind": "test_id",
          "id": "ui-gallery-date-picker-dropdowns-drawer-content"
        }
      },
      "timeout_frames": 600
    },

    { "type": "capture_bundle", "label": "ui-gallery-date-picker-dropdowns-mobile-drawer" }
  ]
}
