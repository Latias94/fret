{
  "schema_version": 2,
  "meta": {
    "name": "ui-gallery-web-ime-harness-beforeinput-control-intents",
    "required_capabilities": ["diag.script_v2"],
    "tags": ["ui_gallery", "ime", "web", "beforeinput", "control_intents"],
    "target_hints": [
      "Run against the web UI Gallery harness page (`page=web_ime_harness`) in a debug build.",
      "Exercises synthetic beforeinput control intents without a physical keydown."
    ]
  },
  "steps": [
    { "type": "reset_diagnostics" },
    { "type": "set_window_inner_size", "width_px": 1280.0, "height_px": 720.0 },
    { "type": "wait_frames", "n": 20 },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-page-web-ime-harness" }
      },
      "timeout_frames": 600
    },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-web-ime-region" }
      },
      "timeout_frames": 600
    },

    { "type": "click", "target": { "kind": "test_id", "id": "ui-gallery-web-ime-region" } },
    { "type": "type_text", "text": "a" },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "value_equals",
        "target": { "kind": "test_id", "id": "ui-gallery-web-ime-region" },
        "text": "a"
      },
      "timeout_frames": 240
    },

    { "type": "click", "target": { "kind": "test_id", "id": "ui-gallery-web-ime-inject-line-break" } },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "value_equals",
        "target": { "kind": "test_id", "id": "ui-gallery-web-ime-region" },
        "text": "a\n"
      },
      "timeout_frames": 240
    },

    { "type": "click", "target": { "kind": "test_id", "id": "ui-gallery-web-ime-inject-paragraph" } },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "value_equals",
        "target": { "kind": "test_id", "id": "ui-gallery-web-ime-region" },
        "text": "a\n\n"
      },
      "timeout_frames": 240
    },

    { "type": "click", "target": { "kind": "test_id", "id": "ui-gallery-web-ime-inject-delete-backward" } },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "value_equals",
        "target": { "kind": "test_id", "id": "ui-gallery-web-ime-region" },
        "text": "a\n"
      },
      "timeout_frames": 240
    },

    {
      "type": "capture_bundle",
      "label": "ui-gallery-web-ime-harness-beforeinput-control-intents"
    }
  ]
}
