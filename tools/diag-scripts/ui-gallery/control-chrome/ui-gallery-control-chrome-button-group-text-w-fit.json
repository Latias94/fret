{
  "schema_version": 2,
  "meta": {
    "name": "ui-gallery-control-chrome-button-group-text-w-fit",
    "tags": ["ui-gallery", "shadcn", "button-group", "layout", "w-fit"],
    "required_capabilities": ["diag.script_v2", "diag.screenshot_png"],
    "target_hints": [
      "Navigates to the Button Group page.",
      "Asserts the Text example does not stretch to the page width (shadcn `w-fit`)."
    ]
  },
  "steps": [
    { "type": "reset_diagnostics" },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-nav-search" }
      },
      "timeout_frames": 600
    },
    { "type": "press_key", "key": "escape" },
    { "type": "wait_frames", "n": 2 },
    { "type": "set_window_inner_size", "width_px": 1280.0, "height_px": 720.0 },
    { "type": "wait_frames", "n": 15 },

    {
      "type": "type_text_into",
      "target": { "kind": "test_id", "id": "ui-gallery-nav-search" },
      "text": "button group",
      "clear_before_type": true,
      "timeout_frames": 600
    },
    { "type": "wait_frames", "n": 2 },
    {
      "type": "scroll_into_view",
      "container": { "kind": "test_id", "id": "ui-gallery-nav-scroll" },
      "target": { "kind": "test_id", "id": "ui-gallery-nav-button-group" },
      "delta_y": -240.0,
      "timeout_frames": 600
    },
    {
      "type": "click_stable",
      "target": { "kind": "test_id", "id": "ui-gallery-nav-button-group" }
    },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-page-button-group" }
      },
      "timeout_frames": 600
    },

    {
      "type": "scroll_into_view",
      "container": { "kind": "test_id", "id": "ui-gallery-content-scroll" },
      "target": { "kind": "test_id", "id": "ui-gallery-button-group-text" },
      "delta_y": -120.0,
      "require_fully_within_container": true,
      "require_fully_within_window": true,
      "padding_px": 16.0,
      "timeout_frames": 1200
    },
    { "type": "wait_frames", "n": 2 },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "bounds_max_size",
        "target": { "kind": "test_id", "id": "ui-gallery-button-group-text" },
        "max_w_px": 760.0,
        "max_h_px": 10000.0,
        "eps_px": 1.0
      },
      "timeout_frames": 240
    },

    { "type": "capture_bundle", "label": "ui-gallery-control-chrome-button-group-text-w-fit" },
    { "type": "capture_screenshot", "label": "ui-gallery-control-chrome-button-group-text-w-fit" }
  ]
}

