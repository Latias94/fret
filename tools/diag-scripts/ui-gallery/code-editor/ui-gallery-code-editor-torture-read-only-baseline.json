{
  "schema_version": 2,
  "steps": [
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-nav-search" }
      },
      "timeout_frames": 240
    },
    { "type": "click", "target": { "kind": "test_id", "id": "ui-gallery-nav-search" } },
    { "type": "press_key", "key": "a", "modifiers": { "ctrl": true } },
    { "type": "press_key", "key": "backspace" },
    { "type": "type_text", "text": "code_editor_torture" },
    { "type": "wait_frames", "n": 2 },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "bounds_within_window",
        "target": { "kind": "test_id", "id": "ui-gallery-nav-code-editor-torture" },
        "padding_px": 8.0,
        "eps_px": 1.0
      },
      "timeout_frames": 240
    },
    { "type": "click", "target": { "kind": "test_id", "id": "ui-gallery-nav-code-editor-torture" } },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-page-code-editor-torture" }
      },
      "timeout_frames": 240
    },
    { "type": "wait_frames", "n": 20 },

    { "type": "click", "target": { "kind": "test_id", "id": "ui-gallery-code-editor-torture-mode-edit" } },
    { "type": "wait_frames", "n": 2 },
    { "type": "click", "target": { "kind": "test_id", "id": "ui-gallery-code-editor-torture-root" } },
    { "type": "wait_frames", "n": 2 },
    { "type": "capture_bundle", "label": "ui-gallery-code-editor-torture-read-only-before-edit" },

    {
      "type": "type_text_into",
      "target": { "kind": "role_and_name", "role": "text_field", "name": "Code editor" },
      "text": " X",
      "timeout_frames": 240
    },
    { "type": "wait_frames", "n": 4 },
    { "type": "capture_bundle", "label": "ui-gallery-code-editor-torture-read-only-after-edit" },

    { "type": "click", "target": { "kind": "test_id", "id": "ui-gallery-code-editor-torture-mode-read-only" } },
    { "type": "wait_frames", "n": 2 },
    {
      "type": "type_text_into",
      "target": { "kind": "role_and_name", "role": "text_field", "name": "Code editor" },
      "text": " Y",
      "timeout_frames": 240
    },
    { "type": "wait_frames", "n": 4 },
    { "type": "capture_bundle", "label": "ui-gallery-code-editor-torture-read-only-after-read-only" }
  ]
}

