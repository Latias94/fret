{
  "schema_version": 2,
  "meta": {
    "name": "ui-gallery-code-editor-a11y-composition-ime-surrounding-valid",
    "required_capabilities": ["diag.script_v2", "diag.inject_ime", "diag.text_input_snapshot"],
    "tags": ["ui_gallery", "code_editor", "ime", "surrounding_text"]
  },
  "steps": [
    { "type": "reset_diagnostics" },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-nav-search" }
      },
      "timeout_frames": 600
    },

    { "type": "click", "target": { "kind": "test_id", "id": "ui-gallery-nav-search" } },
    { "type": "press_key", "key": "a", "modifiers": { "ctrl": true } },
    { "type": "press_key", "key": "backspace" },
    { "type": "type_text", "text": "code_editor_mvp" },
    { "type": "wait_frames", "n": 2 },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "bounds_within_window",
        "target": { "kind": "test_id", "id": "ui-gallery-nav-code-editor-mvp" },
        "padding_px": 8.0,
        "eps_px": 1.0
      },
      "timeout_frames": 600
    },
    { "type": "click", "target": { "kind": "test_id", "id": "ui-gallery-nav-code-editor-mvp" } },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-page-code-editor-mvp" }
      },
      "timeout_frames": 600
    },
    { "type": "wait_frames", "n": 30 },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": {
          "kind": "test_id",
          "id": "ui-gallery-code-editor-a11y-composition-gate-viewport"
        }
      },
      "timeout_frames": 600
    },

    {
      "type": "type_text_into",
      "target": {
        "kind": "role_and_name",
        "role": "text_field",
        "name": "Code editor a11y composition gate"
      },
      "text": "",
      "timeout_frames": 240
    },
    {
      "type": "wait_until",
      "predicate": { "kind": "ime_cursor_area_is_some", "is_some": true },
      "timeout_frames": 240
    },
    {
      "type": "wait_until",
      "predicate": { "kind": "ime_surrounding_text_valid" },
      "timeout_frames": 240
    },

    {
      "type": "ime",
      "event": { "kind": "preedit", "text": "東京", "cursor_bytes": [0, 6] }
    },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "text_composition_is",
        "target": {
          "kind": "role_and_name",
          "role": "text_field",
          "name": "Code editor a11y composition gate"
        },
        "composing": true
      },
      "timeout_frames": 240
    },
    {
      "type": "wait_until",
      "predicate": { "kind": "ime_surrounding_text_valid" },
      "timeout_frames": 240
    },

    { "type": "capture_bundle", "label": "ui-gallery-code-editor-a11y-composition-ime-surrounding-valid" }
  ]
}

