{
  "schema_version": 2,
  "meta": {
    "name": "ui-gallery-tabs-rtl-keynav-screenshot",
    "required_capabilities": ["diag.script_v2"],
    "tags": ["ui_gallery", "shadcn", "tabs", "rtl", "keyboard", "screenshots"]
  },
  "steps": [
    { "type": "reset_diagnostics" },
    { "type": "press_key", "key": "escape" },
    { "type": "wait_frames", "n": 2 },
    { "type": "set_window_inner_size", "width_px": 1120.0, "height_px": 920.0 },
    { "type": "wait_frames", "n": 10 },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-nav-search" }
      },
      "timeout_frames": 240
    },
    { "type": "click", "target": { "kind": "test_id", "id": "ui-gallery-nav-search" } },
    { "type": "press_key", "key": "a", "modifiers": { "ctrl": true } },
    { "type": "press_key", "key": "backspace" },
    { "type": "type_text", "text": "tabs" },
    { "type": "wait_frames", "n": 2 },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "bounds_within_window",
        "target": { "kind": "test_id", "id": "ui-gallery-nav-tabs" },
        "padding_px": 8.0,
        "eps_px": 1.0
      },
      "timeout_frames": 300
    },
    { "type": "click", "target": { "kind": "test_id", "id": "ui-gallery-nav-tabs" } },
    {
      "type": "wait_until",
      "predicate": { "kind": "exists", "target": { "kind": "test_id", "id": "ui-gallery-page-tabs" } },
      "timeout_frames": 240
    },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-tabs-rtl-trigger-preview" }
      },
      "timeout_frames": 600
    },
    {
      "type": "scroll_into_view",
      "container": { "kind": "test_id", "id": "ui-gallery-content-scroll" },
      "target": { "kind": "test_id", "id": "ui-gallery-tabs-rtl-trigger-preview" },
      "delta_y": -320.0,
      "require_fully_within_window": true,
      "padding_px": 24.0,
      "timeout_frames": 600
    },
    { "type": "wait_frames", "n": 10 },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "bounds_within_window",
        "target": { "kind": "test_id", "id": "ui-gallery-tabs-rtl-trigger-preview" },
        "padding_px": 120.0,
        "eps_px": 1.0
      },
      "timeout_frames": 600
    },

    {
      "type": "click_stable",
      "target": { "kind": "test_id", "id": "ui-gallery-tabs-rtl-trigger-preview" }
    },
    {
      "type": "wait_until",
      "predicate": { "kind": "exists", "target": { "kind": "test_id", "id": "ui-gallery-tabs-rtl-panel-preview" } },
      "timeout_frames": 300
    },

    { "type": "press_key", "key": "arrow_left" },
    {
      "type": "wait_until",
      "predicate": { "kind": "exists", "target": { "kind": "test_id", "id": "ui-gallery-tabs-rtl-panel-code" } },
      "timeout_frames": 300
    },

    { "type": "capture_bundle", "label": "tabs-rtl-keynav" },
    { "type": "capture_screenshot", "label": "ui-gallery-tabs-rtl-keynav" }
  ]
}
