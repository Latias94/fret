{
  "schema_version": 2,
  "meta": {
    "name": "ui-gallery-aspect-ratio-demo-screenshot",
    "required_capabilities": ["diag.script_v2", "diag.screenshot_png"]
  },
  "steps": [
    { "type": "reset_diagnostics" },
    { "type": "press_key", "key": "escape" },
    { "type": "wait_frames", "n": 2 },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-nav-search" }
      },
      "timeout_frames": 600
    },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-nav-scroll" }
      },
      "timeout_frames": 600
    },
    { "type": "click", "target": { "kind": "test_id", "id": "ui-gallery-nav-search" } },
    { "type": "press_key", "key": "a", "modifiers": { "ctrl": true } },
    { "type": "press_key", "key": "backspace" },
    { "type": "type_text", "text": "aspect ratio" },
    { "type": "wait_frames", "n": 2 },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-nav-aspect-ratio" }
      },
      "timeout_frames": 600
    },
    {
      "type": "scroll_into_view",
      "container": { "kind": "test_id", "id": "ui-gallery-nav-scroll" },
      "target": { "kind": "test_id", "id": "ui-gallery-nav-aspect-ratio" },
      "delta_y": -240.0,
      "timeout_frames": 600
    },
    {
      "type": "click",
      "target": { "kind": "test_id", "id": "ui-gallery-nav-aspect-ratio" }
    },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-page-aspect-ratio" }
      },
      "timeout_frames": 600
    },
    {
      "type": "wait_bounds_stable",
      "target": { "kind": "test_id", "id": "ui-gallery-aspect-ratio-demo" },
      "stable_frames": 10,
      "timeout_frames": 600
    },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "bounds_center_approx_equal",
        "a": { "kind": "test_id", "id": "ui-gallery-aspect-ratio-demo" },
        "b": { "kind": "test_id", "id": "ui-gallery-aspect-ratio-demo-content" },
        "eps_px": 8.0
      },
      "timeout_frames": 600
    },
    { "type": "capture_bundle", "label": "ui-gallery-aspect-ratio-demo-screenshot" },
    { "type": "capture_screenshot", "label": "ui-gallery-aspect-ratio-demo-screenshot" }
  ]
}

