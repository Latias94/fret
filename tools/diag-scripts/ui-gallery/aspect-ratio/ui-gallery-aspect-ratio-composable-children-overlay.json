{
  "schema_version": 2,
  "meta": {
    "name": "ui-gallery-aspect-ratio-composable-children-overlay",
    "required_capabilities": ["diag.script_v2"],
    "tags": ["ui_gallery", "shadcn", "aspect_ratio", "composable_children", "overlay"]
  },
  "steps": [
    { "type": "reset_diagnostics" },
    { "type": "press_key", "key": "escape" },
    { "type": "wait_frames", "n": 2 },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-nav-search" }
      },
      "timeout_frames": 600
    },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-nav-scroll" }
      },
      "timeout_frames": 600
    },
    { "type": "set_window_inner_size", "width_px": 1280.0, "height_px": 900.0 },
    { "type": "wait_frames", "n": 12 },
    { "type": "click", "target": { "kind": "test_id", "id": "ui-gallery-nav-search" } },
    { "type": "press_key", "key": "a", "modifiers": { "ctrl": true } },
    { "type": "press_key", "key": "backspace" },
    { "type": "type_text", "text": "aspect ratio" },
    { "type": "wait_frames", "n": 2 },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-nav-aspect-ratio" }
      },
      "timeout_frames": 600
    },
    {
      "type": "scroll_into_view",
      "container": { "kind": "test_id", "id": "ui-gallery-nav-scroll" },
      "target": { "kind": "test_id", "id": "ui-gallery-nav-aspect-ratio" },
      "delta_y": -240.0,
      "timeout_frames": 600
    },
    {
      "type": "click",
      "target": { "kind": "test_id", "id": "ui-gallery-nav-aspect-ratio" }
    },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-page-aspect-ratio" }
      },
      "timeout_frames": 600
    },
    {
      "type": "scroll_into_view",
      "container": { "kind": "test_id", "id": "ui-gallery-content-scroll" },
      "target": {
        "kind": "test_id",
        "id": "ui-gallery-aspect-ratio-composable-children"
      },
      "delta_y": -360.0,
      "require_fully_within_window": true,
      "padding_px": 16.0,
      "timeout_frames": 1800
    },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": {
          "kind": "test_id",
          "id": "ui-gallery-aspect-ratio-composable-children"
        }
      },
      "timeout_frames": 600
    },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": {
          "kind": "test_id",
          "id": "ui-gallery-aspect-ratio-composable-children-image"
        }
      },
      "timeout_frames": 600
    },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": {
          "kind": "test_id",
          "id": "ui-gallery-aspect-ratio-composable-children-badge"
        }
      },
      "timeout_frames": 600
    },
    {
      "type": "scroll_into_view",
      "container": { "kind": "test_id", "id": "ui-gallery-content-scroll" },
      "target": {
        "kind": "test_id",
        "id": "ui-gallery-aspect-ratio-composable-children-badge"
      },
      "delta_y": -120.0,
      "require_fully_within_window": true,
      "padding_px": 16.0,
      "timeout_frames": 1800
    },
    {
      "type": "wait_bounds_stable",
      "target": {
        "kind": "test_id",
        "id": "ui-gallery-aspect-ratio-composable-children"
      },
      "stable_frames": 10,
      "timeout_frames": 600
    },
    {
      "type": "wait_bounds_stable",
      "target": {
        "kind": "test_id",
        "id": "ui-gallery-aspect-ratio-composable-children-image"
      },
      "stable_frames": 10,
      "timeout_frames": 600
    },
    {
      "type": "wait_bounds_stable",
      "target": {
        "kind": "test_id",
        "id": "ui-gallery-aspect-ratio-composable-children-badge"
      },
      "stable_frames": 10,
      "timeout_frames": 600
    },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "bounds_center_approx_equal",
        "a": {
          "kind": "test_id",
          "id": "ui-gallery-aspect-ratio-composable-children"
        },
        "b": {
          "kind": "test_id",
          "id": "ui-gallery-aspect-ratio-composable-children-image"
        },
        "eps_px": 8.0
      },
      "timeout_frames": 600
    },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "bounds_overlapping",
        "a": {
          "kind": "test_id",
          "id": "ui-gallery-aspect-ratio-composable-children"
        },
        "b": {
          "kind": "test_id",
          "id": "ui-gallery-aspect-ratio-composable-children-badge"
        },
        "eps_px": 1.0
      },
      "timeout_frames": 600
    },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "bounds_overlapping",
        "a": {
          "kind": "test_id",
          "id": "ui-gallery-aspect-ratio-composable-children-image"
        },
        "b": {
          "kind": "test_id",
          "id": "ui-gallery-aspect-ratio-composable-children-badge"
        },
        "eps_px": 1.0
      },
      "timeout_frames": 600
    },
    {
      "type": "assert",
      "predicate": {
        "kind": "bounds_within_window",
        "target": {
          "kind": "test_id",
          "id": "ui-gallery-aspect-ratio-composable-children-badge"
        },
        "padding_px": 8.0,
        "eps_px": 1.0
      }
    },
    {
      "type": "assert",
      "predicate": {
        "kind": "bounds_min_size",
        "target": {
          "kind": "test_id",
          "id": "ui-gallery-aspect-ratio-composable-children-badge"
        },
        "min_w_px": 40.0,
        "min_h_px": 18.0,
        "eps_px": 1.0
      }
    },
    {
      "type": "capture_layout_sidecar",
      "label": "ui-gallery-aspect-ratio-composable-children-overlay"
    },
    {
      "type": "capture_bundle",
      "label": "ui-gallery-aspect-ratio-composable-children-overlay"
    }
  ]
}
