{
  "schema_version": 2,
  "steps": [
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-nav-search" }
      },
      "timeout_frames": 600
    },
    { "type": "click", "target": { "kind": "test_id", "id": "ui-gallery-nav-search" } },
    { "type": "press_key", "key": "a", "modifiers": { "ctrl": true } },
    { "type": "press_key", "key": "backspace" },
    { "type": "type_text", "text": "chart" },
    { "type": "wait_frames", "n": 2 },
    {
      "type": "ensure_visible",
      "target": { "kind": "test_id", "id": "ui-gallery-nav-chart" },
      "within_window": true,
      "padding_px": 8.0,
      "timeout_frames": 600
    },
    { "type": "click", "target": { "kind": "test_id", "id": "ui-gallery-nav-chart" } },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-chart-demo-area" }
      },
      "timeout_frames": 600
    },
    { "type": "wait_frames", "n": 30 },
    {
      "type": "click",
      "target": { "kind": "test_id", "id": "ui-gallery-chart-demo-area-canvas" }
    },
    {
      "type": "assert",
      "predicate": {
        "kind": "focus_is",
        "target": { "kind": "test_id", "id": "ui-gallery-chart-demo-area-canvas" }
      }
    },
    { "type": "press_key", "key": "arrow_right" },
    { "type": "wait_frames", "n": 5 },
    {
      "type": "assert",
      "predicate": {
        "kind": "pos_in_set_is",
        "target": { "kind": "test_id", "id": "ui-gallery-chart-demo-area-canvas" },
        "pos_in_set": 2
      }
    },
    { "type": "capture_bundle", "label": "ui-gallery-chart-accessibility-layer-keyboard" }
  ]
}
