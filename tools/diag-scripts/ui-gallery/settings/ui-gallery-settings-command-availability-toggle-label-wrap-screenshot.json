{
  "schema_version": 2,
  "meta": {
    "name": "UI gallery: Settings command availability toggle labels wrap (screenshot)",
    "tags": ["ui-gallery", "settings", "layout", "text", "wrap", "screenshots"],
    "required_capabilities": ["diag.script_v2", "diag.screenshot_png"],
    "target_hints": [
      "Sets theme preset to zinc/light.",
      "Opens Settings sheet and captures a screenshot to guard multiline toggle label layout."
    ]
  },
  "steps": [
    { "type": "reset_diagnostics" },
    { "type": "press_key", "key": "escape" },
    { "type": "wait_frames", "n": 2 },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-theme-preset-trigger" }
      },
      "timeout_frames": 600
    },
    { "type": "click", "target": { "kind": "test_id", "id": "ui-gallery-theme-preset-trigger" } },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-theme-preset-item-zinc-light" }
      },
      "timeout_frames": 600
    },
    { "type": "click_stable", "target": { "kind": "test_id", "id": "ui-gallery-theme-preset-item-zinc-light" } },
    { "type": "wait_frames", "n": 2 },
    { "type": "press_key", "key": "escape" },
    { "type": "wait_frames", "n": 2 },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-settings-open" }
      },
      "timeout_frames": 600
    },
    {
      "type": "click_stable",
      "target": { "kind": "test_id", "id": "ui-gallery-settings-open" },
      "timeout_frames": 300
    },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "app_snapshot_field_equals",
        "pointer": "/shell/last_action",
        "value": "cmd.settings"
      },
      "timeout_frames": 300
    },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "app_snapshot_field_equals",
        "pointer": "/shell/settings_open",
        "value": true
      },
      "timeout_frames": 300
    },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "visible_in_window",
        "target": { "kind": "test_id", "id": "ui-gallery-settings-apply" }
      },
      "timeout_frames": 300
    },
    { "type": "wait_frames", "n": 8 },
    { "type": "capture_bundle", "label": "ui-gallery-settings-command-availability-toggle-label-wrap" },
    { "type": "capture_screenshot", "label": "ui-gallery-settings-command-availability-toggle-label-wrap" }
  ]
}
