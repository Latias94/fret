{
  "schema_version": 2,
  "steps": [
    { "type": "press_key", "key": "escape" },
    { "type": "wait_frames", "n": 2 },

    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-nav-search" }
      },
      "timeout_frames": 240
    },
    { "type": "click", "target": { "kind": "test_id", "id": "ui-gallery-nav-search" } },
    { "type": "press_key", "key": "a", "modifiers": { "ctrl": true } },
    { "type": "press_key", "key": "backspace" },
    { "type": "type_text", "text": "overlay" },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-nav-overlay" }
      },
      "timeout_frames": 240
    },
    { "type": "click", "target": { "kind": "test_id", "id": "ui-gallery-nav-overlay" } },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-overlay-reset" }
      },
      "timeout_frames": 240
    },

    { "type": "set_window_inner_size", "width_px": 1280.0, "height_px": 720.0 },
    { "type": "wait_frames", "n": 2 },
    { "type": "click", "target": { "kind": "test_id", "id": "ui-gallery-overlay-reset" } },
    { "type": "wait_frames", "n": 5 },

    { "type": "reset_diagnostics" },

    { "type": "click", "target": { "kind": "test_id", "id": "ui-gallery-dropdown-trigger" } },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-dropdown-item-apple" }
      },
      "timeout_frames": 60
    },

    { "type": "capture_bundle", "label": "ui-gallery-dropdown-open-fixed-frame-delta-a" },
    { "type": "capture_screenshot", "label": "ui-gallery-dropdown-open-fixed-frame-delta-a" },
    { "type": "wait_frames", "n": 15 },
    { "type": "capture_bundle", "label": "ui-gallery-dropdown-open-fixed-frame-delta-b" },
    { "type": "capture_screenshot", "label": "ui-gallery-dropdown-open-fixed-frame-delta-b" },

    { "type": "press_key", "key": "escape" },
    { "type": "wait_frames", "n": 30 },
    { "type": "capture_bundle", "label": "ui-gallery-dropdown-open-fixed-frame-delta-closed" },
    {
      "type": "capture_screenshot",
      "label": "ui-gallery-dropdown-open-fixed-frame-delta-closed"
    }
  ]
}
