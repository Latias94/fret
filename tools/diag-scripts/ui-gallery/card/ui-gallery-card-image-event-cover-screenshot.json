{
  "schema_version": 2,
  "meta": {
    "name": "UI Gallery: Card image event cover renders and fills",
    "tags": ["ui-gallery", "card", "shadcn", "image", "object-fit"],
    "required_capabilities": ["diag.script_v2", "diag.screenshot_png"]
  },
  "steps": [
    { "type": "reset_diagnostics" },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-nav-scroll" }
      },
      "timeout_frames": 600
    },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-nav-search" }
      },
      "timeout_frames": 600
    },

    { "type": "press_key", "key": "escape" },
    { "type": "wait_frames", "n": 2 },
    { "type": "set_window_inner_size", "width_px": 1280.0, "height_px": 720.0 },
    { "type": "wait_frames", "n": 15 },

    {
      "type": "type_text_into",
      "target": { "kind": "role_and_name", "role": "text_field", "name": "Search components" },
      "text": "card"
    },
    { "type": "wait_frames", "n": 2 },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-nav-card" }
      },
      "timeout_frames": 600
    },
    { "type": "click", "target": { "kind": "test_id", "id": "ui-gallery-nav-card" } },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-page-card" }
      },
      "timeout_frames": 600
    },

    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-card-image-event-cover" }
      },
      "timeout_frames": 600
    },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "bounds_min_size",
        "target": { "kind": "test_id", "id": "ui-gallery-card-image-event-cover-stack" },
        "min_w_px": 240.0,
        "min_h_px": 120.0,
        "eps_px": 1.0
      },
      "timeout_frames": 600
    },

    { "type": "wait_frames", "n": 30 },
    { "type": "capture_bundle", "label": "ui-gallery-card-image-event-cover" },
    { "type": "capture_screenshot", "label": "ui-gallery-card-image-event-cover" }
  ]
}
