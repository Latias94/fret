{
  "schema_version": 2,
  "meta": {
    "name": "ui-gallery-shadcn-tabs-demo-screenshot",
    "required_capabilities": ["diag.script_v2", "diag.screenshot_png"]
  },
  "steps": [
    { "type": "reset_diagnostics" },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-nav-search" }
      },
      "timeout_frames": 240
    },
    { "type": "click", "target": { "kind": "test_id", "id": "ui-gallery-nav-search" } },
    { "type": "press_key", "key": "a", "modifiers": { "ctrl": true } },
    { "type": "press_key", "key": "backspace" },
    { "type": "type_text", "text": "tabs" },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-nav-tabs" }
      },
      "timeout_frames": 240
    },
    { "type": "click", "target": { "kind": "test_id", "id": "ui-gallery-nav-tabs" } },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-tabs-demo" }
      },
      "timeout_frames": 240
    },
    { "type": "wait_frames", "n": 8 },
    { "type": "capture_bundle", "label": "ui-gallery-shadcn-tabs-demo" },
    { "type": "capture_screenshot", "label": "ui-gallery-shadcn-tabs-demo" }
  ]
}
