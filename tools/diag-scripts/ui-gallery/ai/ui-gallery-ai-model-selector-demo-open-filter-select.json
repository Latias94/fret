{
  "schema_version": 2,
  "meta": {
    "name": "UI gallery: AI Elements ModelSelector open -> filter -> select",
    "tags": ["ui-gallery", "ai-elements", "model-selector", "command", "dialog", "screenshots"],
    "required_capabilities": ["diag.script_v2", "diag.screenshot_png"],
    "target_hints": [
      "Navigates to the AI Elements ModelSelector demo page (requires `fret-ui-gallery --features gallery-dev`).",
      "Asserts dialog open auto-focus lands on the input.",
      "Filters for \"claude\" and selects an item.",
      "Captures screenshots + a final bundle for regression triage."
    ]
  },
  "steps": [
    { "type": "reset_diagnostics" },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-nav-search" }
      },
      "timeout_frames": 600
    },
    { "type": "click", "target": { "kind": "test_id", "id": "ui-gallery-nav-search" } },
    { "type": "press_key", "key": "a", "modifiers": { "ctrl": true } },
    { "type": "press_key", "key": "backspace" },
    { "type": "type_text", "text": "ai model selector" },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-nav-ai-model-selector-demo" }
      },
      "timeout_frames": 600
    },
    {
      "type": "click",
      "target": { "kind": "test_id", "id": "ui-gallery-nav-ai-model-selector-demo" }
    },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-ai-model-selector-trigger" }
      },
      "timeout_frames": 600
    },
    {
      "type": "click_stable",
      "target": { "kind": "test_id", "id": "ui-ai-model-selector-trigger" }
    },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-ai-model-selector-input" }
      },
      "timeout_frames": 600
    },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "focus_is",
        "target": { "kind": "test_id", "id": "ui-ai-model-selector-input" }
      },
      "timeout_frames": 600
    },
    { "type": "wait_frames", "n": 2 },
    {
      "type": "capture_screenshot",
      "label": "ui-gallery-ai-model-selector-open",
      "timeout_frames": 600
    },
    { "type": "type_text", "text": "claude" },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": {
          "kind": "test_id",
          "id": "ui-ai-model-selector-item-anthropic-claude-3-5-sonnet"
        }
      },
      "timeout_frames": 600
    },
    { "type": "capture_screenshot", "label": "ui-gallery-ai-model-selector-filtered" },
    {
      "type": "assert",
      "predicate": {
        "kind": "not_exists",
        "target": { "kind": "test_id", "id": "ui-ai-model-selector-item-openai-gpt-4o-mini" }
      }
    },
    {
      "type": "click_stable",
      "target": {
        "kind": "test_id",
        "id": "ui-ai-model-selector-item-anthropic-claude-3-5-sonnet"
      }
    },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": {
          "kind": "test_id",
          "id": "ui-ai-model-selector-selected-anthropic-claude-3-5-sonnet"
        }
      },
      "timeout_frames": 600
    },
    { "type": "capture_screenshot", "label": "ui-gallery-ai-model-selector-selected" },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "not_exists",
        "target": { "kind": "test_id", "id": "ui-ai-model-selector-input" }
      },
      "timeout_frames": 600
    },
    { "type": "capture_screenshot", "label": "ui-gallery-ai-model-selector-after-close" },
    { "type": "capture_bundle", "label": "ui-gallery-ai-model-selector-demo-open-filter-select" }
  ]
}
