{
  "schema_version": 2,
  "meta": {
    "name": "UI Gallery: ai_chat_demo inline citation hovercard",
    "tags": ["ui-gallery", "ai", "inline-citation", "hovercard", "screenshots"],
    "required_capabilities": ["diag.script_v2", "diag.screenshot_png"],
    "target_hints": [
      "Opens AI chat demo.",
      "Scrolls an inline citation into view.",
      "Hovers to open the hovercard, captures a screenshot, then clicks next/prev.",
      "Captures a bundle for triage."
    ]
  },
  "steps": [
    { "type": "reset_diagnostics" },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-nav-search" }
      },
      "timeout_frames": 240
    },
    { "type": "click", "target": { "kind": "test_id", "id": "ui-gallery-nav-search" } },
    { "type": "press_key", "key": "a", "modifiers": { "ctrl": true } },
    { "type": "press_key", "key": "backspace" },
    { "type": "type_text", "text": "ai chat" },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-nav-ai-chat-demo" }
      },
      "timeout_frames": 240
    },
    { "type": "click", "target": { "kind": "test_id", "id": "ui-gallery-nav-ai-chat-demo" } },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-ai-msg-4-citation-3-1" }
      },
      "timeout_frames": 240
    },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-ai-msg-4-citation-3-1-label" }
      },
      "timeout_frames": 240
    },
    {
      "type": "scroll_into_view",
      "container": { "kind": "test_id", "id": "ui-gallery-ai-chat-transcript-root" },
      "target": { "kind": "test_id", "id": "ui-ai-msg-4-citation-3-1" },
      "delta_y": -240.0,
      "require_fully_within_container": true,
      "require_fully_within_window": true,
      "padding_px": 16.0,
      "padding_insets_px": { "left_px": 16.0, "top_px": 16.0, "right_px": 16.0, "bottom_px": 40.0 },
      "timeout_frames": 1800
    },
    {
      "type": "move_pointer",
      "target": { "kind": "test_id", "id": "ui-ai-msg-4-citation-3-1" }
    },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-ai-msg-4-citation-3-1-card" }
      },
      "timeout_frames": 240
    },
    { "type": "wait_frames", "n": 10 },
    {
      "type": "capture_screenshot",
      "label": "ui-gallery-ai-chat-demo-inline-citation-hovercard"
    },
    {
      "type": "click_stable",
      "target": { "kind": "test_id", "id": "ui-ai-msg-4-citation-3-1-next" }
    },
    { "type": "wait_frames", "n": 10 },
    {
      "type": "click_stable",
      "target": { "kind": "test_id", "id": "ui-ai-msg-4-citation-3-1-prev" }
    },
    { "type": "wait_frames", "n": 10 },
    {
      "type": "capture_bundle",
      "label": "ui-gallery-ai-chat-demo-inline-citation-hovercard"
    }
  ]
}
