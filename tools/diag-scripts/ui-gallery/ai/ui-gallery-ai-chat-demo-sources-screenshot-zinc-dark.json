{
  "schema_version": 2,
  "meta": {
    "name": "UI gallery: AI chat demo sources trigger screenshot (zinc dark)",
    "tags": ["ui-gallery", "ai-chat-demo", "sources", "screenshots", "zinc-dark"],
    "required_capabilities": ["diag.script_v2", "diag.screenshot_png"],
    "target_hints": [
      "Sets theme preset to zinc/dark.",
      "Navigates to AI chat demo.",
      "Expands the sources collapsible and captures a screenshot to gate `text-primary` token usage."
    ]
  },
  "steps": [
    { "type": "reset_diagnostics" },
    {
      "type": "wait_until",
      "predicate": { "kind": "exists", "target": { "kind": "test_id", "id": "ui-gallery-theme-preset-trigger" } },
      "timeout_frames": 600
    },
    { "type": "set_window_inner_size", "width_px": 1280.0, "height_px": 1000.0 },
    { "type": "wait_frames", "n": 20 },

    { "type": "click", "target": { "kind": "test_id", "id": "ui-gallery-theme-preset-trigger" } },
    {
      "type": "wait_until",
      "predicate": { "kind": "exists", "target": { "kind": "test_id", "id": "ui-gallery-theme-preset-item-zinc-dark" } },
      "timeout_frames": 240
    },
    { "type": "click_stable", "target": { "kind": "test_id", "id": "ui-gallery-theme-preset-item-zinc-dark" } },
    { "type": "wait_frames", "n": 3 },
    { "type": "press_key", "key": "escape" },
    { "type": "wait_frames", "n": 2 },

    {
      "type": "wait_until",
      "predicate": { "kind": "exists", "target": { "kind": "test_id", "id": "ui-gallery-nav-search" } },
      "timeout_frames": 600
    },
    { "type": "click", "target": { "kind": "test_id", "id": "ui-gallery-nav-search" } },
    { "type": "press_key", "key": "a", "modifiers": { "ctrl": true } },
    { "type": "press_key", "key": "backspace" },
    { "type": "type_text", "text": "ai chat" },
    {
      "type": "wait_until",
      "predicate": { "kind": "exists", "target": { "kind": "test_id", "id": "ui-gallery-nav-ai-chat-demo" } },
      "timeout_frames": 600
    },
    { "type": "click_stable", "target": { "kind": "test_id", "id": "ui-gallery-nav-ai-chat-demo" } },

    {
      "type": "wait_until",
      "predicate": { "kind": "exists", "target": { "kind": "test_id", "id": "ui-ai-msg-4-sources-2-trigger" } },
      "timeout_frames": 600
    },
    {
      "type": "scroll_into_view",
      "container": { "kind": "test_id", "id": "ui-gallery-ai-chat-transcript-root" },
      "target": { "kind": "test_id", "id": "ui-ai-msg-4-sources-2-trigger" },
      "delta_y": -240.0,
      "require_fully_within_container": true,
      "require_fully_within_window": true,
      "padding_px": 16.0,
      "padding_insets_px": { "left_px": 16.0, "top_px": 16.0, "right_px": 16.0, "bottom_px": 40.0 },
      "timeout_frames": 1800
    },
    {
      "type": "click_stable",
      "target": { "kind": "test_id", "id": "ui-ai-msg-4-sources-2-trigger" },
      "stable_frames": 3,
      "max_move_px": 2.0,
      "timeout_frames": 600
    },
    {
      "type": "wait_until",
      "predicate": { "kind": "exists", "target": { "kind": "test_id", "id": "ui-ai-msg-4-sources-2-content" } },
      "timeout_frames": 600
    },
    { "type": "wait_frames", "n": 2 },

    { "type": "capture_screenshot", "label": "ui-gallery-ai-chat-demo-sources-zinc-dark" },
    { "type": "capture_bundle", "label": "ui-gallery-ai-chat-demo-sources-zinc-dark" }
  ]
}

