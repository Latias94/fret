{
  "schema_version": 2,
  "meta": {
    "name": "UI gallery: Sources demo (AI Elements)",
    "tags": ["ui-gallery", "ai-elements", "sources", "collapsible"],
    "required_capabilities": ["diag.script_v2"],
    "target_hints": [
      "Navigates to the AI Sources demo page.",
      "Expands the sources block and asserts it stays intrinsic-width (AI Elements `w-fit` parity)."
    ]
  },
  "steps": [
    { "type": "reset_diagnostics" },
    {
      "type": "wait_until",
      "predicate": { "kind": "exists", "target": { "kind": "test_id", "id": "ui-gallery-nav-search" } },
      "timeout_frames": 600
    },

    { "type": "click", "target": { "kind": "test_id", "id": "ui-gallery-nav-search" } },
    { "type": "press_key", "key": "a", "modifiers": { "ctrl": true } },
    { "type": "press_key", "key": "backspace" },
    { "type": "type_text", "text": "ai_sources_demo" },
    { "type": "wait_frames", "n": 2 },
    {
      "type": "wait_until",
      "predicate": { "kind": "exists", "target": { "kind": "test_id", "id": "ui-gallery-nav-ai-sources-demo" } },
      "timeout_frames": 600
    },
    { "type": "click_stable", "target": { "kind": "test_id", "id": "ui-gallery-nav-ai-sources-demo" } },
    { "type": "wait_frames", "n": 2 },
    {
      "type": "wait_until",
      "predicate": { "kind": "exists", "target": { "kind": "test_id", "id": "ui-gallery-page-ai-sources-demo" } },
      "timeout_frames": 600
    },

    {
      "type": "scroll_into_view",
      "container": { "kind": "test_id", "id": "ui-gallery-content-viewport" },
      "target": { "kind": "test_id", "id": "ui-ai-sources-demo-root-trigger" },
      "delta_y": -200.0,
      "require_fully_within_window": true,
      "padding_px": 16.0,
      "timeout_frames": 1800
    },
    { "type": "click_stable", "target": { "kind": "test_id", "id": "ui-ai-sources-demo-root-trigger" } },
    {
      "type": "wait_until",
      "predicate": { "kind": "exists", "target": { "kind": "test_id", "id": "ui-ai-sources-demo-root-content" } },
      "timeout_frames": 600
    },
    { "type": "wait_bounds_stable", "target": { "kind": "test_id", "id": "ui-ai-sources-demo-root-content" }, "timeout_frames": 600 },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "bounds_max_size",
        "target": { "kind": "test_id", "id": "ui-ai-sources-demo-root-content" },
        "max_w_px": 520.0,
        "max_h_px": 600.0,
        "eps_px": 1.0
      },
      "timeout_frames": 600
    },

    { "type": "capture_bundle", "label": "ui-gallery-ai-sources-demo" }
  ]
}
