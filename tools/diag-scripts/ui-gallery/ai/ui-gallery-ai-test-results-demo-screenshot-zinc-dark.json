{
  "schema_version": 2,
  "meta": {
    "name": "UI gallery: TestResults demo screenshot (zinc dark)",
    "tags": ["ui-gallery", "ai-elements", "test-results", "screenshots", "zinc-dark"],
    "required_capabilities": ["diag.script_v2", "diag.screenshot_png"],
    "target_hints": [
      "Sets theme preset to zinc/dark.",
      "Navigates to the AI Elements test results demo.",
      "Captures screenshots for closed/open suite states."
    ]
  },
  "steps": [
    { "type": "reset_diagnostics" },
    {
      "type": "wait_until",
      "predicate": { "kind": "exists", "target": { "kind": "test_id", "id": "ui-gallery-theme-preset-trigger" } },
      "timeout_frames": 600
    },
    { "type": "set_window_inner_size", "width_px": 1280.0, "height_px": 1000.0 },
    { "type": "wait_frames", "n": 20 },

    { "type": "click", "target": { "kind": "test_id", "id": "ui-gallery-theme-preset-trigger" } },
    { "type": "click", "target": { "kind": "test_id", "id": "ui-gallery-theme-preset-item-zinc-dark" } },
    { "type": "wait_frames", "n": 3 },
    { "type": "press_key", "key": "escape" },
    { "type": "wait_frames", "n": 2 },

    {
      "type": "wait_until",
      "predicate": { "kind": "exists", "target": { "kind": "test_id", "id": "ui-gallery-nav-search" } },
      "timeout_frames": 600
    },
    { "type": "click", "target": { "kind": "test_id", "id": "ui-gallery-nav-search" } },
    { "type": "press_key", "key": "a", "modifiers": { "ctrl": true } },
    { "type": "press_key", "key": "backspace" },
    { "type": "type_text", "text": "ai_test_results_demo" },
    { "type": "wait_frames", "n": 2 },
    {
      "type": "wait_until",
      "predicate": { "kind": "exists", "target": { "kind": "test_id", "id": "ui-gallery-nav-ai-test-results-demo" } },
      "timeout_frames": 600
    },
    { "type": "click_stable", "target": { "kind": "test_id", "id": "ui-gallery-nav-ai-test-results-demo" } },
    { "type": "wait_frames", "n": 2 },
    {
      "type": "wait_until",
      "predicate": { "kind": "exists", "target": { "kind": "test_id", "id": "ui-gallery-page-ai-test-results-demo" } },
      "timeout_frames": 600
    },

    {
      "type": "scroll_into_view",
      "container": { "kind": "test_id", "id": "ui-gallery-content-viewport" },
      "target": { "kind": "test_id", "id": "ui-ai-test-suite-database-trigger" },
      "delta_y": -120.0,
      "require_fully_within_window": true,
      "padding_px": 16.0,
      "timeout_frames": 1800
    },
    { "type": "wait_frames", "n": 2 },
    { "type": "capture_screenshot", "label": "ui-gallery-ai-test-results-closed-zinc-dark" },

    { "type": "click_stable", "target": { "kind": "test_id", "id": "ui-ai-test-suite-database-trigger" } },
    {
      "type": "wait_until",
      "predicate": { "kind": "exists", "target": { "kind": "test_id", "id": "ui-ai-test-suite-database-content" } },
      "timeout_frames": 600
    },
    { "type": "wait_frames", "n": 2 },
    { "type": "capture_screenshot", "label": "ui-gallery-ai-test-results-open-zinc-dark" },
    { "type": "capture_bundle", "label": "ui-gallery-ai-test-results-zinc-dark", "max_snapshots": 240 }
  ]
}
