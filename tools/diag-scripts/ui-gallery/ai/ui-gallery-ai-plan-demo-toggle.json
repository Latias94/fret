{
  "schema_version": 2,
  "steps": [
    { "type": "reset_diagnostics" },
    { "type": "press_key", "key": "escape" },
    { "type": "wait_frames", "n": 2 },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-nav-search" }
      },
      "timeout_frames": 240
    },
    { "type": "click", "target": { "kind": "test_id", "id": "ui-gallery-nav-search" } },
    { "type": "press_key", "key": "a", "modifiers": { "ctrl": true } },
    { "type": "press_key", "key": "backspace" },
    { "type": "type_text", "text": "ai plan" },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-nav-ai-plan-demo" }
      },
      "timeout_frames": 240
    },
    { "type": "click", "target": { "kind": "test_id", "id": "ui-gallery-nav-ai-plan-demo" } },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-ai-plan-trigger" }
      },
      "timeout_frames": 240
    },
    {
      "type": "assert",
      "predicate": {
        "kind": "not_exists",
        "target": { "kind": "test_id", "id": "ui-ai-plan-content-marker" }
      }
    },
    { "type": "click_stable", "target": { "kind": "test_id", "id": "ui-ai-plan-trigger" } },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-ai-plan-content-marker" }
      },
      "timeout_frames": 240
    },
    {
      "type": "capture_layout_sidecar",
      "label": "ui-gallery-ai-plan-demo-toggle.layout"
    },
    {
      "type": "capture_screenshot",
      "label": "ui-gallery-ai-plan-demo-toggle"
    },
    { "type": "capture_bundle", "label": "ui-gallery-ai-plan-demo-toggle" }
  ]
}
