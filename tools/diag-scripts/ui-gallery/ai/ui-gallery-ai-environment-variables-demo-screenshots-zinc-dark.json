{
  "schema_version": 2,
  "meta": {
    "name": "UI gallery: EnvironmentVariables demo screenshots (zinc dark)",
    "tags": ["ui-gallery", "ai-elements", "environment-variables", "screenshots", "zinc-dark"],
    "required_capabilities": ["diag.script_v2", "diag.screenshot_png"],
    "target_hints": [
      "Sets theme preset to zinc/dark.",
      "Navigates to the AI Elements environment variables demo.",
      "Toggles value visibility, copies an export row, and captures screenshots."
    ]
  },
  "steps": [
    { "type": "reset_diagnostics" },
    {
      "type": "wait_until",
      "predicate": { "kind": "exists", "target": { "kind": "test_id", "id": "ui-gallery-theme-preset-trigger" } },
      "timeout_frames": 600
    },
    { "type": "set_window_inner_size", "width_px": 1280.0, "height_px": 1000.0 },
    { "type": "wait_frames", "n": 20 },

    { "type": "click", "target": { "kind": "test_id", "id": "ui-gallery-theme-preset-trigger" } },
    { "type": "click", "target": { "kind": "test_id", "id": "ui-gallery-theme-preset-item-zinc-dark" } },
    { "type": "wait_frames", "n": 3 },
    { "type": "press_key", "key": "escape" },
    { "type": "wait_frames", "n": 2 },

    {
      "type": "wait_until",
      "predicate": { "kind": "exists", "target": { "kind": "test_id", "id": "ui-gallery-nav-search" } },
      "timeout_frames": 600
    },
    { "type": "click", "target": { "kind": "test_id", "id": "ui-gallery-nav-search" } },
    { "type": "press_key", "key": "a", "modifiers": { "ctrl": true } },
    { "type": "press_key", "key": "backspace" },
    { "type": "type_text", "text": "ai_environment_variables_demo" },
    { "type": "wait_frames", "n": 2 },
    {
      "type": "wait_until",
      "predicate": { "kind": "exists", "target": { "kind": "test_id", "id": "ui-gallery-nav-ai-environment-variables-demo" } },
      "timeout_frames": 600
    },
    { "type": "click_stable", "target": { "kind": "test_id", "id": "ui-gallery-nav-ai-environment-variables-demo" } },
    { "type": "wait_frames", "n": 2 },
    {
      "type": "wait_until",
      "predicate": { "kind": "exists", "target": { "kind": "test_id", "id": "ui-gallery-page-ai-environment-variables-demo" } },
      "timeout_frames": 600
    },

    {
      "type": "scroll_into_view",
      "container": { "kind": "test_id", "id": "ui-gallery-content-viewport" },
      "target": { "kind": "test_id", "id": "ui-ai-env-vars-root" },
      "delta_y": -240.0,
      "require_fully_within_window": true,
      "padding_px": 16.0,
      "timeout_frames": 1800
    },
    { "type": "wait_frames", "n": 2 },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "checked_is",
        "target": { "kind": "test_id", "id": "ui-ai-env-vars-toggle-switch" },
        "checked": false
      },
      "timeout_frames": 600
    },
    { "type": "capture_screenshot", "label": "ui-gallery-ai-env-vars-hidden-zinc-dark" },

    { "type": "click_stable", "target": { "kind": "test_id", "id": "ui-ai-env-vars-toggle-switch" } },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "checked_is",
        "target": { "kind": "test_id", "id": "ui-ai-env-vars-toggle-switch" },
        "checked": true
      },
      "timeout_frames": 600
    },
    { "type": "wait_frames", "n": 2 },
    { "type": "capture_screenshot", "label": "ui-gallery-ai-env-vars-shown-zinc-dark" },

    { "type": "click_stable", "target": { "kind": "test_id", "id": "ui-ai-env-var-copy-export" } },
    {
      "type": "wait_until",
      "predicate": { "kind": "exists", "target": { "kind": "test_id", "id": "ui-ai-env-var-copy-export-copied" } },
      "timeout_frames": 600
    },
    { "type": "wait_frames", "n": 2 },
    { "type": "capture_screenshot", "label": "ui-gallery-ai-env-vars-after-copy-zinc-dark" },
    { "type": "capture_bundle", "label": "ui-gallery-ai-env-vars-zinc-dark", "max_snapshots": 240 }
  ]
}
