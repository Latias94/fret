{
  "schema_version": 2,
  "meta": {
    "name": "ui-gallery-navigation-menu-escape-close-gate",
    "required_capabilities": ["diag.script_v2", "diag.screenshot_png"],
    "tags": ["ui_gallery", "shadcn", "navigation_menu", "overlay", "focus", "escape", "gate"],
    "target_hints": [
      "Move the pointer over the trigger, open NavigationMenu content, and press Escape to close.",
      "Ensure a small mouse move over the trigger does not immediately re-open after Escape dismissal."
    ]
  },
  "steps": [
    { "type": "reset_diagnostics" },
    { "type": "press_key", "key": "escape" },
    { "type": "wait_frames", "n": 2 },

    {
      "type": "wait_until",
      "predicate": { "kind": "exists", "target": { "kind": "test_id", "id": "ui-gallery-nav-search" } },
      "timeout_frames": 600
    },
    {
      "type": "wait_until",
      "predicate": { "kind": "exists", "target": { "kind": "test_id", "id": "ui-gallery-nav-scroll" } },
      "timeout_frames": 600
    },

    { "type": "set_window_inner_size", "width_px": 1280.0, "height_px": 720.0 },
    { "type": "wait_frames", "n": 20 },

    { "type": "click", "target": { "kind": "test_id", "id": "ui-gallery-nav-search" } },
    { "type": "press_key", "key": "a", "modifiers": { "ctrl": true } },
    { "type": "press_key", "key": "backspace" },
    { "type": "type_text", "text": "navigation_menu" },
    { "type": "wait_frames", "n": 2 },

    {
      "type": "ensure_visible",
      "target": { "kind": "test_id", "id": "ui-gallery-nav-navigation-menu" },
      "within_window": true,
      "padding_px": 8.0,
      "timeout_frames": 600
    },
    { "type": "click_stable", "target": { "kind": "test_id", "id": "ui-gallery-nav-navigation-menu" } },
    {
      "type": "wait_until",
      "predicate": { "kind": "exists", "target": { "kind": "test_id", "id": "ui-gallery-page-navigation-menu" } },
      "timeout_frames": 600
    },

    {
      "type": "wait_until",
      "predicate": { "kind": "exists", "target": { "kind": "test_id", "id": "ui-gallery-content-scroll" } },
      "timeout_frames": 600
    },
    { "type": "wait_frames", "n": 6 },

    {
      "type": "scroll_into_view",
      "container": { "kind": "test_id", "id": "ui-gallery-content-scroll" },
      "target": { "kind": "test_id", "id": "ui-gallery-navigation-menu-docs-demo" },
      "delta_y": -240.0,
      "require_fully_within_window": true,
      "padding_px": 12.0,
      "timeout_frames": 1200
    },
    { "type": "capture_screenshot", "label": "ui-gallery-navigation-menu-docs-escape-gate-closed", "timeout_frames": 240 },

    { "type": "move_pointer", "pointer_kind": "mouse", "target": { "kind": "test_id", "id": "ui-gallery-navigation-menu-docs-demo-trigger-components" } },
    { "type": "click", "target": { "kind": "test_id", "id": "ui-gallery-navigation-menu-docs-demo-trigger-components" } },
    {
      "type": "wait_until",
      "predicate": { "kind": "exists", "target": { "kind": "test_id", "id": "ui-gallery-navigation-menu-docs-demo-viewport" } },
      "timeout_frames": 600
    },
    {
      "type": "wait_until",
      "predicate": { "kind": "exists", "target": { "kind": "test_id", "id": "ui-gallery-navigation-menu-docs-demo-link-alert-dialog" } },
      "timeout_frames": 600
    },
    { "type": "capture_screenshot", "label": "ui-gallery-navigation-menu-docs-escape-gate-open", "timeout_frames": 240 },

    { "type": "press_key", "key": "escape" },
    {
      "type": "wait_until",
      "predicate": { "kind": "not_exists", "target": { "kind": "test_id", "id": "ui-gallery-navigation-menu-docs-demo-viewport" } },
      "timeout_frames": 600
    },

    {
      "type": "move_pointer_sweep",
      "pointer_kind": "mouse",
      "target": { "kind": "test_id", "id": "ui-gallery-navigation-menu-docs-demo-trigger-components" },
      "delta_x": 2.0,
      "delta_y": 0.0,
      "steps": 2,
      "frames_per_step": 1
    },
    { "type": "wait_frames", "n": 40 },
    {
      "type": "assert",
      "predicate": { "kind": "not_exists", "target": { "kind": "test_id", "id": "ui-gallery-navigation-menu-docs-demo-viewport" } }
    },

    { "type": "capture_bundle", "label": "ui-gallery-navigation-menu-escape-close-gate" }
  ]
}
