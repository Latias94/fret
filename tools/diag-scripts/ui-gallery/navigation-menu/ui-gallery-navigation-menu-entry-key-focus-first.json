{
  "schema_version": 2,
  "meta": {
    "name": "ui-gallery-navigation-menu-entry-key-focus-first",
    "required_capabilities": ["diag.script_v2"],
    "tags": ["ui_gallery", "shadcn", "navigation_menu", "keyboard", "focus", "gate"],
    "target_hints": [
      "Open a NavigationMenu item, then press ArrowDown on the focused trigger.",
      "Ensure focus moves into the open content (first link), matching Radix entry-key behavior."
    ]
  },
  "steps": [
    { "type": "reset_diagnostics" },
    { "type": "press_key", "key": "escape" },
    { "type": "wait_frames", "n": 2 },

    {
      "type": "wait_until",
      "predicate": { "kind": "exists", "target": { "kind": "test_id", "id": "ui-gallery-nav-search" } },
      "timeout_frames": 600
    },
    {
      "type": "wait_until",
      "predicate": { "kind": "exists", "target": { "kind": "test_id", "id": "ui-gallery-nav-scroll" } },
      "timeout_frames": 600
    },

    { "type": "set_window_inner_size", "width_px": 1280.0, "height_px": 720.0 },
    { "type": "wait_frames", "n": 20 },

    { "type": "click", "target": { "kind": "test_id", "id": "ui-gallery-nav-search" } },
    { "type": "press_key", "key": "a", "modifiers": { "ctrl": true } },
    { "type": "press_key", "key": "backspace" },
    { "type": "type_text", "text": "navigation_menu" },
    { "type": "wait_frames", "n": 2 },

    {
      "type": "ensure_visible",
      "target": { "kind": "test_id", "id": "ui-gallery-nav-navigation-menu" },
      "within_window": true,
      "padding_px": 8.0,
      "timeout_frames": 600
    },
    { "type": "click_stable", "target": { "kind": "test_id", "id": "ui-gallery-nav-navigation-menu" } },
    {
      "type": "wait_until",
      "predicate": { "kind": "exists", "target": { "kind": "test_id", "id": "ui-gallery-page-navigation-menu" } },
      "timeout_frames": 600
    },

    {
      "type": "wait_until",
      "predicate": { "kind": "exists", "target": { "kind": "test_id", "id": "ui-gallery-content-scroll" } },
      "timeout_frames": 600
    },
    { "type": "wait_frames", "n": 6 },

    {
      "type": "scroll_into_view",
      "container": { "kind": "test_id", "id": "ui-gallery-content-scroll" },
      "target": { "kind": "test_id", "id": "ui-gallery-navigation-menu-demo" },
      "delta_y": -240.0,
      "require_fully_within_window": true,
      "padding_px": 12.0,
      "timeout_frames": 1200
    },

    { "type": "click_stable", "target": { "kind": "test_id", "id": "ui-gallery-navigation-menu-demo-trigger-components" } },
    {
      "type": "wait_until",
      "predicate": { "kind": "exists", "target": { "kind": "test_id", "id": "ui-gallery-navigation-menu-demo-viewport" } },
      "timeout_frames": 600
    },
    {
      "type": "wait_until",
      "predicate": { "kind": "exists", "target": { "kind": "test_id", "id": "ui-gallery-navigation-menu-demo-link-alert-dialog" } },
      "timeout_frames": 600
    },
    {
      "type": "wait_until",
      "predicate": { "kind": "focus_is", "target": { "kind": "test_id", "id": "ui-gallery-navigation-menu-demo-trigger-components" } },
      "timeout_frames": 240
    },

    { "type": "press_key", "key": "arrow_down" },
    {
      "type": "wait_until",
      "predicate": { "kind": "focus_is", "target": { "kind": "test_id", "id": "ui-gallery-navigation-menu-demo-link-alert-dialog" } },
      "timeout_frames": 600
    },

    { "type": "capture_bundle", "label": "ui-gallery-navigation-menu-entry-key-focus-first" }
  ]
}
