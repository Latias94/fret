{
  "schema_version": 2,
  "meta": {
    "name": "ui-gallery-navigation-menu-docs-smoke",
    "required_capabilities": ["diag.script_v2", "diag.screenshot_png"],
    "tags": ["ui_gallery", "shadcn", "navigation_menu", "overlay", "a11y", "screenshot"],
    "target_hints": [
      "Navigates to the Navigation Menu page.",
      "Asserts trigger roles for link vs menu trigger.",
      "Opens a menu and captures screenshots for quick parity triage.",
      "Clicks the Docs link to close the menu (Radix/shadcn outcome)."
    ]
  },
  "steps": [
    { "type": "reset_diagnostics" },
    { "type": "press_key", "key": "escape" },
    { "type": "wait_frames", "n": 2 },

    {
      "type": "wait_until",
      "predicate": { "kind": "exists", "target": { "kind": "test_id", "id": "ui-gallery-nav-search" } },
      "timeout_frames": 600
    },
    {
      "type": "wait_until",
      "predicate": { "kind": "exists", "target": { "kind": "test_id", "id": "ui-gallery-nav-scroll" } },
      "timeout_frames": 600
    },

    { "type": "set_window_inner_size", "width_px": 1280.0, "height_px": 720.0 },
    { "type": "wait_frames", "n": 20 },

    { "type": "click", "target": { "kind": "test_id", "id": "ui-gallery-nav-search" } },
    { "type": "press_key", "key": "a", "modifiers": { "ctrl": true } },
    { "type": "press_key", "key": "backspace" },
    { "type": "type_text", "text": "navigation_menu" },
    { "type": "wait_frames", "n": 2 },

    {
      "type": "ensure_visible",
      "target": { "kind": "test_id", "id": "ui-gallery-nav-navigation-menu" },
      "within_window": true,
      "padding_px": 8.0,
      "timeout_frames": 600
    },
    { "type": "click_stable", "target": { "kind": "test_id", "id": "ui-gallery-nav-navigation-menu" } },
    {
      "type": "wait_until",
      "predicate": { "kind": "exists", "target": { "kind": "test_id", "id": "ui-gallery-page-navigation-menu" } },
      "timeout_frames": 600
    },

    {
      "type": "wait_until",
      "predicate": { "kind": "exists", "target": { "kind": "test_id", "id": "ui-gallery-navigation-menu-demo-content" } },
      "timeout_frames": 600
    },
    {
      "type": "wait_until",
      "predicate": { "kind": "exists", "target": { "kind": "test_id", "id": "ui-gallery-navigation-menu-usage-content" } },
      "timeout_frames": 600
    },
    {
      "type": "wait_until",
      "predicate": { "kind": "exists", "target": { "kind": "test_id", "id": "ui-gallery-navigation-menu-link-component-content" } },
      "timeout_frames": 600
    },
    {
      "type": "wait_until",
      "predicate": { "kind": "exists", "target": { "kind": "test_id", "id": "ui-gallery-navigation-menu-rtl-content" } },
      "timeout_frames": 600
    },
    {
      "type": "wait_until",
      "predicate": { "kind": "exists", "target": { "kind": "test_id", "id": "ui-gallery-navigation-menu-api-reference-content" } },
      "timeout_frames": 600
    },
    {
      "type": "wait_until",
      "predicate": { "kind": "exists", "target": { "kind": "test_id", "id": "ui-gallery-navigation-menu-container-query-toggle-content" } },
      "timeout_frames": 600
    },
    {
      "type": "wait_until",
      "predicate": { "kind": "exists", "target": { "kind": "test_id", "id": "ui-gallery-navigation-menu-notes-content" } },
      "timeout_frames": 600
    },

    {
      "type": "wait_until",
      "predicate": { "kind": "exists", "target": { "kind": "test_id", "id": "ui-gallery-content-scroll" } },
      "timeout_frames": 600
    },
    { "type": "wait_frames", "n": 6 },

    {
      "type": "scroll_into_view",
      "container": { "kind": "test_id", "id": "ui-gallery-content-scroll" },
      "target": { "kind": "test_id", "id": "ui-gallery-navigation-menu-docs-demo" },
      "delta_y": -240.0,
      "require_fully_within_container": true,
      "require_fully_within_window": true,
      "padding_px": 12.0,
      "timeout_frames": 1200
    },
    { "type": "capture_screenshot", "label": "ui-gallery-navigation-menu-docs-demo-closed", "timeout_frames": 240 },

    {
      "type": "assert",
      "predicate": {
        "kind": "role_is",
        "target": { "kind": "test_id", "id": "ui-gallery-navigation-menu-docs-demo-trigger-components" },
        "role": "button"
      }
    },
    {
      "type": "assert",
      "predicate": {
        "kind": "role_is",
        "target": { "kind": "test_id", "id": "ui-gallery-navigation-menu-docs-demo-trigger-docs" },
        "role": "link"
      }
    },

    { "type": "click", "target": { "kind": "test_id", "id": "ui-gallery-navigation-menu-docs-demo-trigger-components" } },
    {
      "type": "wait_until",
      "predicate": { "kind": "exists", "target": { "kind": "test_id", "id": "ui-gallery-navigation-menu-docs-demo-viewport" } },
      "timeout_frames": 600
    },
    {
      "type": "wait_until",
      "predicate": { "kind": "exists", "target": { "kind": "test_id", "id": "ui-gallery-navigation-menu-docs-demo-link-alert-dialog" } },
      "timeout_frames": 600
    },
    {
      "type": "assert",
      "predicate": {
        "kind": "role_is",
        "target": { "kind": "test_id", "id": "ui-gallery-navigation-menu-docs-demo-link-alert-dialog" },
        "role": "link"
      }
    },
    { "type": "capture_screenshot", "label": "ui-gallery-navigation-menu-docs-demo-open-components", "timeout_frames": 240 },

    { "type": "click", "target": { "kind": "test_id", "id": "ui-gallery-navigation-menu-docs-demo-trigger-docs" } },
    {
      "type": "wait_until",
      "predicate": { "kind": "not_exists", "target": { "kind": "test_id", "id": "ui-gallery-navigation-menu-docs-demo-viewport" } },
      "timeout_frames": 600
    },

    {
      "type": "scroll_into_view",
      "container": { "kind": "test_id", "id": "ui-gallery-content-scroll" },
      "target": { "kind": "test_id", "id": "ui-gallery-navigation-menu-rtl" },
      "delta_y": -240.0,
      "require_fully_within_container": true,
      "require_fully_within_window": true,
      "padding_px": 12.0,
      "timeout_frames": 1200
    },
    {
      "type": "assert",
      "predicate": {
        "kind": "role_is",
        "target": { "kind": "test_id", "id": "ui-gallery-navigation-menu-rtl-trigger-docs" },
        "role": "link"
      }
    },
    { "type": "click", "target": { "kind": "test_id", "id": "ui-gallery-navigation-menu-rtl-trigger-components" } },
    {
      "type": "wait_until",
      "predicate": { "kind": "exists", "target": { "kind": "test_id", "id": "ui-gallery-navigation-menu-rtl-viewport" } },
      "timeout_frames": 600
    },
    {
      "type": "wait_until",
      "predicate": { "kind": "exists", "target": { "kind": "test_id", "id": "ui-gallery-navigation-menu-rtl-link-alert-dialog" } },
      "timeout_frames": 600
    },
    {
      "type": "assert",
      "predicate": {
        "kind": "role_is",
        "target": { "kind": "test_id", "id": "ui-gallery-navigation-menu-rtl-link-alert-dialog" },
        "role": "link"
      }
    },
    { "type": "capture_screenshot", "label": "ui-gallery-navigation-menu-rtl-open-components", "timeout_frames": 240 },

    { "type": "capture_bundle", "label": "ui-gallery-navigation-menu-docs-smoke" }
  ]
}
