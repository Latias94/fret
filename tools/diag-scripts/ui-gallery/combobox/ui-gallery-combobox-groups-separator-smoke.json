{
  "schema_version": 2,
  "meta": {
    "name": "ui-gallery-combobox-groups-separator-smoke",
    "required_capabilities": ["diag.script_v2", "diag.overlay_placement_trace"],
    "tags": ["ui_gallery", "shadcn", "combobox", "groups", "separator"]
  },
  "steps": [
    { "type": "reset_diagnostics" },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-nav-search" }
      },
      "timeout_frames": 600
    },
    { "type": "press_key", "key": "escape" },
    { "type": "wait_frames", "n": 2 },
    { "type": "set_window_inner_size", "width_px": 1280.0, "height_px": 720.0 },
    { "type": "wait_frames", "n": 20 },

    { "type": "click", "target": { "kind": "test_id", "id": "ui-gallery-nav-search" } },
    { "type": "press_key", "key": "a", "modifiers": { "ctrl": true } },
    { "type": "press_key", "key": "backspace" },
    { "type": "type_text", "text": "combobox" },
    { "type": "wait_frames", "n": 2 },
    { "type": "click", "target": { "kind": "test_id", "id": "ui-gallery-nav-combobox" } },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-page-combobox" }
      },
      "timeout_frames": 600
    },
    { "type": "wait_frames", "n": 30 },

    {
      "type": "scroll_into_view",
      "container": { "kind": "test_id", "id": "ui-gallery-content-scroll" },
      "target": { "kind": "test_id", "id": "ui-gallery-combobox-groups-separator-trigger" },
      "delta_y": -360.0,
      "require_fully_within_container": true,
      "padding_px": 16.0,
      "timeout_frames": 1800
    },
    { "type": "wait_frames", "n": 10 },

    {
      "type": "click",
      "target": { "kind": "test_id", "id": "ui-gallery-combobox-groups-separator-trigger" }
    },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-combobox-groups-separator-input" }
      },
      "timeout_frames": 600
    },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-combobox-groups-separator-listbox" }
      },
      "timeout_frames": 600
    },
    {
      "type": "wait_overlay_placement_trace",
      "query": {
        "kind": "anchored_panel",
        "anchor_test_id": "ui-gallery-combobox-groups-separator-trigger",
        "content_test_id": "ui-gallery-combobox-groups-separator-listbox"
      },
      "timeout_frames": 240
    },

    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-combobox-groups-separator-sep-group-0" }
      },
      "timeout_frames": 600
    },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-combobox-groups-separator-sep-group-1" }
      },
      "timeout_frames": 600
    },

    { "type": "capture_bundle", "label": "ui-gallery-combobox-groups-separator-smoke" }
  ]
}
