{
  "schema_version": 2,
  "meta": {
    "name": "ui-gallery-combobox-auto-highlight-first-match",
    "required_capabilities": ["diag.script_v2", "diag.overlay_placement_trace"],
    "tags": ["ui_gallery", "shadcn", "combobox", "auto_highlight"]
  },
  "steps": [
    { "type": "reset_diagnostics" },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-nav-search" }
      },
      "timeout_frames": 600
    },
    { "type": "press_key", "key": "escape" },
    { "type": "wait_frames", "n": 2 },
    { "type": "set_window_inner_size", "width_px": 1280.0, "height_px": 720.0 },
    { "type": "wait_frames", "n": 20 },

    { "type": "click", "target": { "kind": "test_id", "id": "ui-gallery-nav-search" } },
    { "type": "press_key", "key": "a", "modifiers": { "ctrl": true } },
    { "type": "press_key", "key": "backspace" },
    { "type": "type_text", "text": "combobox" },
    { "type": "wait_frames", "n": 2 },
    { "type": "click", "target": { "kind": "test_id", "id": "ui-gallery-nav-combobox" } },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-page-combobox" }
      },
      "timeout_frames": 600
    },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-combobox-demo-trigger" }
      },
      "timeout_frames": 600
    },
    { "type": "click", "target": { "kind": "test_id", "id": "ui-gallery-combobox-demo-trigger" } },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-combobox-demo-input" }
      },
      "timeout_frames": 600
    },
    {
      "type": "wait_overlay_placement_trace",
      "query": {
        "kind": "anchored_panel",
        "anchor_test_id": "ui-gallery-combobox-demo-trigger",
        "content_test_id": "ui-gallery-combobox-demo-listbox"
      },
      "timeout_frames": 240
    },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-combobox-demo-item-apple" }
      },
      "timeout_frames": 240
    },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "active_item_is",
        "container": { "kind": "test_id", "id": "ui-gallery-combobox-demo-input" },
        "item": { "kind": "test_id", "id": "ui-gallery-combobox-demo-item-apple" }
      },
      "timeout_frames": 240
    },

    { "type": "type_text", "text": "ban" },
    { "type": "wait_frames", "n": 2 },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-combobox-demo-item-banana" }
      },
      "timeout_frames": 240
    },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "active_item_is",
        "container": { "kind": "test_id", "id": "ui-gallery-combobox-demo-input" },
        "item": { "kind": "test_id", "id": "ui-gallery-combobox-demo-item-banana" }
      },
      "timeout_frames": 240
    },

    { "type": "capture_bundle", "label": "ui-gallery-combobox-auto-highlight-first-match" }
  ]
}
