{
  "schema_version": 2,
  "meta": {
    "name": "ui-gallery-combobox-basic-commit-next",
    "required_capabilities": ["diag.script_v2"],
    "tags": ["ui_gallery", "shadcn", "combobox", "selection"]
  },
  "steps": [
    { "type": "reset_diagnostics" },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-nav-search" }
      },
      "timeout_frames": 600
    },
    { "type": "press_key", "key": "escape" },
    { "type": "wait_frames", "n": 2 },
    { "type": "set_window_inner_size", "width_px": 1280.0, "height_px": 720.0 },
    { "type": "wait_frames", "n": 20 },

    { "type": "click", "target": { "kind": "test_id", "id": "ui-gallery-nav-search" } },
    { "type": "press_key", "key": "a", "modifiers": { "ctrl": true } },
    { "type": "press_key", "key": "backspace" },
    { "type": "type_text", "text": "combobox" },
    { "type": "wait_frames", "n": 2 },
    { "type": "click", "target": { "kind": "test_id", "id": "ui-gallery-nav-combobox" } },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-page-combobox" }
      },
      "timeout_frames": 600
    },
    { "type": "wait_frames", "n": 30 },

    { "type": "click", "target": { "kind": "test_id", "id": "ui-gallery-combobox-basic-trigger" } },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-combobox-basic-listbox" }
      },
      "timeout_frames": 600
    },
    { "type": "click", "target": { "kind": "test_id", "id": "ui-gallery-combobox-basic-item-next" } },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "not_exists",
        "target": { "kind": "test_id", "id": "ui-gallery-combobox-basic-listbox" }
      },
      "timeout_frames": 600
    },

    { "type": "click", "target": { "kind": "test_id", "id": "ui-gallery-combobox-basic-trigger" } },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-combobox-basic-listbox" }
      },
      "timeout_frames": 600
    },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "selected_is",
        "selected": true,
        "target": { "kind": "test_id", "id": "ui-gallery-combobox-basic-item-next" }
      },
      "timeout_frames": 600
    },

    { "type": "capture_bundle", "label": "ui-gallery-combobox-basic-commit-next" }
  ]
}
