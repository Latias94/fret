{
  "schema_version": 2,
  "meta": {
    "name": "ui-gallery-theme-select-trigger-baseline-screenshots",
    "required_capabilities": ["diag.script_v2", "diag.screenshot_png"],
    "tags": [
      "ui_gallery",
      "shadcn",
      "theme",
      "select",
      "trigger",
      "baseline",
      "zinc",
      "screenshots"
    ],
    "target_hints": [
      "Sets theme preset to zinc/light and zinc/dark.",
      "Captures screenshots of the closed theme preset Select trigger for baseline alignment review.",
      "Tip: when using `--launch -- cargo run ...`, pass a larger `--timeout-ms` or launch a prebuilt `target/release/fret-ui-gallery.exe` to avoid compile-time timeouts."
    ]
  },
  "steps": [
    { "type": "reset_diagnostics" },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-theme-preset-trigger" }
      },
      "timeout_frames": 600
    },
    { "type": "press_key", "key": "escape" },
    { "type": "wait_frames", "n": 2 },
    { "type": "set_window_inner_size", "width_px": 1280.0, "height_px": 720.0 },
    { "type": "wait_frames", "n": 20 },

    { "type": "click", "target": { "kind": "test_id", "id": "ui-gallery-theme-preset-trigger" } },
    {
      "type": "click_stable",
      "target": { "kind": "test_id", "id": "ui-gallery-theme-preset-item-zinc-light" }
    },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "not_exists",
        "target": { "kind": "test_id", "id": "select-scroll-viewport" }
      },
      "timeout_frames": 600
    },
    { "type": "wait_frames", "n": 2 },
    {
      "type": "capture_screenshot",
      "label": "ui-gallery-theme-select-trigger-baseline-zinc-light"
    },

    { "type": "click", "target": { "kind": "test_id", "id": "ui-gallery-theme-preset-trigger" } },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "select-scroll-viewport" }
      },
      "timeout_frames": 600
    },
    {
      "type": "capture_screenshot",
      "label": "ui-gallery-theme-select-menu-baseline-zinc-light-open"
    },
    {
      "type": "click_stable",
      "target": { "kind": "test_id", "id": "ui-gallery-theme-preset-item-zinc-dark" }
    },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "not_exists",
        "target": { "kind": "test_id", "id": "select-scroll-viewport" }
      },
      "timeout_frames": 600
    },
    { "type": "wait_frames", "n": 2 },
    {
      "type": "capture_screenshot",
      "label": "ui-gallery-theme-select-trigger-baseline-zinc-dark"
    },

    { "type": "click", "target": { "kind": "test_id", "id": "ui-gallery-theme-preset-trigger" } },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "select-scroll-viewport" }
      },
      "timeout_frames": 600
    },
    {
      "type": "capture_screenshot",
      "label": "ui-gallery-theme-select-menu-baseline-zinc-dark-open"
    },
    { "type": "press_key", "key": "escape" },
    { "type": "wait_frames", "n": 2 },

    { "type": "capture_bundle", "label": "ui-gallery-theme-select-trigger-baseline" }
  ]
}
