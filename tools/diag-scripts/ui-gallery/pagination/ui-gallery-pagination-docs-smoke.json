{
  "meta": {
    "name": "ui-gallery-pagination-docs-smoke",
    "required_capabilities": ["diag.script_v2", "diag.screenshot_png"]
  },
  "schema_version": 2,
  "steps": [
    { "type": "reset_diagnostics" },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-nav-search" }
      },
      "timeout_frames": 600
    },
    { "type": "press_key", "key": "escape" },
    { "type": "wait_frames", "n": 2 },

    { "type": "set_window_inner_size", "width_px": 1280.0, "height_px": 720.0 },
    { "type": "wait_frames", "n": 15 },

    {
      "type": "click",
      "button": "left",
      "target": { "kind": "test_id", "id": "ui-gallery-nav-search" }
    },
    { "type": "press_key", "key": "a", "modifiers": { "ctrl": true } },
    { "type": "press_key", "key": "backspace" },
    { "type": "type_text", "text": "pagination" },
    { "type": "wait_frames", "n": 2 },

    {
      "type": "wait_until",
      "predicate": {
        "kind": "bounds_within_window",
        "target": { "kind": "test_id", "id": "ui-gallery-nav-pagination" },
        "padding_px": 8.0,
        "eps_px": 1.0
      },
      "timeout_frames": 600
    },
    {
      "type": "click",
      "button": "left",
      "target": { "kind": "test_id", "id": "ui-gallery-nav-pagination" }
    },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-page-pagination" }
      },
      "timeout_frames": 600
    },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-pagination-demo" }
      },
      "timeout_frames": 600
    },

    { "type": "capture_bundle", "label": "ui-gallery-pagination-docs-smoke" },
    { "type": "capture_screenshot", "label": "ui-gallery-pagination-docs-smoke" }
  ]
}

