{
  "schema_version": 2,
  "meta": {
    "name": "ui-gallery-empty-outline-screenshot",
    "required_capabilities": ["diag.script_v2", "diag.screenshot_png"]
  },
  "steps": [
    { "type": "reset_diagnostics" },
    { "type": "press_key", "key": "escape" },
    { "type": "wait_frames", "n": 2 },
    { "type": "set_window_inner_size", "width_px": 1280.0, "height_px": 720.0 },
    { "type": "wait_frames", "n": 15 },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-nav-search" }
      },
      "timeout_frames": 600
    },
    { "type": "click", "target": { "kind": "test_id", "id": "ui-gallery-nav-search" } },
    { "type": "press_key", "key": "a", "modifiers": { "ctrl": true } },
    { "type": "press_key", "key": "backspace" },
    { "type": "type_text", "text": "empty" },
    { "type": "wait_frames", "n": 2 },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-nav-empty" }
      },
      "timeout_frames": 600
    },
    { "type": "click", "target": { "kind": "test_id", "id": "ui-gallery-nav-empty" } },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-page-empty" }
      },
      "timeout_frames": 600
    },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-empty-outline" }
      },
      "timeout_frames": 600
    },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-empty-outline-header" }
      },
      "timeout_frames": 600
    },
    {
      "type": "wait_bounds_stable",
      "target": { "kind": "test_id", "id": "ui-gallery-empty-outline-header" },
      "stable_frames": 10,
      "timeout_frames": 600
    },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "bounds_min_size",
        "target": { "kind": "test_id", "id": "ui-gallery-empty-outline-header" },
        "min_w_px": 320.0,
        "min_h_px": 1.0,
        "eps_px": 1.0
      },
      "timeout_frames": 600
    },
    {
      "type": "scroll_into_view",
      "container": { "kind": "test_id", "id": "ui-gallery-content-viewport" },
      "target": { "kind": "test_id", "id": "ui-gallery-empty-outline" },
      "delta_y": 240.0,
      "require_fully_within_container": false,
      "require_fully_within_window": true,
      "padding_px": 96.0,
      "timeout_frames": 600
    },
    { "type": "wait_frames", "n": 20 },
    { "type": "capture_bundle", "label": "ui-gallery-empty-outline" },
    { "type": "capture_screenshot", "label": "ui-gallery-empty-outline" }
  ]
}
