{
  "schema_version": 2,
  "meta": {
    "name": "ui-gallery-empty-rtl-code-tab-scroll-range",
    "required_capabilities": ["diag.script_v2", "diag.screenshot_png"],
    "tags": ["ui_gallery", "empty", "tabs", "scroll", "regression"]
  },
  "steps": [
    { "type": "reset_diagnostics" },
    { "type": "press_key", "key": "escape" },
    { "type": "wait_frames", "n": 2 },
    { "type": "set_window_inner_size", "width_px": 1280.0, "height_px": 720.0 },
    { "type": "wait_frames", "n": 20 },

    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-nav-search" }
      },
      "timeout_frames": 600
    },
    {
      "type": "type_text_into",
      "target": { "kind": "test_id", "id": "ui-gallery-nav-search" },
      "text": "empty",
      "clear_before_type": true,
      "timeout_frames": 600
    },
    { "type": "wait_frames", "n": 4 },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-nav-empty" }
      },
      "timeout_frames": 600
    },
    { "type": "click_stable", "target": { "kind": "test_id", "id": "ui-gallery-nav-empty" } },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-page-empty" }
      },
      "timeout_frames": 600
    },

    {
      "type": "scroll_into_view",
      "container": { "kind": "test_id", "id": "ui-gallery-content-scroll" },
      "target": { "kind": "test_id", "id": "docsec-rtl-tabs-trigger-code" },
      "delta_y": -120.0,
      "require_fully_within_container": true,
      "require_fully_within_window": true,
      "padding_px": 24.0,
      "timeout_frames": 900
    },
    {
      "type": "click_stable",
      "target": { "kind": "test_id", "id": "docsec-rtl-tabs-trigger-code" },
      "stable_frames": 2,
      "max_move_px": 2.0,
      "timeout_frames": 900
    },
    {
      "type": "wait_semantics_scroll_stable",
      "target": { "kind": "test_id", "id": "ui-gallery-content-viewport" },
      "field": "y_max",
      "stable_frames": 3,
      "max_delta": 1.0,
      "timeout_frames": 600
    },
    { "type": "capture_bundle", "label": "ui-gallery-empty-rtl-code-tab-scroll-range.after_tab_switch" },

    {
      "type": "assert",
      "predicate": {
        "kind": "semantics_scroll_is_finite",
        "target": { "kind": "test_id", "id": "ui-gallery-content-viewport" },
        "field": "y_max"
      }
    },

    {
      "type": "scroll_into_view",
      "container": { "kind": "test_id", "id": "ui-gallery-content-scroll" },
      "target": { "kind": "role_and_name", "role": "text", "name": "API Reference" },
      "delta_y": -120.0,
      "require_fully_within_container": true,
      "require_fully_within_window": true,
      "padding_px": 24.0,
      "timeout_frames": 900
    },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "bounds_within_window",
        "target": { "kind": "role_and_name", "role": "text", "name": "API Reference" },
        "padding_px": 24.0,
        "eps_px": 1.0
      },
      "timeout_frames": 600
    },
    { "type": "capture_bundle", "label": "ui-gallery-empty-rtl-code-tab-scroll-range.before_edge_wheel" },

    { "type": "wheel", "target": { "kind": "test_id", "id": "ui-gallery-content-viewport" }, "delta_y": -240.0 },
    { "type": "wheel", "target": { "kind": "test_id", "id": "ui-gallery-content-viewport" }, "delta_y": -240.0 },
    { "type": "wheel", "target": { "kind": "test_id", "id": "ui-gallery-content-viewport" }, "delta_y": -240.0 },
    {
      "type": "wait_semantics_scroll_stable",
      "target": { "kind": "test_id", "id": "ui-gallery-content-viewport" },
      "field": "y_max",
      "stable_frames": 3,
      "max_delta": 1.0,
      "timeout_frames": 600
    },
    {
      "type": "wait_semantics_scroll_stable",
      "target": { "kind": "test_id", "id": "ui-gallery-content-viewport" },
      "field": "y",
      "stable_frames": 3,
      "max_delta": 1.0,
      "timeout_frames": 600
    },

    {
      "type": "assert",
      "predicate": {
        "kind": "semantics_scroll_is_finite",
        "target": { "kind": "test_id", "id": "ui-gallery-content-viewport" },
        "field": "y_max"
      }
    },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "bounds_within_window",
        "target": { "kind": "role_and_name", "role": "text", "name": "API Reference" },
        "padding_px": 24.0,
        "eps_px": 1.0
      },
      "timeout_frames": 600
    },

    { "type": "capture_screenshot", "label": "ui-gallery-empty-rtl-code-tab-scroll-range.api_reference_visible_after_edge_wheel" },
    { "type": "capture_bundle", "label": "ui-gallery-empty-rtl-code-tab-scroll-range" }
  ]
}
