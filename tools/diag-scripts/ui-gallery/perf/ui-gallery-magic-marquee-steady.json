{
  "schema_version": 2,
  "steps": [
    { "type": "press_key", "key": "escape" },
    { "type": "wait_frames", "n": 2 },

    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-nav-scroll" }
      },
      "timeout_frames": 240
    },

    {
      "type": "scroll_into_view",
      "container": { "kind": "test_id", "id": "ui-gallery-nav-scroll" },
      "target": { "kind": "test_id", "id": "ui-gallery-nav-magic-marquee" },
      "delta_y": 720.0,
      "timeout_frames": 360
    },
    { "type": "click", "target": { "kind": "test_id", "id": "ui-gallery-nav-magic-marquee" } },

    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-magic-marquee" }
      },
      "timeout_frames": 360
    },

    { "type": "reset_diagnostics" },
    { "type": "set_window_inner_size", "width_px": 1280.0, "height_px": 720.0 },
    { "type": "wait_frames", "n": 120 },

    { "type": "capture_bundle", "label": "ui-gallery-magic-marquee-steady" },
    { "type": "wait_frames", "n": 2 }
  ]
}
