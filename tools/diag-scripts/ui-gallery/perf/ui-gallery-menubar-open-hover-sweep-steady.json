{
  "schema_version": 2,
  "steps": [
    { "type": "press_key", "key": "escape" },
    { "type": "wait_frames", "n": 2 },

    { "type": "set_window_inner_size", "width_px": 1280.0, "height_px": 720.0 },
    { "type": "wait_frames", "n": 2 },

    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "menubar-trigger-file" }
      },
      "timeout_frames": 240
    },

    { "type": "click", "target": { "kind": "test_id", "id": "menubar-trigger-file" } },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "menubar-item-ui_gallery-app-open" }
      },
      "timeout_frames": 120
    },

    { "type": "wait_frames", "n": 2 },
    { "type": "reset_diagnostics" },

    {
      "type": "move_pointer_sweep",
      "target": { "kind": "test_id", "id": "menubar-item-ui_gallery-app-open" },
      "delta_x": 0.0,
      "delta_y": 160.0,
      "steps": 24,
      "frames_per_step": 1
    },

    { "type": "wait_frames", "n": 2 },
    { "type": "reset_diagnostics" },

    {
      "type": "move_pointer_sweep",
      "target": { "kind": "test_id", "id": "menubar-item-ui_gallery-app-open" },
      "delta_x": 0.0,
      "delta_y": 160.0,
      "steps": 24,
      "frames_per_step": 1
    },

    { "type": "wait_frames", "n": 3 },
    { "type": "capture_bundle", "label": "ui-gallery-menubar-open-hover-sweep-steady" },
    { "type": "wait_frames", "n": 2 },

    { "type": "press_key", "key": "escape" },
    { "type": "wait_frames", "n": 2 }
  ]
}
