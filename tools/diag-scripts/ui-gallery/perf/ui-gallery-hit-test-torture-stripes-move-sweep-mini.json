{
  "schema_version": 2,
  "steps": [
    { "type": "press_key", "key": "escape" },
    { "type": "wait_frames", "n": 2 },

    { "type": "set_window_inner_size", "width_px": 1280.0, "height_px": 900.0 },
    { "type": "wait_frames", "n": 2 },

    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-hit-test-torture-root" }
      },
      "timeout_frames": 600
    },

    { "type": "move_pointer", "target": { "kind": "test_id", "id": "ui-gallery-hit-test-torture-root" } },
    { "type": "wait_frames", "n": 15 },
    { "type": "reset_diagnostics" },

    {
      "type": "move_pointer_sweep",
      "target": { "kind": "test_id", "id": "ui-gallery-hit-test-torture-root" },
      "delta_x": 250.0,
      "delta_y": 0.0,
      "steps": 31
    },
    { "type": "wait_frames", "n": 1 },
    {
      "type": "move_pointer_sweep",
      "target": { "kind": "test_id", "id": "ui-gallery-hit-test-torture-root" },
      "delta_x": -250.0,
      "delta_y": 0.0,
      "steps": 31
    },

    { "type": "wait_frames", "n": 2 },
    { "type": "capture_bundle", "label": "ui-gallery-hit-test-torture-stripes-move-sweep-mini" },

    { "type": "press_key", "key": "escape" },
    { "type": "wait_frames", "n": 2 }
  ]
}

