{
  "schema_version": 2,
  "meta": {
    "name": "UI Gallery: Hover layout torture (steady)",
    "tags": ["ui-gallery", "perf", "layout", "hover", "steady"],
    "required_capabilities": ["diag.script_v2"]
  },
  "steps": [
    { "type": "press_key", "key": "escape" },
    { "type": "wait_frames", "n": 2 },

    { "type": "set_window_inner_size", "width_px": 1280.0, "height_px": 720.0 },
    { "type": "wait_frames", "n": 2 },

    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-overlay-reset" }
      },
      "timeout_frames": 240
    },

    {
      "type": "wait_until",
      "predicate": { "kind": "font_catalog_populated" },
      "timeout_frames": 1800
    },
    {
      "type": "wait_until",
      "predicate": { "kind": "system_font_rescan_idle" },
      "timeout_frames": 1800
    },
    {
      "type": "wait_until",
      "predicate": { "kind": "text_font_stack_key_stable", "stable_frames": 120 },
      "timeout_frames": 600
    },

    { "type": "reset_diagnostics" },

    { "type": "move_pointer", "target": { "kind": "test_id", "id": "ui-gallery-overlay-reset" } },
    { "type": "wait_frames", "n": 1 },
    { "type": "move_pointer", "target": { "kind": "test_id", "id": "ui-gallery-popover-trigger" } },
    { "type": "wait_frames", "n": 1 },
    { "type": "move_pointer", "target": { "kind": "test_id", "id": "ui-gallery-dialog-trigger" } },
    { "type": "wait_frames", "n": 1 },
    { "type": "move_pointer", "target": { "kind": "test_id", "id": "ui-gallery-overlay-underlay" } },
    { "type": "wait_frames", "n": 1 },

    { "type": "move_pointer", "target": { "kind": "test_id", "id": "ui-gallery-overlay-reset" } },
    { "type": "wait_frames", "n": 1 },
    { "type": "move_pointer", "target": { "kind": "test_id", "id": "ui-gallery-popover-trigger" } },
    { "type": "wait_frames", "n": 1 },
    { "type": "move_pointer", "target": { "kind": "test_id", "id": "ui-gallery-dialog-trigger" } },
    { "type": "wait_frames", "n": 1 },
    { "type": "move_pointer", "target": { "kind": "test_id", "id": "ui-gallery-overlay-underlay" } },
    { "type": "wait_frames", "n": 1 },

    { "type": "move_pointer", "target": { "kind": "test_id", "id": "ui-gallery-overlay-reset" } },
    { "type": "wait_frames", "n": 1 },
    { "type": "move_pointer", "target": { "kind": "test_id", "id": "ui-gallery-popover-trigger" } },
    { "type": "wait_frames", "n": 1 },
    { "type": "move_pointer", "target": { "kind": "test_id", "id": "ui-gallery-dialog-trigger" } },
    { "type": "wait_frames", "n": 1 },
    { "type": "move_pointer", "target": { "kind": "test_id", "id": "ui-gallery-overlay-underlay" } },
    { "type": "wait_frames", "n": 2 },

    { "type": "capture_bundle", "label": "ui-gallery-hover-layout-torture-steady" },

    { "type": "press_key", "key": "escape" },
    { "type": "wait_frames", "n": 2 },
    { "type": "click", "target": { "kind": "test_id", "id": "ui-gallery-overlay-reset" } },
    { "type": "wait_frames", "n": 2 },
    { "type": "wait_frames", "n": 2 }
  ]
}
