{
  "schema_version": 2,
  "steps": [
    { "type": "reset_diagnostics" },
    {
      "predicate": {
        "kind": "exists",
        "target": {
          "id": "ui-gallery-nav-intro",
          "kind": "test_id"
        }
      },
      "timeout_frames": 600,
      "type": "wait_until"
    },
    {
      "type": "press_key",
      "key": "escape"
    },
    { "type": "wait_frames", "n": 2 },
    { "type": "set_window_inner_size", "width_px": 1280.0, "height_px": 720.0 },
    { "type": "wait_frames", "n": 20 },
    {
      "type": "click_stable",
      "target": { "kind": "test_id", "id": "ui-gallery-nav-intro" },
      "stable_frames": 3,
      "max_move_px": 2.0,
      "timeout_frames": 600
    },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-intro-preview-grid" }
      },
      "timeout_frames": 600
    },
    {
      "n": 30,
      "type": "wait_frames"
    },
    {
      "label": "ui-gallery-intro-idle",
      "type": "capture_bundle"
    },
    {
      "label": "ui-gallery-intro-idle",
      "timeout_frames": 300,
      "type": "capture_screenshot"
    }
  ]
}
