{
  "schema_version": 2,
  "meta": {
    "name": "UI gallery: Select docs screenshots (preview + parts code)",
    "tags": ["ui-gallery", "shadcn", "select", "docs", "screenshots"],
    "required_capabilities": ["diag.script_v2", "diag.screenshot_png"],
    "target_hints": [
      "Navigates to the Select page via the left nav search.",
      "Captures representative screenshots for the docs-aligned path plus the Fret-only composable parts and rich items sections, including their code tabs."
    ]
  },
  "steps": [
    { "type": "reset_diagnostics" },
    {
      "type": "wait_until",
      "predicate": { "kind": "exists", "target": { "kind": "test_id", "id": "ui-gallery-nav-search" } },
      "timeout_frames": 600
    },
    {
      "type": "type_text_into",
      "target": { "kind": "test_id", "id": "ui-gallery-nav-search" },
      "text": "select",
      "clear_before_type": true,
      "timeout_frames": 600
    },
    { "type": "wait_frames", "n": 2 },
    {
      "type": "scroll_into_view",
      "container": { "kind": "test_id", "id": "ui-gallery-nav-scroll" },
      "target": { "kind": "test_id", "id": "ui-gallery-nav-select" },
      "delta_y": -240.0,
      "timeout_frames": 600
    },
    { "type": "click_stable", "target": { "kind": "test_id", "id": "ui-gallery-nav-select" } },
    {
      "type": "wait_until",
      "predicate": { "kind": "exists", "target": { "kind": "test_id", "id": "ui-gallery-select" } },
      "timeout_frames": 600
    },

    {
      "type": "scroll_into_view",
      "container": { "kind": "test_id", "id": "ui-gallery-content-scroll" },
      "target": { "kind": "test_id", "id": "ui-gallery-select-demo-content" },
      "delta_y": -120.0,
      "require_fully_within_container": true,
      "require_fully_within_window": true,
      "padding_px": 16.0,
      "timeout_frames": 600
    },
    { "type": "wait_frames", "n": 2 },
    { "type": "capture_screenshot", "label": "ui-gallery-select-docs.01-demo" },

    {
      "type": "scroll_into_view",
      "container": { "kind": "test_id", "id": "ui-gallery-content-scroll" },
      "target": { "kind": "test_id", "id": "ui-gallery-select-usage-content" },
      "delta_y": -120.0,
      "require_fully_within_container": true,
      "require_fully_within_window": true,
      "padding_px": 16.0,
      "timeout_frames": 600
    },
    { "type": "wait_frames", "n": 2 },
    { "type": "capture_screenshot", "label": "ui-gallery-select-docs.02-usage" },

    {
      "type": "scroll_into_view",
      "container": { "kind": "test_id", "id": "ui-gallery-content-scroll" },
      "target": { "kind": "test_id", "id": "ui-gallery-select-composable-parts-content" },
      "delta_y": -120.0,
      "require_fully_within_container": true,
      "require_fully_within_window": true,
      "padding_px": 16.0,
      "timeout_frames": 600
    },
    { "type": "wait_frames", "n": 2 },
    { "type": "capture_screenshot", "label": "ui-gallery-select-docs.03-composable-parts-preview" },
    { "type": "click", "target": { "kind": "test_id", "id": "ui-gallery-select-composable-parts-tabs-trigger-code" } },
    { "type": "wait_frames", "n": 2 },
    { "type": "capture_screenshot", "label": "ui-gallery-select-docs.04-composable-parts-code" },

    {
      "type": "scroll_into_view",
      "container": { "kind": "test_id", "id": "ui-gallery-content-scroll" },
      "target": { "kind": "test_id", "id": "ui-gallery-select-rich-items-content" },
      "delta_y": -120.0,
      "require_fully_within_container": true,
      "require_fully_within_window": true,
      "padding_px": 16.0,
      "timeout_frames": 600
    },
    { "type": "wait_frames", "n": 2 },
    { "type": "capture_screenshot", "label": "ui-gallery-select-docs.05-rich-items-preview" },
    { "type": "click", "target": { "kind": "test_id", "id": "ui-gallery-select-rich-items-tabs-trigger-code" } },
    { "type": "wait_frames", "n": 2 },
    { "type": "capture_screenshot", "label": "ui-gallery-select-docs.06-rich-items-code" },

    {
      "type": "scroll_into_view",
      "container": { "kind": "test_id", "id": "ui-gallery-content-scroll" },
      "target": { "kind": "test_id", "id": "ui-gallery-select-api-reference-content" },
      "delta_y": -120.0,
      "require_fully_within_container": true,
      "require_fully_within_window": true,
      "padding_px": 16.0,
      "timeout_frames": 600
    },
    { "type": "wait_frames", "n": 2 },
    { "type": "capture_screenshot", "label": "ui-gallery-select-docs.07-api-reference" },
    { "type": "capture_bundle", "label": "ui-gallery-select-docs" }
  ]
}
