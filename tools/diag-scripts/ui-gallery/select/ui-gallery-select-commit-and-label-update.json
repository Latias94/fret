{
  "meta": {
    "required_capabilities": [
      "diag.script_v2",
      "diag.screenshot_png"
    ]
  },
  "schema_version": 2,
  "steps": [
    {
      "predicate": {
        "kind": "exists",
        "target": {
          "id": "ui-gallery-nav-search",
          "kind": "test_id"
        }
      },
      "timeout_frames": 600,
      "type": "wait_until"
    },
    {
      "key": "escape",
      "type": "press_key"
    },
    {
      "n": 2,
      "type": "wait_frames"
    },
    {
      "target": {
        "id": "ui-gallery-nav-search",
        "kind": "test_id"
      },
      "type": "click"
    },
    {
      "key": "a",
      "modifiers": {
        "ctrl": true
      },
      "type": "press_key"
    },
    {
      "key": "backspace",
      "type": "press_key"
    },
    {
      "text": "select",
      "type": "type_text"
    },
    {
      "n": 2,
      "type": "wait_frames"
    },
    {
      "target": {
        "id": "ui-gallery-nav-select",
        "kind": "test_id"
      },
      "type": "click"
    },
    {
      "predicate": {
        "kind": "exists",
        "target": {
          "id": "ui-gallery-page-select",
          "kind": "test_id"
        }
      },
      "timeout_frames": 600,
      "type": "wait_until"
    },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": {
          "kind": "test_id",
          "id": "ui-gallery-select-diag-surface"
        }
      },
      "timeout_frames": 600
    },
    {
      "type": "scroll_into_view",
      "container": {
        "kind": "test_id",
        "id": "ui-gallery-content-scroll"
      },
      "target": {
        "kind": "test_id",
        "id": "ui-gallery-select-diag-surface"
      },
      "delta_y": -180.0,
      "require_fully_within_container": true,
      "require_fully_within_window": true,
      "padding_px": 24.0,
      "timeout_frames": 1200
    },
    {
      "predicate": {
        "kind": "exists",
        "target": {
          "id": "ui-gallery-select-trigger",
          "kind": "test_id"
        }
      },
      "timeout_frames": 600,
      "type": "wait_until"
    },
    {
      "target": {
        "id": "ui-gallery-select-trigger",
        "kind": "test_id"
      },
      "type": "click"
    },
    {
      "predicate": {
        "kind": "exists",
        "target": {
          "id": "ui-gallery-select-item-banana",
          "kind": "test_id"
        }
      },
      "timeout_frames": 240,
      "type": "wait_until"
    },
    {
      "predicate": {
        "kind": "exists_under",
        "scope": {
          "kind": "test_id",
          "id": "select-scroll-viewport"
        },
        "target": {
          "kind": "test_id",
          "id": "ui-gallery-select-item-banana"
        }
      },
      "timeout_frames": 240,
      "type": "wait_until"
    },
    {
      "target": {
        "id": "ui-gallery-select-item-banana",
        "kind": "test_id"
      },
      "type": "click"
    },
    {
      "predicate": {
        "kind": "not_exists",
        "target": {
          "id": "select-scroll-viewport",
          "kind": "test_id"
        }
      },
      "timeout_frames": 240,
      "type": "wait_until"
    },
    {
      "predicate": {
        "kind": "label_contains",
        "target": {
          "kind": "test_id",
          "id": "ui-gallery-select-selected-label"
        },
        "text": "Selected: banana"
      },
      "timeout_frames": 240,
      "type": "wait_until"
    },
    {
      "predicate": {
        "kind": "focus_is",
        "target": {
          "id": "ui-gallery-select-trigger",
          "kind": "test_id"
        }
      },
      "timeout_frames": 240,
      "type": "wait_until"
    },
    {
      "label": "ui-gallery-select-commit-and-label-update",
      "type": "capture_bundle"
    },
    {
      "label": "ui-gallery-select-commit-and-label-update",
      "type": "capture_screenshot"
    }
  ]
}
