{
  "meta": {
    "required_capabilities": [
      "diag.script_v2",
      "diag.overlay_placement_trace"
    ]
  },
  "schema_version": 2,
  "steps": [
    {
      "predicate": {
        "kind": "exists",
        "target": {
          "id": "ui-gallery-nav-search",
          "kind": "test_id"
        }
      },
      "timeout_frames": 600,
      "type": "wait_until"
    },
    {
      "key": "escape",
      "modifiers": {
        "alt": false,
        "ctrl": false,
        "meta": false,
        "shift": false
      },
      "repeat": false,
      "type": "press_key"
    },
    {
      "n": 2,
      "type": "wait_frames"
    },
    {
      "button": "left",
      "target": {
        "id": "ui-gallery-nav-search",
        "kind": "test_id"
      },
      "type": "click"
    },
    {
      "key": "a",
      "modifiers": {
        "alt": false,
        "ctrl": true,
        "meta": false,
        "shift": false
      },
      "repeat": false,
      "type": "press_key"
    },
    {
      "key": "backspace",
      "modifiers": {
        "alt": false,
        "ctrl": false,
        "meta": false,
        "shift": false
      },
      "repeat": false,
      "type": "press_key"
    },
    {
      "text": "select",
      "type": "type_text"
    },
    {
      "n": 2,
      "type": "wait_frames"
    },
    {
      "button": "left",
      "target": {
        "id": "ui-gallery-nav-select",
        "kind": "test_id"
      },
      "type": "click"
    },
    {
      "predicate": {
        "kind": "exists",
        "target": {
          "id": "ui-gallery-page-select",
          "kind": "test_id"
        }
      },
      "timeout_frames": 600,
      "type": "wait_until"
    },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": {
          "kind": "test_id",
          "id": "ui-gallery-select-diag-surface"
        }
      },
      "timeout_frames": 600
    },
    {
      "type": "scroll_into_view",
      "container": {
        "kind": "test_id",
        "id": "ui-gallery-content-scroll"
      },
      "target": {
        "kind": "test_id",
        "id": "ui-gallery-select-diag-surface"
      },
      "delta_y": -180.0,
      "require_fully_within_window": true,
      "padding_px": 24.0,
      "timeout_frames": 1200
    },
    {
      "predicate": {
        "kind": "exists",
        "target": {
          "id": "ui-gallery-select-trigger",
          "kind": "test_id"
        }
      },
      "timeout_frames": 600,
      "type": "wait_until"
    },
    {
      "button": "left",
      "target": {
        "id": "ui-gallery-select-trigger",
        "kind": "test_id"
      },
      "type": "click"
    },
    {
      "predicate": {
        "kind": "exists",
        "target": {
          "id": "select-scroll-viewport",
          "kind": "test_id"
        }
      },
      "timeout_frames": 240,
      "type": "wait_until"
    },
    {
      "query": {
        "kind": "placed_rect",
        "anchor_test_id": "ui-gallery-select-trigger"
      },
      "timeout_frames": 240,
      "type": "wait_overlay_placement_trace"
    },
    {
      "predicate": {
        "eps_px": 0.5,
        "kind": "bounds_within_window",
        "padding_px": 2.0,
        "target": {
          "id": "select-scroll-viewport",
          "kind": "test_id"
        }
      },
      "timeout_frames": 240,
      "type": "wait_until"
    },
    {
      "n": 5,
      "type": "wait_frames"
    },
    {
      "button": "left",
      "target": {
        "id": "ui-gallery-select-trigger",
        "kind": "test_id"
      },
      "type": "click"
    },
    {
      "predicate": {
        "kind": "not_exists",
        "target": {
          "id": "select-scroll-viewport",
          "kind": "test_id"
        }
      },
      "timeout_frames": 240,
      "type": "wait_until"
    },
    {
      "predicate": {
        "kind": "focus_is",
        "target": {
          "id": "ui-gallery-select-trigger",
          "kind": "test_id"
        }
      },
      "timeout_frames": 240,
      "type": "wait_until"
    },
    {
      "label": "ui-gallery-select-trigger-toggle-close",
      "type": "capture_bundle"
    }
  ]
}
