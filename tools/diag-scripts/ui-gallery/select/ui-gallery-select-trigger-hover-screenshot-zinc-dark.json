{
  "schema_version": 2,
  "meta": {
    "name": "UI gallery: Select trigger hover screenshot (zinc dark)",
    "tags": [
      "ui-gallery",
      "shadcn",
      "select",
      "trigger",
      "hover",
      "zinc-dark",
      "screenshots"
    ],
    "required_capabilities": [
      "diag.script_v2",
      "diag.screenshot_png"
    ],
    "target_hints": [
      "Sets theme preset to zinc/dark.",
      "Navigates to the Select page.",
      "Captures the closed trigger background.",
      "Hovers the trigger to capture the dark hover background."
    ]
  },
  "steps": [
    {
      "type": "reset_diagnostics"
    },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": {
          "kind": "test_id",
          "id": "ui-gallery-theme-preset-trigger"
        }
      },
      "timeout_frames": 600
    },
    {
      "type": "press_key",
      "key": "escape"
    },
    {
      "type": "wait_frames",
      "n": 2
    },
    {
      "type": "set_window_inner_size",
      "width_px": 1280.0,
      "height_px": 720.0
    },
    {
      "type": "wait_frames",
      "n": 20
    },
    {
      "type": "click",
      "target": {
        "kind": "test_id",
        "id": "ui-gallery-theme-preset-trigger"
      }
    },
    {
      "type": "click_stable",
      "target": {
        "kind": "test_id",
        "id": "ui-gallery-theme-preset-item-zinc-dark"
      }
    },
    {
      "type": "wait_frames",
      "n": 2
    },
    {
      "type": "press_key",
      "key": "escape"
    },
    {
      "type": "wait_frames",
      "n": 2
    },
    {
      "type": "click",
      "target": {
        "kind": "test_id",
        "id": "ui-gallery-nav-search"
      }
    },
    {
      "type": "press_key",
      "key": "a",
      "modifiers": {
        "ctrl": true
      }
    },
    {
      "type": "press_key",
      "key": "backspace"
    },
    {
      "type": "type_text",
      "text": "select"
    },
    {
      "type": "wait_frames",
      "n": 2
    },
    {
      "type": "click_stable",
      "target": {
        "kind": "test_id",
        "id": "ui-gallery-nav-select"
      }
    },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": {
          "kind": "test_id",
          "id": "ui-gallery-page-select"
        }
      },
      "timeout_frames": 600
    },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": {
          "kind": "test_id",
          "id": "ui-gallery-select-diag-surface"
        }
      },
      "timeout_frames": 600
    },
    {
      "type": "scroll_into_view",
      "container": {
        "kind": "test_id",
        "id": "ui-gallery-content-scroll"
      },
      "target": {
        "kind": "test_id",
        "id": "ui-gallery-select-diag-surface"
      },
      "delta_y": -180.0,
      "require_fully_within_window": true,
      "padding_px": 24.0,
      "timeout_frames": 1200
    },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": {
          "kind": "test_id",
          "id": "ui-gallery-select-trigger"
        }
      },
      "timeout_frames": 600
    },
    {
      "type": "capture_screenshot",
      "label": "ui-gallery-select-trigger-closed-zinc-dark"
    },
    {
      "type": "move_pointer",
      "target": {
        "kind": "test_id",
        "id": "ui-gallery-select-trigger"
      }
    },
    {
      "type": "wait_frames",
      "n": 2
    },
    {
      "type": "capture_screenshot",
      "label": "ui-gallery-select-trigger-hover-zinc-dark"
    },
    {
      "type": "capture_bundle",
      "label": "ui-gallery-select-trigger-hover-zinc-dark"
    }
  ]
}
