{
  "schema_version": 2,
  "meta": {
    "name": "ui-gallery-select-label-click-focus",
    "required_capabilities": ["diag.script_v2"],
    "tags": ["ui_gallery", "shadcn", "select", "label", "focus", "a11y"],
    "target_hints": [
      "Navigates to the Select page.",
      "Scrolls the Label Association example into view.",
      "Clicks the FieldLabel and verifies focus moves to the Select trigger."
    ]
  },
  "steps": [
    { "type": "reset_diagnostics" },
    {
      "type": "wait_until",
      "predicate": { "kind": "exists", "target": { "kind": "test_id", "id": "ui-gallery-nav-search" } },
      "timeout_frames": 600
    },
    {
      "type": "wait_until",
      "predicate": { "kind": "exists", "target": { "kind": "test_id", "id": "ui-gallery-nav-scroll" } },
      "timeout_frames": 600
    },
    { "type": "press_key", "key": "escape" },
    { "type": "wait_frames", "n": 2 },

    { "type": "click", "target": { "kind": "test_id", "id": "ui-gallery-nav-search" } },
    { "type": "press_key", "key": "a", "modifiers": { "ctrl": true } },
    { "type": "press_key", "key": "backspace" },
    { "type": "type_text", "text": "select" },
    { "type": "wait_frames", "n": 2 },

    {
      "type": "wait_until",
      "predicate": { "kind": "exists", "target": { "kind": "test_id", "id": "ui-gallery-nav-select" } },
      "timeout_frames": 600
    },
    {
      "type": "scroll_into_view",
      "container": { "kind": "test_id", "id": "ui-gallery-nav-scroll" },
      "target": { "kind": "test_id", "id": "ui-gallery-nav-select" },
      "delta_y": -240.0,
      "padding_px": 24.0,
      "timeout_frames": 600
    },
    { "type": "click_stable", "target": { "kind": "test_id", "id": "ui-gallery-nav-select" } },

    {
      "type": "wait_until",
      "predicate": { "kind": "exists", "target": { "kind": "test_id", "id": "ui-gallery-select-label-content" } },
      "timeout_frames": 600
    },
    {
      "type": "scroll_into_view",
      "container": { "kind": "test_id", "id": "ui-gallery-content-viewport" },
      "target": { "kind": "test_id", "id": "ui-gallery-select-label-content" },
      "delta_y": -240.0,
      "require_fully_within_window": true,
      "padding_px": 24.0,
      "timeout_frames": 1200
    },
    {
      "type": "wait_until",
      "predicate": { "kind": "exists", "target": { "kind": "test_id", "id": "ui-gallery-select-label-label" } },
      "timeout_frames": 600
    },
    {
      "type": "wait_until",
      "predicate": { "kind": "exists", "target": { "kind": "test_id", "id": "ui-gallery-select-label-trigger.chrome" } },
      "timeout_frames": 600
    },

    { "type": "click_stable", "target": { "kind": "test_id", "id": "ui-gallery-select-label-label" } },
    {
      "type": "wait_until",
      "predicate": { "kind": "not_exists", "target": { "kind": "test_id", "id": "select-scroll-viewport" } },
      "timeout_frames": 240
    },
    { "type": "wait_frames", "n": 1 },
    { "type": "press_key", "key": "enter" },
    {
      "type": "wait_until",
      "predicate": { "kind": "exists", "target": { "kind": "test_id", "id": "select-scroll-viewport" } },
      "timeout_frames": 240
    },

    { "type": "capture_bundle", "label": "ui-gallery-select-label-click-focus" }
  ]
}
