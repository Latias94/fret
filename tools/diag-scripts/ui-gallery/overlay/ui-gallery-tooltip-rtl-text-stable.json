{
  "meta": {
    "required_capabilities": ["diag.script_v2"]
  },
  "schema_version": 2,
  "steps": [
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-nav-search" }
      },
      "timeout_frames": 600
    },
    {
      "type": "wait_until",
      "predicate": { "kind": "text_font_stack_key_stable", "stable_frames": 30 },
      "timeout_frames": 1200
    },

    { "type": "press_key", "key": "escape" },
    { "type": "wait_frames", "n": 2 },

    {
      "type": "click_stable",
      "target": { "kind": "test_id", "id": "ui-gallery-nav-search" },
      "button": "left",
      "stable_frames": 10,
      "max_move_px": 0.5,
      "timeout_frames": 600
    },
    { "type": "press_key", "key": "a", "modifiers": { "ctrl": true } },
    { "type": "press_key", "key": "backspace" },
    { "type": "type_text", "text": "tooltip" },
    { "type": "wait_frames", "n": 2 },

    {
      "type": "wait_until",
      "predicate": {
        "kind": "bounds_within_window",
        "target": { "kind": "test_id", "id": "ui-gallery-nav-tooltip" },
        "padding_px": 8.0,
        "eps_px": 1.0
      },
      "timeout_frames": 600
    },
    {
      "type": "click_stable",
      "target": { "kind": "test_id", "id": "ui-gallery-nav-tooltip" },
      "button": "left",
      "stable_frames": 10,
      "max_move_px": 0.5,
      "timeout_frames": 600
    },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-page-tooltip" }
      },
      "timeout_frames": 600
    },

    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": {
          "kind": "test_id",
          "id": "ui-gallery-tooltip-rtl-top-trigger"
        }
      },
      "timeout_frames": 600
    },
    {
      "type": "scroll_into_view",
      "container": { "kind": "test_id", "id": "ui-gallery-content-scroll" },
      "target": { "kind": "test_id", "id": "ui-gallery-tooltip-rtl-top-trigger" },
      "delta_y": 240.0,
      "require_fully_within_window": true,
      "padding_px": 12.0,
      "timeout_frames": 1200
    },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "bounds_within_window",
        "target": { "kind": "test_id", "id": "ui-gallery-tooltip-rtl-top-trigger" },
        "padding_px": 8.0,
        "eps_px": 1.0
      },
      "timeout_frames": 600
    },
    {
      "type": "move_pointer",
      "target": { "kind": "test_id", "id": "ui-gallery-tooltip-rtl-top-trigger" }
    },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-tooltip-rtl-top-panel" }
      },
      "timeout_frames": 600
    },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-tooltip-rtl-top-text" }
      },
      "timeout_frames": 600
    },
    {
      "type": "wait_bounds_stable",
      "target": { "kind": "test_id", "id": "ui-gallery-tooltip-rtl-top-panel" },
      "stable_frames": 30,
      "max_move_px": 0.75,
      "timeout_frames": 1200
    },
    {
      "type": "wait_bounds_stable",
      "target": { "kind": "test_id", "id": "ui-gallery-tooltip-rtl-top-text" },
      "stable_frames": 30,
      "max_move_px": 0.75,
      "timeout_frames": 1200
    },

    {
      "type": "capture_bundle",
      "label": "ui-gallery-tooltip-rtl-text-stable"
    }
  ]
}
