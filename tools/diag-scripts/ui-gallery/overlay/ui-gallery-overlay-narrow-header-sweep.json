{
  "schema_version": 2,
  "meta": {
    "name": "ui-gallery-overlay-narrow-header-sweep",
    "tags": ["ui-gallery", "overlay", "narrow", "wrap", "header"],
    "required_capabilities": ["diag.script_v2", "diag.screenshot_png"],
    "target_hints": [
      "Navigates to Popover, Sheet, Drawer, and Alert Dialog docs pages in a narrow window.",
      "Opens the default demo for each overlay family.",
      "Captures screenshots and bounded bundles so header/description clipping is easy to review."
    ]
  },
  "steps": [
    { "type": "reset_diagnostics" },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-nav-search" }
      },
      "timeout_frames": 600
    },
    { "type": "set_window_inner_size", "width_px": 420.0, "height_px": 760.0 },
    { "type": "press_key", "key": "escape" },
    { "type": "wait_frames", "n": 6 },

    {
      "type": "type_text_into",
      "target": { "kind": "test_id", "id": "ui-gallery-nav-search" },
      "text": "popover",
      "clear_before_type": true,
      "timeout_frames": 600
    },
    { "type": "wait_frames", "n": 2 },
    {
      "type": "ensure_visible",
      "target": { "kind": "test_id", "id": "ui-gallery-nav-popover" },
      "within_window": true,
      "padding_px": 8.0,
      "timeout_frames": 600
    },
    { "type": "click_stable", "target": { "kind": "test_id", "id": "ui-gallery-nav-popover" } },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-page-popover" }
      },
      "timeout_frames": 600
    },
    {
      "type": "scroll_into_view",
      "container": { "kind": "test_id", "id": "ui-gallery-content-scroll" },
      "target": { "kind": "test_id", "id": "ui-gallery-popover-demo-trigger" },
      "delta_y": -120.0,
      "require_fully_within_container": true,
      "require_fully_within_window": true,
      "padding_px": 16.0,
      "timeout_frames": 600
    },
    { "type": "wait_frames", "n": 2 },
    { "type": "click_stable", "target": { "kind": "test_id", "id": "ui-gallery-popover-demo-trigger" } },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-popover-demo-panel" }
      },
      "timeout_frames": 600
    },
    {
      "type": "assert",
      "predicate": {
        "kind": "bounds_within_window",
        "target": { "kind": "test_id", "id": "ui-gallery-popover-demo-panel" },
        "padding_px": 0.0,
        "eps_px": 1.0
      }
    },
    { "type": "capture_screenshot", "label": "ui-gallery-overlay-narrow-sweep.popover" },
    { "type": "capture_bundle", "label": "ui-gallery-overlay-narrow-sweep.popover" },
    { "type": "press_key", "key": "escape" },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "not_exists",
        "target": { "kind": "test_id", "id": "ui-gallery-popover-demo-panel" }
      },
      "timeout_frames": 240
    },

    {
      "type": "type_text_into",
      "target": { "kind": "test_id", "id": "ui-gallery-nav-search" },
      "text": "sheet",
      "clear_before_type": true,
      "timeout_frames": 600
    },
    { "type": "wait_frames", "n": 2 },
    {
      "type": "ensure_visible",
      "target": { "kind": "test_id", "id": "ui-gallery-nav-sheet" },
      "within_window": true,
      "padding_px": 8.0,
      "timeout_frames": 600
    },
    { "type": "click_stable", "target": { "kind": "test_id", "id": "ui-gallery-nav-sheet" } },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-page-sheet" }
      },
      "timeout_frames": 600
    },
    {
      "type": "scroll_into_view",
      "container": { "kind": "test_id", "id": "ui-gallery-content-scroll" },
      "target": { "kind": "test_id", "id": "ui-gallery-sheet-demo" },
      "delta_y": -120.0,
      "require_fully_within_container": true,
      "require_fully_within_window": true,
      "padding_px": 16.0,
      "timeout_frames": 600
    },
    { "type": "wait_frames", "n": 2 },
    { "type": "click_stable", "target": { "kind": "test_id", "id": "ui-gallery-sheet-demo" } },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-sheet-demo-panel" }
      },
      "timeout_frames": 600
    },
    { "type": "wait_frames", "n": 40 },
    {
      "type": "assert",
      "predicate": {
        "kind": "bounds_within_window",
        "target": { "kind": "test_id", "id": "ui-gallery-sheet-demo-panel" },
        "padding_px": 0.0,
        "eps_px": 4.0
      }
    },
    { "type": "capture_screenshot", "label": "ui-gallery-overlay-narrow-sweep.sheet" },
    { "type": "capture_bundle", "label": "ui-gallery-overlay-narrow-sweep.sheet" },
    { "type": "press_key", "key": "escape" },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "not_exists",
        "target": { "kind": "test_id", "id": "ui-gallery-sheet-demo-panel" }
      },
      "timeout_frames": 240
    },

    {
      "type": "type_text_into",
      "target": { "kind": "test_id", "id": "ui-gallery-nav-search" },
      "text": "drawer",
      "clear_before_type": true,
      "timeout_frames": 600
    },
    { "type": "wait_frames", "n": 2 },
    {
      "type": "ensure_visible",
      "target": { "kind": "test_id", "id": "ui-gallery-nav-drawer" },
      "within_window": true,
      "padding_px": 8.0,
      "timeout_frames": 600
    },
    { "type": "click_stable", "target": { "kind": "test_id", "id": "ui-gallery-nav-drawer" } },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-page-drawer" }
      },
      "timeout_frames": 600
    },
    {
      "type": "scroll_into_view",
      "container": { "kind": "test_id", "id": "ui-gallery-content-scroll" },
      "target": { "kind": "test_id", "id": "ui-gallery-drawer-demo-trigger" },
      "delta_y": -120.0,
      "require_fully_within_container": true,
      "require_fully_within_window": true,
      "padding_px": 16.0,
      "timeout_frames": 600
    },
    { "type": "wait_frames", "n": 2 },
    { "type": "click_stable", "target": { "kind": "test_id", "id": "ui-gallery-drawer-demo-trigger" } },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-drawer-demo-content" }
      },
      "timeout_frames": 600
    },
    { "type": "wait_frames", "n": 40 },
    {
      "type": "assert",
      "predicate": {
        "kind": "bounds_within_window",
        "target": { "kind": "test_id", "id": "ui-gallery-drawer-demo-content" },
        "padding_px": 0.0,
        "eps_px": 4.0
      }
    },
    { "type": "capture_screenshot", "label": "ui-gallery-overlay-narrow-sweep.drawer" },
    { "type": "capture_bundle", "label": "ui-gallery-overlay-narrow-sweep.drawer" },
    { "type": "press_key", "key": "escape" },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "not_exists",
        "target": { "kind": "test_id", "id": "ui-gallery-drawer-demo-content" }
      },
      "timeout_frames": 240
    },

    {
      "type": "type_text_into",
      "target": { "kind": "test_id", "id": "ui-gallery-nav-search" },
      "text": "alert dialog",
      "clear_before_type": true,
      "timeout_frames": 600
    },
    { "type": "wait_frames", "n": 2 },
    {
      "type": "ensure_visible",
      "target": { "kind": "test_id", "id": "ui-gallery-nav-alert-dialog" },
      "within_window": true,
      "padding_px": 8.0,
      "timeout_frames": 600
    },
    { "type": "click_stable", "target": { "kind": "test_id", "id": "ui-gallery-nav-alert-dialog" } },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-page-alert-dialog" }
      },
      "timeout_frames": 600
    },
    {
      "type": "scroll_into_view",
      "container": { "kind": "test_id", "id": "ui-gallery-content-scroll" },
      "target": { "kind": "test_id", "id": "ui-gallery-alert-dialog-demo-trigger" },
      "delta_y": -120.0,
      "require_fully_within_container": true,
      "require_fully_within_window": true,
      "padding_px": 16.0,
      "timeout_frames": 600
    },
    { "type": "wait_frames", "n": 2 },
    { "type": "click_stable", "target": { "kind": "test_id", "id": "ui-gallery-alert-dialog-demo-trigger" } },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-alert-dialog-demo-content" }
      },
      "timeout_frames": 600
    },
    { "type": "wait_frames", "n": 40 },
    {
      "type": "assert",
      "predicate": {
        "kind": "bounds_within_window",
        "target": { "kind": "test_id", "id": "ui-gallery-alert-dialog-demo-content" },
        "padding_px": 8.0,
        "eps_px": 1.0
      }
    },
    { "type": "capture_screenshot", "label": "ui-gallery-overlay-narrow-sweep.alert-dialog" },
    { "type": "capture_bundle", "label": "ui-gallery-overlay-narrow-sweep.alert-dialog" },
    { "type": "click_stable", "target": { "kind": "test_id", "id": "ui-gallery-alert-dialog-demo-cancel" } },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "not_exists",
        "target": { "kind": "test_id", "id": "ui-gallery-alert-dialog-demo-content" }
      },
      "timeout_frames": 240
    }
  ]
}
