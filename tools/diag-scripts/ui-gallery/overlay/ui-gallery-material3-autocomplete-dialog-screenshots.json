{
  "schema_version": 2,
  "steps": [
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-page-material3-autocomplete" }
      },
      "timeout_frames": 600
    },
    { "type": "wait_frames", "n": 30 },

    { "type": "capture_bundle", "label": "ui-gallery-material3-autocomplete-idle" },
    { "type": "capture_screenshot", "label": "ui-gallery-material3-autocomplete-idle" },

    {
      "type": "ensure_visible",
      "target": { "kind": "test_id", "id": "ui-gallery-material3-autocomplete" },
      "within_window": true,
      "padding_px": 8.0,
      "timeout_frames": 600
    },
    { "type": "click", "target": { "kind": "test_id", "id": "ui-gallery-material3-autocomplete" } },
    { "type": "press_key", "key": "arrow_down" },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-material3-autocomplete-listbox" }
      },
      "timeout_frames": 600
    },
    { "type": "wait_frames", "n": 12 },
    {
      "type": "assert",
      "predicate": {
        "kind": "bounds_within_window",
        "target": { "kind": "test_id", "id": "ui-gallery-material3-autocomplete-listbox" },
        "padding_px": 8.0
      }
    },
    { "type": "capture_bundle", "label": "ui-gallery-material3-autocomplete-open" },
    { "type": "capture_screenshot", "label": "ui-gallery-material3-autocomplete-open" },
    { "type": "press_key", "key": "escape" },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "not_exists",
        "target": { "kind": "test_id", "id": "ui-gallery-material3-autocomplete-listbox" }
      },
      "timeout_frames": 600
    },

    {
      "type": "scroll_into_view",
      "container": { "kind": "test_id", "id": "ui-gallery-content-viewport" },
      "target": { "kind": "test_id", "id": "ui-gallery-material3-autocomplete-dialog-open" },
      "delta_y": -240.0,
      "require_fully_within_window": true,
      "padding_px": 16.0,
      "timeout_frames": 600
    },
    { "type": "click", "target": { "kind": "test_id", "id": "ui-gallery-material3-autocomplete-dialog-open" } },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": {
          "kind": "test_id",
          "id": "ui-gallery-material3-autocomplete-dialog-scrim"
        }
      },
      "timeout_frames": 600
    },
    { "type": "wait_frames", "n": 18 },

    {
      "type": "ensure_visible",
      "target": {
        "kind": "test_id",
        "id": "ui-gallery-material3-autocomplete-dialog-field-bottom"
      },
      "within_window": true,
      "padding_px": 8.0,
      "timeout_frames": 600
    },
    {
      "type": "click",
      "target": {
        "kind": "test_id",
        "id": "ui-gallery-material3-autocomplete-dialog-field-bottom"
      }
    },
    { "type": "press_key", "key": "arrow_down" },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": {
          "kind": "test_id",
          "id": "ui-gallery-material3-autocomplete-dialog-field-bottom-listbox"
        }
      },
      "timeout_frames": 600
    },
    { "type": "wait_frames", "n": 12 },
    {
      "type": "assert",
      "predicate": {
        "kind": "bounds_within_window",
        "target": {
          "kind": "test_id",
          "id": "ui-gallery-material3-autocomplete-dialog-field-bottom-listbox"
        },
        "padding_px": 8.0
      }
    },
    { "type": "capture_bundle", "label": "ui-gallery-material3-autocomplete-dialog-open-bottom" },
    { "type": "capture_screenshot", "label": "ui-gallery-material3-autocomplete-dialog-open-bottom" },
    { "type": "press_key", "key": "escape" },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "not_exists",
        "target": {
          "kind": "test_id",
          "id": "ui-gallery-material3-autocomplete-dialog-field-bottom-listbox"
        }
      },
      "timeout_frames": 600
    },
    { "type": "press_key", "key": "escape" },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "not_exists",
        "target": {
          "kind": "test_id",
          "id": "ui-gallery-material3-autocomplete-dialog-scrim"
        }
      },
      "timeout_frames": 600
    }
  ]
}
