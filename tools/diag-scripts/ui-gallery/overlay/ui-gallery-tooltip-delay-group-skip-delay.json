{
  "schema_version": 2,
  "meta": {
    "name": "ui-gallery-tooltip-delay-group-skip-delay",
    "required_capabilities": ["diag.script_v2"]
  },
  "steps": [
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-nav-search" }
      },
      "timeout_frames": 240
    },
    { "type": "press_key", "key": "escape" },
    { "type": "wait_frames", "n": 2 },

    { "type": "click", "target": { "kind": "test_id", "id": "ui-gallery-nav-search" } },
    { "type": "press_key", "key": "a", "modifiers": { "ctrl": true } },
    { "type": "press_key", "key": "backspace" },
    { "type": "type_text", "text": "overlay" },
    { "type": "wait_frames", "n": 2 },
    { "type": "click", "target": { "kind": "test_id", "id": "ui-gallery-nav-overlay" } },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-page-overlay" }
      },
      "timeout_frames": 240
    },
    { "type": "wait_frames", "n": 10 },

    {
      "type": "move_pointer",
      "target": { "kind": "test_id", "id": "ui-gallery-overlay-underlay" }
    },
    { "type": "wait_frames", "n": 2 },

    {
      "type": "move_pointer",
      "target": { "kind": "test_id", "id": "ui-gallery-tooltip-trigger" }
    },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-tooltip-content" }
      },
      "timeout_frames": 240
    },

    {
      "type": "move_pointer",
      "target": { "kind": "test_id", "id": "ui-gallery-overlay-underlay" }
    },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "not_exists",
        "target": { "kind": "test_id", "id": "ui-gallery-tooltip-content" }
      },
      "timeout_frames": 240
    },

    {
      "type": "move_pointer",
      "target": { "kind": "test_id", "id": "ui-gallery-tooltip-skip-trigger" }
    },
    { "type": "wait_frames", "n": 2 },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-tooltip-skip-content" }
      },
      "timeout_frames": 6
    },

    { "type": "capture_bundle", "label": "ui-gallery-tooltip-delay-group-skip-delay" }
  ]
}
