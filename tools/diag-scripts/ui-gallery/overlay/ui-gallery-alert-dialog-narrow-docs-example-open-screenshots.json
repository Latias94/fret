{
  "schema_version": 2,
  "meta": {
    "name": "ui-gallery-alert-dialog-narrow-docs-example-open-screenshots",
    "required_capabilities": ["diag.script_v2", "diag.screenshot_png"]
  },
  "steps": [
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-nav-search" }
      },
      "timeout_frames": 600
    },
    { "type": "press_key", "key": "escape" },
    { "type": "wait_frames", "n": 2 },
    { "type": "set_window_inner_size", "width_px": 420.0, "height_px": 760.0 },
    { "type": "wait_frames", "n": 8 },
    {
      "type": "type_text_into",
      "target": { "kind": "test_id", "id": "ui-gallery-nav-search" },
      "text": "alert dialog",
      "clear_before_type": true,
      "timeout_frames": 600
    },
    { "type": "wait_frames", "n": 4 },
    {
      "type": "ensure_visible",
      "target": { "kind": "test_id", "id": "ui-gallery-nav-alert-dialog" },
      "within_window": true,
      "padding_px": 8.0,
      "timeout_frames": 600
    },
    {
      "type": "click_stable",
      "target": { "kind": "test_id", "id": "ui-gallery-nav-alert-dialog" }
    },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-page-alert-dialog" }
      },
      "timeout_frames": 600
    },
    { "type": "wait_frames", "n": 20 },

    {
      "type": "scroll_into_view",
      "container": { "kind": "test_id", "id": "ui-gallery-content-scroll" },
      "target": { "kind": "test_id", "id": "ui-gallery-alert-dialog-small-media-trigger" },
      "delta_y": -140.0,
      "require_fully_within_container": true,
      "require_fully_within_window": true,
      "padding_px": 16.0,
      "timeout_frames": 600
    },
    { "type": "wait_frames", "n": 2 },
    {
      "type": "click_stable",
      "target": { "kind": "test_id", "id": "ui-gallery-alert-dialog-small-media-trigger" }
    },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": {
          "kind": "test_id",
          "id": "ui-gallery-alert-dialog-small-media-content"
        }
      },
      "timeout_frames": 600
    },
    {
      "type": "wait_bounds_stable",
      "target": {
        "kind": "test_id",
        "id": "ui-gallery-alert-dialog-small-media-content"
      },
      "stable_frames": 6,
      "max_move_px": 1.0,
      "timeout_frames": 600
    },
    {
      "type": "assert",
      "predicate": {
        "kind": "bounds_within_window",
        "target": {
          "kind": "test_id",
          "id": "ui-gallery-alert-dialog-small-media-content"
        },
        "padding_px": 8.0,
        "eps_px": 1.0
      }
    },
    {
      "type": "assert",
      "predicate": {
        "kind": "bounds_within_window",
        "target": {
          "kind": "test_id",
          "id": "ui-gallery-alert-dialog-small-media-title"
        },
        "padding_px": 8.0,
        "eps_px": 1.0
      }
    },
    {
      "type": "assert",
      "predicate": {
        "kind": "bounds_within_window",
        "target": {
          "kind": "test_id",
          "id": "ui-gallery-alert-dialog-small-media-description"
        },
        "padding_px": 8.0,
        "eps_px": 1.0
      }
    },
    {
      "type": "capture_screenshot",
      "label": "ui-gallery-alert-dialog-small-media-open-narrow"
    },
    {
      "type": "capture_bundle",
      "label": "ui-gallery-alert-dialog-small-media-open-narrow"
    },
    { "type": "press_key", "key": "escape" },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "not_exists",
        "target": {
          "kind": "test_id",
          "id": "ui-gallery-alert-dialog-small-media-content"
        }
      },
      "timeout_frames": 600
    },
    { "type": "wait_frames", "n": 4 },

    {
      "type": "scroll_into_view",
      "container": { "kind": "test_id", "id": "ui-gallery-content-scroll" },
      "target": { "kind": "test_id", "id": "ui-gallery-alert-dialog-rtl-trigger" },
      "delta_y": -120.0,
      "require_fully_within_container": true,
      "require_fully_within_window": true,
      "padding_px": 16.0,
      "timeout_frames": 600
    },
    { "type": "wait_frames", "n": 2 },
    {
      "type": "click_stable",
      "target": { "kind": "test_id", "id": "ui-gallery-alert-dialog-rtl-small-trigger" }
    },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": {
          "kind": "test_id",
          "id": "ui-gallery-alert-dialog-rtl-small-content"
        }
      },
      "timeout_frames": 600
    },
    {
      "type": "wait_bounds_stable",
      "target": {
        "kind": "test_id",
        "id": "ui-gallery-alert-dialog-rtl-small-content"
      },
      "stable_frames": 6,
      "max_move_px": 1.0,
      "timeout_frames": 600
    },
    {
      "type": "assert",
      "predicate": {
        "kind": "bounds_within_window",
        "target": {
          "kind": "test_id",
          "id": "ui-gallery-alert-dialog-rtl-small-content"
        },
        "padding_px": 8.0,
        "eps_px": 1.0
      }
    },
    {
      "type": "assert",
      "predicate": {
        "kind": "bounds_within_window",
        "target": {
          "kind": "test_id",
          "id": "ui-gallery-alert-dialog-rtl-small-title"
        },
        "padding_px": 8.0,
        "eps_px": 1.0
      }
    },
    {
      "type": "assert",
      "predicate": {
        "kind": "bounds_within_window",
        "target": {
          "kind": "test_id",
          "id": "ui-gallery-alert-dialog-rtl-small-description"
        },
        "padding_px": 8.0,
        "eps_px": 1.0
      }
    },
    {
      "type": "capture_screenshot",
      "label": "ui-gallery-alert-dialog-rtl-small-open-narrow"
    },
    {
      "type": "capture_bundle",
      "label": "ui-gallery-alert-dialog-rtl-small-open-narrow"
    }
  ]
}
