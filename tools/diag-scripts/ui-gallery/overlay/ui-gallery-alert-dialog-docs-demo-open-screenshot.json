{
  "schema_version": 2,
  "meta": {
    "name": "ui-gallery-alert-dialog-docs-demo-open-screenshot",
    "required_capabilities": ["diag.script_v2", "diag.screenshot_png"]
  },
  "steps": [
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-nav-search" }
      },
      "timeout_frames": 600
    },
    { "type": "press_key", "key": "escape" },
    { "type": "wait_frames", "n": 2 },
    { "type": "set_window_inner_size", "width_px": 1280.0, "height_px": 900.0 },
    { "type": "wait_frames", "n": 8 },

    {
      "type": "type_text_into",
      "target": { "kind": "test_id", "id": "ui-gallery-nav-search" },
      "text": "alert dialog",
      "clear_before_type": true,
      "timeout_frames": 600
    },
    { "type": "wait_frames", "n": 4 },

    {
      "type": "ensure_visible",
      "target": { "kind": "test_id", "id": "ui-gallery-nav-alert-dialog" },
      "within_window": true,
      "padding_px": 8.0,
      "timeout_frames": 600
    },
    {
      "type": "click_stable",
      "target": { "kind": "test_id", "id": "ui-gallery-nav-alert-dialog" }
    },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-page-alert-dialog" }
      },
      "timeout_frames": 600
    },
    { "type": "wait_frames", "n": 20 },

    {
      "type": "click_stable",
      "target": { "kind": "test_id", "id": "ui-gallery-alert-dialog-demo-trigger" }
    },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-alert-dialog-demo-content" }
      },
      "timeout_frames": 600
    },
    { "type": "wait_frames", "n": 6 },
    {
      "type": "capture_screenshot",
      "label": "ui-gallery-alert-dialog-docs-demo-open-desktop"
    },
    {
      "type": "capture_bundle",
      "label": "ui-gallery-alert-dialog-docs-demo-open-desktop"
    }
  ]
}
