{
  "schema_version": 2,
  "meta": {
    "name": "ui-gallery-sheet-docs-smoke",
    "required_capabilities": ["diag.script_v2"]
  },
  "steps": [
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-nav-search" }
      },
      "timeout_frames": 600
    },
    { "type": "press_key", "key": "escape" },
    { "type": "wait_frames", "n": 2 },
    {
      "type": "type_text_into",
      "target": { "kind": "test_id", "id": "ui-gallery-nav-search" },
      "text": "sheet",
      "clear_before_type": true,
      "timeout_frames": 600
    },
    { "type": "wait_frames", "n": 4 },
    {
      "type": "ensure_visible",
      "target": { "kind": "test_id", "id": "ui-gallery-nav-sheet" },
      "within_window": true,
      "padding_px": 8.0,
      "timeout_frames": 600
    },
    { "type": "click_stable", "target": { "kind": "test_id", "id": "ui-gallery-nav-sheet" } },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-page-sheet" }
      },
      "timeout_frames": 600
    },
    { "type": "wait_frames", "n": 20 },
    {
      "type": "assert",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-section-usage-title" }
      }
    },
    {
      "type": "assert",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-sheet-demo-content" }
      }
    },
    {
      "type": "assert",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-sheet-side-content" }
      }
    },
    {
      "type": "assert",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-sheet-no-close-content" }
      }
    },
    {
      "type": "assert",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-sheet-rtl-content" }
      }
    },
    {
      "type": "scroll_into_view",
      "container": { "kind": "test_id", "id": "ui-gallery-content-scroll" },
      "target": { "kind": "test_id", "id": "ui-gallery-sheet-api-reference-content" },
      "delta_y": 220.0,
      "padding_px": 24.0,
      "require_fully_within_container": false,
      "require_fully_within_window": false,
      "timeout_frames": 600
    },
    {
      "type": "assert",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-sheet-api-reference-content" }
      }
    },
    {
      "type": "assert",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-sheet-parts-content" }
      }
    },
    { "type": "wait_frames", "n": 4 },
    { "type": "capture_bundle", "label": "ui-gallery-sheet-docs-smoke" }
  ]
}
