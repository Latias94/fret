{
  "schema_version": 2,
  "meta": {
    "name": "ui-gallery-dialog-demo-narrow-sweep",
    "tags": ["ui-gallery", "dialog", "narrow", "screenshots"],
    "required_capabilities": ["diag.script_v2", "diag.screenshot_png"],
    "target_hints": [
      "Navigates to the Dialog docs page in a narrow window.",
      "Opens the lead dialog demo and verifies both trigger and content stay within the window."
    ]
  },
  "steps": [
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-nav-search" }
      },
      "timeout_frames": 600
    },
    { "type": "press_key", "key": "escape" },
    { "type": "wait_frames", "n": 2 },
    { "type": "set_window_inner_size", "width_px": 420.0, "height_px": 760.0 },
    { "type": "wait_frames", "n": 8 },

    {
      "type": "type_text_into",
      "target": { "kind": "test_id", "id": "ui-gallery-nav-search" },
      "text": "dialog",
      "clear_before_type": true,
      "timeout_frames": 600
    },
    { "type": "wait_frames", "n": 4 },
    {
      "type": "ensure_visible",
      "target": { "kind": "test_id", "id": "ui-gallery-nav-dialog" },
      "within_window": true,
      "padding_px": 8.0,
      "timeout_frames": 600
    },
    {
      "type": "click_stable",
      "target": { "kind": "test_id", "id": "ui-gallery-nav-dialog" }
    },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-page-dialog" }
      },
      "timeout_frames": 600
    },
    {
      "type": "scroll_into_view",
      "container": { "kind": "test_id", "id": "ui-gallery-content-scroll" },
      "target": { "kind": "test_id", "id": "ui-gallery-dialog-demo-trigger" },
      "delta_y": -120.0,
      "require_fully_within_container": false,
      "require_fully_within_window": false,
      "padding_px": 16.0,
      "timeout_frames": 600
    },
    { "type": "wait_frames", "n": 2 },
    {
      "type": "assert",
      "predicate": {
        "kind": "bounds_within_window",
        "target": { "kind": "test_id", "id": "ui-gallery-dialog-demo-trigger" },
        "padding_px": 0.0,
        "eps_px": 1.0
      }
    },
    {
      "type": "click_stable",
      "target": { "kind": "test_id", "id": "ui-gallery-dialog-demo-trigger" }
    },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-dialog-demo-content" }
      },
      "timeout_frames": 600
    },
    { "type": "wait_frames", "n": 8 },
    {
      "type": "assert",
      "predicate": {
        "kind": "bounds_within_window",
        "target": { "kind": "test_id", "id": "ui-gallery-dialog-demo-content" },
        "padding_px": 0.0,
        "eps_px": 1.0
      }
    },
    { "type": "capture_screenshot", "label": "ui-gallery-dialog-demo-open-narrow" },
    { "type": "capture_bundle", "label": "ui-gallery-dialog-demo-open-narrow" }
  ]
}
