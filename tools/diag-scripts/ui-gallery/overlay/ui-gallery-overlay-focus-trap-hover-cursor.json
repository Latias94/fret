{
  "schema_version": 2,
  "meta": {
    "name": "ui-gallery-overlay-focus-trap-hover-cursor",
    "required_capabilities": ["diag.script_v2"],
    "tags": ["ui_gallery", "overlay", "dialog", "focus", "hover", "cursor", "gate"]
  },
  "steps": [
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-nav-scroll" }
      },
      "timeout_frames": 600
    },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-nav-search" }
      },
      "timeout_frames": 600
    },
    { "type": "press_key", "key": "escape" },
    { "type": "wait_frames", "n": 2 },

    { "type": "click", "target": { "kind": "test_id", "id": "ui-gallery-nav-search" } },
    { "type": "press_key", "key": "a", "modifiers": { "ctrl": true } },
    { "type": "press_key", "key": "backspace" },
    { "type": "type_text", "text": "overlay" },
    { "type": "wait_frames", "n": 2 },
    {
      "type": "wheel",
      "target": { "kind": "test_id", "id": "ui-gallery-nav-scroll" },
      "delta_y": 2000.0
    },
    { "type": "wait_frames", "n": 2 },
    {
      "type": "click_stable",
      "target": { "kind": "test_id", "id": "ui-gallery-nav-overlay" },
      "button": "left",
      "stable_frames": 10,
      "max_move_px": 0.5,
      "timeout_frames": 600
    },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-page-overlay" }
      },
      "timeout_frames": 600
    },
    { "type": "wait_frames", "n": 10 },

    { "type": "click", "target": { "kind": "test_id", "id": "ui-gallery-overlay-reset" } },
    { "type": "wait_frames", "n": 10 },

    {
      "type": "move_pointer",
      "target": { "kind": "test_id", "id": "ui-gallery-tooltip-trigger" }
    },
    { "type": "wait_frames", "n": 30 },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-tooltip-content" }
      },
      "timeout_frames": 600
    },
    { "type": "capture_bundle", "label": "ui-gallery-overlay-focus-trap-hover-cursor-tooltip-open" },

    {
      "type": "move_pointer",
      "target": { "kind": "test_id", "id": "ui-gallery-overlay-reset" }
    },
    { "type": "wait_frames", "n": 10 },

    {
      "type": "move_pointer",
      "target": { "kind": "test_id", "id": "ui-gallery-hovercard-trigger" }
    },
    { "type": "wait_frames", "n": 40 },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-hovercard-content" }
      },
      "timeout_frames": 600
    },
    { "type": "capture_bundle", "label": "ui-gallery-overlay-focus-trap-hover-cursor-hovercard-open" },

    {
      "type": "move_pointer",
      "target": { "kind": "test_id", "id": "ui-gallery-overlay-reset" }
    },
    { "type": "wait_frames", "n": 10 },

    {
      "type": "click_stable",
      "target": { "kind": "test_id", "id": "ui-gallery-dialog-trigger" },
      "button": "left",
      "stable_frames": 10,
      "max_move_px": 0.5,
      "timeout_frames": 600
    },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-dialog-close" }
      },
      "timeout_frames": 600
    },

    { "type": "press_key", "key": "tab" },
    {
      "type": "assert",
      "predicate": {
        "kind": "focus_is",
        "target": { "kind": "test_id", "id": "ui-gallery-dialog-confirm" }
      }
    },
    { "type": "press_key", "key": "tab" },
    {
      "type": "assert",
      "predicate": {
        "kind": "focus_is",
        "target": { "kind": "test_id", "id": "ui-gallery-dialog-close" }
      }
    },

    { "type": "capture_bundle", "label": "ui-gallery-overlay-focus-trap-hover-cursor-dialog-open" },
    { "type": "capture_screenshot", "label": "ui-gallery-overlay-focus-trap-hover-cursor-dialog-open" },

    { "type": "press_key", "key": "escape" },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "focus_is",
        "target": { "kind": "test_id", "id": "ui-gallery-dialog-trigger" }
      },
      "timeout_frames": 600
    },

    { "type": "capture_bundle", "label": "ui-gallery-overlay-focus-trap-hover-cursor-dialog-closed" }
  ]
}

