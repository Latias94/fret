{
  "schema_version": 2,
  "meta": {
    "name": "ui-gallery-sheet-docs-demo-open-screenshot",
    "required_capabilities": ["diag.script_v2", "diag.screenshot_png"]
  },
  "steps": [
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-nav-search" }
      },
      "timeout_frames": 600
    },
    { "type": "press_key", "key": "escape" },
    { "type": "wait_frames", "n": 2 },
    { "type": "set_window_inner_size", "width_px": 1280.0, "height_px": 900.0 },
    { "type": "wait_frames", "n": 8 },

    {
      "type": "type_text_into",
      "target": { "kind": "test_id", "id": "ui-gallery-nav-search" },
      "text": "sheet",
      "clear_before_type": true,
      "timeout_frames": 600
    },
    { "type": "wait_frames", "n": 4 },

    {
      "type": "ensure_visible",
      "target": { "kind": "test_id", "id": "ui-gallery-nav-sheet" },
      "within_window": true,
      "padding_px": 8.0,
      "timeout_frames": 600
    },
    {
      "type": "click_stable",
      "target": { "kind": "test_id", "id": "ui-gallery-nav-sheet" }
    },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-page-sheet" }
      },
      "timeout_frames": 600
    },
    { "type": "wait_frames", "n": 20 },

    {
      "type": "scroll_into_view",
      "container": { "kind": "test_id", "id": "ui-gallery-content-scroll" },
      "target": { "kind": "test_id", "id": "ui-gallery-sheet-demo-trigger" },
      "delta_y": -120.0,
      "require_fully_within_container": true,
      "require_fully_within_window": true,
      "padding_px": 16.0,
      "timeout_frames": 600
    },
    { "type": "wait_frames", "n": 2 },
    {
      "type": "click_stable",
      "target": { "kind": "test_id", "id": "ui-gallery-sheet-demo-trigger" }
    },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-sheet-demo-content" }
      },
      "timeout_frames": 600
    },
    { "type": "wait_frames", "n": 6 },
    {
      "type": "capture_screenshot",
      "label": "ui-gallery-sheet-docs-demo-open-desktop"
    },
    {
      "type": "capture_bundle",
      "label": "ui-gallery-sheet-docs-demo-open-desktop"
    }
  ]
}
