{
  "schema_version": 2,
  "meta": {
    "name": "ui-gallery-alert-dialog-focus-trap-tab-cycle",
    "required_capabilities": ["diag.script_v2"],
    "tags": ["ui_gallery", "shadcn", "alert_dialog", "focus", "keyboard", "trap"]
  },
  "steps": [
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-nav-search" }
      },
      "timeout_frames": 240
    },
    {
      "type": "type_text_into",
      "target": { "kind": "test_id", "id": "ui-gallery-nav-search" },
      "text": "alert dialog",
      "clear_before_type": true,
      "timeout_frames": 600
    },
    { "type": "wait_frames", "n": 4 },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-nav-alert-dialog" }
      },
      "timeout_frames": 600
    },
    {
      "type": "ensure_visible",
      "target": { "kind": "test_id", "id": "ui-gallery-nav-alert-dialog" },
      "within_window": true,
      "padding_px": 8.0,
      "timeout_frames": 600
    },
    {
      "type": "click_stable",
      "target": { "kind": "test_id", "id": "ui-gallery-nav-alert-dialog" }
    },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-page-alert-dialog" }
      },
      "timeout_frames": 600
    },
    { "type": "wait_frames", "n": 20 },

    {
      "type": "click_stable",
      "target": { "kind": "test_id", "id": "ui-gallery-alert-dialog-demo-trigger" }
    },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-alert-dialog-demo-content" }
      },
      "timeout_frames": 600
    },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "focused_descendant_is",
        "scope": { "kind": "test_id", "id": "ui-gallery-alert-dialog-demo-content" },
        "target": { "kind": "test_id", "id": "ui-gallery-alert-dialog-demo-cancel" }
      },
      "timeout_frames": 60
    },

    { "type": "press_key", "key": "tab" },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "focused_descendant_is",
        "scope": { "kind": "test_id", "id": "ui-gallery-alert-dialog-demo-content" },
        "target": { "kind": "test_id", "id": "ui-gallery-alert-dialog-demo-action" }
      },
      "timeout_frames": 60
    },
    { "type": "press_key", "key": "tab" },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "focused_descendant_is",
        "scope": { "kind": "test_id", "id": "ui-gallery-alert-dialog-demo-content" },
        "target": { "kind": "test_id", "id": "ui-gallery-alert-dialog-demo-cancel" }
      },
      "timeout_frames": 60
    },
    { "type": "press_key", "key": "tab", "modifiers": { "shift": true } },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "focused_descendant_is",
        "scope": { "kind": "test_id", "id": "ui-gallery-alert-dialog-demo-content" },
        "target": { "kind": "test_id", "id": "ui-gallery-alert-dialog-demo-action" }
      },
      "timeout_frames": 60
    },

    { "type": "press_key", "key": "escape" },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "not_exists",
        "target": { "kind": "test_id", "id": "ui-gallery-alert-dialog-demo-content" }
      },
      "timeout_frames": 600
    },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "focus_is",
        "target": { "kind": "test_id", "id": "ui-gallery-alert-dialog-demo-trigger" }
      },
      "timeout_frames": 120
    },

    { "type": "capture_bundle", "label": "ui-gallery-alert-dialog-focus-trap-tab-cycle" }
  ]
}
