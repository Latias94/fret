{
  "schema_version": 2,
  "meta": {
    "name": "ui-gallery-hovercard-open",
    "required_capabilities": ["diag.script_v2"],
    "tags": ["ui_gallery", "overlay", "hovercard", "hover", "gate"]
  },
  "steps": [
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-nav-scroll" }
      },
      "timeout_frames": 600
    },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-nav-search" }
      },
      "timeout_frames": 600
    },

    { "type": "press_key", "key": "escape" },
    { "type": "wait_frames", "n": 2 },

    { "type": "click", "target": { "kind": "test_id", "id": "ui-gallery-nav-search" } },
    { "type": "press_key", "key": "a", "modifiers": { "ctrl": true } },
    { "type": "press_key", "key": "backspace" },
    { "type": "type_text", "text": "overlay" },
    { "type": "wait_frames", "n": 2 },

    {
      "type": "click_stable",
      "target": { "kind": "test_id", "id": "ui-gallery-nav-overlay" },
      "button": "left",
      "stable_frames": 10,
      "max_move_px": 0.5,
      "timeout_frames": 600
    },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-page-overlay" }
      },
      "timeout_frames": 600
    },
    { "type": "wait_frames", "n": 10 },

    { "type": "click", "target": { "kind": "test_id", "id": "ui-gallery-overlay-reset" } },
    { "type": "wait_frames", "n": 10 },

    {
      "type": "move_pointer",
      "target": { "kind": "test_id", "id": "ui-gallery-overlay-underlay" }
    },
    { "type": "wait_frames", "n": 5 },
    {
      "type": "move_pointer",
      "target": { "kind": "test_id", "id": "ui-gallery-hovercard-trigger" }
    },
    { "type": "wait_frames", "n": 30 },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-hovercard-content" }
      },
      "timeout_frames": 600
    },

    { "type": "capture_bundle", "label": "ui-gallery-hovercard-open" }
  ]
}

