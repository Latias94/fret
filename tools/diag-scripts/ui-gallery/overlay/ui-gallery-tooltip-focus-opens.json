{
  "schema_version": 2,
  "meta": {
    "name": "ui-gallery-tooltip-focus-opens",
    "required_capabilities": [
      "diag.script_v2"
    ],
    "tags": [
      "ui_gallery",
      "shadcn",
      "tooltip",
      "keyboard",
      "focus"
    ]
  },
  "steps": [
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": {
          "kind": "test_id",
          "id": "ui-gallery-nav-search"
        }
      },
      "timeout_frames": 600
    },
    {
      "type": "press_key",
      "key": "escape"
    },
    {
      "type": "wait_frames",
      "n": 2
    },
    {
      "type": "click_stable",
      "target": {
        "kind": "test_id",
        "id": "ui-gallery-nav-search"
      },
      "button": "left",
      "stable_frames": 10,
      "max_move_px": 0.5,
      "timeout_frames": 600
    },
    {
      "type": "press_key",
      "key": "a",
      "modifiers": {
        "ctrl": true
      }
    },
    {
      "type": "press_key",
      "key": "backspace"
    },
    {
      "type": "type_text",
      "text": "tooltip"
    },
    {
      "type": "wait_frames",
      "n": 2
    },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "bounds_within_window",
        "target": {
          "kind": "test_id",
          "id": "ui-gallery-nav-tooltip"
        },
        "padding_px": 8.0,
        "eps_px": 1.0
      },
      "timeout_frames": 600
    },
    {
      "type": "click_stable",
      "target": {
        "kind": "test_id",
        "id": "ui-gallery-nav-tooltip"
      },
      "button": "left",
      "stable_frames": 10,
      "max_move_px": 0.5,
      "timeout_frames": 600
    },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": {
          "kind": "test_id",
          "id": "ui-gallery-page-tooltip"
        }
      },
      "timeout_frames": 600
    },
    {
      "type": "scroll_into_view",
      "container": {
        "kind": "test_id",
        "id": "ui-gallery-content-scroll"
      },
      "target": {
        "kind": "test_id",
        "id": "ui-gallery-tooltip-focus-start"
      },
      "delta_y": -240.0,
      "require_fully_within_window": true,
      "padding_px": 12.0,
      "timeout_frames": 1200,
      "require_fully_within_container": true
    },
    {
      "type": "click_stable",
      "target": {
        "kind": "test_id",
        "id": "ui-gallery-tooltip-focus-start"
      },
      "button": "left",
      "stable_frames": 10,
      "max_move_px": 0.5,
      "timeout_frames": 600
    },
    {
      "type": "press_key",
      "key": "tab"
    },
    {
      "type": "assert",
      "predicate": {
        "kind": "focus_is",
        "target": {
          "kind": "test_id",
          "id": "ui-gallery-tooltip-focus-trigger"
        }
      }
    },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": {
          "kind": "test_id",
          "id": "ui-gallery-tooltip-focus-panel"
        }
      },
      "timeout_frames": 600
    },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": {
          "kind": "test_id",
          "id": "ui-gallery-tooltip-focus-arrow"
        }
      },
      "timeout_frames": 600
    },
    {
      "type": "wait_bounds_stable",
      "target": {
        "kind": "test_id",
        "id": "ui-gallery-tooltip-focus-panel"
      },
      "stable_frames": 30,
      "max_move_px": 0.75,
      "timeout_frames": 1200
    },
    {
      "type": "capture_bundle",
      "label": "ui-gallery-tooltip-focus-opens"
    }
  ]
}
