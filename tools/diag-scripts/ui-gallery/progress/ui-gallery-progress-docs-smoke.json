{
  "meta": {
    "name": "ui-gallery-progress-docs-smoke",
    "required_capabilities": ["diag.script_v2", "diag.screenshot_png"]
  },
  "schema_version": 2,
  "steps": [
    { "type": "reset_diagnostics" },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-nav-search" }
      },
      "timeout_frames": 600
    },
    { "type": "press_key", "key": "escape" },
    { "type": "wait_frames", "n": 2 },
    { "type": "set_window_inner_size", "width_px": 1280.0, "height_px": 720.0 },
    { "type": "wait_frames", "n": 15 },
    {
      "type": "click",
      "button": "left",
      "target": { "kind": "test_id", "id": "ui-gallery-nav-search" }
    },
    { "type": "press_key", "key": "a", "modifiers": { "ctrl": true } },
    { "type": "press_key", "key": "backspace" },
    { "type": "type_text", "text": "progress" },
    { "type": "wait_frames", "n": 2 },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "bounds_within_window",
        "target": { "kind": "test_id", "id": "ui-gallery-nav-progress" },
        "padding_px": 8.0,
        "eps_px": 1.0
      },
      "timeout_frames": 600
    },
    {
      "type": "click",
      "button": "left",
      "target": { "kind": "test_id", "id": "ui-gallery-nav-progress" }
    },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-page-progress" }
      },
      "timeout_frames": 600
    },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": {
          "kind": "test_id",
          "id": "ui-gallery-progress-section-title-usage"
        }
      },
      "timeout_frames": 600
    },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": {
          "kind": "test_id",
          "id": "ui-gallery-progress-section-title-label"
        }
      },
      "timeout_frames": 600
    },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": {
          "kind": "test_id",
          "id": "ui-gallery-progress-section-title-controlled"
        }
      },
      "timeout_frames": 600
    },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": {
          "kind": "test_id",
          "id": "ui-gallery-progress-section-title-rtl"
        }
      },
      "timeout_frames": 600
    },
    {
      "type": "scroll_into_view",
      "container": { "kind": "test_id", "id": "ui-gallery-content-scroll" },
      "target": {
        "kind": "test_id",
        "id": "ui-gallery-progress-api-reference-content"
      },
      "delta_y": -200.0,
      "require_fully_within_container": false,
      "require_fully_within_window": false,
      "padding_px": 16.0,
      "padding_insets_px": {
        "left_px": 16.0,
        "top_px": 16.0,
        "right_px": 16.0,
        "bottom_px": 40.0
      },
      "timeout_frames": 1800
    },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": {
          "kind": "test_id",
          "id": "ui-gallery-progress-api-reference-content"
        }
      },
      "timeout_frames": 600
    },
    { "type": "capture_bundle", "label": "ui-gallery-progress-docs-smoke" },
    { "type": "capture_screenshot", "label": "ui-gallery-progress-docs-smoke" }
  ]
}
