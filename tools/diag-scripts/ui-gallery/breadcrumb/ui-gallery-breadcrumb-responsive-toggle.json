{
  "schema_version": 2,
  "meta": {
    "name": "ui-gallery-breadcrumb-responsive-toggle",
    "required_capabilities": ["diag.script_v2"],
    "tags": ["ui_gallery", "shadcn", "breadcrumb", "responsive", "drawer", "dropdown_menu"]
  },
  "steps": [
    { "type": "reset_diagnostics" },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-nav-search" }
      },
      "timeout_frames": 600
    },
    { "type": "press_key", "key": "escape" },
    { "type": "wait_frames", "n": 2 },
    { "type": "set_window_inner_size", "width_px": 1280.0, "height_px": 720.0 },
    { "type": "wait_frames", "n": 20 },

    { "type": "click", "target": { "kind": "test_id", "id": "ui-gallery-nav-search" } },
    { "type": "press_key", "key": "a", "modifiers": { "ctrl": true } },
    { "type": "press_key", "key": "backspace" },
    { "type": "type_text", "text": "breadcrumb" },
    { "type": "wait_frames", "n": 2 },
    {
      "type": "click_stable",
      "target": { "kind": "test_id", "id": "ui-gallery-nav-breadcrumb" },
      "stable_frames": 3,
      "max_move_px": 2.0,
      "timeout_frames": 600
    },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-page-breadcrumb" }
      },
      "timeout_frames": 600
    },
    { "type": "wait_frames", "n": 20 },

    {
      "type": "scroll_into_view",
      "container": { "kind": "test_id", "id": "ui-gallery-content-scroll" },
      "target": { "kind": "test_id", "id": "ui-gallery-breadcrumb-responsive" },
      "delta_y": -160.0,
      "padding_px": 16.0,
      "timeout_frames": 1800
    },
    { "type": "wait_frames", "n": 10 },

    {
      "type": "click_stable",
      "target": { "kind": "test_id", "id": "ui-gallery-breadcrumb-responsive-trigger" },
      "stable_frames": 3,
      "max_move_px": 2.0,
      "timeout_frames": 600
    },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": {
          "kind": "test_id",
          "id": "ui-gallery-breadcrumb-responsive-menu-docs"
        }
      },
      "timeout_frames": 600
    },
    { "type": "press_key", "key": "escape" },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "not_exists",
        "target": {
          "kind": "test_id",
          "id": "ui-gallery-breadcrumb-responsive-menu-docs"
        }
      },
      "timeout_frames": 600
    },

    { "type": "set_window_inner_size", "width_px": 600.0, "height_px": 720.0 },
    { "type": "wait_frames", "n": 20 },
    {
      "type": "scroll_into_view",
      "container": { "kind": "test_id", "id": "ui-gallery-content-scroll" },
      "target": {
        "kind": "test_id",
        "id": "ui-gallery-breadcrumb-responsive-trigger"
      },
      "delta_y": -160.0,
      "require_fully_within_container": true,
      "require_fully_within_window": true,
      "padding_px": 16.0,
      "timeout_frames": 600
    },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "bounds_within_window",
        "target": {
          "kind": "test_id",
          "id": "ui-gallery-breadcrumb-responsive-trigger"
        },
        "padding_px": 8.0,
        "eps_px": 1.0
      },
      "timeout_frames": 240
    },
    {
      "type": "click_stable",
      "target": { "kind": "test_id", "id": "ui-gallery-breadcrumb-responsive-trigger" },
      "stable_frames": 3,
      "max_move_px": 2.0,
      "timeout_frames": 600
    },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": {
          "kind": "test_id",
          "id": "ui-gallery-breadcrumb-responsive-drawer-content"
        }
      },
      "timeout_frames": 600
    },
    {
      "type": "click_stable",
      "target": {
        "kind": "test_id",
        "id": "ui-gallery-breadcrumb-responsive-drawer-close"
      },
      "stable_frames": 3,
      "max_move_px": 2.0,
      "timeout_frames": 600
    },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "not_exists",
        "target": {
          "kind": "test_id",
          "id": "ui-gallery-breadcrumb-responsive-drawer-content"
        }
      },
      "timeout_frames": 600
    },

    { "type": "capture_bundle", "label": "ui-gallery-breadcrumb-responsive-toggle" }
  ]
}
