{
  "schema_version": 2,
  "meta": {
    "name": "ui-gallery-skeleton-docs-smoke",
    "tags": ["ui-gallery", "shadcn", "skeleton", "docs", "smoke"],
    "required_capabilities": ["diag.script_v2"],
    "target_hints": [
      "Navigates to the Skeleton page via the left nav search.",
      "Asserts the docs-path sections first, then the Fret-only API Reference and Notes follow-up."
    ]
  },
  "steps": [
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-nav-search" }
      },
      "timeout_frames": 600
    },
    { "type": "press_key", "key": "escape" },
    { "type": "wait_frames", "n": 2 },
    {
      "type": "type_text_into",
      "target": { "kind": "test_id", "id": "ui-gallery-nav-search" },
      "text": "skeleton",
      "clear_before_type": true,
      "timeout_frames": 600
    },
    { "type": "wait_frames", "n": 4 },
    {
      "type": "ensure_visible",
      "target": { "kind": "test_id", "id": "ui-gallery-nav-skeleton" },
      "within_window": true,
      "padding_px": 8.0,
      "timeout_frames": 600
    },
    {
      "type": "click_stable",
      "target": { "kind": "test_id", "id": "ui-gallery-nav-skeleton" }
    },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-page-skeleton" }
      },
      "timeout_frames": 600
    },
    { "type": "wait_frames", "n": 20 },
    {
      "type": "assert",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-skeleton-demo-content" }
      }
    },
    {
      "type": "assert",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-skeleton-usage-content" }
      }
    },
    {
      "type": "assert",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-skeleton-avatar-content" }
      }
    },
    {
      "type": "scroll_into_view",
      "container": { "kind": "test_id", "id": "ui-gallery-content-scroll" },
      "target": { "kind": "test_id", "id": "ui-gallery-skeleton-card-content" },
      "delta_y": 180.0,
      "padding_px": 24.0,
      "require_fully_within_container": false,
      "require_fully_within_window": false,
      "timeout_frames": 600
    },
    {
      "type": "assert",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-skeleton-card-content" }
      }
    },
    {
      "type": "assert",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-skeleton-text-content" }
      }
    },
    {
      "type": "assert",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-skeleton-form-content" }
      }
    },
    {
      "type": "assert",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-skeleton-table-content" }
      }
    },
    {
      "type": "scroll_into_view",
      "container": { "kind": "test_id", "id": "ui-gallery-content-scroll" },
      "target": { "kind": "test_id", "id": "ui-gallery-skeleton-api-reference-content" },
      "delta_y": 240.0,
      "padding_px": 24.0,
      "require_fully_within_container": false,
      "require_fully_within_window": false,
      "timeout_frames": 600
    },
    {
      "type": "assert",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-skeleton-rtl-content" }
      }
    },
    {
      "type": "assert",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-skeleton-api-reference-content" }
      }
    },
    {
      "type": "assert",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-skeleton-notes-content" }
      }
    },
    { "type": "wait_frames", "n": 4 },
    { "type": "capture_bundle", "label": "ui-gallery-skeleton-docs-smoke" }
  ]
}
