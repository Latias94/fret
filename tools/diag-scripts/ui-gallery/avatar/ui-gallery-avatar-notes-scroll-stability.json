{
  "schema_version": 2,
  "meta": {
    "name": "ui-gallery-avatar-notes-scroll-stability",
    "required_capabilities": [
      "diag.script_v2",
      "diag.screenshot_png"
    ],
    "tags": [
      "ui_gallery",
      "avatar",
      "notes",
      "scroll",
      "stability"
    ]
  },
  "steps": [
    {
      "type": "reset_diagnostics"
    },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": {
          "kind": "test_id",
          "id": "ui-gallery-nav-search"
        }
      },
      "timeout_frames": 600
    },
    {
      "type": "press_key",
      "key": "escape"
    },
    {
      "type": "wait_frames",
      "n": 2
    },
    {
      "type": "set_window_inner_size",
      "width_px": 1280.0,
      "height_px": 720.0
    },
    {
      "type": "wait_frames",
      "n": 20
    },
    {
      "type": "click",
      "target": {
        "kind": "test_id",
        "id": "ui-gallery-nav-search"
      }
    },
    {
      "type": "press_key",
      "key": "a",
      "modifiers": {
        "ctrl": true
      }
    },
    {
      "type": "press_key",
      "key": "backspace"
    },
    {
      "type": "type_text",
      "text": "avatar"
    },
    {
      "type": "wait_frames",
      "n": 2
    },
    {
      "type": "click",
      "target": {
        "kind": "test_id",
        "id": "ui-gallery-nav-avatar"
      }
    },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": {
          "kind": "test_id",
          "id": "ui-gallery-page-avatar"
        }
      },
      "timeout_frames": 600
    },
    {
      "type": "wait_frames",
      "n": 20
    },
    {
      "type": "scroll_into_view",
      "container": {
        "kind": "test_id",
        "id": "ui-gallery-content-scroll"
      },
      "target": {
        "kind": "test_id",
        "id": "ui-gallery-avatar-notes-content"
      },
      "delta_y": -360.0,
      "padding_px": 16.0,
      "padding_insets_px": {
        "left_px": 16.0,
        "top_px": 16.0,
        "right_px": 16.0,
        "bottom_px": 40.0
      },
      "timeout_frames": 1800
    },
    {
      "type": "wait_frames",
      "n": 10
    },
    {
      "type": "capture_bundle",
      "label": "ui-gallery-avatar-notes-before-wheel"
    },
    {
      "type": "capture_screenshot",
      "label": "ui-gallery-avatar-notes-before-wheel"
    },
    {
      "type": "wheel",
      "target": {
        "kind": "test_id",
        "id": "ui-gallery-avatar-notes-content"
      },
      "delta_y": -240.0
    },
    {
      "type": "wait_frames",
      "n": 6
    },
    {
      "type": "wheel",
      "target": {
        "kind": "test_id",
        "id": "ui-gallery-avatar-notes-content"
      },
      "delta_y": -240.0
    },
    {
      "type": "wait_frames",
      "n": 6
    },
    {
      "type": "wheel",
      "target": {
        "kind": "test_id",
        "id": "ui-gallery-avatar-notes-content"
      },
      "delta_y": -240.0
    },
    {
      "type": "wait_frames",
      "n": 10
    },
    {
      "type": "capture_bundle",
      "label": "ui-gallery-avatar-notes-after-wheel"
    },
    {
      "type": "capture_screenshot",
      "label": "ui-gallery-avatar-notes-after-wheel"
    }
  ]
}
