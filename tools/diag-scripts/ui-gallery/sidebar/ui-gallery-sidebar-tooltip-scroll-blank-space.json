{
  "schema_version": 2,
  "meta": {
    "name": "ui-gallery-sidebar-tooltip-scroll-blank-space",
    "required_capabilities": ["diag.script_v2", "diag.screenshot_png"],
    "tags": ["ui_gallery", "sidebar", "scroll", "regression"],
    "target_hints": [
      "Repro: filter the sidebar to a small set of items, then wheel-scroll to the bottom; there should be no large blank space after the last item."
    ],
    "env_defaults": {
      "FRET_UI_GALLERY_BISECT": "0"
    }
  },
  "steps": [
    { "type": "reset_diagnostics" },
    { "type": "press_key", "key": "escape" },
    { "type": "wait_frames", "n": 2 },
    { "type": "set_window_inner_size", "width_px": 1280.0, "height_px": 800.0 },
    { "type": "wait_frames", "n": 30 },

    {
      "type": "wait_until",
      "predicate": { "kind": "exists", "target": { "kind": "test_id", "id": "ui-gallery-nav-search" } },
      "timeout_frames": 600
    },
    {
      "type": "type_text_into",
      "target": { "kind": "test_id", "id": "ui-gallery-nav-search" },
      "text": "tooltip",
      "clear_before_type": true,
      "timeout_frames": 900
    },
    { "type": "wait_frames", "n": 8 },

    {
      "type": "wait_until",
      "predicate": { "kind": "exists", "target": { "kind": "test_id", "id": "ui-gallery-nav-tooltip" } },
      "timeout_frames": 900
    },

    { "type": "move_pointer", "target": { "kind": "test_id", "id": "ui-gallery-nav-scroll" } },
    { "type": "wait_frames", "n": 4 },

    { "type": "wheel", "target": { "kind": "test_id", "id": "ui-gallery-nav-scroll" }, "delta_y": -20000.0 },
    { "type": "wait_frames", "n": 2 },
    { "type": "wheel", "target": { "kind": "test_id", "id": "ui-gallery-nav-scroll" }, "delta_y": -20000.0 },
    { "type": "wait_frames", "n": 2 },
    { "type": "wheel", "target": { "kind": "test_id", "id": "ui-gallery-nav-scroll" }, "delta_y": -20000.0 },
    { "type": "wait_frames", "n": 2 },

    { "type": "wait_frames", "n": 10 },
    { "type": "capture_screenshot", "label": "ui-gallery-sidebar-tooltip-scroll-blank-space" },
    { "type": "capture_bundle", "label": "ui-gallery-sidebar-tooltip-scroll-blank-space" }
  ]
}
