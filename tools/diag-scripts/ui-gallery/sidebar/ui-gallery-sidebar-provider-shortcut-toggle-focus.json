{
  "meta": {
    "name": "ui-gallery-sidebar-provider-shortcut-toggle-focus",
    "required_capabilities": ["diag.script_v2"]
  },
  "schema_version": 2,
  "steps": [
    { "type": "reset_diagnostics" },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-nav-search" }
      },
      "timeout_frames": 600
    },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-nav-scroll" }
      },
      "timeout_frames": 600
    },
    { "type": "press_key", "key": "escape" },
    { "type": "wait_frames", "n": 2 },

    { "type": "set_window_inner_size", "width_px": 1280.0, "height_px": 720.0 },
    { "type": "wait_frames", "n": 15 },

    { "type": "click", "target": { "kind": "test_id", "id": "ui-gallery-nav-search" } },
    { "type": "press_key", "key": "a", "modifiers": { "ctrl": true } },
    { "type": "press_key", "key": "backspace" },
    { "type": "type_text", "text": "sidebar" },
    { "type": "wait_frames", "n": 2 },

    {
      "type": "scroll_into_view",
      "container": { "kind": "test_id", "id": "ui-gallery-nav-scroll" },
      "target": { "kind": "test_id", "id": "ui-gallery-nav-sidebar" },
      "delta_y": -240.0,
      "timeout_frames": 600
    },
    { "type": "click", "target": { "kind": "test_id", "id": "ui-gallery-nav-sidebar" } },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-page-sidebar" }
      },
      "timeout_frames": 600
    },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-content-scroll" }
      },
      "timeout_frames": 600
    },
    { "type": "wait_frames", "n": 10 },
    {
      "type": "scroll_into_view",
      "container": { "kind": "test_id", "id": "ui-gallery-content-scroll" },
      "target": { "kind": "test_id", "id": "ui-gallery-sidebar-demo-focus" },
      "delta_y": -220.0,
      "padding_px": 16.0,
      "timeout_frames": 1800
    },

    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-sidebar-demo-toggle" }
      },
      "timeout_frames": 600
    },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-sidebar-demo-sidebar" }
      },
      "timeout_frames": 600
    },

    {
      "type": "wait_until",
      "predicate": {
        "kind": "bounds_min_size",
        "target": { "kind": "test_id", "id": "ui-gallery-sidebar-demo-sidebar" },
        "min_w_px": 180.0,
        "min_h_px": 200.0,
        "eps_px": 1.0
      },
      "timeout_frames": 240
    },

    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-sidebar-demo-focus" }
      },
      "timeout_frames": 600
    },
    {
      "type": "click_stable",
      "target": { "kind": "test_id", "id": "ui-gallery-sidebar-demo-focus" }
    },
    { "type": "wait_frames", "n": 2 },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "focus_is",
        "target": { "kind": "test_id", "id": "ui-gallery-sidebar-demo-focus" }
      },
      "timeout_frames": 240
    },

    { "type": "press_key", "key": "b", "modifiers": { "ctrl": true } },
    {
      "type": "wait_bounds_stable",
      "target": { "kind": "test_id", "id": "ui-gallery-sidebar-demo-sidebar" },
      "stable_frames": 3,
      "max_move_px": 2.0,
      "timeout_frames": 600
    },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "bounds_max_size",
        "target": { "kind": "test_id", "id": "ui-gallery-sidebar-demo-sidebar" },
        "max_w_px": 120.0,
        "max_h_px": 1000.0,
        "eps_px": 1.0
      },
      "timeout_frames": 600
    },

    {
      "type": "click_stable",
      "target": { "kind": "test_id", "id": "ui-gallery-sidebar-demo-focus" }
    },
    { "type": "press_key", "key": "b", "modifiers": { "ctrl": true } },
    {
      "type": "wait_bounds_stable",
      "target": { "kind": "test_id", "id": "ui-gallery-sidebar-demo-sidebar" },
      "stable_frames": 3,
      "max_move_px": 2.0,
      "timeout_frames": 600
    },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "bounds_min_size",
        "target": { "kind": "test_id", "id": "ui-gallery-sidebar-demo-sidebar" },
        "min_w_px": 180.0,
        "min_h_px": 200.0,
        "eps_px": 1.0
      },
      "timeout_frames": 600
    },

    {
      "type": "click_stable",
      "target": { "kind": "test_id", "id": "ui-gallery-sidebar-demo-focus" }
    },
    { "type": "press_key", "key": "b", "modifiers": { "ctrl": true } },
    {
      "type": "wait_bounds_stable",
      "target": { "kind": "test_id", "id": "ui-gallery-sidebar-demo-sidebar" },
      "stable_frames": 3,
      "max_move_px": 2.0,
      "timeout_frames": 600
    },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "bounds_max_size",
        "target": { "kind": "test_id", "id": "ui-gallery-sidebar-demo-sidebar" },
        "max_w_px": 120.0,
        "max_h_px": 1000.0,
        "eps_px": 1.0
      },
      "timeout_frames": 600
    },

    {
      "type": "capture_bundle",
      "label": "ui-gallery-sidebar-provider-shortcut-toggle-focus"
    }
  ]
}
