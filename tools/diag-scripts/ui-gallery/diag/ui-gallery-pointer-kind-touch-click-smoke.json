{
  "schema_version": 2,
  "meta": {
    "name": "UI gallery: pointer_kind=touch click smoke",
    "tags": ["ui-gallery", "diag", "pointer-kind", "touch"],
    "required_capabilities": ["diag.script_v2", "diag.pointer_kind_touch"],
    "target_hints": [
      "Exercises touch pointer injection via pointer_kind=touch.",
      "Fails fast when the runner does not advertise diag.pointer_kind_touch."
    ]
  },
  "steps": [
    { "type": "reset_diagnostics" },
    {
      "type": "wait_until",
      "predicate": { "kind": "exists", "target": { "kind": "test_id", "id": "ui-gallery-nav-search" } },
      "timeout_frames": 600
    },
    { "type": "press_key", "key": "escape" },
    { "type": "wait_frames", "n": 2 },
    { "type": "set_window_inner_size", "width_px": 1280.0, "height_px": 720.0 },
    { "type": "wait_frames", "n": 10 },

    {
      "type": "click",
      "pointer_kind": "touch",
      "target": { "kind": "test_id", "id": "ui-gallery-nav-search" }
    },
    { "type": "press_key", "key": "a", "modifiers": { "ctrl": true } },
    { "type": "press_key", "key": "backspace" },
    { "type": "type_text", "text": "button" },
    { "type": "wait_frames", "n": 2 },
    {
      "type": "wait_until",
      "predicate": { "kind": "exists", "target": { "kind": "test_id", "id": "ui-gallery-nav-button" } },
      "timeout_frames": 600
    },
    {
      "type": "click",
      "pointer_kind": "touch",
      "target": { "kind": "test_id", "id": "ui-gallery-nav-button" }
    },
    {
      "type": "wait_until",
      "predicate": { "kind": "exists", "target": { "kind": "test_id", "id": "ui-gallery-page-button" } },
      "timeout_frames": 600
    },

    {
      "type": "scroll_into_view",
      "container": { "kind": "test_id", "id": "ui-gallery-content-scroll" },
      "target": { "kind": "test_id", "id": "ui-gallery-button-render-link" },
      "delta_y": -360.0,
      "padding_px": 16.0,
      "timeout_frames": 1800
    },
    {
      "type": "assert",
      "predicate": {
        "kind": "role_is",
        "target": { "kind": "test_id", "id": "ui-gallery-button-render-link" },
        "role": "link"
      }
    },
    {
      "type": "click_stable",
      "pointer_kind": "touch",
      "target": { "kind": "test_id", "id": "ui-gallery-button-render-link" }
    },
    { "type": "wait_frames", "n": 10 },
    { "type": "capture_bundle", "label": "ui-gallery-pointer-kind-touch-click-smoke" }
  ]
}
