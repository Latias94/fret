{
  "schema_version": 2,
  "meta": {
    "name": "UI gallery: gesture swipe smoke",
    "tags": ["ui-gallery", "diag", "gesture", "swipe"],
    "required_capabilities": ["diag.script_v2", "diag.gesture_swipe"],
    "target_hints": [
      "Exercises the intent-level swipe step (touch-first).",
      "Waits for pointer.up in the diagnostics ring as proof of delivery.",
      "Fails fast when the runner does not advertise diag.gesture_swipe."
    ]
  },
  "steps": [
    { "type": "reset_diagnostics" },
    {
      "type": "wait_until",
      "predicate": { "kind": "exists", "target": { "kind": "test_id", "id": "ui-gallery-nav-search" } },
      "timeout_frames": 600
    },
    { "type": "press_key", "key": "escape" },
    { "type": "wait_frames", "n": 2 },
    { "type": "set_window_inner_size", "width_px": 1280.0, "height_px": 720.0 },
    { "type": "wait_frames", "n": 10 },

    {
      "type": "swipe",
      "target": { "kind": "test_id", "id": "ui-gallery-nav-search" },
      "delta_x": 0.0,
      "delta_y": 120.0,
      "steps": 8
    },
    { "type": "wait_frames", "n": 2 },
    {
      "type": "wait_until",
      "predicate": { "kind": "event_kind_seen", "event_kind": "pointer.up" },
      "timeout_frames": 240
    },

    { "type": "capture_bundle", "label": "ui-gallery-gesture-swipe-smoke" }
  ]
}

