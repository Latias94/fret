{
  "schema_version": 2,
  "meta": {
    "name": "ui-gallery-context-menu-shortcuts-non-overlap",
    "required_capabilities": ["diag.script_v2"]
  },
  "steps": [
    { "type": "reset_diagnostics" },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-nav-search" }
      },
      "timeout_frames": 600
    },
    { "type": "press_key", "key": "escape" },
    { "type": "wait_frames", "n": 2 },

    { "type": "click", "target": { "kind": "test_id", "id": "ui-gallery-nav-search" } },
    { "type": "press_key", "key": "a", "modifiers": { "ctrl": true } },
    { "type": "press_key", "key": "backspace" },
    { "type": "type_text", "text": "context menu" },
    { "type": "wait_frames", "n": 2 },

    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-nav-context-menu" }
      },
      "timeout_frames": 600
    },
    { "type": "click", "target": { "kind": "test_id", "id": "ui-gallery-nav-context-menu" } },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-page-context-menu" }
      },
      "timeout_frames": 600
    },
    {
      "type": "scroll_into_view",
      "container": { "kind": "test_id", "id": "ui-gallery-content-scroll" },
      "target": {
        "kind": "test_id",
        "id": "ui-gallery-context-menu-shortcuts-trigger"
      },
      "delta_y": -360.0,
      "require_fully_within_window": true,
      "padding_px": 16.0,
      "timeout_frames": 1800
    },

    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": {
          "kind": "test_id",
          "id": "ui-gallery-context-menu-shortcuts-trigger"
        }
      },
      "timeout_frames": 600
    },
    {
      "type": "move_pointer",
      "target": { "kind": "test_id", "id": "ui-gallery-context-menu-shortcuts-trigger" }
    },
    {
      "type": "click",
      "button": "right",
      "target": { "kind": "test_id", "id": "ui-gallery-context-menu-shortcuts-trigger" }
    },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": {
          "kind": "test_id",
          "id": "ui-gallery-context-menu-shortcuts-open-file"
        }
      },
      "timeout_frames": 240
    },

    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": {
          "kind": "test_id",
          "id": "ui-gallery-context-menu-shortcuts-open-file.chrome-label"
        }
      },
      "timeout_frames": 240
    },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": {
          "kind": "test_id",
          "id": "ui-gallery-context-menu-shortcuts-open-file.chrome-trailing"
        }
      },
      "timeout_frames": 240
    },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "bounds_non_overlapping",
        "a": {
          "kind": "test_id",
          "id": "ui-gallery-context-menu-shortcuts-open-file.chrome-label"
        },
        "b": {
          "kind": "test_id",
          "id": "ui-gallery-context-menu-shortcuts-open-file.chrome-trailing"
        },
        "eps_px": 0.5
      },
      "timeout_frames": 240
    },

    { "type": "capture_bundle", "label": "ui-gallery-context-menu-shortcuts-non-overlap" }
  ]
}
