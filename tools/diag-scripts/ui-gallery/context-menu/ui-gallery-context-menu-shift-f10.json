{
  "schema_version": 1,
  "steps": [
    { "type": "press_key", "key": "escape" },
    { "type": "wait_frames", "n": 2 },
    {
      "type": "click",
      "target": { "kind": "test_id", "id": "ui-gallery-overlay-reset" }
    },
    { "type": "wait_frames", "n": 10 },

    { "type": "click", "target": { "kind": "test_id", "id": "ui-gallery-context-trigger" } },
    { "type": "wait_frames", "n": 2 },

    { "type": "press_key", "key": "f10", "modifiers": { "shift": true } },
    { "type": "wait_frames", "n": 6 },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-context-item-action" }
      },
      "timeout_frames": 240
    },

    { "type": "capture_bundle", "label": "ui-gallery-context-menu-shift-f10" }
  ]
}

