{
  "schema_version": 2,
  "meta": {
    "name": "UI gallery: Context Menu sides placement (zinc light)",
    "tags": ["ui-gallery", "shadcn", "context-menu", "sides", "placement", "zinc-light"],
    "required_capabilities": ["diag.script_v2", "diag.overlay_placement_trace", "diag.screenshot_png"],
    "env_defaults": {
      "FRET_UI_GALLERY_START_PAGE": "context_menu"
    },
    "target_hints": [
      "Sets theme preset to zinc/light.",
      "Boots the UI gallery directly on the Context Menu page.",
      "Opens the Top/Right/Bottom/Left side examples and asserts overlay placement trace stays on the requested side without flipping."
    ]
  },
  "steps": [
    { "type": "reset_diagnostics" },
    {
      "type": "wait_until",
      "predicate": { "kind": "exists", "target": { "kind": "test_id", "id": "ui-gallery-theme-preset-trigger" } },
      "timeout_frames": 600
    },
    { "type": "press_key", "key": "escape" },
    { "type": "wait_frames", "n": 2 },
    { "type": "set_window_inner_size", "width_px": 1440.0, "height_px": 1024.0 },
    { "type": "wait_frames", "n": 20 },

    { "type": "click", "target": { "kind": "test_id", "id": "ui-gallery-theme-preset-trigger" } },
    { "type": "click_stable", "target": { "kind": "test_id", "id": "ui-gallery-theme-preset-item-zinc-light" } },
    { "type": "wait_frames", "n": 2 },
    { "type": "press_key", "key": "escape" },
    { "type": "wait_frames", "n": 2 },
    {
      "type": "wait_until",
      "predicate": { "kind": "exists", "target": { "kind": "test_id", "id": "ui-gallery-page-context-menu" } },
      "timeout_frames": 600
    },

    {
      "type": "scroll_into_view",
      "container": { "kind": "test_id", "id": "ui-gallery-content-scroll" },
      "target": { "kind": "test_id", "id": "ui-gallery-context-menu-sides-top-trigger" },
      "delta_y": -200.0,
      "require_fully_within_container": true,
      "require_fully_within_window": true,
      "padding_px": 16.0,
      "padding_insets_px": { "left_px": 16.0, "top_px": 240.0, "right_px": 16.0, "bottom_px": 240.0 },
      "timeout_frames": 600
    },
    { "type": "wait_frames", "n": 2 },
    { "type": "reset_diagnostics" },
    { "type": "move_pointer", "target": { "kind": "test_id", "id": "ui-gallery-context-menu-sides-top-trigger" } },
    { "type": "click", "button": "right", "target": { "kind": "test_id", "id": "ui-gallery-context-menu-sides-top-trigger" } },
    {
      "type": "wait_until",
      "predicate": { "kind": "exists", "target": { "kind": "test_id", "id": "ui-gallery-context-menu-sides-top-content" } },
      "timeout_frames": 240
    },
    {
      "type": "wait_overlay_placement_trace",
      "query": {
        "kind": "anchored_panel",
        "content_test_id": "ui-gallery-context-menu-sides-top-content",
        "preferred_side": "top",
        "chosen_side": "top",
        "flipped": false
      },
      "timeout_frames": 240
    },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "bounds_within_window",
        "target": { "kind": "test_id", "id": "ui-gallery-context-menu-sides-top-content" },
        "padding_px": 2.0,
        "eps_px": 0.5
      },
      "timeout_frames": 240
    },
    { "type": "press_key", "key": "escape" },
    {
      "type": "wait_until",
      "predicate": { "kind": "not_exists", "target": { "kind": "test_id", "id": "ui-gallery-context-menu-sides-top-content" } },
      "timeout_frames": 240
    },

    {
      "type": "scroll_into_view",
      "container": { "kind": "test_id", "id": "ui-gallery-content-scroll" },
      "target": { "kind": "test_id", "id": "ui-gallery-context-menu-sides-right-trigger" },
      "delta_y": -200.0,
      "require_fully_within_container": true,
      "require_fully_within_window": true,
      "padding_px": 16.0,
      "padding_insets_px": { "left_px": 16.0, "top_px": 240.0, "right_px": 16.0, "bottom_px": 240.0 },
      "timeout_frames": 600
    },
    { "type": "wait_frames", "n": 2 },
    { "type": "reset_diagnostics" },
    { "type": "move_pointer", "target": { "kind": "test_id", "id": "ui-gallery-context-menu-sides-right-trigger" } },
    { "type": "click", "button": "right", "target": { "kind": "test_id", "id": "ui-gallery-context-menu-sides-right-trigger" } },
    {
      "type": "wait_until",
      "predicate": { "kind": "exists", "target": { "kind": "test_id", "id": "ui-gallery-context-menu-sides-right-content" } },
      "timeout_frames": 240
    },
    {
      "type": "wait_overlay_placement_trace",
      "query": {
        "kind": "anchored_panel",
        "content_test_id": "ui-gallery-context-menu-sides-right-content",
        "preferred_side": "right",
        "chosen_side": "right",
        "flipped": false
      },
      "timeout_frames": 240
    },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "bounds_within_window",
        "target": { "kind": "test_id", "id": "ui-gallery-context-menu-sides-right-content" },
        "padding_px": 2.0,
        "eps_px": 0.5
      },
      "timeout_frames": 240
    },
    { "type": "press_key", "key": "escape" },
    {
      "type": "wait_until",
      "predicate": { "kind": "not_exists", "target": { "kind": "test_id", "id": "ui-gallery-context-menu-sides-right-content" } },
      "timeout_frames": 240
    },

    {
      "type": "scroll_into_view",
      "container": { "kind": "test_id", "id": "ui-gallery-content-scroll" },
      "target": { "kind": "test_id", "id": "ui-gallery-context-menu-sides-bottom-trigger" },
      "delta_y": -200.0,
      "require_fully_within_container": true,
      "require_fully_within_window": true,
      "padding_px": 16.0,
      "padding_insets_px": { "left_px": 16.0, "top_px": 240.0, "right_px": 16.0, "bottom_px": 240.0 },
      "timeout_frames": 600
    },
    { "type": "wait_frames", "n": 2 },
    { "type": "reset_diagnostics" },
    { "type": "move_pointer", "target": { "kind": "test_id", "id": "ui-gallery-context-menu-sides-bottom-trigger" } },
    { "type": "click", "button": "right", "target": { "kind": "test_id", "id": "ui-gallery-context-menu-sides-bottom-trigger" } },
    {
      "type": "wait_until",
      "predicate": { "kind": "exists", "target": { "kind": "test_id", "id": "ui-gallery-context-menu-sides-bottom-content" } },
      "timeout_frames": 240
    },
    {
      "type": "wait_overlay_placement_trace",
      "query": {
        "kind": "anchored_panel",
        "content_test_id": "ui-gallery-context-menu-sides-bottom-content",
        "preferred_side": "bottom",
        "chosen_side": "bottom",
        "flipped": false
      },
      "timeout_frames": 240
    },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "bounds_within_window",
        "target": { "kind": "test_id", "id": "ui-gallery-context-menu-sides-bottom-content" },
        "padding_px": 2.0,
        "eps_px": 0.5
      },
      "timeout_frames": 240
    },
    { "type": "press_key", "key": "escape" },
    {
      "type": "wait_until",
      "predicate": { "kind": "not_exists", "target": { "kind": "test_id", "id": "ui-gallery-context-menu-sides-bottom-content" } },
      "timeout_frames": 240
    },

    {
      "type": "scroll_into_view",
      "container": { "kind": "test_id", "id": "ui-gallery-content-scroll" },
      "target": { "kind": "test_id", "id": "ui-gallery-context-menu-sides-left-trigger" },
      "delta_y": -200.0,
      "require_fully_within_container": true,
      "require_fully_within_window": true,
      "padding_px": 16.0,
      "padding_insets_px": { "left_px": 16.0, "top_px": 240.0, "right_px": 16.0, "bottom_px": 240.0 },
      "timeout_frames": 600
    },
    { "type": "wait_frames", "n": 2 },
    { "type": "reset_diagnostics" },
    { "type": "move_pointer", "target": { "kind": "test_id", "id": "ui-gallery-context-menu-sides-left-trigger" } },
    { "type": "click", "button": "right", "target": { "kind": "test_id", "id": "ui-gallery-context-menu-sides-left-trigger" } },
    {
      "type": "wait_until",
      "predicate": { "kind": "exists", "target": { "kind": "test_id", "id": "ui-gallery-context-menu-sides-left-content" } },
      "timeout_frames": 240
    },
    {
      "type": "wait_overlay_placement_trace",
      "query": {
        "kind": "anchored_panel",
        "content_test_id": "ui-gallery-context-menu-sides-left-content",
        "preferred_side": "left",
        "chosen_side": "left",
        "flipped": false
      },
      "timeout_frames": 240
    },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "bounds_within_window",
        "target": { "kind": "test_id", "id": "ui-gallery-context-menu-sides-left-content" },
        "padding_px": 2.0,
        "eps_px": 0.5
      },
      "timeout_frames": 240
    },

    { "type": "capture_screenshot", "label": "ui-gallery-context-menu-sides-placement-zinc-light" },
    { "type": "capture_bundle", "label": "ui-gallery-context-menu-sides-placement-zinc-light" }
  ]
}
