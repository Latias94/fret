{
  "schema_version": 2,
  "steps": [
    {
      "key": "escape",
      "modifiers": {
        "alt": false,
        "ctrl": false,
        "meta": false,
        "shift": false
      },
      "repeat": false,
      "type": "press_key"
    },
    {
      "n": 2,
      "type": "wait_frames"
    },
    {
      "button": "left",
      "target": {
        "id": "ui-gallery-overlay-reset",
        "kind": "test_id"
      },
      "type": "click"
    },
    {
      "n": 10,
      "type": "wait_frames"
    },
    {
      "target": {
        "id": "ui-gallery-context-trigger",
        "kind": "test_id"
      },
      "type": "move_pointer"
    },
    {
      "button": "right",
      "target": {
        "id": "ui-gallery-context-trigger",
        "kind": "test_id"
      },
      "type": "click"
    },
    {
      "predicate": {
        "kind": "exists",
        "target": {
          "id": "ui-gallery-context-item-action",
          "kind": "test_id"
        }
      },
      "timeout_frames": 180,
      "type": "wait_until"
    },
    {
      "button": "left",
      "target": {
        "id": "ui-gallery-context-item-action",
        "kind": "test_id"
      },
      "type": "click"
    },
    {
      "label": "ui-gallery-context-action",
      "type": "capture_bundle"
    }
  ]
}
