{
  "schema_version": 2,
  "meta": {
    "name": "ui-gallery-context-menu-basic-touch-long-press-open",
    "required_capabilities": [
      "diag.script_v2",
      "diag.pointer_kind_touch"
    ],
    "tags": ["ui_gallery", "shadcn", "context_menu", "touch", "long_press", "screenshot"],
    "target_hints": [
      "Navigates to the Context Menu page using touch pointer injection.",
      "Holds a touch pointer down on the basic trigger long enough to verify the menu opens on the touch long-press path."
    ]
  },
  "steps": [
    { "type": "reset_diagnostics" },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-nav-search" }
      },
      "timeout_frames": 600
    },
    { "type": "press_key", "key": "escape" },
    { "type": "wait_frames", "n": 2 },
    { "type": "set_window_inner_size", "width_px": 1440.0, "height_px": 960.0 },
    { "type": "wait_frames", "n": 10 },

    {
      "type": "click_stable",
      "pointer_kind": "touch",
      "target": { "kind": "test_id", "id": "ui-gallery-nav-search" },
      "button": "left",
      "stable_frames": 10,
      "max_move_px": 0.5,
      "timeout_frames": 600
    },
    { "type": "press_key", "key": "a", "modifiers": { "ctrl": true } },
    { "type": "press_key", "key": "backspace" },
    { "type": "type_text", "text": "context menu" },
    { "type": "wait_frames", "n": 2 },

    {
      "type": "wait_until",
      "predicate": {
        "kind": "bounds_within_window",
        "target": { "kind": "test_id", "id": "ui-gallery-nav-context-menu" },
        "padding_px": 8.0,
        "eps_px": 1.0
      },
      "timeout_frames": 600
    },
    {
      "type": "click_stable",
      "pointer_kind": "touch",
      "target": { "kind": "test_id", "id": "ui-gallery-nav-context-menu" },
      "button": "left",
      "stable_frames": 10,
      "max_move_px": 0.5,
      "timeout_frames": 600
    },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-page-context-menu" }
      },
      "timeout_frames": 600
    },
    {
      "type": "scroll_into_view",
      "container": { "kind": "test_id", "id": "ui-gallery-content-scroll" },
      "target": { "kind": "test_id", "id": "ui-gallery-context-menu-basic-trigger" },
      "delta_y": -320.0,
      "require_fully_within_window": true,
      "padding_px": 16.0,
      "timeout_frames": 1800
    },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "bounds_within_window",
        "target": { "kind": "test_id", "id": "ui-gallery-context-menu-basic-trigger" },
        "padding_px": 16.0,
        "eps_px": 1.0
      },
      "timeout_frames": 600
    },

    {
      "type": "pointer_down",
      "pointer_kind": "touch",
      "target": { "kind": "test_id", "id": "ui-gallery-context-menu-basic-trigger" }
    },
    { "type": "wait_ms", "n_ms": 700 },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-context-menu-basic-content" }
      },
      "timeout_frames": 240
    },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-context-menu-basic-profile" }
      },
      "timeout_frames": 240
    },
    {
      "type": "capture_screenshot",
      "label": "ui-gallery-context-menu-basic-touch-long-press-open"
    },
    { "type": "pointer_up", "pointer_kind": "touch" },
    { "type": "wait_frames", "n": 2 },
    {
      "type": "click_stable",
      "pointer_kind": "touch",
      "target": { "kind": "test_id", "id": "ui-gallery-context-menu-basic-profile" },
      "button": "left",
      "stable_frames": 10,
      "max_move_px": 0.5,
      "timeout_frames": 600
    },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "label_contains",
        "target": { "kind": "test_id", "id": "ui-gallery-status-last-action" },
        "text": "menu.context.action"
      },
      "timeout_frames": 240
    },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "not_exists",
        "target": { "kind": "test_id", "id": "ui-gallery-context-menu-basic-profile" }
      },
      "timeout_frames": 240
    },

    {
      "type": "capture_bundle",
      "label": "ui-gallery-context-menu-basic-touch-long-press-open"
    }
  ]
}
