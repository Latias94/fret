{
  "schema_version": 2,
  "meta": {
    "name": "UI gallery: Context Menu icons screenshots (zinc light)",
    "tags": ["ui-gallery", "shadcn", "context-menu", "icons", "screenshots", "zinc-light"],
    "env_defaults": {
      "FRET_UI_GALLERY_START_PAGE": "context_menu"
    },
    "required_capabilities": ["diag.script_v2", "diag.screenshot_png"],
    "target_hints": [
      "Sets theme preset to zinc/light.",
      "Boots the UI gallery directly on the Context Menu page.",
      "Opens the Icons menu and captures screenshots to gate leading-icon foreground inheritance."
    ]
  },
  "steps": [
    { "type": "reset_diagnostics" },
    {
      "type": "wait_until",
      "predicate": { "kind": "exists", "target": { "kind": "test_id", "id": "ui-gallery-theme-preset-trigger" } },
      "timeout_frames": 600
    },
    { "type": "click", "target": { "kind": "test_id", "id": "ui-gallery-theme-preset-trigger" } },
    { "type": "click", "target": { "kind": "test_id", "id": "ui-gallery-theme-preset-item-zinc-light" } },
    { "type": "wait_frames", "n": 2 },
    {
      "type": "wait_until",
      "predicate": { "kind": "exists", "target": { "kind": "test_id", "id": "ui-gallery-page-context-menu" } },
      "timeout_frames": 600
    },

    {
      "type": "scroll_into_view",
      "container": { "kind": "test_id", "id": "ui-gallery-content-scroll" },
      "target": { "kind": "test_id", "id": "ui-gallery-context-menu-icons-trigger" },
      "delta_y": -120.0,
      "require_fully_within_container": true,
      "require_fully_within_window": true,
      "padding_px": 16.0,
      "timeout_frames": 600
    },
    { "type": "wait_frames", "n": 2 },
    {
      "type": "move_pointer",
      "target": { "kind": "test_id", "id": "ui-gallery-context-menu-icons-trigger" }
    },
    {
      "type": "click",
      "button": "right",
      "target": { "kind": "test_id", "id": "ui-gallery-context-menu-icons-trigger" }
    },
    {
      "type": "wait_until",
      "predicate": { "kind": "exists", "target": { "kind": "test_id", "id": "ui-gallery-context-menu-icons-content" } },
      "timeout_frames": 600
    },
    { "type": "wait_frames", "n": 2 },
    { "type": "capture_screenshot", "label": "ui-gallery-context-menu-icons-zinc-light" },
    { "type": "capture_bundle", "label": "ui-gallery-context-menu-icons-zinc-light" }
  ]
}
