{
  "schema_version": 2,
  "meta": {
    "name": "ui-gallery-context-menu-basic-keyboard-nav",
    "required_capabilities": ["diag.script_v2"],
    "tags": ["ui_gallery", "shadcn", "context_menu", "keyboard", "nav", "regression_pack"]
  },
  "steps": [
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-nav-search" }
      },
      "timeout_frames": 600
    },
    { "type": "press_key", "key": "escape" },
    { "type": "wait_frames", "n": 2 },

    {
      "type": "click_stable",
      "target": { "kind": "test_id", "id": "ui-gallery-nav-search" },
      "button": "left",
      "stable_frames": 10,
      "max_move_px": 0.5,
      "timeout_frames": 600
    },
    { "type": "press_key", "key": "a", "modifiers": { "ctrl": true } },
    { "type": "press_key", "key": "backspace" },
    { "type": "type_text", "text": "context menu" },
    { "type": "wait_frames", "n": 2 },

    {
      "type": "wait_until",
      "predicate": {
        "kind": "bounds_within_window",
        "target": { "kind": "test_id", "id": "ui-gallery-nav-context-menu" },
        "padding_px": 8.0,
        "eps_px": 1.0
      },
      "timeout_frames": 600
    },
    {
      "type": "click_stable",
      "target": { "kind": "test_id", "id": "ui-gallery-nav-context-menu" },
      "button": "left",
      "stable_frames": 10,
      "max_move_px": 0.5,
      "timeout_frames": 600
    },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-page-context-menu" }
      },
      "timeout_frames": 600
    },

    {
      "type": "click_stable",
      "target": { "kind": "test_id", "id": "ui-gallery-context-menu-basic-trigger" },
      "button": "right",
      "stable_frames": 10,
      "max_move_px": 0.5,
      "timeout_frames": 600
    },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-context-menu-basic-content" }
      },
      "timeout_frames": 240
    },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-context-menu-basic-profile" }
      },
      "timeout_frames": 240
    },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-context-menu-basic-billing" }
      },
      "timeout_frames": 240
    },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-context-menu-basic-team" }
      },
      "timeout_frames": 240
    },

    {
      "type": "wait_until",
      "predicate": {
        "kind": "focused_descendant_is",
        "scope": { "kind": "test_id", "id": "ui-gallery-context-menu-basic-content" },
        "target": { "kind": "test_id", "id": "ui-gallery-context-menu-basic-profile" }
      },
      "timeout_frames": 240
    },

    { "type": "press_key", "key": "arrow_down" },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "focused_descendant_is",
        "scope": { "kind": "test_id", "id": "ui-gallery-context-menu-basic-content" },
        "target": { "kind": "test_id", "id": "ui-gallery-context-menu-basic-billing" }
      },
      "timeout_frames": 240
    },

    { "type": "press_key", "key": "arrow_down" },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "focused_descendant_is",
        "scope": { "kind": "test_id", "id": "ui-gallery-context-menu-basic-content" },
        "target": { "kind": "test_id", "id": "ui-gallery-context-menu-basic-team" }
      },
      "timeout_frames": 240
    },

    { "type": "press_key", "key": "enter" },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "label_contains",
        "target": { "kind": "test_id", "id": "ui-gallery-context-menu-last-action" },
        "text": "menu.context.action"
      },
      "timeout_frames": 240
    },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "not_exists",
        "target": { "kind": "test_id", "id": "ui-gallery-context-menu-basic-team" }
      },
      "timeout_frames": 240
    },

    {
      "type": "capture_bundle",
      "label": "ui-gallery-context-menu-basic-keyboard-nav"
    }
  ]
}

