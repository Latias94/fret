{
  "schema_version": 2,
  "meta": {
    "name": "UI gallery: Context Menu destructive screenshot (zinc dark)",
    "tags": ["ui-gallery", "shadcn", "context-menu", "destructive", "screenshots", "zinc-dark"],
    "required_capabilities": ["diag.script_v2", "diag.screenshot_png"],
    "env_defaults": {
      "FRET_UI_GALLERY_START_PAGE": "context_menu"
    },
    "target_hints": [
      "Sets theme preset to zinc/dark.",
      "Boots the UI gallery directly on the Context Menu page.",
      "Opens the Destructive example and captures a screenshot to gate destructive item chrome and icon coloring."
    ]
  },
  "steps": [
    { "type": "reset_diagnostics" },
    {
      "type": "wait_until",
      "predicate": { "kind": "exists", "target": { "kind": "test_id", "id": "ui-gallery-theme-preset-trigger" } },
      "timeout_frames": 600
    },
    { "type": "press_key", "key": "escape" },
    { "type": "wait_frames", "n": 2 },
    { "type": "set_window_inner_size", "width_px": 1280.0, "height_px": 900.0 },
    { "type": "wait_frames", "n": 20 },

    { "type": "click", "target": { "kind": "test_id", "id": "ui-gallery-theme-preset-trigger" } },
    { "type": "click_stable", "target": { "kind": "test_id", "id": "ui-gallery-theme-preset-item-zinc-dark" } },
    { "type": "wait_frames", "n": 2 },
    { "type": "press_key", "key": "escape" },
    { "type": "wait_frames", "n": 2 },
    {
      "type": "wait_until",
      "predicate": { "kind": "exists", "target": { "kind": "test_id", "id": "ui-gallery-page-context-menu" } },
      "timeout_frames": 600
    },

    {
      "type": "scroll_into_view",
      "container": { "kind": "test_id", "id": "ui-gallery-content-scroll" },
      "target": { "kind": "test_id", "id": "ui-gallery-context-menu-destructive-trigger" },
      "delta_y": -120.0,
      "require_fully_within_container": true,
      "require_fully_within_window": true,
      "padding_px": 16.0,
      "timeout_frames": 600
    },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "bounds_within_window",
        "target": { "kind": "test_id", "id": "ui-gallery-context-menu-destructive-trigger" },
        "padding_px": 8.0,
        "eps_px": 1.0
      },
      "timeout_frames": 240
    },
    { "type": "move_pointer", "target": { "kind": "test_id", "id": "ui-gallery-context-menu-destructive-trigger" } },
    { "type": "click", "button": "right", "target": { "kind": "test_id", "id": "ui-gallery-context-menu-destructive-trigger" } },
    {
      "type": "wait_until",
      "predicate": { "kind": "exists", "target": { "kind": "test_id", "id": "ui-gallery-context-menu-destructive-delete" } },
      "timeout_frames": 240
    },
    { "type": "wait_frames", "n": 2 },

    { "type": "capture_screenshot", "label": "ui-gallery-context-menu-destructive-zinc-dark" },
    { "type": "capture_bundle", "label": "ui-gallery-context-menu-destructive-zinc-dark" }
  ]
}
