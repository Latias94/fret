{
  "schema_version": 2,
  "meta": {
    "name": "UI gallery: carousel embla duration fast vs slow settling gate",
    "tags": ["ui-gallery", "carousel", "embla", "duration", "gate", "settling"],
    "required_capabilities": ["diag.script_v2"]
  },
  "steps": [
    { "type": "reset_diagnostics" },
    { "type": "press_key", "key": "escape" },
    { "type": "wait_frames", "n": 2 },

    {
      "type": "wait_until",
      "predicate": { "kind": "exists", "target": { "kind": "test_id", "id": "ui-gallery-nav-search" } },
      "timeout_frames": 600
    },

    { "type": "set_window_inner_size", "width_px": 1280.0, "height_px": 720.0 },
    { "type": "wait_frames", "n": 10 },

    { "type": "click_stable", "target": { "kind": "test_id", "id": "ui-gallery-nav-search" } },
    { "type": "press_key", "key": "a", "modifiers": { "ctrl": true } },
    { "type": "press_key", "key": "backspace" },
    { "type": "type_text", "text": "carousel" },
    { "type": "wait_frames", "n": 2 },

    {
      "type": "wait_until",
      "predicate": {
        "kind": "bounds_within_window",
        "target": { "kind": "test_id", "id": "ui-gallery-nav-carousel" },
        "padding_px": 8.0,
        "eps_px": 1.0
      },
      "timeout_frames": 240
    },
    { "type": "click_stable", "target": { "kind": "test_id", "id": "ui-gallery-nav-carousel" } },

    {
      "type": "wait_until",
      "predicate": { "kind": "exists", "target": { "kind": "test_id", "id": "ui-gallery-page-carousel" } },
      "timeout_frames": 600
    },
    {
      "type": "wait_until",
      "predicate": { "kind": "exists", "target": { "kind": "test_id", "id": "ui-gallery-carousel-duration-fast" } },
      "timeout_frames": 600
    },

    {
      "type": "scroll_into_view",
      "container": { "kind": "test_id", "id": "ui-gallery-content-scroll" },
      "target": { "kind": "test_id", "id": "ui-gallery-carousel-duration-fast" },
      "delta_y": -120.0,
      "require_fully_within_container": true,
      "require_fully_within_window": true,
      "padding_px": 16.0,
      "timeout_frames": 600
    },
    { "type": "wait_frames", "n": 12 },

    {
      "type": "wait_until",
      "predicate": { "kind": "visible_in_window", "target": { "kind": "test_id", "id": "ui-gallery-carousel-duration-fast-next" } },
      "timeout_frames": 240
    },
    {
      "type": "wait_until",
      "predicate": { "kind": "visible_in_window", "target": { "kind": "test_id", "id": "ui-gallery-carousel-duration-slow-next" } },
      "timeout_frames": 240
    },
    {
      "type": "wait_until",
      "predicate": { "kind": "checked_is", "target": { "kind": "test_id", "id": "ui-gallery-carousel-duration-fast-can-next" }, "checked": true },
      "timeout_frames": 600
    },
    {
      "type": "wait_until",
      "predicate": { "kind": "checked_is", "target": { "kind": "test_id", "id": "ui-gallery-carousel-duration-slow-can-next" }, "checked": true },
      "timeout_frames": 600
    },
    {
      "type": "wait_until",
      "predicate": { "kind": "checked_is", "target": { "kind": "test_id", "id": "ui-gallery-carousel-duration-fast-embla-enabled" }, "checked": true },
      "timeout_frames": 600
    },
    {
      "type": "wait_until",
      "predicate": { "kind": "checked_is", "target": { "kind": "test_id", "id": "ui-gallery-carousel-duration-slow-embla-enabled" }, "checked": true },
      "timeout_frames": 600
    },
    {
      "type": "wait_until",
      "predicate": { "kind": "checked_is", "target": { "kind": "test_id", "id": "ui-gallery-carousel-duration-fast-at-snap" }, "checked": true },
      "timeout_frames": 600
    },
    {
      "type": "wait_until",
      "predicate": { "kind": "checked_is", "target": { "kind": "test_id", "id": "ui-gallery-carousel-duration-slow-at-snap" }, "checked": true },
      "timeout_frames": 600
    },

    {
      "type": "assert",
      "predicate": { "kind": "checked_is", "target": { "kind": "test_id", "id": "ui-gallery-carousel-duration-fast-settling" }, "checked": false }
    },
    {
      "type": "assert",
      "predicate": { "kind": "checked_is", "target": { "kind": "test_id", "id": "ui-gallery-carousel-duration-slow-settling" }, "checked": false }
    },
    {
      "type": "assert",
      "predicate": { "kind": "checked_is", "target": { "kind": "test_id", "id": "ui-gallery-carousel-duration-fast-selected-1" }, "checked": false }
    },
    {
      "type": "assert",
      "predicate": { "kind": "checked_is", "target": { "kind": "test_id", "id": "ui-gallery-carousel-duration-slow-selected-1" }, "checked": false }
    },

    { "type": "click_stable", "target": { "kind": "test_id", "id": "ui-gallery-carousel-duration-fast-next" } },
    { "type": "wait_frames", "n": 1 },
    {
      "type": "wait_until",
      "predicate": { "kind": "checked_is", "target": { "kind": "test_id", "id": "ui-gallery-carousel-duration-fast-selected-1" }, "checked": true },
      "timeout_frames": 240
    },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "checked_is",
        "target": { "kind": "test_id", "id": "ui-gallery-carousel-duration-fast-selected-snap-large" },
        "checked": true
      },
      "timeout_frames": 240
    },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "checked_is",
        "target": { "kind": "test_id", "id": "ui-gallery-carousel-duration-fast-scroll-duration-fast" },
        "checked": true
      },
      "timeout_frames": 240
    },
    {
      "type": "wait_until",
      "predicate": { "kind": "checked_is", "target": { "kind": "test_id", "id": "ui-gallery-carousel-duration-fast-at-snap" }, "checked": true },
      "timeout_frames": 240
    },

    {
      "type": "wait_until",
      "predicate": { "kind": "checked_is", "target": { "kind": "test_id", "id": "ui-gallery-carousel-duration-fast-settling" }, "checked": false },
      "timeout_frames": 600
    },

    { "type": "click_stable", "target": { "kind": "test_id", "id": "ui-gallery-carousel-duration-slow-next" } },
    {
      "type": "wait_until",
      "predicate": { "kind": "checked_is", "target": { "kind": "test_id", "id": "ui-gallery-carousel-duration-slow-selected-1" }, "checked": true },
      "timeout_frames": 240
    },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "checked_is",
        "target": { "kind": "test_id", "id": "ui-gallery-carousel-duration-slow-selected-snap-large" },
        "checked": true
      },
      "timeout_frames": 240
    },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "checked_is",
        "target": { "kind": "test_id", "id": "ui-gallery-carousel-duration-slow-scroll-duration-slow" },
        "checked": true
      },
      "timeout_frames": 240
    },

    {
      "type": "wait_until",
      "predicate": { "kind": "checked_is", "target": { "kind": "test_id", "id": "ui-gallery-carousel-duration-slow-settling" }, "checked": true },
      "timeout_frames": 240
    },
    {
      "type": "assert",
      "predicate": { "kind": "checked_is", "target": { "kind": "test_id", "id": "ui-gallery-carousel-duration-fast-settling" }, "checked": false }
    },
    {
      "type": "wait_until",
      "predicate": { "kind": "checked_is", "target": { "kind": "test_id", "id": "ui-gallery-carousel-duration-slow-at-snap" }, "checked": true },
      "timeout_frames": 1200
    },

    { "type": "capture_bundle", "label": "ui-gallery-carousel-duration-fast-vs-slow-settling-gate" }
  ]
}
