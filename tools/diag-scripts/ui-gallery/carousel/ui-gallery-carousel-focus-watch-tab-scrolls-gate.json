{
  "schema_version": 2,
  "meta": {
    "name": "UI gallery: carousel watch_focus scrolls focused slide into view",
    "tags": ["ui-gallery", "carousel", "focus", "gate"],
    "required_capabilities": ["diag.script_v2"],
    "target_hints": [
      "Navigate to the Carousel page and use Tab to move focus between slide buttons.",
      "Expected behavior: when focus moves to an offscreen slide, the carousel scrolls it into view."
    ]
  },
  "steps": [
    { "type": "reset_diagnostics" },
    { "type": "press_key", "key": "escape" },
    { "type": "wait_frames", "n": 2 },

    {
      "type": "wait_until",
      "predicate": { "kind": "exists", "target": { "kind": "test_id", "id": "ui-gallery-nav-search" } },
      "timeout_frames": 600
    },

    { "type": "set_window_inner_size", "width_px": 1280.0, "height_px": 720.0 },
    { "type": "wait_frames", "n": 10 },

    { "type": "click", "target": { "kind": "test_id", "id": "ui-gallery-nav-search" } },
    { "type": "press_key", "key": "a", "modifiers": { "ctrl": true } },
    { "type": "press_key", "key": "backspace" },
    { "type": "type_text", "text": "carousel" },
    { "type": "wait_frames", "n": 2 },

    {
      "type": "wait_until",
      "predicate": {
        "kind": "bounds_within_window",
        "target": { "kind": "test_id", "id": "ui-gallery-nav-carousel" },
        "padding_px": 8.0,
        "eps_px": 1.0
      },
      "timeout_frames": 240
    },
    { "type": "click", "target": { "kind": "test_id", "id": "ui-gallery-nav-carousel" } },

    {
      "type": "wait_until",
      "predicate": { "kind": "exists", "target": { "kind": "test_id", "id": "ui-gallery-page-carousel" } },
      "timeout_frames": 600
    },
    {
      "type": "wait_until",
      "predicate": { "kind": "exists", "target": { "kind": "test_id", "id": "ui-gallery-carousel-focus" } },
      "timeout_frames": 600
    },
    {
      "type": "scroll_into_view",
      "container": { "kind": "test_id", "id": "ui-gallery-content-scroll" },
      "target": { "kind": "test_id", "id": "ui-gallery-carousel-focus" },
      "delta_y": -120.0,
      "require_fully_within_container": true,
      "require_fully_within_window": true,
      "padding_px": 16.0,
      "timeout_frames": 600
    },

    {
      "type": "wait_until",
      "predicate": { "kind": "visible_in_window", "target": { "kind": "test_id", "id": "ui-gallery-carousel-focus-item-1" } },
      "timeout_frames": 240
    },
    { "type": "click", "target": { "kind": "test_id", "id": "ui-gallery-carousel-focus-button-1" } },
    { "type": "wait_frames", "n": 2 },
    { "type": "press_key", "key": "tab" },
    { "type": "wait_frames", "n": 12 },

    {
      "type": "wait_until",
      "predicate": { "kind": "visible_in_window", "target": { "kind": "test_id", "id": "ui-gallery-carousel-focus-item-2" } },
      "timeout_frames": 600
    },

    { "type": "capture_bundle", "label": "ui-gallery-carousel-focus-watch-tab-scrolls" }
  ]
}

