{
  "schema_version": 2,
  "steps": [
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-nav-search" }
      },
      "timeout_frames": 240
    },
    { "type": "click", "target": { "kind": "test_id", "id": "ui-gallery-nav-search" } },
    {
      "type": "press_key",
      "key": "a",
      "modifiers": {
        "alt": false,
        "ctrl": true,
        "meta": false,
        "shift": false
      },
      "repeat": false
    },
    {
      "type": "press_key",
      "key": "backspace",
      "modifiers": {
        "alt": false,
        "ctrl": false,
        "meta": false,
        "shift": false
      },
      "repeat": false
    },
    { "type": "type_text", "text": "datatable" },
    { "type": "wait_frames", "n": 2 },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "bounds_within_window",
        "padding_px": 8.0,
        "eps_px": 0.0,
        "target": { "kind": "test_id", "id": "ui-gallery-nav-data-table" }
      },
      "timeout_frames": 240
    },
    { "type": "click", "target": { "kind": "test_id", "id": "ui-gallery-nav-data-table" } },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-data-table-reusable-root" }
      },
      "timeout_frames": 240
    },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-data-table-reusable-view-options" }
      },
      "timeout_frames": 240
    },
    {
      "type": "scroll_into_view",
      "container": { "kind": "test_id", "id": "ui-gallery-content-scroll" },
      "target": { "kind": "test_id", "id": "ui-gallery-data-table-reusable-view-options" },
      "delta_y": -320.0,
      "padding_px": 16.0,
      "timeout_frames": 600
    },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-data-table-reusable-cell-1-status" }
      },
      "timeout_frames": 240
    },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-data-table-reusable-cell-1-email" }
      },
      "timeout_frames": 240
    },
    { "type": "click_stable", "target": { "kind": "test_id", "id": "ui-gallery-data-table-reusable-view-options" } },
    { "type": "wait_frames", "n": 2 },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "role_and_name", "role": "menu_item_checkbox", "name": "Status" }
      },
      "timeout_frames": 240
    },
    { "type": "click", "target": { "kind": "role_and_name", "role": "menu_item_checkbox", "name": "Status" } },
    { "type": "wait_frames", "n": 2 },
    {
      "type": "assert",
      "predicate": {
        "kind": "not_exists",
        "target": { "kind": "test_id", "id": "ui-gallery-data-table-reusable-cell-1-status" }
      }
    },
    {
      "type": "assert",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-data-table-reusable-cell-1-email" }
      }
    },
    {
      "type": "assert",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-data-table-reusable-pagination" }
      }
    },
    {
      "type": "capture_bundle",
      "label": "ui-gallery-data-table-reusable-view-options-toggle"
    }
  ]
}
