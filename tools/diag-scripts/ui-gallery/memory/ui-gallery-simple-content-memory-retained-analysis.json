{
  "schema_version": 2,
  "meta": {
    "name": "ui-gallery: simple content retained memory analysis (nav none)",
    "tags": [
      "ui-gallery",
      "memory",
      "analysis",
      "retained",
      "nav-none",
      "simple-content",
      "bisect"
    ],
    "required_capabilities": [
      "diag.script_v2"
    ],
    "env_defaults": {
      "FRET_DIAG_DEBUG_SNAPSHOT": 1,
      "FRET_DIAG_SEMANTICS_TEST_IDS_ONLY": 0,
      "FRET_DIAG_BUNDLE_DUMP_SEMANTICS_TEST_IDS_ONLY": 1,
      "FRET_DIAG_MAX_SEMANTICS_NODES": 8000,
      "FRET_DIAG_WGPU_ALLOCATOR_REPORT": 1,
      "FRET_DIAG_WGPU_ALLOCATOR_REPORT_EVERY_N_FRAMES": 600,
      "FRET_UI_GALLERY_START_PAGE": "card",
      "FRET_UI_GALLERY_NAV_QUERY": "__none__",
      "FRET_UI_GALLERY_BISECT": 32
    },
    "target_hints": [
      "Starts UI Gallery on the card page with the nav list hidden and BISECT_SIMPLE_CONTENT enabled, then captures a retained-analysis bundle for the shared shell floor."
    ]
  },
  "steps": [
    {
      "type": "reset_diagnostics"
    },
    {
      "type": "wait_frames",
      "n": 10
    },
    {
      "type": "reset_diagnostics"
    },
    {
      "type": "wait_frames",
      "n": 600
    },
    {
      "type": "capture_bundle",
      "label": "ui-gallery-simple-content-memory-retained-analysis",
      "max_snapshots": 1
    }
  ]
}
