{
  "schema_version": 2,
  "meta": {
    "name": "ui-gallery: minimal root memory steady",
    "tags": ["ui-gallery", "memory", "steady", "bisect", "minimal-root"],
    "required_capabilities": ["diag.script_v2"],
    "env_defaults": {
      "FRET_DIAG_DEBUG_SNAPSHOT": 0,
      "FRET_DIAG_SEMANTICS_TEST_IDS_ONLY": 1,
      "FRET_DIAG_MAX_SEMANTICS_NODES": 8000,
      "FRET_DIAG_WGPU_ALLOCATOR_REPORT": 1,
      "FRET_DIAG_WGPU_ALLOCATOR_REPORT_EVERY_N_FRAMES": 600,
      "FRET_UI_GALLERY_BISECT": 1
    },
    "target_hints": [
      "Runs UI Gallery with BISECT_MINIMAL_ROOT and captures a steady-state bundle."
    ]
  },
  "steps": [
    { "type": "reset_diagnostics" },
    { "type": "wait_frames", "n": 10 },
    { "type": "reset_diagnostics" },
    { "type": "wait_frames", "n": 600 },
    { "type": "capture_bundle", "label": "ui-gallery-minimal-root-memory-steady", "max_snapshots": 1 }
  ]
}
