{
  "schema_version": 2,
  "meta": {
    "name": "ui-gallery: nav search debug (code editor query)",
    "tags": ["ui-gallery", "nav", "search", "debug"],
    "required_capabilities": ["diag.script_v2"],
    "target_hints": ["Types into the UI Gallery nav search and captures a bundle for inspection."]
  },
  "steps": [
    { "type": "reset_diagnostics" },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-nav-search" }
      },
      "timeout_frames": 240
    },
    { "type": "click", "target": { "kind": "test_id", "id": "ui-gallery-nav-search" } },
    { "type": "press_key", "key": "a", "modifiers": { "ctrl": true } },
    { "type": "press_key", "key": "backspace" },
    { "type": "type_text", "text": "code editor" },
    { "type": "wait_frames", "n": 10 },
    { "type": "capture_bundle", "label": "ui-gallery-nav-search-code-editor-debug" }
  ]
}

