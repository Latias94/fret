{
  "schema_version": 2,
  "meta": {
    "name": "ui-gallery: card retained memory analysis (no heavy sections, preview only, nav none)",
    "tags": [
      "ui-gallery",
      "card",
      "memory",
      "analysis",
      "retained",
      "nav-none",
      "section",
      "heavy-sections",
      "preview-only"
    ],
    "required_capabilities": [
      "diag.script_v2"
    ],
    "env_defaults": {
      "FRET_DIAG_DEBUG_SNAPSHOT": 1,
      "FRET_DIAG_SEMANTICS_TEST_IDS_ONLY": 0,
      "FRET_DIAG_BUNDLE_DUMP_SEMANTICS_TEST_IDS_ONLY": 1,
      "FRET_DIAG_MAX_SEMANTICS_NODES": 8000,
      "FRET_DIAG_WGPU_ALLOCATOR_REPORT": 1,
      "FRET_DIAG_WGPU_ALLOCATOR_REPORT_EVERY_N_FRAMES": 600,
      "FRET_UI_GALLERY_START_PAGE": "card",
      "FRET_UI_GALLERY_NAV_QUERY": "__none__",
      "FRET_UI_GALLERY_BISECT": 176128
    },
    "target_hints": [
      "Starts UI Gallery on the card page with Image + Compositions + Meeting Notes hidden, all remaining card code tabs suppressed, and the nav list hidden so the lighter preview-body half can be measured in retained-analysis mode."
    ]
  },
  "steps": [
    {
      "type": "reset_diagnostics"
    },
    {
      "type": "wait_frames",
      "n": 10
    },
    {
      "type": "reset_diagnostics"
    },
    {
      "type": "wait_frames",
      "n": 600
    },
    {
      "type": "capture_bundle",
      "label": "ui-gallery-card-no-heavy-sections-preview-only-memory-retained-analysis",
      "max_snapshots": 1
    }
  ]
}
