{
  "schema_version": 2,
  "meta": {
    "name": "ui-gallery: code-editor torture memory steady",
    "tags": ["ui-gallery", "code-editor", "memory", "steady"],
    "required_capabilities": ["diag.script_v2"],
    "target_hints": [
      "Navigates to the code editor torture page, scrolls to grow caches, waits for steady state, then captures a bundle."
    ]
  },
  "steps": [
    { "type": "reset_diagnostics" },
    { "type": "wait_frames", "n": 10 },

    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-nav-search" }
      },
      "timeout_frames": 240
    },
    { "type": "click", "target": { "kind": "test_id", "id": "ui-gallery-nav-search" } },
    { "type": "press_key", "key": "a", "modifiers": { "ctrl": true } },
    { "type": "press_key", "key": "backspace" },
    { "type": "type_text", "text": "code_editor_torture" },
    { "type": "wait_frames", "n": 2 },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "bounds_within_window",
        "target": { "kind": "test_id", "id": "ui-gallery-nav-code-editor-torture" },
        "padding_px": 8.0,
        "eps_px": 1.0
      },
      "timeout_frames": 240
    },
    { "type": "click", "target": { "kind": "test_id", "id": "ui-gallery-nav-code-editor-torture" } },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-page-code-editor-torture" }
      },
      "timeout_frames": 240
    },

    { "type": "wait_frames", "n": 30 },
    { "type": "click", "target": { "kind": "test_id", "id": "ui-gallery-code-editor-torture-viewport" } },

    { "type": "wheel", "target": { "kind": "test_id", "id": "ui-gallery-code-editor-torture-viewport" }, "delta_y": -720.0 },
    { "type": "wheel", "target": { "kind": "test_id", "id": "ui-gallery-code-editor-torture-viewport" }, "delta_y": -720.0 },
    { "type": "wheel", "target": { "kind": "test_id", "id": "ui-gallery-code-editor-torture-viewport" }, "delta_y": -720.0 },
    { "type": "wheel", "target": { "kind": "test_id", "id": "ui-gallery-code-editor-torture-viewport" }, "delta_y": 720.0 },
    { "type": "wheel", "target": { "kind": "test_id", "id": "ui-gallery-code-editor-torture-viewport" }, "delta_y": 720.0 },

    { "type": "wait_frames", "n": 600 },
    { "type": "capture_bundle", "label": "ui-gallery-code-editor-torture-memory-steady" }
  ]
}

