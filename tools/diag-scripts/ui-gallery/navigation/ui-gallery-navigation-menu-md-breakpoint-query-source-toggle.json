{
  "schema_version": 2,
  "meta": {
    "name": "ui-gallery-navigation-menu-md-breakpoint-query-source-toggle",
    "required_capabilities": ["diag.script_v2", "diag.screenshot_png"]
  },
  "steps": [
    { "type": "reset_diagnostics" },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-nav-search" }
      },
      "timeout_frames": 600
    },
    { "type": "press_key", "key": "escape" },
    { "type": "wait_frames", "n": 2 },

    { "type": "set_window_outer_position", "x_px": 120.0, "y_px": 120.0 },
    { "type": "set_window_inner_size", "width_px": 1280.0, "height_px": 720.0 },
    { "type": "wait_frames", "n": 12 },

    { "type": "click", "target": { "kind": "test_id", "id": "ui-gallery-nav-search" } },
    { "type": "press_key", "key": "a", "modifiers": { "ctrl": true } },
    { "type": "press_key", "key": "backspace" },
    { "type": "type_text", "text": "navigation menu" },
    { "type": "wait_frames", "n": 2 },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-nav-navigation-menu" }
      },
      "timeout_frames": 600
    },
    { "type": "click", "target": { "kind": "test_id", "id": "ui-gallery-nav-navigation-menu" } },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-page-navigation-menu" }
      },
      "timeout_frames": 600
    },

    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": {
          "kind": "test_id",
          "id": "ui-gallery-navigation-menu-md-breakpoint-query-switch"
        }
      },
      "timeout_frames": 600
    },
    {
      "type": "assert",
      "predicate": {
        "kind": "checked_is",
        "target": {
          "kind": "test_id",
          "id": "ui-gallery-navigation-menu-md-breakpoint-query-switch"
        },
        "checked": false
      }
    },

    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": {
          "kind": "test_id",
          "id": "ui-gallery-navigation-menu-demo-trigger-components"
        }
      },
      "timeout_frames": 600
    },
    {
      "type": "scroll_into_view",
      "container": { "kind": "test_id", "id": "ui-gallery-content-scroll" },
      "target": {
        "kind": "test_id",
        "id": "ui-gallery-navigation-menu-demo-trigger-components"
      },
      "delta_y": -120.0,
      "require_fully_within_container": false,
      "require_fully_within_window": false,
      "padding_px": 16.0,
      "timeout_frames": 600
    },
    { "type": "wait_frames", "n": 2 },
    {
      "type": "click_stable",
      "target": {
        "kind": "test_id",
        "id": "ui-gallery-navigation-menu-demo-trigger-components"
      }
    },
    { "type": "wait_frames", "n": 12 },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": {
          "kind": "test_id",
          "id": "ui-gallery-navigation-menu-demo-link-alert-dialog"
        }
      },
      "timeout_frames": 600
    },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": {
          "kind": "test_id",
          "id": "ui-gallery-navigation-menu-demo-viewport"
        }
      },
      "timeout_frames": 600
    },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": {
          "kind": "test_id",
          "id": "ui-gallery-navigation-menu-demo-components-layout-two-col"
        }
      },
      "timeout_frames": 600
    },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "not_exists",
        "target": {
          "kind": "test_id",
          "id": "ui-gallery-navigation-menu-demo-components-layout-single-col"
        }
      },
      "timeout_frames": 600
    },
    {
      "type": "capture_screenshot",
      "label": "ui-gallery-navigation-menu-md-breakpoint-query-source-toggle-viewport"
    },

    {
      "type": "click_stable",
      "target": {
        "kind": "test_id",
        "id": "ui-gallery-navigation-menu-demo-trigger-components"
      }
    },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "not_exists",
        "target": {
          "kind": "test_id",
          "id": "ui-gallery-navigation-menu-demo-link-alert-dialog"
        }
      },
      "timeout_frames": 600
    },

    {
      "type": "click",
      "target": {
        "kind": "test_id",
        "id": "ui-gallery-navigation-menu-md-breakpoint-query-switch"
      }
    },
    { "type": "wait_frames", "n": 2 },
    {
      "type": "assert",
      "predicate": {
        "kind": "checked_is",
        "target": {
          "kind": "test_id",
          "id": "ui-gallery-navigation-menu-md-breakpoint-query-switch"
        },
        "checked": true
      }
    },

    {
      "type": "move_pointer",
      "target": { "kind": "test_id", "id": "ui-gallery-nav-search" }
    },
    { "type": "wait_frames", "n": 2 },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": {
          "kind": "test_id",
          "id": "ui-gallery-navigation-menu-demo-trigger-components"
        }
      },
      "timeout_frames": 600
    },
    {
      "type": "scroll_into_view",
      "container": { "kind": "test_id", "id": "ui-gallery-content-scroll" },
      "target": {
        "kind": "test_id",
        "id": "ui-gallery-navigation-menu-demo-trigger-components"
      },
      "delta_y": -120.0,
      "require_fully_within_container": false,
      "require_fully_within_window": false,
      "padding_px": 16.0,
      "timeout_frames": 600
    },
    { "type": "wait_frames", "n": 2 },

    {
      "type": "click",
      "target": {
        "kind": "test_id",
        "id": "ui-gallery-navigation-menu-demo-trigger-components"
      }
    },
    { "type": "wait_frames", "n": 12 },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": {
          "kind": "test_id",
          "id": "ui-gallery-navigation-menu-demo-link-alert-dialog"
        }
      },
      "timeout_frames": 600
    },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": {
          "kind": "test_id",
          "id": "ui-gallery-navigation-menu-demo-viewport"
        }
      },
      "timeout_frames": 600
    },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": {
          "kind": "test_id",
          "id": "ui-gallery-navigation-menu-demo-components-layout-single-col"
        }
      },
      "timeout_frames": 600
    },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "not_exists",
        "target": {
          "kind": "test_id",
          "id": "ui-gallery-navigation-menu-demo-components-layout-two-col"
        }
      },
      "timeout_frames": 600
    },
    {
      "type": "capture_screenshot",
      "label": "ui-gallery-navigation-menu-md-breakpoint-query-source-toggle-container"
    },

    {
      "type": "capture_bundle",
      "label": "ui-gallery-navigation-menu-md-breakpoint-query-source-toggle"
    }
  ]
}
