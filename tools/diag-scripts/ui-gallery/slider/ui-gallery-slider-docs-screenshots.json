{
  "schema_version": 2,
  "meta": {
    "name": "UI gallery: Slider docs screenshots",
    "tags": ["ui-gallery", "shadcn", "slider", "docs", "screenshots"],
    "required_capabilities": ["diag.script_v2", "diag.screenshot_png"],
    "target_hints": [
      "Navigates to the Slider page via the left nav search.",
      "Captures the docs-path sections first (`Demo` through `API Reference`) so docs-surface parity stays reviewable."
    ]
  },
  "steps": [
    { "type": "reset_diagnostics" },
    {
      "type": "wait_until",
      "predicate": { "kind": "exists", "target": { "kind": "test_id", "id": "ui-gallery-nav-search" } },
      "timeout_frames": 600
    },
    {
      "type": "type_text_into",
      "target": { "kind": "test_id", "id": "ui-gallery-nav-search" },
      "text": "slider",
      "clear_before_type": true,
      "timeout_frames": 600
    },
    { "type": "wait_frames", "n": 2 },
    {
      "type": "scroll_into_view",
      "container": { "kind": "test_id", "id": "ui-gallery-nav-scroll" },
      "target": { "kind": "test_id", "id": "ui-gallery-nav-slider" },
      "delta_y": -240.0,
      "timeout_frames": 600
    },
    { "type": "click_stable", "target": { "kind": "test_id", "id": "ui-gallery-nav-slider" } },
    {
      "type": "wait_until",
      "predicate": { "kind": "exists", "target": { "kind": "test_id", "id": "ui-gallery-page-slider" } },
      "timeout_frames": 600
    },

    {
      "type": "scroll_into_view",
      "container": { "kind": "test_id", "id": "ui-gallery-content-scroll" },
      "target": { "kind": "test_id", "id": "ui-gallery-slider-demo-content" },
      "delta_y": -120.0,
      "require_fully_within_container": true,
      "require_fully_within_window": true,
      "padding_px": 16.0,
      "timeout_frames": 600
    },
    { "type": "wait_frames", "n": 2 },
    { "type": "capture_screenshot", "label": "ui-gallery-slider-docs.01-demo" },

    {
      "type": "scroll_into_view",
      "container": { "kind": "test_id", "id": "ui-gallery-content-scroll" },
      "target": { "kind": "test_id", "id": "ui-gallery-slider-usage-section-content" },
      "delta_y": -120.0,
      "require_fully_within_container": true,
      "require_fully_within_window": true,
      "padding_px": 16.0,
      "timeout_frames": 600
    },
    { "type": "wait_frames", "n": 2 },
    { "type": "capture_screenshot", "label": "ui-gallery-slider-docs.02-usage" },

    {
      "type": "scroll_into_view",
      "container": { "kind": "test_id", "id": "ui-gallery-content-scroll" },
      "target": { "kind": "test_id", "id": "ui-gallery-slider-range-section-content" },
      "delta_y": -120.0,
      "require_fully_within_container": true,
      "require_fully_within_window": true,
      "padding_px": 16.0,
      "timeout_frames": 600
    },
    { "type": "wait_frames", "n": 2 },
    { "type": "capture_screenshot", "label": "ui-gallery-slider-docs.03-range" },

    {
      "type": "scroll_into_view",
      "container": { "kind": "test_id", "id": "ui-gallery-content-scroll" },
      "target": { "kind": "test_id", "id": "ui-gallery-slider-multiple-section-content" },
      "delta_y": -120.0,
      "require_fully_within_container": true,
      "require_fully_within_window": true,
      "padding_px": 16.0,
      "timeout_frames": 600
    },
    { "type": "wait_frames", "n": 2 },
    { "type": "capture_screenshot", "label": "ui-gallery-slider-docs.04-multiple" },

    {
      "type": "scroll_into_view",
      "container": { "kind": "test_id", "id": "ui-gallery-content-scroll" },
      "target": { "kind": "test_id", "id": "ui-gallery-slider-vertical-section-content" },
      "delta_y": -120.0,
      "require_fully_within_container": true,
      "require_fully_within_window": true,
      "padding_px": 16.0,
      "timeout_frames": 600
    },
    { "type": "wait_frames", "n": 2 },
    { "type": "capture_screenshot", "label": "ui-gallery-slider-docs.05-vertical" },

    {
      "type": "scroll_into_view",
      "container": { "kind": "test_id", "id": "ui-gallery-content-scroll" },
      "target": { "kind": "test_id", "id": "ui-gallery-slider-controlled-section-content" },
      "delta_y": -120.0,
      "require_fully_within_container": true,
      "require_fully_within_window": true,
      "padding_px": 16.0,
      "timeout_frames": 600
    },
    { "type": "wait_frames", "n": 2 },
    { "type": "capture_screenshot", "label": "ui-gallery-slider-docs.06-controlled" },

    {
      "type": "scroll_into_view",
      "container": { "kind": "test_id", "id": "ui-gallery-content-scroll" },
      "target": { "kind": "test_id", "id": "ui-gallery-slider-disabled-section-content" },
      "delta_y": -120.0,
      "require_fully_within_container": true,
      "require_fully_within_window": true,
      "padding_px": 16.0,
      "timeout_frames": 600
    },
    { "type": "wait_frames", "n": 2 },
    { "type": "capture_screenshot", "label": "ui-gallery-slider-docs.07-disabled" },

    {
      "type": "scroll_into_view",
      "container": { "kind": "test_id", "id": "ui-gallery-content-scroll" },
      "target": { "kind": "test_id", "id": "ui-gallery-slider-rtl-section-content" },
      "delta_y": -120.0,
      "require_fully_within_container": true,
      "require_fully_within_window": true,
      "padding_px": 16.0,
      "timeout_frames": 600
    },
    { "type": "wait_frames", "n": 2 },
    { "type": "capture_screenshot", "label": "ui-gallery-slider-docs.08-rtl" },

    {
      "type": "scroll_into_view",
      "container": { "kind": "test_id", "id": "ui-gallery-content-scroll" },
      "target": { "kind": "test_id", "id": "ui-gallery-slider-api-reference-content" },
      "delta_y": -120.0,
      "require_fully_within_container": true,
      "require_fully_within_window": true,
      "padding_px": 16.0,
      "timeout_frames": 600
    },
    { "type": "wait_frames", "n": 2 },
    { "type": "capture_screenshot", "label": "ui-gallery-slider-docs.09-api-reference" },
    { "type": "capture_bundle", "label": "ui-gallery-slider-docs" }
  ]
}
