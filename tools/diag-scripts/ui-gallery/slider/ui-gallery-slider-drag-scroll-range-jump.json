{
  "schema_version": 2,
  "meta": {
    "name": "ui-gallery-slider-drag-scroll-range-jump",
    "required_capabilities": ["diag.script_v2", "diag.screenshot_png"],
    "tags": ["ui_gallery", "shadcn", "slider", "scroll", "regression"],
    "env_defaults": {
      "FRET_UI_GALLERY_BISECT": "0"
    },
    "target_hints": [
      "Repro: navigating to the Slider page and dragging the controlled slider should not cause the content scroll range to jump."
    ]
  },
  "steps": [
    { "type": "reset_diagnostics" },
    { "type": "press_key", "key": "escape" },
    { "type": "wait_frames", "n": 2 },
    { "type": "set_window_inner_size", "width_px": 1280.0, "height_px": 1024.0 },
    { "type": "wait_frames", "n": 20 },

    {
      "type": "wait_until",
      "predicate": { "kind": "exists", "target": { "kind": "test_id", "id": "ui-gallery-nav-search" } },
      "timeout_frames": 600
    },
    {
      "type": "type_text_into",
      "target": { "kind": "test_id", "id": "ui-gallery-nav-search" },
      "text": "slider",
      "clear_before_type": true,
      "timeout_frames": 900
    },
    { "type": "wait_frames", "n": 2 },

    {
      "type": "wait_until",
      "predicate": { "kind": "bounds_within_window", "target": { "kind": "test_id", "id": "ui-gallery-nav-slider" }, "padding_px": 8.0, "eps_px": 1.0 },
      "timeout_frames": 600
    },
    {
      "type": "wait_until",
      "predicate": { "kind": "exists", "target": { "kind": "test_id", "id": "ui-gallery-nav-slider" } },
      "timeout_frames": 900
    },
    {
      "type": "click_stable",
      "target": { "kind": "test_id", "id": "ui-gallery-nav-slider" },
      "stable_frames": 3,
      "max_move_px": 2.0,
      "timeout_frames": 900
    },
    {
      "type": "wait_until",
      "predicate": { "kind": "exists", "target": { "kind": "test_id", "id": "ui-gallery-page-slider" } },
      "timeout_frames": 900
    },
    {
      "type": "wait_until",
      "predicate": { "kind": "exists", "target": { "kind": "test_id", "id": "ui-gallery-content-scroll" } },
      "timeout_frames": 900
    },
    {
      "type": "wait_until",
      "predicate": { "kind": "exists", "target": { "kind": "test_id", "id": "ui-gallery-slider-demo-tabs-trigger-preview" } },
      "timeout_frames": 900
    },
    {
      "type": "click_stable",
      "target": { "kind": "test_id", "id": "ui-gallery-slider-demo-tabs-trigger-preview" },
      "stable_frames": 2,
      "max_move_px": 2.0,
      "timeout_frames": 900
    },
    { "type": "wait_frames", "n": 10 },

    {
      "type": "scroll_into_view",
      "container": { "kind": "test_id", "id": "ui-gallery-content-scroll" },
      "target": { "kind": "test_id", "id": "ui-gallery-slider-controlled" },
      "delta_y": -120.0,
      "require_fully_within_container": true,
      "require_fully_within_window": true,
      "padding_px": 24.0,
      "timeout_frames": 900
    },
    {
      "type": "wait_bounds_stable",
      "target": { "kind": "test_id", "id": "ui-gallery-slider-controlled" },
      "stable_frames": 8,
      "max_move_px": 0.5,
      "timeout_frames": 900
    },
    { "type": "wait_frames", "n": 10 },
    { "type": "capture_bundle", "label": "ui-gallery-slider-drag-scroll-range-jump.before_drag" },
    { "type": "capture_screenshot", "label": "ui-gallery-slider-drag-scroll-range-jump.before_drag" },

    {
      "type": "drag_pointer",
      "target": { "kind": "test_id", "id": "ui-gallery-slider-controlled-thumb-0" },
      "delta_x": 260.0,
      "delta_y": 0.0,
      "steps": 18
    },
    { "type": "wait_frames", "n": 15 },
    { "type": "capture_bundle", "label": "ui-gallery-slider-drag-scroll-range-jump.after_drag_thumb_0" },
    { "type": "capture_screenshot", "label": "ui-gallery-slider-drag-scroll-range-jump.after_drag_thumb_0" },

    {
      "type": "drag_pointer",
      "target": { "kind": "test_id", "id": "ui-gallery-slider-controlled-thumb-1" },
      "delta_x": 260.0,
      "delta_y": 0.0,
      "steps": 18
    },
    { "type": "wait_frames", "n": 15 },
    { "type": "capture_bundle", "label": "ui-gallery-slider-drag-scroll-range-jump.after_drag_thumb_1" },
    { "type": "capture_screenshot", "label": "ui-gallery-slider-drag-scroll-range-jump.after_drag_thumb_1" },

    {
      "type": "scroll_into_view",
      "container": { "kind": "test_id", "id": "ui-gallery-content-scroll" },
      "target": { "kind": "test_id", "id": "ui-gallery-slider-single" },
      "delta_y": -240.0,
      "require_fully_within_container": true,
      "require_fully_within_window": true,
      "padding_px": 24.0,
      "timeout_frames": 900
    },
    {
      "type": "wait_bounds_stable",
      "target": { "kind": "test_id", "id": "ui-gallery-slider-single" },
      "stable_frames": 8,
      "max_move_px": 0.5,
      "timeout_frames": 900
    },
    { "type": "capture_bundle", "label": "ui-gallery-slider-drag-scroll-range-jump.before_drag_single" },
    { "type": "capture_screenshot", "label": "ui-gallery-slider-drag-scroll-range-jump.before_drag_single" },
    {
      "type": "drag_pointer",
      "target": { "kind": "test_id", "id": "ui-gallery-slider-single-thumb-0" },
      "delta_x": 260.0,
      "delta_y": 0.0,
      "steps": 18
    },
    { "type": "wait_frames", "n": 15 },
    { "type": "capture_bundle", "label": "ui-gallery-slider-drag-scroll-range-jump.after_drag_single" },
    { "type": "capture_screenshot", "label": "ui-gallery-slider-drag-scroll-range-jump.after_drag_single" },

    { "type": "wait_frames", "n": 2 },
    { "type": "capture_bundle", "label": "ui-gallery-slider-drag-scroll-range-jump" }
  ]
}
