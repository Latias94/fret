{
  "schema_version": 2,
  "meta": {
    "name": "ui-gallery-dropdown-menu-part-surface-smoke",
    "required_capabilities": ["diag.script_v2"],
    "env_defaults": {
      "FRET_UI_GALLERY_START_PAGE": "dropdown_menu"
    }
  },
  "steps": [
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-page-dropdown-menu" }
      },
      "timeout_frames": 240
    },
    {
      "type": "scroll_into_view",
      "container": { "kind": "test_id", "id": "ui-gallery-content-scroll" },
      "target": { "kind": "test_id", "id": "ui-gallery-dropdown-menu-parts-trigger" },
      "delta_y": -160.0,
      "require_fully_within_container": true,
      "require_fully_within_window": true,
      "padding_px": 24.0,
      "timeout_frames": 600
    },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "bounds_within_window",
        "target": { "kind": "test_id", "id": "ui-gallery-dropdown-menu-parts-trigger" },
        "padding_px": 8.0,
        "eps_px": 1.0
      },
      "timeout_frames": 240
    },
    {
      "type": "click_stable",
      "target": { "kind": "test_id", "id": "ui-gallery-dropdown-menu-parts-trigger" }
    },
    { "type": "wait_frames", "n": 2 },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-dropdown-menu-parts-profile" }
      },
      "timeout_frames": 240
    },
    {
      "type": "move_pointer",
      "target": { "kind": "test_id", "id": "ui-gallery-dropdown-menu-parts-more" }
    },
    { "type": "wait_frames", "n": 10 },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-dropdown-menu-parts-sub-rename" }
      },
      "timeout_frames": 240
    },
    { "type": "capture_bundle", "label": "ui-gallery-dropdown-menu-part-surface-smoke" },
    { "type": "capture_screenshot", "label": "ui-gallery-dropdown-menu-part-surface-smoke" }
  ]
}
