{
  "schema_version": 2,
  "meta": {
    "name": "ui-gallery-dropdown-menu-submenu-open-smoke",
    "required_capabilities": ["diag.script_v2"],
    "tags": ["ui_gallery", "shadcn", "dropdown_menu", "submenu", "mouse", "regression_pack"],
    "env_defaults": {
      "FRET_UI_GALLERY_START_PAGE": "dropdown_menu"
    }
  },
  "steps": [
    { "type": "reset_diagnostics" },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-page-dropdown-menu" }
      },
      "timeout_frames": 600
    },
    { "type": "press_key", "key": "escape" },
    { "type": "wait_frames", "n": 2 },
    { "type": "set_window_inner_size", "width_px": 1280.0, "height_px": 760.0 },
    { "type": "wait_frames", "n": 10 },
    {
      "type": "scroll_into_view",
      "container": { "kind": "test_id", "id": "ui-gallery-content-scroll" },
      "target": { "kind": "test_id", "id": "ui-gallery-dropdown-menu-submenu-trigger.chrome" },
      "delta_y": -240.0,
      "padding_px": 16.0,
      "timeout_frames": 1200
    },
    { "type": "wait_frames", "n": 2 },
    {
      "type": "click_stable",
      "target": {
        "kind": "test_id",
        "id": "ui-gallery-dropdown-menu-submenu-trigger.chrome"
      }
    },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": {
          "kind": "test_id",
          "id": "ui-gallery-dropdown-menu-submenu-invite-users"
        }
      },
      "timeout_frames": 600
    },
    {
      "type": "move_pointer",
      "target": {
        "kind": "test_id",
        "id": "ui-gallery-dropdown-menu-submenu-invite-users"
      }
    },
    { "type": "wait_frames", "n": 10 },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": {
          "kind": "test_id",
          "id": "ui-gallery-dropdown-menu-submenu-more-options"
        }
      },
      "timeout_frames": 600
    },
    {
      "type": "move_pointer",
      "target": {
        "kind": "test_id",
        "id": "ui-gallery-dropdown-menu-submenu-more-options"
      }
    },
    { "type": "wait_frames", "n": 10 },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": {
          "kind": "test_id",
          "id": "ui-gallery-dropdown-menu-submenu-calendly"
        }
      },
      "timeout_frames": 600
    },
    {
      "type": "capture_bundle",
      "label": "ui-gallery-dropdown-menu-submenu-open-smoke"
    }
  ]
}
