{
  "schema_version": 2,
  "meta": {
    "name": "ui-gallery-dropdown-menu-demo-click-profile-last-action",
    "required_capabilities": ["diag.script_v2"],
    "tags": ["ui_gallery", "shadcn", "dropdown_menu", "mouse", "regression_pack"]
  },
  "steps": [
    {
      "type": "ensure_visible",
      "target": { "kind": "test_id", "id": "ui-gallery-nav-search" },
      "within_window": true,
      "padding_px": 8.0,
      "timeout_frames": 600
    },
    { "type": "press_key", "key": "escape" },
    { "type": "wait_frames", "n": 2 },

    {
      "type": "click_stable",
      "target": { "kind": "test_id", "id": "ui-gallery-nav-search" },
      "button": "left",
      "stable_frames": 10,
      "max_move_px": 0.5,
      "timeout_frames": 600
    },
    { "type": "press_key", "key": "a", "modifiers": { "ctrl": true } },
    { "type": "press_key", "key": "backspace" },
    { "type": "type_text", "text": "dropdown menu" },
    { "type": "wait_frames", "n": 2 },

    {
      "type": "ensure_visible",
      "target": { "kind": "test_id", "id": "ui-gallery-nav-dropdown-menu" },
      "within_window": true,
      "padding_px": 8.0,
      "timeout_frames": 600
    },
    {
      "type": "click_stable",
      "target": { "kind": "test_id", "id": "ui-gallery-nav-dropdown-menu" },
      "button": "left",
      "stable_frames": 10,
      "max_move_px": 0.5,
      "timeout_frames": 600
    },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-page-dropdown-menu" }
      },
      "timeout_frames": 600
    },

    {
      "type": "click_stable",
      "target": { "kind": "test_id", "id": "ui-gallery-dropdown-menu-demo-trigger.chrome" },
      "button": "left",
      "stable_frames": 10,
      "max_move_px": 0.5,
      "timeout_frames": 600
    },
    { "type": "press_key", "key": "arrow_down" },
    { "type": "wait_frames", "n": 2 },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-dropdown-menu-demo-profile" }
      },
      "timeout_frames": 240
    },
    {
      "type": "click_stable",
      "target": { "kind": "test_id", "id": "ui-gallery-dropdown-menu-demo-profile" },
      "button": "left",
      "stable_frames": 10,
      "max_move_px": 0.5,
      "timeout_frames": 600
    },
    {
      "type": "wait_frames",
      "n": 5
    },
    {
      "type": "assert",
      "predicate": {
        "kind": "label_contains",
        "target": { "kind": "test_id", "id": "ui-gallery-status-last-action" },
        "text": "menu.dropdown.apple"
      }
    },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "focus_is",
        "target": { "kind": "test_id", "id": "ui-gallery-dropdown-menu-demo-trigger" }
      },
      "timeout_frames": 600
    },

    {
      "type": "capture_bundle",
      "label": "ui-gallery-dropdown-menu-demo-click-profile-last-action"
    }
  ]
}
