{
  "schema_version": 2,
  "meta": {
    "name": "UI gallery: Dropdown Menu checkbox icons hover screenshots (zinc light)",
    "tags": [
      "ui-gallery",
      "shadcn",
      "dropdown-menu",
      "checkbox",
      "icons",
      "hover",
      "screenshots",
      "zinc-light"
    ],
    "required_capabilities": ["diag.script_v2", "diag.screenshot_png"],
    "env_defaults": {
      "FRET_UI_GALLERY_START_PAGE": "dropdown_menu"
    },
    "target_hints": [
      "Sets theme preset to zinc/light.",
      "Starts UI Gallery on the Dropdown Menu page.",
      "Opens the Checkboxes Icons menu and captures a hover-state screenshot to gate notification icon foreground inheritance."
    ]
  },
  "steps": [
    { "type": "reset_diagnostics" },
    {
      "type": "wait_until",
      "predicate": { "kind": "exists", "target": { "kind": "test_id", "id": "ui-gallery-theme-preset-trigger" } },
      "timeout_frames": 600
    },
    { "type": "click", "target": { "kind": "test_id", "id": "ui-gallery-theme-preset-trigger" } },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-theme-preset-item-zinc-light" }
      },
      "timeout_frames": 600
    },
    {
      "type": "click_stable",
      "target": { "kind": "test_id", "id": "ui-gallery-theme-preset-item-zinc-light" }
    },
    { "type": "wait_frames", "n": 2 },
    { "type": "press_key", "key": "escape" },
    { "type": "wait_frames", "n": 2 },
    {
      "type": "wait_until",
      "predicate": { "kind": "exists", "target": { "kind": "test_id", "id": "ui-gallery-page-dropdown-menu" } },
      "timeout_frames": 240
    },

    {
      "type": "scroll_into_view",
      "container": { "kind": "test_id", "id": "ui-gallery-content-scroll" },
      "target": { "kind": "test_id", "id": "ui-gallery-dropdown-menu-checkboxes-icons-trigger" },
      "delta_y": -120.0,
      "require_fully_within_container": true,
      "require_fully_within_window": true,
      "padding_px": 16.0,
      "timeout_frames": 600
    },
    {
      "type": "click_stable",
      "target": {
        "kind": "test_id",
        "id": "ui-gallery-dropdown-menu-checkboxes-icons-trigger.chrome"
      }
    },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-dropdown-menu-checkboxes-icons-email" }
      },
      "timeout_frames": 240
    },
    {
      "type": "move_pointer",
      "target": { "kind": "test_id", "id": "ui-gallery-dropdown-menu-checkboxes-icons-email" }
    },
    { "type": "wait_frames", "n": 2 },
    { "type": "capture_screenshot", "label": "ui-gallery-dropdown-menu-checkable-icons-notifications-zinc-light" },
    { "type": "capture_bundle", "label": "ui-gallery-dropdown-menu-checkable-icons-notifications-zinc-light" }
  ]
}
