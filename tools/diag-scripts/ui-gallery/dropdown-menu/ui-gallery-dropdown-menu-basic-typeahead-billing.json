{
  "schema_version": 2,
  "meta": {
    "name": "ui-gallery-dropdown-menu-basic-typeahead-billing",
    "required_capabilities": ["diag.script_v2"],
    "tags": ["ui_gallery", "shadcn", "dropdown_menu", "keyboard", "typeahead", "regression_pack"]
  },
  "steps": [
    {
      "type": "ensure_visible",
      "target": { "kind": "test_id", "id": "ui-gallery-nav-search" },
      "within_window": true,
      "padding_px": 8.0,
      "timeout_frames": 600
    },
    { "type": "press_key", "key": "escape" },
    { "type": "wait_frames", "n": 2 },
    { "type": "set_window_inner_size", "width_px": 1280.0, "height_px": 720.0 },
    { "type": "wait_frames", "n": 10 },

    {
      "type": "click_stable",
      "target": { "kind": "test_id", "id": "ui-gallery-nav-search" },
      "button": "left",
      "stable_frames": 10,
      "max_move_px": 0.5,
      "timeout_frames": 600
    },
    { "type": "press_key", "key": "a", "modifiers": { "ctrl": true } },
    { "type": "press_key", "key": "backspace" },
    { "type": "type_text", "text": "dropdown menu" },
    { "type": "wait_frames", "n": 2 },

    {
      "type": "ensure_visible",
      "target": { "kind": "test_id", "id": "ui-gallery-nav-dropdown-menu" },
      "within_window": true,
      "padding_px": 8.0,
      "timeout_frames": 600
    },
    {
      "type": "click_stable",
      "target": { "kind": "test_id", "id": "ui-gallery-nav-dropdown-menu" },
      "button": "left",
      "stable_frames": 10,
      "max_move_px": 0.5,
      "timeout_frames": 600
    },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-page-dropdown-menu" }
      },
      "timeout_frames": 600
    },

    {
      "type": "scroll_into_view",
      "container": { "kind": "test_id", "id": "ui-gallery-content-scroll" },
      "target": { "kind": "test_id", "id": "ui-gallery-dropdown-menu-basic-trigger.chrome" },
      "delta_y": -360.0,
      "padding_px": 16.0,
      "timeout_frames": 1800
    },
    {
      "type": "click_stable",
      "target": { "kind": "test_id", "id": "ui-gallery-dropdown-menu-basic-trigger.chrome" },
      "button": "left",
      "stable_frames": 2,
      "max_move_px": 1.0,
      "timeout_frames": 600
    },
    { "type": "press_key", "key": "arrow_down" },
    { "type": "wait_frames", "n": 2 },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-dropdown-menu-basic-profile" }
      },
      "timeout_frames": 240
    },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "focus_is",
        "target": { "kind": "test_id", "id": "ui-gallery-dropdown-menu-basic-profile" }
      },
      "timeout_frames": 240
    },

    { "type": "press_key", "key": "b" },
    { "type": "wait_frames", "n": 2 },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "focus_is",
        "target": { "kind": "test_id", "id": "ui-gallery-dropdown-menu-basic-billing" }
      },
      "timeout_frames": 240
    },
    { "type": "press_key", "key": "enter" },
    {
      "type": "wait_frames",
      "n": 5
    },
    {
      "type": "assert",
      "predicate": {
        "kind": "label_contains",
        "target": { "kind": "test_id", "id": "ui-gallery-status-last-action" },
        "text": "menu.dropdown.orange"
      }
    },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "focus_is",
        "target": { "kind": "test_id", "id": "ui-gallery-dropdown-menu-basic-trigger" }
      },
      "timeout_frames": 240
    },

    {
      "type": "capture_bundle",
      "label": "ui-gallery-dropdown-menu-basic-typeahead-billing"
    }
  ]
}
