{
  "schema_version": 2,
  "meta": {
    "name": "ui-gallery-hover-card-trigger-delays",
    "required_capabilities": ["diag.script_v2"]
  },
  "steps": [
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-nav-search" }
      },
      "timeout_frames": 240
    },
    { "type": "press_key", "key": "escape" },
    { "type": "wait_frames", "n": 2 },

    { "type": "click", "target": { "kind": "test_id", "id": "ui-gallery-nav-search" } },
    { "type": "press_key", "key": "a", "modifiers": { "ctrl": true } },
    { "type": "press_key", "key": "backspace" },
    { "type": "type_text", "text": "hover card" },
    { "type": "wait_frames", "n": 2 },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-nav-hover-card" }
      },
      "timeout_frames": 240
    },
    { "type": "click", "target": { "kind": "test_id", "id": "ui-gallery-nav-hover-card" } },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-page-hover-card" }
      },
      "timeout_frames": 240
    },
    {
      "type": "scroll_into_view",
      "container": { "kind": "test_id", "id": "ui-gallery-content-scroll" },
      "target": {
        "kind": "test_id",
        "id": "ui-gallery-hover-card-delay-delayed-trigger"
      },
      "delta_y": -240.0,
      "require_fully_within_container": true,
      "require_fully_within_window": true,
      "padding_px": 24.0,
      "timeout_frames": 1200
    },

    {
      "type": "move_pointer",
      "target": {
        "kind": "test_id",
        "id": "ui-gallery-hover-card-delay-delayed-trigger"
      }
    },
    { "type": "wait_frames", "n": 2 },
    {
      "type": "assert",
      "predicate": {
        "kind": "not_exists",
        "target": {
          "kind": "test_id",
          "id": "ui-gallery-hover-card-delay-delayed-content"
        }
      }
    },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": {
          "kind": "test_id",
          "id": "ui-gallery-hover-card-delay-delayed-content"
        }
      },
      "timeout_frames": 240
    },

    {
      "type": "move_pointer",
      "target": { "kind": "test_id", "id": "ui-gallery-nav-search" }
    },
    { "type": "wait_frames", "n": 2 },
    {
      "type": "assert",
      "predicate": {
        "kind": "exists",
        "target": {
          "kind": "test_id",
          "id": "ui-gallery-hover-card-delay-delayed-content"
        }
      }
    },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "not_exists",
        "target": {
          "kind": "test_id",
          "id": "ui-gallery-hover-card-delay-delayed-content"
        }
      },
      "timeout_frames": 240
    },

    { "type": "capture_bundle", "label": "ui-gallery-hover-card-trigger-delays" }
  ]
}
