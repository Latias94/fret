{
  "meta": {
    "required_capabilities": [
      "diag.script_v2",
      "diag.overlay_placement_trace",
      "diag.screenshot_png"
    ]
  },
  "schema_version": 2,
  "steps": [
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-nav-search" }
      },
      "timeout_frames": 600
    },
    { "type": "press_key", "key": "escape" },
    { "type": "wait_frames", "n": 2 },
    { "type": "set_window_inner_size", "width_px": 1280.0, "height_px": 960.0 },
    { "type": "wait_frames", "n": 20 },

    {
      "type": "click",
      "button": "left",
      "target": { "kind": "test_id", "id": "ui-gallery-nav-search" }
    },
    { "type": "press_key", "key": "a", "modifiers": { "ctrl": true } },
    { "type": "press_key", "key": "backspace" },
    { "type": "type_text", "text": "hover card" },
    { "type": "wait_frames", "n": 2 },

    {
      "type": "wait_until",
      "predicate": {
        "kind": "bounds_within_window",
        "target": { "kind": "test_id", "id": "ui-gallery-nav-hover-card" },
        "padding_px": 8.0,
        "eps_px": 1.0
      },
      "timeout_frames": 600
    },
    {
      "type": "click",
      "button": "left",
      "target": { "kind": "test_id", "id": "ui-gallery-nav-hover-card" }
    },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-page-hover-card" }
      },
      "timeout_frames": 600
    },

    {
      "type": "scroll_into_view",
      "container": { "kind": "test_id", "id": "ui-gallery-content-viewport" },
      "target": { "kind": "test_id", "id": "ui-gallery-hover-card-side-left-trigger" },
      "require_fully_within_window": true,
      "padding_px": 8.0,
      "padding_insets_px": { "left_px": 8.0, "top_px": 120.0, "right_px": 8.0, "bottom_px": 240.0 },
      "timeout_frames": 600
    },
    { "type": "reset_diagnostics" },

    {
      "type": "move_pointer",
      "target": { "kind": "test_id", "id": "ui-gallery-hover-card-side-left-trigger" }
    },
    { "type": "wait_frames", "n": 25 },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-hover-card-side-left-content" }
      },
      "timeout_frames": 600
    },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "bounds_max_size",
        "target": { "kind": "test_id", "id": "ui-gallery-hover-card-side-left-content" },
        "max_w_px": 256.0,
        "max_h_px": 1000.0,
        "eps_px": 1.0
      },
      "timeout_frames": 240
    },
    {
      "type": "wait_overlay_placement_trace",
      "query": {
        "kind": "anchored_panel",
        "content_test_id": "ui-gallery-hover-card-side-left-content",
        "preferred_side": "left",
        "chosen_side": "left",
        "flipped": false
      },
      "timeout_frames": 600
    },
    {
      "type": "move_pointer",
      "target": { "kind": "test_id", "id": "ui-gallery-status-last-action" }
    },
    { "type": "wait_frames", "n": 20 },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "not_exists",
        "target": { "kind": "test_id", "id": "ui-gallery-hover-card-side-left-content" }
      },
      "timeout_frames": 600
    },

    {
      "type": "scroll_into_view",
      "container": { "kind": "test_id", "id": "ui-gallery-content-viewport" },
      "target": { "kind": "test_id", "id": "ui-gallery-hover-card-side-top-trigger" },
      "require_fully_within_window": true,
      "padding_px": 8.0,
      "padding_insets_px": { "left_px": 8.0, "top_px": 120.0, "right_px": 8.0, "bottom_px": 240.0 },
      "timeout_frames": 600
    },
    { "type": "wait_frames", "n": 2 },
    { "type": "reset_diagnostics" },
    {
      "type": "move_pointer",
      "target": { "kind": "test_id", "id": "ui-gallery-hover-card-side-top-trigger" }
    },
    { "type": "wait_frames", "n": 25 },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-hover-card-side-top-content" }
      },
      "timeout_frames": 600
    },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "bounds_max_size",
        "target": { "kind": "test_id", "id": "ui-gallery-hover-card-side-top-content" },
        "max_w_px": 256.0,
        "max_h_px": 1000.0,
        "eps_px": 1.0
      },
      "timeout_frames": 240
    },
    {
      "type": "wait_overlay_placement_trace",
      "query": {
        "kind": "anchored_panel",
        "content_test_id": "ui-gallery-hover-card-side-top-content",
        "preferred_side": "top",
        "chosen_side": "top",
        "flipped": false
      },
      "timeout_frames": 600
    },
    {
      "type": "move_pointer",
      "target": { "kind": "test_id", "id": "ui-gallery-status-last-action" }
    },
    { "type": "wait_frames", "n": 20 },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "not_exists",
        "target": { "kind": "test_id", "id": "ui-gallery-hover-card-side-top-content" }
      },
      "timeout_frames": 600
    },

    {
      "type": "scroll_into_view",
      "container": { "kind": "test_id", "id": "ui-gallery-content-viewport" },
      "target": { "kind": "test_id", "id": "ui-gallery-hover-card-side-bottom-trigger" },
      "delta_y": -240.0,
      "require_fully_within_window": true,
      "padding_px": 8.0,
      "padding_insets_px": { "left_px": 8.0, "top_px": 120.0, "right_px": 8.0, "bottom_px": 240.0 },
      "timeout_frames": 600
    },
    { "type": "wait_frames", "n": 2 },
    { "type": "reset_diagnostics" },
    {
      "type": "move_pointer",
      "target": { "kind": "test_id", "id": "ui-gallery-hover-card-side-bottom-trigger" }
    },
    { "type": "wait_frames", "n": 25 },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-hover-card-side-bottom-content" }
      },
      "timeout_frames": 600
    },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "bounds_max_size",
        "target": { "kind": "test_id", "id": "ui-gallery-hover-card-side-bottom-content" },
        "max_w_px": 256.0,
        "max_h_px": 1000.0,
        "eps_px": 1.0
      },
      "timeout_frames": 240
    },
    {
      "type": "wait_overlay_placement_trace",
      "query": {
        "kind": "anchored_panel",
        "content_test_id": "ui-gallery-hover-card-side-bottom-content",
        "preferred_side": "bottom",
        "chosen_side": "bottom",
        "flipped": false
      },
      "timeout_frames": 600
    },
    {
      "type": "move_pointer",
      "target": { "kind": "test_id", "id": "ui-gallery-status-last-action" }
    },
    { "type": "wait_frames", "n": 20 },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "not_exists",
        "target": { "kind": "test_id", "id": "ui-gallery-hover-card-side-bottom-content" }
      },
      "timeout_frames": 600
    },

    {
      "type": "scroll_into_view",
      "container": { "kind": "test_id", "id": "ui-gallery-content-viewport" },
      "target": { "kind": "test_id", "id": "ui-gallery-hover-card-side-right-trigger" },
      "require_fully_within_window": true,
      "padding_px": 8.0,
      "padding_insets_px": { "left_px": 8.0, "top_px": 120.0, "right_px": 8.0, "bottom_px": 240.0 },
      "timeout_frames": 600
    },
    { "type": "wait_frames", "n": 2 },
    { "type": "reset_diagnostics" },
    {
      "type": "move_pointer",
      "target": { "kind": "test_id", "id": "ui-gallery-hover-card-side-right-trigger" }
    },
    { "type": "wait_frames", "n": 25 },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-hover-card-side-right-content" }
      },
      "timeout_frames": 600
    },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "bounds_max_size",
        "target": { "kind": "test_id", "id": "ui-gallery-hover-card-side-right-content" },
        "max_w_px": 256.0,
        "max_h_px": 1000.0,
        "eps_px": 1.0
      },
      "timeout_frames": 240
    },
    {
      "type": "wait_overlay_placement_trace",
      "query": {
        "kind": "anchored_panel",
        "content_test_id": "ui-gallery-hover-card-side-right-content",
        "preferred_side": "right",
        "chosen_side": "right",
        "flipped": false
      },
      "timeout_frames": 600
    },

    { "type": "capture_bundle", "label": "ui-gallery-hover-card-sides-placement" },
    { "type": "capture_screenshot", "label": "ui-gallery-hover-card-sides-placement" }
  ]
}
