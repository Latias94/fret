{
  "schema_version": 2,
  "meta": {
    "name": "UI gallery: workspace shell focus/command scope smoke",
    "tags": ["focus", "keyboard", "smoke", "ui-gallery", "workspace", "workspace_shell"],
    "env_defaults": {
      "FRET_UI_GALLERY_DIAG_PROFILE": "workspace_shell"
    },
    "required_capabilities": ["diag.script_v2"],
    "target_hints": [
      "Boots ui_gallery with the workspace_shell diag profile so the shell starts on the overlay page under zinc/dark with the tab strip enabled.",
      "Focuses the workspace content surface, presses Ctrl+F6, and asserts focus moves into the active tab.",
      "Presses Escape and asserts focus returns to the workspace content surface."
    ]
  },
  "steps": [
    { "type": "reset_diagnostics" },
    { "type": "press_key", "key": "escape" },
    { "type": "wait_frames", "n": 2 },
    { "type": "set_window_inner_size", "width_px": 1440.0, "height_px": 960.0 },
    { "type": "wait_frames", "n": 8 },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-workspace-tabstrip" }
      },
      "timeout_frames": 600
    },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-workspace-content" }
      },
      "timeout_frames": 600
    },
    {
      "type": "click_stable",
      "target": { "kind": "test_id", "id": "ui-gallery-workspace-content" }
    },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "focus_is",
        "target": { "kind": "test_id", "id": "ui-gallery-workspace-content" }
      },
      "timeout_frames": 240
    },
    { "type": "press_key", "key": "f6", "modifiers": { "ctrl": true }, "repeat": false },
    { "type": "wait_frames", "n": 6 },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "focus_is",
        "target": { "kind": "test_id", "id": "ui-gallery-workspace-tab-overlay" }
      },
      "timeout_frames": 240
    },
    { "type": "press_key", "key": "escape", "repeat": false },
    { "type": "wait_frames", "n": 6 },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "focus_is",
        "target": { "kind": "test_id", "id": "ui-gallery-workspace-content" }
      },
      "timeout_frames": 240
    },
    {
      "type": "capture_bundle",
      "label": "ui-gallery-workspace-shell-focus-command-scope-smoke"
    }
  ]
}
