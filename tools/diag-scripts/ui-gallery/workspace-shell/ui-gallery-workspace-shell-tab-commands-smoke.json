{
  "schema_version": 2,
  "meta": {
    "name": "UI gallery: workspace shell tab commands smoke",
    "tags": ["keyboard", "smoke", "tabs", "ui-gallery", "workspace", "workspace_shell"],
    "env_defaults": {
      "FRET_UI_GALLERY_DIAG_PROFILE": "workspace_shell"
    },
    "required_capabilities": ["diag.script_v2", "diag.command_dispatch_trace"],
    "target_hints": [
      "Boots ui_gallery with the workspace_shell diag profile so the shell starts on the overlay page under zinc/dark with the tab strip enabled.",
      "Focuses the workspace content surface, then exercises next/previous/close tab commands from the workspace command scope.",
      "Asserts the single-pane workspace layout mirror updates the selected tab and removes the closed tab."
    ]
  },
  "steps": [
    { "type": "reset_diagnostics" },
    { "type": "press_key", "key": "escape" },
    { "type": "wait_frames", "n": 2 },
    { "type": "set_window_inner_size", "width_px": 1440.0, "height_px": 960.0 },
    { "type": "wait_frames", "n": 8 },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-workspace-tabstrip" }
      },
      "timeout_frames": 600
    },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-workspace-content" }
      },
      "timeout_frames": 600
    },
    {
      "type": "click_stable",
      "target": { "kind": "test_id", "id": "ui-gallery-workspace-tab-overlay" }
    },
    { "type": "wait_frames", "n": 2 },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-workspace-tab-command" }
      },
      "timeout_frames": 240
    },
    {
      "type": "click_stable",
      "target": { "kind": "test_id", "id": "ui-gallery-workspace-content" }
    },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "focus_is",
        "target": { "kind": "test_id", "id": "ui-gallery-workspace-content" }
      },
      "timeout_frames": 240
    },
    { "type": "press_key", "key": "tab", "modifiers": { "ctrl": true }, "repeat": false },
    {
      "type": "wait_command_dispatch_trace",
      "query": {
        "command": "workspace.tab.next",
        "handled": true,
        "started_from_focus": true
      },
      "timeout_frames": 240
    },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "selected_is",
        "target": { "kind": "test_id", "id": "ui-gallery-workspace-tab-command" },
        "selected": true
      },
      "timeout_frames": 240
    },
    { "type": "press_key", "key": "tab", "modifiers": { "ctrl": true, "shift": true }, "repeat": false },
    {
      "type": "wait_command_dispatch_trace",
      "query": {
        "command": "workspace.tab.prev",
        "handled": true,
        "started_from_focus": true
      },
      "timeout_frames": 240
    },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "selected_is",
        "target": { "kind": "test_id", "id": "ui-gallery-workspace-tab-intro" },
        "selected": true
      },
      "timeout_frames": 240
    },
    { "type": "press_shortcut", "shortcut": "primary+w", "repeat": false },
    {
      "type": "wait_command_dispatch_trace",
      "query": {
        "command": "workspace.tab.close",
        "handled": true,
        "started_from_focus": true
      },
      "timeout_frames": 240
    },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "not_exists",
        "target": { "kind": "test_id", "id": "ui-gallery-workspace-tab-intro" }
      },
      "timeout_frames": 240
    },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "selected_is",
        "target": { "kind": "test_id", "id": "ui-gallery-workspace-tab-command" },
        "selected": true
      },
      "timeout_frames": 240
    },
    {
      "type": "capture_bundle",
      "label": "ui-gallery-workspace-shell-tab-commands-smoke"
    }
  ]
}
