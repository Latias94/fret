{
  "schema_version": 2,
  "meta": {
    "name": "UI gallery: Resizable initial bundle",
    "tags": ["ui-gallery", "shadcn", "resizable", "smoke"],
    "required_capabilities": ["diag.script_v2", "diag.screenshot_png"],
    "target_hints": [
      "Navigates to the Resizable docs page and waits for the page root plus the main demo group.",
      "Leaves a bounded bundle and screenshot as the baseline artifact for page-level parity checks."
    ]
  },
  "steps": [
    { "type": "reset_diagnostics" },
    { "type": "press_key", "key": "escape" },
    { "type": "wait_frames", "n": 2 },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-nav-scroll" }
      },
      "timeout_frames": 600
    },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-nav-search" }
      },
      "timeout_frames": 600
    },
    { "type": "click", "target": { "kind": "test_id", "id": "ui-gallery-nav-search" } },
    { "type": "press_key", "key": "a", "modifiers": { "ctrl": true } },
    { "type": "press_key", "key": "backspace" },
    { "type": "type_text", "text": "resizable" },
    { "type": "wait_frames", "n": 2 },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "bounds_within_window",
        "target": { "kind": "test_id", "id": "ui-gallery-nav-resizable" },
        "padding_px": 8.0
      },
      "timeout_frames": 600
    },
    { "type": "click", "target": { "kind": "test_id", "id": "ui-gallery-nav-resizable" } },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-page-resizable" }
      },
      "timeout_frames": 600
    },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "bounds_within_window",
        "target": { "kind": "test_id", "id": "ui-gallery-page-resizable" },
        "padding_px": 0.0,
        "eps_px": 1.0
      },
      "timeout_frames": 600
    },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "bounds_min_size",
        "target": { "kind": "test_id", "id": "ui-gallery-resizable-panels" },
        "min_w_px": 200.0,
        "min_h_px": 240.0,
        "eps_px": 1.0
      },
      "timeout_frames": 600
    },
    { "type": "wait_frames", "n": 60 },
    { "type": "capture_bundle", "label": "ui-gallery-resizable-initial" },
    { "type": "capture_screenshot", "label": "ui-gallery-resizable-initial" }
  ]
}
