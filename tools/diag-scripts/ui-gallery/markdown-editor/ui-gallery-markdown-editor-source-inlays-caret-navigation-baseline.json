{
  "schema_version": 2,
  "steps": [
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-nav-search" }
      },
      "timeout_frames": 240
    },
    { "type": "click", "target": { "kind": "test_id", "id": "ui-gallery-nav-search" } },
    { "type": "press_key", "key": "a", "modifiers": { "ctrl": true } },
    { "type": "press_key", "key": "backspace" },
    { "type": "type_text", "text": "markdown_editor_source" },
    { "type": "wait_frames", "n": 2 },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "bounds_within_window",
        "target": { "kind": "test_id", "id": "ui-gallery-nav-markdown-editor-source" },
        "padding_px": 8.0,
        "eps_px": 1.0
      },
      "timeout_frames": 240
    },
    {
      "type": "click",
      "target": { "kind": "test_id", "id": "ui-gallery-nav-markdown-editor-source" }
    },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-page-markdown-editor-source" }
      },
      "timeout_frames": 240
    },
    { "type": "wait_frames", "n": 20 },

    {
      "type": "click",
      "target": { "kind": "test_id", "id": "ui-gallery-markdown-editor-mode-edit" }
    },
    { "type": "wait_frames", "n": 2 },
    {
      "type": "click",
      "target": { "kind": "test_id", "id": "ui-gallery-markdown-editor-soft-wrap-set-off" }
    },
    { "type": "wait_frames", "n": 4 },
    {
      "type": "click",
      "target": { "kind": "test_id", "id": "ui-gallery-markdown-editor-folds-set-off" }
    },
    { "type": "wait_frames", "n": 2 },
    {
      "type": "click",
      "target": { "kind": "test_id", "id": "ui-gallery-markdown-editor-inlays-set-off" }
    },
    { "type": "wait_frames", "n": 4 },

    {
      "type": "click",
      "target": { "kind": "role_and_name", "role": "text_field", "name": "Markdown editor" }
    },
    { "type": "wait_frames", "n": 2 },
    { "type": "press_key", "key": "a", "modifiers": { "ctrl": true } },
    { "type": "press_key", "key": "backspace" },
    { "type": "type_text", "text": "hello" },
    { "type": "wait_frames", "n": 2 },

    { "type": "press_key", "key": "home", "modifiers": { "ctrl": true } },
    { "type": "wait_frames", "n": 2 },
    { "type": "press_key", "key": "arrow_right" },
    { "type": "wait_frames", "n": 1 },
    { "type": "press_key", "key": "arrow_right" },
    { "type": "wait_frames", "n": 2 },
    {
      "type": "capture_bundle",
      "label": "ui-gallery-markdown-editor-source-inlays-caret-navigation-baseline-a"
    },

    {
      "type": "click",
      "target": { "kind": "test_id", "id": "ui-gallery-markdown-editor-inlays-set-on" }
    },
    { "type": "wait_frames", "n": 20 },
    { "type": "press_key", "key": "arrow_right" },
    { "type": "wait_frames", "n": 2 },
    { "type": "press_key", "key": "arrow_left" },
    { "type": "wait_frames", "n": 2 },
    {
      "type": "capture_bundle",
      "label": "ui-gallery-markdown-editor-source-inlays-caret-navigation-baseline-b"
    }
  ]
}
