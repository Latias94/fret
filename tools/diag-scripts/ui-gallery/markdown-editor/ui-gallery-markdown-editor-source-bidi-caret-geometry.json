{
  "schema_version": 2,
  "meta": {
    "name": "ui-gallery-markdown-editor-source-bidi-caret-geometry",
    "required_capabilities": ["diag.script_v2", "diag.screenshot_png"]
  },
  "steps": [
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-nav-search" }
      },
      "timeout_frames": 600
    },
    { "type": "click", "target": { "kind": "test_id", "id": "ui-gallery-nav-search" } },
    { "type": "press_key", "key": "a", "modifiers": { "ctrl": true } },
    { "type": "press_key", "key": "backspace" },
    { "type": "type_text", "text": "markdown_editor_source" },
    { "type": "wait_frames", "n": 2 },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "bounds_within_window",
        "target": { "kind": "test_id", "id": "ui-gallery-nav-markdown-editor-source" },
        "padding_px": 8.0,
        "eps_px": 1.0
      },
      "timeout_frames": 600
    },
    {
      "type": "click",
      "target": { "kind": "test_id", "id": "ui-gallery-nav-markdown-editor-source" }
    },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-page-markdown-editor-source" }
      },
      "timeout_frames": 600
    },
    { "type": "wait_frames", "n": 20 },

    { "type": "click", "target": { "kind": "test_id", "id": "ui-gallery-markdown-editor-mode-edit" } },
    { "type": "wait_frames", "n": 2 },
    {
      "type": "type_text_into",
      "target": { "kind": "role_and_name", "role": "text_field", "name": "Markdown editor" },
      "text": "abc 😄 אבג XYZ 漢字",
      "timeout_frames": 600
    },
    { "type": "wait_frames", "n": 2 },

    {
      "type": "wait_until",
      "predicate": { "kind": "ime_cursor_area_is_some", "is_some": true },
      "timeout_frames": 240
    },
    {
      "type": "wait_until",
      "predicate": { "kind": "ime_cursor_area_min_size", "min_w_px": 1.0, "min_h_px": 6.0, "eps_px": 1.0 },
      "timeout_frames": 240
    },
    {
      "type": "wait_until",
      "predicate": { "kind": "ime_cursor_area_within_window", "padding_px": 0.0, "eps_px": 2.0 },
      "timeout_frames": 240
    },

    { "type": "press_key", "key": "home", "modifiers": { "ctrl": true } },
    { "type": "wait_frames", "n": 2 },
    {
      "type": "wait_until",
      "predicate": { "kind": "ime_cursor_area_within_window", "padding_px": 0.0, "eps_px": 2.0 },
      "timeout_frames": 240
    },
    { "type": "press_key", "key": "right" },
    { "type": "wait_frames", "n": 2 },
    {
      "type": "wait_until",
      "predicate": { "kind": "ime_cursor_area_within_window", "padding_px": 0.0, "eps_px": 2.0 },
      "timeout_frames": 240
    },
    { "type": "press_key", "key": "right" },
    { "type": "wait_frames", "n": 2 },
    {
      "type": "wait_until",
      "predicate": { "kind": "ime_cursor_area_within_window", "padding_px": 0.0, "eps_px": 2.0 },
      "timeout_frames": 240
    },
    { "type": "press_key", "key": "left" },
    { "type": "wait_frames", "n": 2 },
    {
      "type": "wait_until",
      "predicate": { "kind": "ime_cursor_area_within_window", "padding_px": 0.0, "eps_px": 2.0 },
      "timeout_frames": 240
    },

    { "type": "press_key", "key": "end", "modifiers": { "ctrl": true } },
    { "type": "wait_frames", "n": 2 },
    {
      "type": "wait_until",
      "predicate": { "kind": "ime_cursor_area_within_window", "padding_px": 0.0, "eps_px": 2.0 },
      "timeout_frames": 240
    },

    { "type": "wait_frames", "n": 12 },
    { "type": "capture_screenshot", "label": "ui-gallery-markdown-editor-source-bidi-caret-geometry" },
    { "type": "capture_bundle", "label": "ui-gallery-markdown-editor-source-bidi-caret-geometry" }
  ]
}
