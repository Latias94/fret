{
  "schema_version": 2,
  "steps": [
    {
      "type": "click",
      "target": { "kind": "test_id", "id": "ui-gallery-command-palette" }
    },
    { "type": "wait_frames", "n": 3 },
    { "type": "type_text", "text": "Settings" },
    { "type": "wait_frames", "n": 10 },
    { "type": "press_key", "key": "enter" },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "app_snapshot_field_equals",
        "pointer": "/shell/last_action",
        "value": "cmd.settings"
      },
      "timeout_frames": 120
    },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "app_snapshot_field_equals",
        "pointer": "/shell/settings_open",
        "value": true
      },
      "timeout_frames": 120
    },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "visible_in_window",
        "target": { "kind": "test_id", "id": "ui-gallery-settings-in-window-menubar" }
      },
      "timeout_frames": 120
    },
    {
      "type": "click_stable",
      "target": { "kind": "test_id", "id": "ui-gallery-settings-in-window-menubar" },
      "timeout_frames": 300
    },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "visible_in_window",
        "target": { "kind": "test_id", "id": "ui-gallery-settings-in-window-menubar-on" }
      },
      "timeout_frames": 120
    },
    {
      "type": "click_stable",
      "target": { "kind": "test_id", "id": "ui-gallery-settings-in-window-menubar-on" },
      "timeout_frames": 300
    },
    {
      "type": "click_stable",
      "target": { "kind": "test_id", "id": "ui-gallery-settings-apply" },
      "timeout_frames": 300
    },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "app_snapshot_field_equals",
        "pointer": "/shell/last_action",
        "value": "settings.apply"
      },
      "timeout_frames": 300
    },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "app_snapshot_field_equals",
        "pointer": "/shell/settings_open",
        "value": false
      },
      "timeout_frames": 300
    },
    { "type": "wait_frames", "n": 2 },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "menubar-trigger-file" }
      },
      "timeout_frames": 240
    },

    { "type": "press_key", "key": "alt", "modifiers": { "alt": true } },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "focus_is",
        "target": { "kind": "test_id", "id": "menubar-trigger-file" }
      },
      "timeout_frames": 120
    },

    { "type": "press_key", "key": "arrow_right" },
    { "type": "wait_frames", "n": 1 },
    {
      "type": "assert",
      "predicate": {
        "kind": "focus_is",
        "target": { "kind": "test_id", "id": "menubar-trigger-edit" }
      }
    },

    { "type": "press_key", "key": "arrow_right" },
    { "type": "wait_frames", "n": 1 },
    {
      "type": "assert",
      "predicate": {
        "kind": "focus_is",
        "target": { "kind": "test_id", "id": "menubar-trigger-view" }
      }
    },

    { "type": "press_key", "key": "arrow_right" },
    { "type": "wait_frames", "n": 1 },
    {
      "type": "assert",
      "predicate": {
        "kind": "focus_is",
        "target": { "kind": "test_id", "id": "menubar-trigger-window" }
      }
    },

    { "type": "press_key", "key": "arrow_down" },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "menubar-item-menu-window-submenu-split" }
      },
      "timeout_frames": 120
    },

    { "type": "press_key", "key": "arrow_down" },
    { "type": "press_key", "key": "arrow_down" },
    { "type": "press_key", "key": "arrow_down" },
    { "type": "press_key", "key": "arrow_down" },
    { "type": "press_key", "key": "arrow_down" },
    { "type": "press_key", "key": "arrow_down" },
    { "type": "press_key", "key": "arrow_down" },
    { "type": "press_key", "key": "arrow_down" },
    { "type": "press_key", "key": "arrow_down" },
    { "type": "press_key", "key": "arrow_down" },

    {
      "type": "assert",
      "predicate": {
        "kind": "focus_is",
        "target": { "kind": "test_id", "id": "menubar-item-menu-window-submenu-split" }
      }
    },

    { "type": "press_key", "key": "arrow_right" },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": {
          "kind": "test_id",
          "id": "menubar-item-workspace-pane-split-right"
        }
      },
      "timeout_frames": 120
    },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "focus_is",
        "target": {
          "kind": "test_id",
          "id": "menubar-item-workspace-pane-split-right"
        }
      },
      "timeout_frames": 120
    },

    { "type": "press_key", "key": "escape" },
    { "type": "wait_frames", "n": 2 },
    {
      "type": "assert",
      "predicate": {
        "kind": "focus_is",
        "target": { "kind": "test_id", "id": "menubar-item-menu-window-submenu-split" }
      }
    },
    {
      "type": "assert",
      "predicate": {
        "kind": "not_exists",
        "target": {
          "kind": "test_id",
          "id": "menubar-item-workspace-pane-split-right"
        }
      }
    },

    { "type": "press_key", "key": "escape" },
    { "type": "wait_frames", "n": 2 },
    {
      "type": "assert",
      "predicate": {
        "kind": "focus_is",
        "target": { "kind": "test_id", "id": "menubar-trigger-window" }
      }
    },
    {
      "type": "assert",
      "predicate": {
        "kind": "not_exists",
        "target": { "kind": "test_id", "id": "menubar-item-menu-window-submenu-split" }
      }
    },

    { "type": "capture_bundle", "label": "ui-gallery-menubar-keyboard-navigation" }
  ]
}
