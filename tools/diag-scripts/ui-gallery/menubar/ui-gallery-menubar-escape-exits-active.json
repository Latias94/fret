{
  "schema_version": 2,
  "steps": [
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-command-palette" }
      },
      "timeout_frames": 240
    },
    {
      "type": "click",
      "target": { "kind": "test_id", "id": "ui-gallery-command-palette" }
    },
    { "type": "wait_frames", "n": 3 },
    { "type": "type_text", "text": "Settings" },
    { "type": "wait_frames", "n": 10 },
    { "type": "press_key", "key": "enter" },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "app_snapshot_field_equals",
        "pointer": "/shell/last_action",
        "value": "cmd.settings"
      },
      "timeout_frames": 120
    },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "app_snapshot_field_equals",
        "pointer": "/shell/settings_open",
        "value": true
      },
      "timeout_frames": 120
    },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "visible_in_window",
        "target": { "kind": "test_id", "id": "ui-gallery-settings-in-window-menubar" }
      },
      "timeout_frames": 120
    },
    {
      "type": "click_stable",
      "target": { "kind": "test_id", "id": "ui-gallery-settings-in-window-menubar" },
      "timeout_frames": 300
    },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "visible_in_window",
        "target": { "kind": "test_id", "id": "ui-gallery-settings-in-window-menubar-on" }
      },
      "timeout_frames": 120
    },
    {
      "type": "click_stable",
      "target": { "kind": "test_id", "id": "ui-gallery-settings-in-window-menubar-on" },
      "timeout_frames": 300
    },
    {
      "type": "click_stable",
      "target": { "kind": "test_id", "id": "ui-gallery-settings-apply" },
      "timeout_frames": 300
    },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "app_snapshot_field_equals",
        "pointer": "/shell/last_action",
        "value": "settings.apply"
      },
      "timeout_frames": 300
    },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "app_snapshot_field_equals",
        "pointer": "/shell/settings_open",
        "value": false
      },
      "timeout_frames": 300
    },
    { "type": "wait_frames", "n": 2 },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "menubar-trigger-file" }
      },
      "timeout_frames": 240
    },
    { "type": "press_key", "key": "f10" },
    { "type": "wait_frames", "n": 2 },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "focus_is",
        "target": { "kind": "test_id", "id": "menubar-trigger-file" }
      },
      "timeout_frames": 120
    },
    { "type": "press_key", "key": "escape" },
    { "type": "wait_frames", "n": 4 },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "focus_is",
        "target": { "kind": "test_id", "id": "ui-gallery-command-palette" }
      },
      "timeout_frames": 120
    },
    { "type": "capture_bundle", "label": "ui-gallery-menubar-escape-exits-active" }
  ]
}
