{
  "schema_version": 1,
  "steps": [
    { "type": "press_key", "key": "escape" },
    { "type": "wait_frames", "n": 2 },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "menubar-trigger-window" }
      },
      "timeout_frames": 240
    },

    { "type": "click", "target": { "kind": "test_id", "id": "menubar-trigger-window" } },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "menubar-item-menu-window-submenu-split" }
      },
      "timeout_frames": 240
    },

    { "type": "move_pointer", "target": { "kind": "test_id", "id": "menubar-trigger-file" } },
    { "type": "wait_frames", "n": 12 },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "menubar-item-ui_gallery-app-open" }
      },
      "timeout_frames": 240
    },
    {
      "type": "assert",
      "predicate": {
        "kind": "not_exists",
        "target": { "kind": "test_id", "id": "menubar-item-menu-window-submenu-split" }
      }
    },

    { "type": "capture_bundle", "label": "ui-gallery-menubar-hover-switch" }
  ]
}

