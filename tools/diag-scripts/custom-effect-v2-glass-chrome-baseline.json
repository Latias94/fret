{
  "schema_version": 1,
  "steps": [
    { "type": "press_key", "key": "escape" },
    { "type": "wait_frames", "n": 5 },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "customv2.glass_chrome.enabled" }
      },
      "timeout_frames": 360
    },
    { "type": "wait_frames", "n": 60 },
    { "type": "capture_bundle", "label": "customv2-glass-chrome-baseline" },
    { "type": "capture_screenshot", "label": "customv2-glass-chrome-baseline" }
  ]
}

