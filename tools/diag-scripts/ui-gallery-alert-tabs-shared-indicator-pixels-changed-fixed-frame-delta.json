{
  "schema_version": 2,
  "meta": {
    "name": "ui-gallery-alert-tabs-shared-indicator-pixels-changed-fixed-frame-delta",
    "required_capabilities": ["diag.script_v2", "diag.screenshot_png"]
  },
  "steps": [
    { "type": "press_key", "key": "escape" },
    { "type": "wait_frames", "n": 2 },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-nav-alert" }
      },
      "timeout_frames": 240
    },
    {
      "type": "click_stable",
      "target": { "kind": "test_id", "id": "ui-gallery-nav-alert" },
      "stable_frames": 6,
      "max_move_px": 0.5,
      "timeout_frames": 240
    },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-alert-tabs-trigger-component" }
      },
      "timeout_frames": 240
    },
    { "type": "wait_frames", "n": 8 },
    { "type": "capture_bundle", "label": "ui-gallery-alert-tabs-shared-indicator-before" },
    { "type": "capture_screenshot", "label": "ui-gallery-alert-tabs-shared-indicator-before" },

    {
      "type": "click_stable",
      "target": { "kind": "test_id", "id": "ui-gallery-alert-tabs-trigger-code" },
      "stable_frames": 4,
      "max_move_px": 0.5,
      "timeout_frames": 240
    },
    { "type": "wait_frames", "n": 20 },
    { "type": "capture_bundle", "label": "ui-gallery-alert-tabs-shared-indicator-after" },
    { "type": "capture_screenshot", "label": "ui-gallery-alert-tabs-shared-indicator-after" },

    {
      "type": "capture_bundle",
      "label": "ui-gallery-alert-tabs-shared-indicator-pixels-changed-fixed-frame-delta"
    }
  ]
}

