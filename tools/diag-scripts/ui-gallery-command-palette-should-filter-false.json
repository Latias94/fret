      "timeout_frames": 240,
      "type": "wait_until"
    },
    {
      "padding_px": 4.0,
      "target": {
        "id": "ui-gallery-command-demo-filter-input",
        "kind": "test_id"
      },
      "timeout_frames": 600,
      "type": "ensure_visible",
