      "timeout_frames": 240,
      "type": "wait_until"
    },
    {
      "predicate": {
        "kind": "exists",
        "target": {
          "id": "ui-gallery-content-scroll",
          "kind": "test_id"
        }
      },
      "timeout_frames": 240,
      "type": "wait_until"
    },
    {
      "delta_y": 720.0,
      "target": {
        "id": "ui-gallery-content-scroll",
        "kind": "test_id"
      },
      "type": "wheel"
    },
    {
      "n": 10,
      "type": "wait_frames"
    },
    {
      "delta_y": 720.0,
      "target": {
        "id": "ui-gallery-content-scroll",
