    {
      "key": "a",
      "modifiers": {
        "ctrl": true
      },
      "type": "press_key"
    },
    {
      "key": "backspace",
      "type": "press_key"
    },
    {
      "text": "zzzz",
      "type": "type_text"
    },
    {
      "n": 2,
      "type": "wait_frames"
