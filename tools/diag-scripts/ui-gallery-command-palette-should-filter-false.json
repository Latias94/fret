      },
      "timeout_frames": 240,
      "type": "wait_until"
    },
    {
      "height_px": 1200.0,
      "type": "set_window_inner_size",
      "width_px": 1280.0
    },
    {
      "n": 20,
      "type": "wait_frames"
    },
    {
      "target": {
        "id": "ui-gallery-nav-search",
        "kind": "test_id"
      },
      "type": "click"
    },
    {
      "key": "a",
      "modifiers": {
        "ctrl": true
      },
      "type": "press_key"
    },
    {
      "key": "backspace",
      "type": "press_key"
    },
    {
      "text": "command",
      "type": "type_text"
    },
    {
      "n": 2,
      "type": "wait_frames"
    },
    {
      "predicate": {
        "kind": "exists",
        "target": {
          "id": "ui-gallery-nav-command",
          "kind": "test_id"
        }
      },
