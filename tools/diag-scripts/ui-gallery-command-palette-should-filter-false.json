    {
      "predicate": {
        "container": {
          "id": "ui-gallery-command-demo-filter-input",
          "kind": "test_id"
        },
        "item": {
          "id": "ui-gallery-command-demo-filter-item-calendar",
          "kind": "test_id"
        },
