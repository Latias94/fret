{
  "schema_version": 2,
  "steps": [
    { "type": "press_key", "key": "escape" },
    { "type": "wait_frames", "n": 2 },

    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-nav-search" }
      },
      "timeout_frames": 240
    },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-nav-scroll" }
      },
      "timeout_frames": 240
    },

    { "type": "wheel", "target": { "kind": "test_id", "id": "ui-gallery-nav-scroll" }, "delta_y": -20000.0 },
    { "type": "wheel", "target": { "kind": "test_id", "id": "ui-gallery-nav-scroll" }, "delta_y": -20000.0 },
    { "type": "wait_frames", "n": 2 },

    {
      "type": "type_text_into",
      "target": { "kind": "test_id", "id": "ui-gallery-nav-search" },
      "text": "chrome_torture",
      "clear_before_type": true,
      "timeout_frames": 240
    },
    { "type": "wait_frames", "n": 2 },
    {
      "type": "scroll_into_view",
      "container": { "kind": "test_id", "id": "ui-gallery-nav-scroll" },
      "target": { "kind": "test_id", "id": "ui-gallery-nav-chrome-torture" },
      "delta_y": 720.0,
      "require_fully_within_window": true,
      "padding_px": 8.0,
      "timeout_frames": 240
    },
    { "type": "click", "target": { "kind": "test_id", "id": "ui-gallery-nav-chrome-torture" } },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-page-chrome-torture" }
      },
      "timeout_frames": 240
    },

    { "type": "set_window_inner_size", "width_px": 1280.0, "height_px": 720.0 },
    { "type": "wait_frames", "n": 30 },
    { "type": "reset_diagnostics" },

    { "type": "move_pointer", "target": { "kind": "test_id", "id": "ui-gallery-chrome-btn-1" } },
    { "type": "move_pointer", "target": { "kind": "test_id", "id": "ui-gallery-chrome-btn-2" } },
    { "type": "move_pointer", "target": { "kind": "test_id", "id": "ui-gallery-chrome-btn-3" } },
    { "type": "wait_frames", "n": 2 },
    { "type": "click", "target": { "kind": "test_id", "id": "ui-gallery-chrome-btn-1" } },
    { "type": "press_key", "key": "tab" },
    { "type": "press_key", "key": "tab" },
    { "type": "press_key", "key": "tab" },

    {
      "type": "move_pointer_sweep",
      "target": { "kind": "test_id", "id": "ui-gallery-page-chrome-torture" },
      "delta_x": 900.0,
      "delta_y": 420.0,
      "steps": 300
    },
    { "type": "wait_frames", "n": 2 },
    {
      "type": "capture_bundle",
      "label": "ui-gallery-chrome-torture-typical",
      "max_snapshots": 180
    },

    { "type": "wait_frames", "n": 2 }
  ]
}
