{
  "schema_version": 2,
  "meta": {
    "name": "UI Gallery: UI kit list (torture) viewport height bounded",
    "tags": ["ui-gallery", "ui-kit", "list", "virtual-list", "layout", "screenshot"],
    "required_capabilities": ["diag.script_v2", "diag.screenshot_png"]
  },
  "steps": [
    { "type": "reset_diagnostics" },
    {
      "type": "wait_until",
      "predicate": { "kind": "exists", "target": { "kind": "test_id", "id": "ui-gallery-nav-scroll" } },
      "timeout_frames": 600
    },
    { "type": "press_key", "key": "escape" },
    { "type": "wait_frames", "n": 2 },
    { "type": "set_window_inner_size", "width_px": 1280.0, "height_px": 720.0 },
    { "type": "wait_frames", "n": 15 },
    { "type": "click", "target": { "kind": "test_id", "id": "ui-gallery-nav-ui-kit-list-torture" } },
    {
      "type": "wait_until",
      "predicate": { "kind": "exists", "target": { "kind": "test_id", "id": "ui-gallery-ui-kit-list-viewport" } },
      "timeout_frames": 600
    },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "bounds_min_size",
        "target": { "kind": "test_id", "id": "ui-gallery-ui-kit-list-viewport" },
        "min_w_px": 200.0,
        "min_h_px": 480.0,
        "eps_px": 1.0
      },
      "timeout_frames": 600
    },
    { "type": "wait_frames", "n": 30 },
    { "type": "capture_screenshot", "label": "ui-gallery-ui-kit-list-viewport-height" }
  ]
}

