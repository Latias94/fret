{
  "schema_version": 2,
  "meta": {
    "name": "Node graph (paint-only): hover shows portal tooltip (declarative overlay)",
    "tags": ["node-graph", "declarative", "paint-only", "portal", "hover", "tooltip", "gate"],
    "required_capabilities": ["diag.script_v2"],
    "target_hints": [
      "Run the `node_graph_demo` binary (it defaults to the paint-only declarative surface).",
      "Requires `FRET_DIAG=1` (Ctrl+4 normalization shortcut).",
      "This gates that paint-only hover state can drive a declarative overlay (tooltip) without enabling portal hit-testing."
    ]
  },
  "steps": [
    { "type": "press_key", "key": "escape" },
    { "type": "wait_frames", "n": 5 },

    {
      "type": "wait_until",
      "predicate": { "kind": "exists", "target": { "kind": "test_id", "id": "node_graph.canvas" } },
      "timeout_frames": 600
    },

    { "type": "click", "target": { "kind": "test_id", "id": "node_graph.canvas" }, "button": "middle" },
    { "type": "wait_frames", "n": 2 },

    { "type": "press_key", "key": "4", "modifiers": { "ctrl": true } },
    { "type": "wait_frames", "n": 20 },
    { "type": "press_key", "key": "7", "modifiers": { "ctrl": true } },
    { "type": "wait_frames", "n": 2 },

    { "type": "move_pointer", "target": { "kind": "test_id", "id": "node_graph.canvas" } },
    { "type": "wait_frames", "n": 2 },

    {
      "type": "wait_until",
      "predicate": { "kind": "exists", "target": { "kind": "test_id", "id": "node_graph.portal.tooltip" } },
      "timeout_frames": 600
    },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "value_contains",
        "target": { "kind": "test_id", "id": "node_graph.portal.tooltip" },
        "text": "source=portal_bounds_store;"
      },
      "timeout_frames": 600
    },

    { "type": "capture_bundle", "label": "node-graph-paint-only-hover-shows-portal-tooltip" }
  ]
}
