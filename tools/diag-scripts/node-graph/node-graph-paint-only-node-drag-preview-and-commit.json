{
  "schema_version": 2,
  "meta": {
    "name": "Node graph (paint-only): node drag preview does not rebuild geometry; commit rebuilds once",
    "tags": ["node-graph", "declarative", "paint-only", "drag", "cache", "gate"],
    "required_capabilities": ["diag.script_v2"],
    "target_hints": [
      "Run with `FRET_NODE_GRAPH_DECLARATIVE=paint` so the paint-only declarative surface is active.",
      "Requires `FRET_DIAG=1` (diagnostics-only shortcuts).",
      "Uses the diagnostics-only normalize shortcut (Ctrl+4) to place a node under the canvas center.",
      "Asserts that drag preview does not rebuild cached node/edge geometry render data; commit (pointer-up) does."
    ]
  },
  "steps": [
    { "type": "press_key", "key": "escape" },
    { "type": "wait_frames", "n": 5 },
    {
      "type": "wait_until",
      "predicate": { "kind": "exists", "target": { "kind": "test_id", "id": "node_graph.canvas" } },
      "timeout_frames": 600
    },
    { "type": "move_pointer", "target": { "kind": "test_id", "id": "node_graph.canvas" } },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "value_contains",
        "target": { "kind": "test_id", "id": "node_graph.canvas" },
        "text": "nodes_rebuilds:1;"
      },
      "timeout_frames": 600
    },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "value_contains",
        "target": { "kind": "test_id", "id": "node_graph.canvas" },
        "text": "edges_rebuilds:1;"
      },
      "timeout_frames": 600
    },

    { "type": "click", "target": { "kind": "test_id", "id": "node_graph.canvas" }, "button": "middle" },
    { "type": "wait_frames", "n": 2 },

    { "type": "press_key", "key": "4", "modifiers": { "ctrl": true } },
    { "type": "wait_frames", "n": 10 },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "value_contains",
        "target": { "kind": "test_id", "id": "node_graph.canvas" },
        "text": "nodes_rebuilds:2;"
      },
      "timeout_frames": 600
    },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "value_contains",
        "target": { "kind": "test_id", "id": "node_graph.canvas" },
        "text": "edges_rebuilds:2;"
      },
      "timeout_frames": 600
    },

    {
      "type": "pointer_down",
      "window": { "kind": "current" },
      "target": { "kind": "test_id", "id": "node_graph.canvas" },
      "button": "left"
    },
    { "type": "wait_until", "predicate": { "kind": "event_kind_seen", "event_kind": "pointer.down" }, "timeout_frames": 120 },
    { "type": "pointer_move", "window": { "kind": "current" }, "delta_x": 80.0, "delta_y": 40.0, "steps": 10 },
    { "type": "wait_frames", "n": 2 },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "value_contains",
        "target": { "kind": "test_id", "id": "node_graph.canvas" },
        "text": "node_dragging:true;"
      },
      "timeout_frames": 240
    },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "value_contains",
        "target": { "kind": "test_id", "id": "node_graph.canvas" },
        "text": "nodes_rebuilds:2;"
      },
      "timeout_frames": 240
    },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "value_contains",
        "target": { "kind": "test_id", "id": "node_graph.canvas" },
        "text": "edges_rebuilds:2;"
      },
      "timeout_frames": 240
    },

    { "type": "pointer_move", "window": { "kind": "current" }, "delta_x": 120.0, "delta_y": 60.0, "steps": 10 },
    { "type": "wait_frames", "n": 2 },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "value_contains",
        "target": { "kind": "test_id", "id": "node_graph.canvas" },
        "text": "nodes_rebuilds:2;"
      },
      "timeout_frames": 240
    },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "value_contains",
        "target": { "kind": "test_id", "id": "node_graph.canvas" },
        "text": "edges_rebuilds:2;"
      },
      "timeout_frames": 240
    },

    { "type": "pointer_up", "window": { "kind": "current" } },
    { "type": "wait_frames", "n": 10 },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "value_contains",
        "target": { "kind": "test_id", "id": "node_graph.canvas" },
        "text": "nodes_rebuilds:3;"
      },
      "timeout_frames": 600
    },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "value_contains",
        "target": { "kind": "test_id", "id": "node_graph.canvas" },
        "text": "edges_rebuilds:3;"
      },
      "timeout_frames": 600
    },

    { "type": "capture_bundle", "label": "node-graph-paint-only-node-drag-preview-and-commit" }
  ]
}
