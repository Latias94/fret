{
  "schema_version": 2,
  "meta": {
    "name": "Node graph (paint-only): wires screenshots",
    "tags": ["node-graph", "declarative", "paint-only", "wires", "screenshot"],
    "required_capabilities": ["diag.script_v2", "diag.screenshot_png"],
    "target_hints": [
      "Run with `FRET_NODE_GRAPH_DECLARATIVE=paint` so the paint-only declarative surface is active.",
      "Requires `FRET_DIAG_GPU_SCREENSHOTS=1` to actually emit GPU screenshots."
    ]
  },
  "steps": [
    { "type": "press_key", "key": "escape" },
    { "type": "wait_frames", "n": 5 },
    {
      "type": "wait_until",
      "predicate": { "kind": "exists", "target": { "kind": "test_id", "id": "node_graph.canvas" } },
      "timeout_frames": 600
    },
    { "type": "move_pointer", "target": { "kind": "test_id", "id": "node_graph.canvas" } },
    { "type": "click", "target": { "kind": "test_id", "id": "node_graph.canvas" }, "button": "middle" },
    { "type": "wait_frames", "n": 20 },

    { "type": "capture_bundle", "label": "node-graph-paint-only-wires-before" },
    { "type": "capture_screenshot", "label": "node-graph-paint-only-wires-before" },

    { "type": "press_key", "key": "2", "modifiers": { "ctrl": true } },
    { "type": "wait_frames", "n": 5 },
    { "type": "press_key", "key": "2", "modifiers": { "ctrl": true } },
    { "type": "wait_frames", "n": 5 },
    { "type": "press_key", "key": "1", "modifiers": { "ctrl": true } },
    { "type": "wait_frames", "n": 10 },

    { "type": "capture_bundle", "label": "node-graph-paint-only-wires-after-zoom" },
    { "type": "capture_screenshot", "label": "node-graph-paint-only-wires-after-zoom" }
  ]
}
