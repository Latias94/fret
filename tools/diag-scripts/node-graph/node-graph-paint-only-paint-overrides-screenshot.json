{
  "schema_version": 2,
  "meta": {
    "name": "Node graph (paint-only): paint overrides screenshots",
    "tags": ["node-graph", "declarative", "paint-only", "overrides", "paint", "screenshot"],
    "required_capabilities": ["diag.script_v2", "diag.screenshot_png"],
    "target_hints": [
      "Run the `node_graph_demo` binary (it defaults to the paint-only declarative surface).",
      "Requires `FRET_DIAG=1` so Ctrl+6 diagnostics toggle is enabled.",
      "Requires `FRET_DIAG_GPU_SCREENSHOTS=1` to actually emit GPU screenshots."
    ]
  },
  "steps": [
    { "type": "press_key", "key": "escape" },
    { "type": "wait_frames", "n": 5 },
    {
      "type": "wait_until",
      "predicate": { "kind": "exists", "target": { "kind": "test_id", "id": "node_graph.canvas" } },
      "timeout_frames": 600
    },
    { "type": "move_pointer", "target": { "kind": "test_id", "id": "node_graph.canvas" } },
    { "type": "click", "target": { "kind": "test_id", "id": "node_graph.canvas" }, "button": "middle" },
    { "type": "wait_frames", "n": 20 },

    { "type": "capture_bundle", "label": "node-graph-paint-only-paint-overrides-before" },
    { "type": "capture_screenshot", "label": "node-graph-paint-only-paint-overrides-before" },

    { "type": "press_key", "key": "6", "modifiers": { "ctrl": true } },
    { "type": "wait_frames", "n": 10 },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "value_contains",
        "target": { "kind": "test_id", "id": "node_graph.canvas" },
        "text": "paint_overrides_rev:1;"
      },
      "timeout_frames": 600
    },

    { "type": "capture_bundle", "label": "node-graph-paint-only-paint-overrides-after" },
    { "type": "capture_screenshot", "label": "node-graph-paint-only-paint-overrides-after" }
  ]
}
