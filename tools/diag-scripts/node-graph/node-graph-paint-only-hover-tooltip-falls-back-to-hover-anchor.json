{
  "schema_version": 2,
  "meta": {
    "name": "Node graph (paint-only): hover tooltip falls back to hover anchor when portals disabled",
    "tags": ["node-graph", "declarative", "paint-only", "portal", "hover", "tooltip", "gate", "fallback"],
    "required_capabilities": ["diag.script_v2"],
    "target_hints": [
      "Run with `FRET_NODE_GRAPH_DECLARATIVE=paint` so the paint-only declarative surface is active.",
      "Requires `FRET_DIAG=1` (Ctrl+4 normalization, Ctrl+8 disable portals).",
      "This gates that hover-driven overlays do not depend on portal hosting caps; tooltip falls back to HoverAnchorStore."
    ]
  },
  "steps": [
    { "type": "press_key", "key": "escape" },
    { "type": "wait_frames", "n": 5 },

    {
      "type": "wait_until",
      "predicate": { "kind": "exists", "target": { "kind": "test_id", "id": "node_graph.canvas" } },
      "timeout_frames": 600
    },

    { "type": "click", "target": { "kind": "test_id", "id": "node_graph.canvas" }, "button": "middle" },
    { "type": "wait_frames", "n": 2 },

    { "type": "press_key", "key": "4", "modifiers": { "ctrl": true } },
    { "type": "wait_frames", "n": 20 },

    { "type": "press_key", "key": "8", "modifiers": { "ctrl": true } },
    { "type": "wait_frames", "n": 5 },

    { "type": "move_pointer", "target": { "kind": "test_id", "id": "node_graph.canvas" } },
    { "type": "wait_frames", "n": 2 },

    {
      "type": "wait_until",
      "predicate": { "kind": "exists", "target": { "kind": "test_id", "id": "node_graph.portal.tooltip" } },
      "timeout_frames": 600
    },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "value_contains",
        "target": { "kind": "test_id", "id": "node_graph.portal.tooltip" },
        "text": "source=hover_anchor_store;"
      },
      "timeout_frames": 600
    },

    { "type": "capture_bundle", "label": "node-graph-paint-only-hover-tooltip-falls-back-to-hover-anchor" }
  ]
}
