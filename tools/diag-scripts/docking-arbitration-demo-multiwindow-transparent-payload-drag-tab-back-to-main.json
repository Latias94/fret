{
  "schema_version": 2,
  "meta": {
    "name": "Docking arbitration demo: transparent payload drag tab back to main restores canonical graph",
    "tags": ["docking", "multiwindow", "drag", "transparent_payload", "gate"],
    "required_capabilities": ["diag.script_v2", "diag.multi_window"],
    "env_defaults": {
      "FRET_DOCK_ALLOW_MULTI_WINDOW_TEAR_OFF": "1",
      "FRET_DOCK_TEAROFF_TRANSPARENT_PAYLOAD": "1"
    },
    "target_hints": [
      "This gate exercises an ImGui-style 'peek-behind' drag-back flow: tear off a tab to create a dock-floating OS window, then drag the tab back into the main window while the floating window follows the cursor and is rendered semi-transparent.",
      "Expected: `dock_drag_transparent_payload_applied_is` becomes true, and `dock_drag_current_window_is` can switch to the main window even while the moving window overlaps it (via window-under-moving-window routing)."
    ]
  },
  "steps": [
    { "type": "press_key", "window": { "kind": "first_seen" }, "key": "escape" },
    { "type": "wait_frames", "n": 2 },

    { "type": "set_window_outer_position", "window": { "kind": "first_seen" }, "x_px": 120.0, "y_px": 120.0 },
    { "type": "set_window_inner_size", "window": { "kind": "first_seen" }, "width_px": 1600.0, "height_px": 900.0 },
    { "type": "wait_frames", "n": 2 },

    {
      "type": "wait_bounds_stable",
      "target": { "kind": "test_id", "id": "dock-arb-tab-drag-anchor-right" },
      "stable_frames": 12,
      "max_move_px": 0.5,
      "timeout_frames": 240
    },
    {
      "type": "wait_until",
      "window": { "kind": "first_seen" },
      "predicate": { "kind": "exists", "target": { "kind": "test_id", "id": "dock-arb-tab-drag-anchor-right" } },
      "timeout_frames": 240
    },

    {
      "type": "drag_pointer_until",
      "window": { "kind": "current" },
      "target": { "kind": "test_id", "id": "dock-arb-tab-drag-anchor-right" },
      "delta_x": 2400.0,
      "delta_y": 0.0,
      "steps": 140,
      "predicate": { "kind": "known_window_count_ge", "n": 2 },
      "timeout_frames": 600
    },
    { "type": "wait_until", "predicate": { "kind": "known_window_count_ge", "n": 2 }, "timeout_frames": 240 },
    { "type": "wait_frames", "n": 30 },

    { "type": "set_window_outer_position", "window": { "kind": "last_seen" }, "x_px": 180.0, "y_px": 180.0 },
    { "type": "wait_frames", "n": 10 },

    { "type": "wait_until", "window": { "kind": "last_seen" }, "predicate": { "kind": "exists", "target": { "kind": "test_id", "id": "dock-arb-dock-space" } }, "timeout_frames": 240 },
    { "type": "wait_frames", "n": 2 },

    { "type": "raise_window", "window": { "kind": "last_seen" } },
    { "type": "set_cursor_in_window_logical", "window": { "kind": "last_seen" }, "x_px": 640.0, "y_px": 260.0 },
    { "type": "wait_frames", "n": 2 },

    { "type": "pointer_down", "window": { "kind": "last_seen" }, "target": { "kind": "test_id", "id": "dock-arb-tab-drag-anchor-right" } },
    { "type": "pointer_move", "window": { "kind": "last_seen" }, "delta_x": 20.0, "delta_y": 0.0, "steps": 12 },
    { "type": "wait_until", "window": { "kind": "last_seen" }, "predicate": { "kind": "dock_drag_active_is", "active": true }, "timeout_frames": 120 },
    { "type": "wait_frames", "n": 2 },
    {
      "type": "wait_until",
      "window": { "kind": "last_seen" },
      "predicate": { "kind": "dock_drag_transparent_payload_applied_is", "applied": true },
      "timeout_frames": 120
    },
    {
      "type": "wait_until",
      "window": { "kind": "last_seen" },
      "predicate": { "kind": "dock_drag_moving_window_is", "window": { "kind": "last_seen" } },
      "timeout_frames": 240
    },

    { "type": "raise_window", "window": { "kind": "last_seen" } },
    { "type": "set_cursor_in_window_logical", "window": { "kind": "last_seen" }, "x_px": 220.0, "y_px": 220.0 },
    { "type": "wait_frames", "n": 2 },

    {
      "type": "pointer_move",
      "window": { "kind": "last_seen" },
      "delta_x": -800.0,
      "delta_y": 0.0,
      "steps": 90
    },
    {
      "type": "wait_until",
      "window": { "kind": "last_seen" },
      "predicate": { "kind": "dock_drag_current_window_is", "window": { "kind": "first_seen" } },
      "timeout_frames": 240
    },
    { "type": "pointer_up", "window": { "kind": "last_seen" } },
    { "type": "wait_until", "window": { "kind": "last_seen" }, "predicate": { "kind": "dock_drag_active_is", "active": false }, "timeout_frames": 240 },

    { "type": "wait_until", "window": { "kind": "last_seen" }, "predicate": { "kind": "dock_graph_canonical_is", "canonical": true }, "timeout_frames": 240 },
    {
      "type": "assert",
      "window": { "kind": "first_seen" },
      "predicate": {
        "kind": "dock_graph_signature_is",
        "signature": "dock(root=split(v,[split(h,[tabs([demo.viewport.left]),tabs([demo.viewport.right])]),tabs([demo.controls])]);floatings=[])"
      }
    },

    { "type": "capture_bundle", "label": "docking-arbitration-demo-multiwindow-transparent-payload-drag-tab-back-to-main" },
    { "type": "wait_frames", "n": 2 }
  ]
}
