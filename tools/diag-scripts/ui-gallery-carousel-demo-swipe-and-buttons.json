{
  "schema_version": 2,
  "meta": {
    "name": "UI gallery: carousel demo swipe + buttons",
    "tags": ["ui-gallery", "carousel", "gate"],
    "required_capabilities": ["diag.script_v2"],
    "target_hints": [
      "Navigate to the Carousel page and exercise next/previous controls plus a swipe gesture.",
      "Expected behavior: interactions are routed correctly and do not regress pointer event propagation."
    ]
  },
  "steps": [
    { "type": "reset_diagnostics" },
    { "type": "press_key", "key": "escape" },
    { "type": "wait_frames", "n": 2 },

    {
      "type": "wait_until",
      "predicate": { "kind": "exists", "target": { "kind": "test_id", "id": "ui-gallery-nav-search" } },
      "timeout_frames": 240
    },

    { "type": "set_window_inner_size", "width_px": 1280.0, "height_px": 720.0 },
    { "type": "wait_frames", "n": 10 },

    { "type": "click", "target": { "kind": "test_id", "id": "ui-gallery-nav-search" } },
    { "type": "press_key", "key": "a", "modifiers": { "ctrl": true } },
    { "type": "press_key", "key": "backspace" },
    { "type": "type_text", "text": "carousel" },
    { "type": "wait_frames", "n": 2 },

    {
      "type": "wait_until",
      "predicate": {
        "kind": "bounds_within_window",
        "target": { "kind": "test_id", "id": "ui-gallery-nav-carousel" },
        "padding_px": 8.0,
        "eps_px": 1.0
      },
      "timeout_frames": 240
    },
    { "type": "click", "target": { "kind": "test_id", "id": "ui-gallery-nav-carousel" } },

    {
      "type": "wait_until",
      "predicate": { "kind": "exists", "target": { "kind": "test_id", "id": "ui-gallery-page-carousel" } },
      "timeout_frames": 240
    },
    {
      "type": "wait_until",
      "predicate": { "kind": "exists", "target": { "kind": "test_id", "id": "ui-gallery-carousel-demo" } },
      "timeout_frames": 240
    },
    {
      "type": "scroll_into_view",
      "container": { "kind": "test_id", "id": "ui-gallery-content-scroll" },
      "target": { "kind": "test_id", "id": "ui-gallery-carousel-demo" },
      "delta_y": -120.0,
      "require_fully_within_container": true,
      "require_fully_within_window": true,
      "padding_px": 16.0,
      "timeout_frames": 600
    },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-carousel-demo-inner-button" }
      },
      "timeout_frames": 240
    },

    {
      "type": "wait_until",
      "predicate": {
        "kind": "bounds_within_window",
        "target": { "kind": "test_id", "id": "ui-gallery-carousel-demo-inner-button" },
        "padding_px": 8.0,
        "eps_px": 1.0
      },
      "timeout_frames": 240
    },

    { "type": "pointer_down", "target": { "kind": "test_id", "id": "ui-gallery-carousel-demo-inner-button" } },
    { "type": "pointer_move", "delta_x": -40.0, "delta_y": 0.0, "steps": 24 },
    { "type": "pointer_up" },
    { "type": "wait_frames", "n": 20 },
    {
      "type": "assert",
      "predicate": { "kind": "not_exists", "target": { "kind": "test_id", "id": "ui-gallery-carousel-demo-inner-clicked" } }
    },

    { "type": "click_stable", "target": { "kind": "test_id", "id": "ui-gallery-carousel-demo-inner-button" } },
    {
      "type": "wait_until",
      "predicate": { "kind": "exists", "target": { "kind": "test_id", "id": "ui-gallery-carousel-demo-inner-clicked" } },
      "timeout_frames": 240
    },

    { "type": "click", "target": { "kind": "test_id", "id": "ui-gallery-carousel-demo-next" } },
    { "type": "wait_frames", "n": 3 },
    { "type": "click", "target": { "kind": "test_id", "id": "ui-gallery-carousel-demo-next" } },
    { "type": "wait_frames", "n": 3 },
    { "type": "click", "target": { "kind": "test_id", "id": "ui-gallery-carousel-demo-previous" } },
    { "type": "wait_frames", "n": 3 },
    { "type": "click", "target": { "kind": "test_id", "id": "ui-gallery-carousel-demo-previous" } },
    { "type": "wait_frames", "n": 3 },

    { "type": "pointer_down", "target": { "kind": "test_id", "id": "ui-gallery-carousel-demo-item-1" } },
    { "type": "pointer_move", "delta_x": -180.0, "delta_y": 0.0, "steps": 24 },
    { "type": "pointer_up" },
    { "type": "wait_frames", "n": 10 },

    { "type": "capture_bundle", "label": "ui-gallery-carousel-demo-swipe-and-buttons" }
  ]
}
