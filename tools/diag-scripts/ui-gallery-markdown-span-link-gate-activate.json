{
  "schema_version": 2,
  "meta": {
    "name": "ui-gallery-markdown-span-link-gate-activate",
    "required_capabilities": ["diag.script_v2", "diag.screenshot_png"],
    "tags": ["ui_gallery", "markdown", "text", "selectable_text", "interactive_spans", "links"]
  },
  "steps": [
    { "type": "reset_diagnostics" },
    { "type": "press_key", "key": "escape" },
    { "type": "wait_frames", "n": 2 },

    {
      "type": "wait_until",
      "predicate": { "kind": "exists", "target": { "kind": "test_id", "id": "ui-gallery-nav-search" } },
      "timeout_frames": 600
    },
    {
      "type": "wait_until",
      "predicate": { "kind": "exists", "target": { "kind": "test_id", "id": "ui-gallery-nav-scroll" } },
      "timeout_frames": 600
    },

    { "type": "set_window_inner_size", "width_px": 1280.0, "height_px": 720.0 },
    { "type": "wait_frames", "n": 10 },

    { "type": "click", "target": { "kind": "test_id", "id": "ui-gallery-nav-search" } },
    { "type": "press_key", "key": "a", "modifiers": { "ctrl": true } },
    { "type": "press_key", "key": "backspace" },
    { "type": "type_text", "text": "markdown" },
    { "type": "wait_frames", "n": 2 },

    {
      "type": "scroll_into_view",
      "container": { "kind": "test_id", "id": "ui-gallery-nav-scroll" },
      "target": { "kind": "test_id", "id": "ui-gallery-nav-markdown-editor-source" },
      "delta_y": -240.0,
      "timeout_frames": 600
    },
    { "type": "click", "target": { "kind": "test_id", "id": "ui-gallery-nav-markdown-editor-source" } },
    {
      "type": "wait_until",
      "predicate": { "kind": "exists", "target": { "kind": "test_id", "id": "ui-gallery-markdown-editor-root" } },
      "timeout_frames": 600
    },

    { "type": "wait_until", "predicate": { "kind": "font_catalog_populated" }, "timeout_frames": 1800 },
    { "type": "wait_until", "predicate": { "kind": "system_font_rescan_idle" }, "timeout_frames": 1800 },
    {
      "type": "wait_until",
      "predicate": { "kind": "text_font_stack_key_stable", "stable_frames": 120 },
      "timeout_frames": 900
    },

    { "type": "wait_frames", "n": 10 },
    { "type": "capture_screenshot", "label": "markdown-span-link-gate-before", "timeout_frames": 240 },

    {
      "type": "scroll_into_view",
      "container": { "kind": "test_id", "id": "ui-gallery-content-scroll" },
      "target": { "kind": "test_id", "id": "ui-gallery-markdown-span-link-gate" },
      "delta_y": -160.0,
      "require_fully_within_window": true,
      "padding_px": 24.0,
      "timeout_frames": 600
    },

    {
      "type": "click_selectable_text_span_stable",
      "target": { "kind": "test_id", "id": "ui-gallery-markdown-span-link-gate" },
      "tag": "https://example.com"
    },
    {
      "type": "wait_until",
      "predicate": { "kind": "exists", "target": { "kind": "test_id", "id": "ui-gallery-markdown-span-link-activated" } },
      "timeout_frames": 600
    },

    { "type": "wait_frames", "n": 5 },
    { "type": "capture_screenshot", "label": "markdown-span-link-gate-after", "timeout_frames": 240 },
    { "type": "capture_bundle", "label": "ui-gallery-markdown-span-link-gate-activate" },
    { "type": "wait_frames", "n": 2 }
  ]
}
