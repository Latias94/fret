{
  "schema_version": 2,
  "steps": [
    {
      "type": "wait_until",
      "predicate": { "kind": "font_catalog_populated" },
      "timeout_frames": 1800
    },
    {
      "type": "wait_until",
      "predicate": { "kind": "system_font_rescan_idle" },
      "timeout_frames": 1800
    },
    {
      "type": "wait_until",
      "predicate": { "kind": "text_font_stack_key_stable", "stable_frames": 120 },
      "timeout_frames": 600
    },
    { "type": "reset_diagnostics" },
    { "type": "wait_frames", "n": 1 }
  ]
}
