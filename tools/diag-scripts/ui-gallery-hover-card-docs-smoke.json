{
  "meta": {
    "required_capabilities": ["diag.script_v2"]
  },
  "schema_version": 2,
  "steps": [
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-nav-search" }
      },
      "timeout_frames": 600
    },
    { "type": "press_key", "key": "escape" },
    { "type": "wait_frames", "n": 2 },

    {
      "type": "click",
      "button": "left",
      "target": { "kind": "test_id", "id": "ui-gallery-nav-search" }
    },
    { "type": "press_key", "key": "a", "modifiers": { "ctrl": true } },
    { "type": "press_key", "key": "backspace" },
    { "type": "type_text", "text": "hover card" },
    { "type": "wait_frames", "n": 2 },

    {
      "type": "wait_until",
      "predicate": {
        "kind": "bounds_within_window",
        "target": { "kind": "test_id", "id": "ui-gallery-nav-hover-card" },
        "padding_px": 8.0,
        "eps_px": 1.0
      },
      "timeout_frames": 600
    },
    {
      "type": "click",
      "button": "left",
      "target": { "kind": "test_id", "id": "ui-gallery-nav-hover-card" }
    },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-page-hover-card" }
      },
      "timeout_frames": 600
    },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-hover-card-demo" }
      },
      "timeout_frames": 600
    },

    {
      "type": "move_pointer",
      "target": { "kind": "test_id", "id": "ui-gallery-hover-card-demo-trigger" }
    },
    { "type": "wait_frames", "n": 20 },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-hover-card-demo-content" }
      },
      "timeout_frames": 600
    },
    {
      "type": "move_pointer",
      "target": { "kind": "test_id", "id": "ui-gallery-hover-card-demo-content" }
    },

    { "type": "capture_bundle", "label": "ui-gallery-hover-card-docs-smoke" },
    { "type": "capture_screenshot", "label": "ui-gallery-hover-card-docs-smoke" }
  ]
}
