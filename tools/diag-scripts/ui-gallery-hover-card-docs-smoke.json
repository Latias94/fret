{
  "schema_version": 2,
  "meta": {
    "name": "ui-gallery-hover-card-docs-smoke",
    "required_capabilities": ["diag.script_v2"]
  },
  "steps": [
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-nav-search" }
      },
      "timeout_frames": 240
    },
    { "type": "click", "target": { "kind": "test_id", "id": "ui-gallery-nav-search" } },
    { "type": "press_key", "key": "a", "modifiers": { "ctrl": true } },
    { "type": "press_key", "key": "backspace" },
    { "type": "type_text", "text": "hover card" },
    { "type": "wait_frames", "n": 2 },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-nav-hover-card" }
      },
      "timeout_frames": 240
    },
    { "type": "click", "target": { "kind": "test_id", "id": "ui-gallery-nav-hover-card" } },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-page-hover-card" }
      },
      "timeout_frames": 240
    },
    {
      "type": "move_pointer",
      "target": { "kind": "test_id", "id": "ui-gallery-hover-card-demo-trigger" }
    },
    { "type": "wait_frames", "n": 20 },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-hover-card-demo-content" }
      },
      "timeout_frames": 240
    },
    { "type": "capture_bundle", "label": "ui-gallery-hover-card-docs-smoke" }
  ]
}
