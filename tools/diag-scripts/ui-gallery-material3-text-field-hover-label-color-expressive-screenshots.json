{
  "schema_version": 2,
  "meta": {
    "name": "ui-gallery-material3-text-field-hover-label-color-expressive-screenshots",
    "required_capabilities": ["diag.script_v2", "diag.screenshot_png"],
    "tags": ["ui_gallery", "material3", "text_field", "outlined", "hover", "label", "expressive", "screenshots"]
  },
  "steps": [
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-nav-search" }
      },
      "timeout_frames": 600
    },
    { "type": "click", "target": { "kind": "test_id", "id": "ui-gallery-nav-search" } },
    { "type": "press_key", "key": "a", "modifiers": { "ctrl": true } },
    { "type": "press_key", "key": "backspace" },
    { "type": "type_text", "text": "text field" },
    { "type": "wait_frames", "n": 2 },
    {
      "type": "ensure_visible",
      "target": { "kind": "test_id", "id": "ui-gallery-nav-material3-text-field" },
      "within_window": true,
      "padding_px": 8.0,
      "timeout_frames": 600
    },
    {
      "type": "click",
      "target": { "kind": "test_id", "id": "ui-gallery-nav-material3-text-field" }
    },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-page-material3-text-field" }
      },
      "timeout_frames": 600
    },
    { "type": "wait_frames", "n": 20 },
    {
      "type": "ensure_visible",
      "target": { "kind": "test_id", "id": "ui-gallery-material3-text-field" },
      "within_window": true,
      "padding_px": 8.0,
      "timeout_frames": 600
    },
    { "type": "capture_bundle", "label": "m3-text-field-00-idle" },
    { "type": "capture_screenshot", "label": "m3-text-field-00-idle" },
    {
      "type": "move_pointer",
      "target": { "kind": "test_id", "id": "ui-gallery-material3-text-field" }
    },
    { "type": "wait_frames", "n": 6 },
    { "type": "capture_bundle", "label": "m3-text-field-10-hover-outlined" },
    { "type": "capture_screenshot", "label": "m3-text-field-10-hover-outlined" },
    { "type": "capture_bundle", "label": "ui-gallery-material3-text-field-hover-label-color-expressive" }
  ]
}

