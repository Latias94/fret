{
  "schema_version": 2,
  "meta": {
    "name": "Workspace shell demo: cross-pane tab move (drop at end)",
    "tags": ["workspace", "tabstrip", "cross_pane", "gate"],
    "required_capabilities": ["diag.script_v2"]
  },
  "steps": [
    { "type": "set_window_inner_size", "width_px": 1280.0, "height_px": 720.0 },
    { "type": "wait_frames", "n": 10 },

    {
      "type": "wait_until",
      "predicate": { "kind": "exists", "target": { "kind": "test_id", "id": "workspace-shell-pane-pane-a-tab-doc-a-2" } },
      "timeout_frames": 240
    },
    {
      "type": "wait_until",
      "predicate": { "kind": "exists", "target": { "kind": "test_id", "id": "workspace-shell-pane-pane-b-tab-strip.drop_end" } },
      "timeout_frames": 240
    },

    {
      "type": "drag_to",
      "from": { "kind": "test_id", "id": "workspace-shell-pane-pane-a-tab-doc-a-2" },
      "to": { "kind": "test_id", "id": "workspace-shell-pane-pane-b-tab-strip.drop_end" },
      "steps": 84,
      "timeout_frames": 240
    },

    {
      "type": "wait_until",
      "predicate": { "kind": "exists", "target": { "kind": "test_id", "id": "workspace-shell-pane-pane-b-tab-doc-a-2" } },
      "timeout_frames": 240
    },
    {
      "type": "wait_until",
      "predicate": { "kind": "not_exists", "target": { "kind": "test_id", "id": "workspace-shell-pane-pane-a-tab-doc-a-2" } },
      "timeout_frames": 240
    },

    { "type": "capture_bundle", "label": "workspace-shell-demo-tab-cross-pane-move-to-end" }
  ]
}
