{
  "schema_version": 2,
  "meta": {
    "name": "Workspace shell demo: open tab context menu via right click (smoke)",
    "tags": ["workspace", "tabstrip", "context_menu", "pointer", "smoke"],
    "required_capabilities": ["diag.script_v2"],
    "target_hints": [
      "Right-clicks a tab (doc-a-2).",
      "Waits for the Pin Tab menu item test_id to appear."
    ]
  },
  "steps": [
    { "type": "set_window_inner_size", "width_px": 1280.0, "height_px": 720.0 },
    { "type": "wait_frames", "n": 10 },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "workspace-shell-pane-pane-a-tab-doc-a-2" }
      },
      "timeout_frames": 240
    },
    {
      "type": "click",
      "button": "right",
      "target": { "kind": "test_id", "id": "workspace-shell-pane-pane-a-tab-doc-a-2" }
    },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "workspace-shell-pane-pane-a-tab-doc-a-2.menu.pin" }
      },
      "timeout_frames": 240
    },
    { "type": "capture_bundle", "label": "contextmenu-opened-via-right-click" }
  ]
}

