{
  "meta": {
    "name": "Workspace shell demo: drag tab to pane edge to split (right)",
    "required_capabilities": [
      "diag.script_v2"
    ],
    "tags": [
      "workspace",
      "tabstrip",
      "drag_to_split",
      "gate"
    ]
  },
  "schema_version": 2,
  "steps": [
    {
      "height_px": 720.0,
      "type": "set_window_inner_size",
      "width_px": 1280.0
    },
    {
      "n": 10,
      "type": "wait_frames"
    },
    {
      "predicate": {
        "kind": "exists",
        "target": {
          "id": "workspace-shell-pane-pane-a-tab-doc-a-2",
          "kind": "test_id"
        }
      },
      "timeout_frames": 240,
      "type": "wait_until"
    },
    {
      "predicate": {
        "kind": "exists",
        "target": {
          "id": "workspace-shell-pane-pane-b-root",
          "kind": "test_id"
        }
      },
      "timeout_frames": 240,
      "type": "wait_until"
    },
    {
      "delta_x": 1200.0,
      "delta_y": 140.0,
      "predicate": {
        "kind": "exists",
        "target": {
          "id": "workspace-pane-pane-b.drop_preview.right",
          "kind": "test_id"
        }
      },
      "release_on_success": true,
      "steps": 160,
      "target": {
        "id": "workspace-shell-pane-pane-a-tab-doc-a-2",
        "kind": "test_id"
      },
      "timeout_frames": 480,
      "type": "drag_pointer_until",
      "window": {
        "kind": "current"
      }
    },
    {
      "n": 10,
      "type": "wait_frames"
    },
    {
      "predicate": {
        "kind": "exists",
        "target": {
          "id": "workspace-shell-pane-window-1.pane.1-root",
          "kind": "test_id"
        }
      },
      "timeout_frames": 240,
      "type": "wait_until"
    },
    {
      "predicate": {
        "kind": "exists",
        "target": {
          "id": "workspace-shell-pane-window-1.pane.1-tab-doc-a-2",
          "kind": "test_id"
        }
      },
      "timeout_frames": 240,
      "type": "wait_until"
    },
    {
      "predicate": {
        "kind": "not_exists",
        "target": {
          "id": "workspace-shell-pane-pane-a-tab-doc-a-2",
          "kind": "test_id"
        }
      },
      "timeout_frames": 240,
      "type": "wait_until"
    },
    {
      "label": "workspace-shell-demo-tab-drag-to-split-right",
      "type": "capture_bundle"
    }
  ]
}
