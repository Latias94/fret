{
  "meta": {
    "name": "Workspace shell demo: close button closes active tab (smoke)",
    "required_capabilities": [
      "diag.script_v2",
      "diag.command_dispatch_trace"
    ],
    "tags": [
      "workspace",
      "tabstrip",
      "close",
      "smoke",
      "gate"
    ],
    "target_hints": [
      "Resets diagnostics so dispatch trace assertions are deterministic.",
      "Activates doc-a-0 (pane A) so the close target is in-view.",
      "Clicks the close button and asserts a pointer-triggered dispatch trace entry exists.",
      "Asserts the tab is removed from the UI tree."
    ]
  },
  "schema_version": 2,
  "steps": [
    {
      "type": "reset_diagnostics"
    },
    {
      "height_px": 720.0,
      "type": "set_window_inner_size",
      "width_px": 1280.0
    },
    {
      "n": 10,
      "type": "wait_frames"
    },
    {
      "predicate": {
        "kind": "exists",
        "target": {
          "id": "workspace-shell-pane-pane-a-tab-doc-a-0",
          "kind": "test_id"
        }
      },
      "timeout_frames": 240,
      "type": "wait_until"
    },
    {
      "target": {
        "id": "workspace-shell-pane-pane-a-tab-doc-a-0",
        "kind": "test_id"
      },
      "type": "click_stable"
    },
    {
      "predicate": {
        "kind": "selected_is",
        "selected": true,
        "target": {
          "id": "workspace-shell-pane-pane-a-tab-doc-a-0",
          "kind": "test_id"
        }
      },
      "timeout_frames": 240,
      "type": "wait_until"
    },
    {
      "predicate": {
        "kind": "exists",
        "target": {
          "id": "workspace-shell-pane-pane-a-tab-doc-a-0.close",
          "kind": "test_id"
        }
      },
      "timeout_frames": 240,
      "type": "wait_until"
    },
    {
      "target": {
        "id": "workspace-shell-pane-pane-a-tab-doc-a-0.close",
        "kind": "test_id"
      },
      "type": "click_stable"
    },
    {
      "query": {
        "command": "workspace.tab.close.doc-a-0",
        "handled": true,
        "source_kind": "pointer",
        "source_test_id": "workspace-shell-pane-pane-a-tab-doc-a-0.close"
      },
      "timeout_frames": 240,
      "type": "wait_command_dispatch_trace"
    },
    {
      "predicate": {
        "kind": "not_exists",
        "target": {
          "id": "workspace-shell-pane-pane-a-tab-doc-a-0",
          "kind": "test_id"
        }
      },
      "timeout_frames": 240,
      "type": "wait_until"
    },
    {
      "label": "workspace-shell-demo-tab-close-button-closes-tab-smoke",
      "type": "capture_bundle"
    }
  ]
}
