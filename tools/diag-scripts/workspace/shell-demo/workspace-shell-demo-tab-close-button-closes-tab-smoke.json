{
  "schema_version": 2,
  "meta": {
    "name": "Workspace shell demo: close button closes active tab (smoke)",
    "tags": ["workspace", "tabstrip", "close", "smoke", "gate"],
    "required_capabilities": ["diag.script_v2", "diag.command_dispatch_trace"],
    "target_hints": [
      "Activates a visible tab (pane A, doc-a-0).",
      "Waits for its close button.",
      "Clicks the close button.",
      "Asserts a pointer-triggered command dispatch trace entry exists for the close command.",
      "Asserts the tab is removed from the UI tree."
    ]
  },
  "steps": [
    { "type": "reset_diagnostics" },
    { "type": "set_window_inner_size", "width_px": 1280.0, "height_px": 720.0 },
    { "type": "wait_frames", "n": 10 },

    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "workspace-shell-pane-pane-a-tab-doc-a-0" }
      },
      "timeout_frames": 240
    },

    {
      "type": "click_stable",
      "target": { "kind": "test_id", "id": "workspace-shell-pane-pane-a-tab-doc-a-0" }
    },
    { "type": "wait_frames", "n": 10 },

    {
      "type": "wait_until",
      "predicate": {
        "kind": "selected_is",
        "target": { "kind": "test_id", "id": "workspace-shell-pane-pane-a-tab-doc-a-0" },
        "selected": true
      },
      "timeout_frames": 240
    },

    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "workspace-shell-pane-pane-a-tab-doc-a-0.close" }
      },
      "timeout_frames": 240
    },

    {
      "type": "click_stable",
      "target": { "kind": "test_id", "id": "workspace-shell-pane-pane-a-tab-doc-a-0.close" }
    },
    {
      "type": "wait_command_dispatch_trace",
      "query": {
        "command": "workspace.tab.close.doc-a-0",
        "source_kind": "pointer"
      },
      "timeout_frames": 240
    },

    {
      "type": "wait_until",
      "predicate": {
        "kind": "not_exists",
        "target": { "kind": "test_id", "id": "workspace-shell-pane-pane-a-tab-doc-a-0" }
      },
      "timeout_frames": 240
    },

    { "type": "capture_bundle", "label": "workspace-shell-demo-tab-close-button-closes-tab-smoke" }
  ]
}
