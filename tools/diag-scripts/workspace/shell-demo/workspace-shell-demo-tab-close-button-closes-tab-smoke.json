{
  "schema_version": 2,
  "meta": {
    "name": "Workspace shell demo: close button closes active tab (smoke)",
    "tags": ["workspace", "tabstrip", "close", "smoke", "gate"],
    "required_capabilities": ["diag.script_v2"],
    "target_hints": [
      "Waits for the close button on the active tab (pane A, doc-a-2).",
      "Clicks the close button.",
      "Asserts the tab is removed from the UI tree."
    ]
  },
  "steps": [
    { "type": "set_window_inner_size", "width_px": 1280.0, "height_px": 720.0 },
    { "type": "wait_frames", "n": 10 },

    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "workspace-shell-pane-pane-a-tab-doc-a-2.close" }
      },
      "timeout_frames": 240
    },

    { "type": "click", "target": { "kind": "test_id", "id": "workspace-shell-pane-pane-a-tab-doc-a-2.close" } },
    { "type": "wait_frames", "n": 10 },

    {
      "type": "wait_until",
      "predicate": {
        "kind": "not_exists",
        "target": { "kind": "test_id", "id": "workspace-shell-pane-pane-a-tab-doc-a-2" }
      },
      "timeout_frames": 240
    },

    { "type": "capture_bundle", "label": "workspace-shell-demo-tab-close-button-closes-tab-smoke" }
  ]
}

