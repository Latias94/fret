{
  "meta": {
    "name": "Workspace shell demo: close button closes active tab (smoke)",
    "required_capabilities": [
      "diag.script_v2"
    ],
    "tags": [
      "workspace",
      "tabstrip",
      "close",
      "smoke",
      "gate"
    ],
    "target_hints": [
      "Activates doc-a-0 (pane A) so the close target is guaranteed to be in-view.",
      "Waits for the close button on the active tab (pane A, doc-a-0).",
      "Clicks the close button.",
      "Asserts the tab is removed from the UI tree."
    ]
  },
  "schema_version": 2,
  "steps": [
    {
      "height_px": 720.0,
      "type": "set_window_inner_size",
      "width_px": 1280.0
    },
    {
      "n": 10,
      "type": "wait_frames"
    },
    {
      "predicate": {
        "kind": "exists",
        "target": {
          "id": "workspace-shell-pane-pane-a-tab-doc-a-0",
          "kind": "test_id"
        }
      },
      "timeout_frames": 240,
      "type": "wait_until"
    },
    {
      "target": {
        "id": "workspace-shell-pane-pane-a-tab-doc-a-0",
        "kind": "test_id"
      },
      "type": "click"
    },
    {
      "n": 6,
      "type": "wait_frames"
    },
    {
      "predicate": {
        "kind": "exists",
        "target": {
          "id": "workspace-shell-pane-pane-a-tab-doc-a-0.close",
          "kind": "test_id"
        }
      },
      "timeout_frames": 240,
      "type": "wait_until"
    },
    {
      "target": {
        "id": "workspace-shell-pane-pane-a-tab-doc-a-0.close",
        "kind": "test_id"
      },
      "type": "click"
    },
    {
      "n": 10,
      "type": "wait_frames"
    },
    {
      "predicate": {
        "kind": "not_exists",
        "target": {
          "id": "workspace-shell-pane-pane-a-tab-doc-a-0",
          "kind": "test_id"
        }
      },
      "timeout_frames": 240,
      "type": "wait_until"
    },
    {
      "label": "workspace-shell-demo-tab-close-button-closes-tab-smoke",
      "type": "capture_bundle"
    }
  ]
}
