{
  "schema_version": 2,
  "meta": {
    "name": "Workspace shell demo: overflow menu close does not activate tab (smoke)",
    "tags": ["workspace", "tabstrip", "overflow", "close", "smoke", "gate"],
    "required_capabilities": ["diag.script_v2"],
    "target_hints": [
      "Shrinks the window to force tab strip overflow.",
      "Selects a stable active tab (doc-a-0).",
      "Opens the overflow menu and clicks the close affordance for a hidden tab entry.",
      "Asserts the closed tab is removed and the previously active tab remains selected."
    ]
  },
  "steps": [
    { "type": "set_window_inner_size", "width_px": 420.0, "height_px": 720.0 },
    { "type": "wait_frames", "n": 10 },

    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "workspace-shell-pane-pane-a-tab-strip.overflow_button" }
      },
      "timeout_frames": 240
    },

    {
      "type": "click",
      "target": { "kind": "test_id", "id": "workspace-shell-pane-pane-a-tab-doc-a-0" }
    },
    { "type": "wait_frames", "n": 10 },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "selected_is",
        "target": { "kind": "test_id", "id": "workspace-shell-pane-pane-a-tab-doc-a-0" },
        "selected": true
      },
      "timeout_frames": 240
    },

    {
      "type": "click",
      "target": { "kind": "test_id", "id": "workspace-shell-pane-pane-a-tab-strip.overflow_button" }
    },
    { "type": "wait_frames", "n": 20 },

    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": {
          "kind": "test_id",
          "id": "workspace-shell-pane-pane-a-tab-strip.overflow_entry.doc-a-2.close"
        }
      },
      "timeout_frames": 240
    },

    {
      "type": "click",
      "target": {
        "kind": "test_id",
        "id": "workspace-shell-pane-pane-a-tab-strip.overflow_entry.doc-a-2.close"
      }
    },
    { "type": "wait_frames", "n": 20 },

    {
      "type": "wait_until",
      "predicate": {
        "kind": "not_exists",
        "target": { "kind": "test_id", "id": "workspace-shell-pane-pane-a-tab-doc-a-2" }
      },
      "timeout_frames": 240
    },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "selected_is",
        "target": { "kind": "test_id", "id": "workspace-shell-pane-pane-a-tab-doc-a-0" },
        "selected": true
      },
      "timeout_frames": 240
    },

    { "type": "capture_bundle", "label": "workspace-shell-demo-tab-overflow-close-does-not-activate" }
  ]
}
