{
  "meta": {
    "name": "Workspace shell demo: drop preview screenshot while dragging tab to split (right)",
    "required_capabilities": [
      "diag.script_v2",
      "diag.screenshot_png"
    ],
    "tags": [
      "workspace",
      "tabstrip",
      "drop_preview",
      "screenshots",
      "gate"
    ],
    "target_hints": [
      "Drags a tab from pane A toward the right edge of pane B.",
      "Waits for the right-edge drop preview indicator to appear.",
      "Captures a screenshot while the preview is visible (used to gate docking drop overlay tokens)."
    ]
  },
  "schema_version": 2,
  "steps": [
    {
      "height_px": 720.0,
      "type": "set_window_inner_size",
      "width_px": 1280.0
    },
    {
      "n": 10,
      "type": "wait_frames"
    },
    {
      "predicate": {
        "kind": "exists",
        "target": {
          "id": "workspace-shell-pane-pane-a-tab-doc-a-0",
          "kind": "test_id"
        }
      },
      "timeout_frames": 240,
      "type": "wait_until"
    },
    {
      "predicate": {
        "kind": "exists",
        "target": {
          "id": "workspace-shell-pane-pane-b-root",
          "kind": "test_id"
        }
      },
      "timeout_frames": 240,
      "type": "wait_until"
    },
    {
      "delta_x": 4000.0,
      "delta_y": 140.0,
      "predicate": {
        "kind": "exists",
        "target": {
          "id": "workspace-pane-pane-b.drop_preview.right",
          "kind": "test_id"
        }
      },
      "release_on_success": false,
      "steps": 200,
      "target": {
        "id": "workspace-shell-pane-pane-a-tab-doc-a-0",
        "kind": "test_id"
      },
      "timeout_frames": 480,
      "type": "drag_pointer_until",
      "window": {
        "kind": "current"
      }
    },
    {
      "n": 8,
      "type": "wait_frames"
    },
    {
      "label": "workspace-shell-demo-drop-preview-right",
      "type": "capture_screenshot"
    },
    {
      "key": "escape",
      "type": "press_key"
    },
    {
      "n": 2,
      "type": "wait_frames"
    },
    {
      "type": "pointer_up",
      "window": {
        "kind": "current"
      }
    },
    {
      "n": 8,
      "type": "wait_frames"
    },
    {
      "predicate": {
        "kind": "not_exists",
        "target": {
          "id": "workspace-pane-pane-b.drop_preview.right",
          "kind": "test_id"
        }
      },
      "timeout_frames": 240,
      "type": "wait_until"
    },
    {
      "label": "workspace-shell-demo-tab-drag-to-split-right-drop-preview-screenshot",
      "type": "capture_bundle"
    }
  ]
}
