{
  "meta": {
    "name": "Workspace shell demo: drop preview screenshot while dragging tab to split (right)",
    "required_capabilities": [
      "diag.script_v2",
      "diag.screenshot_png"
    ],
    "tags": [
      "workspace",
      "tabstrip",
      "drop_preview",
      "screenshots",
      "gate"
    ],
    "target_hints": [
      "Drags a tab from pane A toward the right edge of pane B.",
      "Waits for the right-edge drop preview indicator to appear.",
      "Captures a screenshot while the preview is visible (used to gate docking drop overlay tokens)."
    ]
  },
  "schema_version": 2,
  "steps": [
    {
      "height_px": 720.0,
      "type": "set_window_inner_size",
      "width_px": 1280.0
    },
    {
      "n": 10,
      "type": "wait_frames"
    },
    {
      "predicate": {
        "kind": "exists",
        "target": {
          "id": "workspace-shell-pane-pane-a-tab-doc-a-2",
          "kind": "test_id"
        }
      },
      "timeout_frames": 240,
      "type": "wait_until"
    },
    {
      "predicate": {
        "kind": "exists",
        "target": {
          "id": "workspace-shell-pane-pane-b-root",
          "kind": "test_id"
        }
      },
      "timeout_frames": 240,
      "type": "wait_until"
    },
    {
      "type": "pointer_down",
      "window": { "kind": "current" },
      "target": { "kind": "test_id", "id": "workspace-shell-pane-pane-a-tab-doc-a-2" },
      "button": "left"
    },
    {
      "type": "pointer_move",
      "window": { "kind": "current" },
      "delta_x": 420.0,
      "delta_y": 0.0,
      "steps": 42
    },
    {
      "type": "set_cursor_in_window_logical",
      "window": { "kind": "current" },
      "x_px": 1278.0,
      "y_px": 160.0
    },
    {
      "type": "pointer_move",
      "window": { "kind": "current" },
      "delta_x": -1.0,
      "delta_y": 0.0,
      "steps": 1
    },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "workspace-pane-pane-b.drop_preview.right" }
      },
      "timeout_frames": 480
    },
    {
      "n": 8,
      "type": "wait_frames"
    },
    {
      "label": "workspace-shell-demo-drop-preview-right",
      "type": "capture_screenshot"
    },
    {
      "type": "set_cursor_in_window_logical",
      "window": {
        "kind": "current"
      },
      "x_px": 1100.0,
      "y_px": 160.0
    },
    {
      "delta_x": -1.0,
      "delta_y": 0.0,
      "steps": 1,
      "type": "pointer_move",
      "window": {
        "kind": "current"
      }
    },
    {
      "type": "pointer_up",
      "window": {
        "kind": "current"
      }
    },
    {
      "type": "move_pointer",
      "target": { "kind": "test_id", "id": "workspace-shell-pane-pane-b-content" }
    },
    {
      "n": 8,
      "type": "wait_frames"
    },
    {
      "predicate": {
        "kind": "not_exists",
        "target": {
          "id": "workspace-pane-pane-b.drop_preview.right",
          "kind": "test_id"
        }
      },
      "timeout_frames": 240,
      "type": "wait_until"
    },
    {
      "label": "workspace-shell-demo-tab-drag-to-split-right-drop-preview-screenshot",
      "type": "capture_bundle"
    }
  ]
}
