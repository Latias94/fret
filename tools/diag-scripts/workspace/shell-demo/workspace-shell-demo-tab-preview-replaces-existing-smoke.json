{
  "schema_version": 2,
  "meta": {
    "name": "Workspace shell demo: preview tab replaces previous preview (smoke)",
    "tags": ["workspace", "tabstrip", "preview", "smoke", "gate"],
    "required_capabilities": ["diag.script_v2"],
    "env_defaults": {
      "FRET_WORKSPACE_SHELL_DEBUG_PREVIEW": "1"
    },
    "target_hints": [
      "Clicks the demo-only debug controls to open preview A, then preview B.",
      "Asserts the previous preview tab is replaced (removed) and the new one is marked as preview."
    ]
  },
  "steps": [
    { "type": "set_window_inner_size", "width_px": 1280.0, "height_px": 720.0 },
    { "type": "wait_frames", "n": 10 },

    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "workspace-shell-pane-pane-a-debug-open-preview-a" }
      },
      "timeout_frames": 240
    },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "workspace-shell-pane-pane-a-debug-open-preview-b" }
      },
      "timeout_frames": 240
    },

    { "type": "click", "target": { "kind": "test_id", "id": "workspace-shell-pane-pane-a-debug-open-preview-a" } },
    { "type": "wait_frames", "n": 6 },
    {
      "type": "wait_until",
      "predicate": { "kind": "exists", "target": { "kind": "test_id", "id": "workspace-shell-pane-pane-a-tab-doc-a-preview-a.preview" } },
      "timeout_frames": 240
    },

    { "type": "click", "target": { "kind": "test_id", "id": "workspace-shell-pane-pane-a-debug-open-preview-b" } },
    { "type": "wait_frames", "n": 6 },
    {
      "type": "wait_until",
      "predicate": { "kind": "not_exists", "target": { "kind": "test_id", "id": "workspace-shell-pane-pane-a-tab-doc-a-preview-a" } },
      "timeout_frames": 240
    },
    {
      "type": "wait_until",
      "predicate": { "kind": "exists", "target": { "kind": "test_id", "id": "workspace-shell-pane-pane-a-tab-doc-a-preview-b.preview" } },
      "timeout_frames": 240
    },

    { "type": "capture_bundle", "label": "workspace-shell-demo-tab-preview-replaces-existing-smoke" }
  ]
}
