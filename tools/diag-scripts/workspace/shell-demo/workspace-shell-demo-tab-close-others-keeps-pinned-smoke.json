{
  "schema_version": 2,
  "meta": {
    "name": "Workspace shell demo: close others keeps pinned (smoke)",
    "tags": ["workspace", "tabstrip", "close", "pinned", "smoke", "gate"],
    "required_capabilities": ["diag.script_v2"],
    "target_hints": [
      "Pins doc-a-0 via the tab context menu.",
      "Activates doc-a-2 (pane A).",
      "Runs Close Other Tabs from doc-a-2's tab context menu.",
      "Asserts the pinned tab is kept and only the active unpinned tab remains."
    ]
  },
  "steps": [
    { "type": "set_window_inner_size", "width_px": 1280.0, "height_px": 720.0 },
    { "type": "wait_frames", "n": 10 },

    {
      "type": "wait_until",
      "predicate": { "kind": "exists", "target": { "kind": "test_id", "id": "workspace-shell-pane-pane-a-tab-doc-a-0" } },
      "timeout_frames": 240
    },

    { "type": "click", "button": "right", "target": { "kind": "test_id", "id": "workspace-shell-pane-pane-a-tab-doc-a-0" } },
    {
      "type": "wait_until",
      "predicate": { "kind": "bounds_within_window", "target": { "kind": "role_and_name", "role": "menu_item", "name": "Pin Tab" } },
      "timeout_frames": 240
    },
    { "type": "click", "target": { "kind": "role_and_name", "role": "menu_item", "name": "Pin Tab" } },
    {
      "type": "wait_until",
      "predicate": { "kind": "exists", "target": { "kind": "test_id", "id": "workspace-shell-pane-pane-a-tab-doc-a-0.pinned" } },
      "timeout_frames": 240
    },

    {
      "type": "pointer_down",
      "window": { "kind": "current" },
      "target": { "kind": "test_id", "id": "workspace-shell-pane-pane-a-tab-doc-a-2" },
      "button": "left"
    },
    { "type": "pointer_up", "window": { "kind": "current" } },
    {
      "type": "wait_until",
      "predicate": { "kind": "selected_is", "target": { "kind": "test_id", "id": "workspace-shell-pane-pane-a-tab-doc-a-2" }, "selected": true },
      "timeout_frames": 240
    },

    { "type": "click", "button": "right", "target": { "kind": "test_id", "id": "workspace-shell-pane-pane-a-tab-doc-a-2" } },
    {
      "type": "wait_until",
      "predicate": { "kind": "bounds_within_window", "target": { "kind": "role_and_name", "role": "menu_item", "name": "Close Other Tabs" } },
      "timeout_frames": 240
    },
    { "type": "click", "target": { "kind": "role_and_name", "role": "menu_item", "name": "Close Other Tabs" } },
    { "type": "wait_frames", "n": 10 },

    {
      "type": "wait_until",
      "predicate": { "kind": "not_exists", "target": { "kind": "test_id", "id": "workspace-shell-pane-pane-a-tab-doc-a-1" } },
      "timeout_frames": 240
    },
    {
      "type": "wait_until",
      "predicate": { "kind": "set_size_is", "target": { "kind": "test_id", "id": "workspace-shell-pane-pane-a-tab-doc-a-2" }, "set_size": 2 },
      "timeout_frames": 240
    },
    { "type": "assert", "predicate": { "kind": "exists", "target": { "kind": "test_id", "id": "workspace-shell-pane-pane-a-tab-doc-a-0.pinned" } } },
    { "type": "assert", "predicate": { "kind": "exists", "target": { "kind": "test_id", "id": "workspace-shell-pane-pane-a-tab-doc-a-2" } } },
    { "type": "assert", "predicate": { "kind": "pos_in_set_is", "target": { "kind": "test_id", "id": "workspace-shell-pane-pane-a-tab-doc-a-0" }, "pos_in_set": 1 } },
    { "type": "assert", "predicate": { "kind": "pos_in_set_is", "target": { "kind": "test_id", "id": "workspace-shell-pane-pane-a-tab-doc-a-2" }, "pos_in_set": 2 } },

    { "type": "capture_bundle", "label": "workspace-shell-demo-tab-close-others-keeps-pinned-smoke" }
  ]
}
