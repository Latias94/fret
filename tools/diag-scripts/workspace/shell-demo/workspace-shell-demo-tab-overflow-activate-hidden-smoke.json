{
  "schema_version": 2,
  "meta": {
    "name": "Workspace shell demo: overflow menu activates hidden tab (smoke)",
    "tags": ["workspace", "tabstrip", "overflow", "smoke", "gate"],
    "required_capabilities": ["diag.script_v2"],
    "target_hints": [
      "Shrinks the window to force tab strip overflow.",
      "Opens the overflow menu.",
      "Selects a known tab entry from the overflow list.",
      "Asserts the tab becomes selected."
    ]
  },
  "steps": [
    { "type": "set_window_inner_size", "width_px": 420.0, "height_px": 720.0 },
    { "type": "wait_frames", "n": 10 },

    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "workspace-shell-pane-pane-a-tab-strip.overflow_button" }
      },
      "timeout_frames": 240
    },

    {
      "type": "click",
      "target": { "kind": "test_id", "id": "workspace-shell-pane-pane-a-tab-doc-a-0" }
    },
    { "type": "wait_frames", "n": 10 },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "selected_is",
        "target": { "kind": "test_id", "id": "workspace-shell-pane-pane-a-tab-doc-a-0" },
        "selected": true
      },
      "timeout_frames": 240
    },

    {
      "type": "click",
      "target": { "kind": "test_id", "id": "workspace-shell-pane-pane-a-tab-strip.overflow_button" }
    },
    { "type": "wait_frames", "n": 20 },

    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "workspace-shell-pane-pane-a-tab-strip.overflow_entry.doc-a-2" }
      },
      "timeout_frames": 240
    },

    {
      "type": "click",
      "target": { "kind": "test_id", "id": "workspace-shell-pane-pane-a-tab-strip.overflow_entry.doc-a-2" }
    },
    { "type": "wait_frames", "n": 20 },

    {
      "type": "wait_until",
      "predicate": {
        "kind": "selected_is",
        "target": { "kind": "test_id", "id": "workspace-shell-pane-pane-a-tab-doc-a-2" },
        "selected": true
      },
      "timeout_frames": 240
    },

    {
      "type": "wait_until",
      "predicate": {
        "kind": "workspace_tab_strip_active_overflow_is",
        "overflow": true,
        "pane_id": "pane-a"
      },
      "timeout_frames": 240
    },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "workspace_tab_strip_active_visible_is",
        "visible": true,
        "pane_id": "pane-a"
      },
      "timeout_frames": 240
    },

    { "type": "capture_bundle", "label": "workspace-shell-demo-tab-overflow-activate-hidden-smoke" }
  ]
}
