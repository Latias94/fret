{
  "meta": {
    "name": "Workspace shell demo: overflow menu activates hidden tab (smoke)",
    "required_capabilities": [
      "diag.script_v2"
    ],
    "tags": [
      "workspace",
      "tabstrip",
      "overflow",
      "smoke",
      "gate"
    ],
    "target_hints": [
      "Shrinks the window to force tab strip overflow.",
      "Opens the overflow menu.",
      "Selects a known tab entry from the overflow list.",
      "Asserts the tab becomes selected."
    ]
  },
  "schema_version": 2,
  "steps": [
    {
      "height_px": 720.0,
      "type": "set_window_inner_size",
      "width_px": 420.0
    },
    {
      "n": 10,
      "type": "wait_frames"
    },
    {
      "predicate": {
        "kind": "exists",
        "target": {
          "id": "workspace-shell-pane-pane-a-tab-strip.overflow_button",
          "kind": "test_id"
        }
      },
      "timeout_frames": 240,
      "type": "wait_until"
    },
    {
      "target": {
        "id": "workspace-shell-pane-pane-a-tab-doc-a-0",
        "kind": "test_id"
      },
      "type": "click"
    },
    {
      "n": 10,
      "type": "wait_frames"
    },
    {
      "predicate": {
        "kind": "selected_is",
        "selected": true,
        "target": {
          "id": "workspace-shell-pane-pane-a-tab-doc-a-0",
          "kind": "test_id"
        }
      },
      "timeout_frames": 240,
      "type": "wait_until"
    },
    {
      "target": {
        "id": "workspace-shell-pane-pane-a-tab-strip.overflow_button",
        "kind": "test_id"
      },
      "type": "click"
    },
    {
      "n": 20,
      "type": "wait_frames"
    },
    {
      "predicate": {
        "kind": "exists",
        "target": {
          "id": "workspace-shell-pane-pane-a-tab-strip.overflow_entry.doc-a-2",
          "kind": "test_id"
        }
      },
      "timeout_frames": 240,
      "type": "wait_until"
    },
    {
      "target": {
        "id": "workspace-shell-pane-pane-a-tab-strip.overflow_entry.doc-a-2",
        "kind": "test_id"
      },
      "type": "click"
    },
    {
      "n": 20,
      "type": "wait_frames"
    },
    {
      "predicate": {
        "kind": "selected_is",
        "selected": true,
        "target": {
          "id": "workspace-shell-pane-pane-a-tab-doc-a-2",
          "kind": "test_id"
        }
      },
      "timeout_frames": 240,
      "type": "wait_until"
    },
    {
      "predicate": {
        "kind": "workspace_tab_strip_active_overflow_is",
        "overflow": true,
        "pane_id": "pane-a"
      },
      "timeout_frames": 240,
      "type": "wait_until"
    },
    {
      "predicate": {
        "kind": "workspace_tab_strip_active_visible_is",
        "pane_id": "pane-a",
        "visible": true
      },
      "timeout_frames": 240,
      "type": "wait_until"
    },
    {
      "predicate": {
        "kind": "workspace_tab_strip_active_scroll_px_ge",
        "pane_id": "pane-a",
        "px": 1.0
      },
      "timeout_frames": 240,
      "type": "wait_until"
    },
    {
      "label": "workspace-shell-demo-tab-overflow-activate-hidden-smoke",
      "type": "capture_bundle"
    }
  ]
}
