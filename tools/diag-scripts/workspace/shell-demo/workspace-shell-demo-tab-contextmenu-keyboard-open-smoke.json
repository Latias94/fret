{
  "schema_version": 2,
  "meta": {
    "name": "Workspace shell demo: open tab context menu via keyboard (Shift+F10)",
    "tags": ["workspace", "tabstrip", "context_menu", "keyboard", "smoke"],
    "required_capabilities": ["diag.script_v2"],
    "target_hints": [
      "Focuses a tab (doc-a-0).",
      "Invokes the tab context menu via Shift+F10.",
      "Waits for the Pin Tab menu item test_id to appear."
    ]
  },
  "steps": [
    { "type": "set_window_inner_size", "width_px": 1280.0, "height_px": 720.0 },
    { "type": "wait_frames", "n": 10 },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "workspace-shell-pane-pane-a-tab-doc-a-2" }
      },
      "timeout_frames": 240
    },
    {
      "type": "click",
      "target": { "kind": "test_id", "id": "workspace-shell-pane-pane-a-tab-doc-a-2" }
    },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "selected_is",
        "target": { "kind": "test_id", "id": "workspace-shell-pane-pane-a-tab-doc-a-2" },
        "selected": true
      },
      "timeout_frames": 240
    },
    { "type": "press_key", "key": "f10", "modifiers": { "shift": true } },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "workspace-shell-pane-pane-a-tab-doc-a-2.menu.pin" }
      },
      "timeout_frames": 240
    },
    { "type": "capture_bundle", "label": "contextmenu-opened-via-shift-f10" }
  ]
}
