{
  "schema_version": 2,
  "meta": {
    "name": "Workspace shell demo: tabstrip close keeps focus in strip (smoke)",
    "tags": ["workspace", "tabstrip", "focus", "close", "smoke", "gate"],
    "required_capabilities": ["diag.script_v2"],
    "target_hints": [
      "Sets MRU by activating doc-a-2 then doc-a-1.",
      "Moves keyboard focus into the tab strip (Ctrl+F6).",
      "Closes the active tab via the close button.",
      "Asserts selection and focus stay within the tab strip (MRU fallback)."
    ]
  },
  "steps": [
    { "type": "set_window_inner_size", "width_px": 1280.0, "height_px": 720.0 },
    { "type": "wait_frames", "n": 10 },

    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "workspace-shell-pane-pane-a-tab-doc-a-2" }
      },
      "timeout_frames": 240
    },

    { "type": "click", "target": { "kind": "test_id", "id": "workspace-shell-pane-pane-a-tab-doc-a-2" } },
    { "type": "wait_frames", "n": 6 },
    { "type": "click", "target": { "kind": "test_id", "id": "workspace-shell-pane-pane-a-tab-doc-a-1" } },
    { "type": "wait_frames", "n": 6 },

    { "type": "press_key", "key": "f6", "modifiers": { "ctrl": true }, "repeat": false },
    { "type": "wait_frames", "n": 10 },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "focus_is",
        "target": { "kind": "test_id", "id": "workspace-shell-pane-pane-a-tab-doc-a-1" }
      },
      "timeout_frames": 240
    },

    {
      "type": "click_stable",
      "target": { "kind": "test_id", "id": "workspace-shell-pane-pane-a-tab-doc-a-1.close" },
      "button": "left",
      "stable_frames": 2,
      "max_move_px": 1.0,
      "timeout_frames": 240
    },
    { "type": "wait_frames", "n": 20 },

    {
      "type": "wait_until",
      "predicate": { "kind": "not_exists", "target": { "kind": "test_id", "id": "workspace-shell-pane-pane-a-tab-doc-a-1" } },
      "timeout_frames": 240
    },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "selected_is",
        "target": { "kind": "test_id", "id": "workspace-shell-pane-pane-a-tab-doc-a-2" },
        "selected": true
      },
      "timeout_frames": 240
    },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "focus_is",
        "target": { "kind": "test_id", "id": "workspace-shell-pane-pane-a-tab-doc-a-2" }
      },
      "timeout_frames": 240
    },

    { "type": "capture_bundle", "label": "workspace-shell-demo-tabstrip-close-keeps-focus-smoke" }
  ]
}
