{
  "meta": {
    "name": "Workspace shell demo: close active tab selects MRU fallback (smoke)",
    "required_capabilities": [
      "diag.script_v2"
    ],
    "tags": [
      "workspace",
      "tabstrip",
      "close",
      "smoke",
      "gate"
    ],
    "target_hints": [
      "Activates doc-a-1 (pane A) so MRU is deterministic.",
      "Closes doc-a-1 via the close button.",
      "Asserts doc-a-1 is removed and selection falls back to doc-a-2 (MRU fallback)."
    ]
  },
  "schema_version": 2,
  "steps": [
    {
      "height_px": 720.0,
      "type": "set_window_inner_size",
      "width_px": 1280.0
    },
    {
      "n": 10,
      "type": "wait_frames"
    },
    {
      "predicate": {
        "kind": "exists",
        "target": {
          "id": "workspace-shell-pane-pane-a-tab-doc-a-2.close",
          "kind": "test_id"
        }
      },
      "timeout_frames": 240,
      "type": "wait_until"
    },
    {
      "target": {
        "id": "workspace-shell-pane-pane-a-tab-doc-a-1",
        "kind": "test_id"
      },
      "type": "click"
    },
    {
      "n": 6,
      "type": "wait_frames"
    },
    {
      "predicate": {
        "kind": "exists",
        "target": {
          "id": "workspace-shell-pane-pane-a-tab-doc-a-1.close",
          "kind": "test_id"
        }
      },
      "timeout_frames": 240,
      "type": "wait_until"
    },
    {
      "target": {
        "id": "workspace-shell-pane-pane-a-tab-doc-a-1.close",
        "kind": "test_id"
      },
      "type": "click"
    },
    {
      "n": 10,
      "type": "wait_frames"
    },
    {
      "predicate": {
        "kind": "not_exists",
        "target": {
          "id": "workspace-shell-pane-pane-a-tab-doc-a-1",
          "kind": "test_id"
        }
      },
      "timeout_frames": 240,
      "type": "wait_until"
    },
    {
      "predicate": {
        "kind": "exists",
        "target": {
          "id": "workspace-shell-pane-pane-a-tab-doc-a-2.close",
          "kind": "test_id"
        }
      },
      "timeout_frames": 240,
      "type": "wait_until"
    },
    {
      "label": "workspace-shell-demo-tab-close-mru-fallback-smoke",
      "type": "capture_bundle"
    }
  ]
}
