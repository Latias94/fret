{
  "schema_version": 2,
  "meta": {
    "name": "Docking arbitration demo: float-zone forces in-window floating",
    "tags": ["docking", "floating", "gate"],
    "required_capabilities": ["diag.script_v2"],
    "target_hints": [
      "Drag a docked tab to the float-zone affordance (top-right of the dock tab bar) and drop it.",
      "Expected behavior: the panel becomes an in-window floating container (no OS window tear-off).",
      "This gate is invariant-based (dock diagnostics), not pixel-based."
    ]
  },
  "steps": [
    { "type": "press_key", "key": "escape" },
    { "type": "wait_frames", "n": 2 },

    { "type": "set_window_outer_position", "x_px": 120.0, "y_px": 120.0 },
    { "type": "set_window_inner_size", "width_px": 1600.0, "height_px": 900.0 },
    { "type": "wait_frames", "n": 2 },

    {
      "type": "wait_until",
      "predicate": { "kind": "exists", "target": { "kind": "test_id", "id": "dock-arb-dock-space" } },
      "timeout_frames": 240
    },
    {
      "type": "wait_until",
      "predicate": { "kind": "exists", "target": { "kind": "test_id", "id": "dock-arb-tab-drag-anchor-right" } },
      "timeout_frames": 240
    },
    {
      "type": "wait_until",
      "predicate": { "kind": "dock_graph_signature_is", "signature": "dock(root=split(v,[split(h,[tabs([demo.viewport.left]),tabs([demo.viewport.right])]),tabs([demo.controls])]);floatings=[])" },
      "timeout_frames": 240
    },

    { "type": "pointer_down", "target": { "kind": "test_id", "id": "dock-arb-tab-drag-anchor-right" } },
    { "type": "pointer_move", "delta_x": 20.0, "delta_y": 0.0, "steps": 12 },
    { "type": "wait_until", "predicate": { "kind": "dock_drag_active_is", "active": true }, "timeout_frames": 120 },

    {
      "type": "pointer_move",
      "delta_x": 386.0,
      "delta_y": 0.0,
      "steps": 36
    },
    {
      "type": "wait_until",
      "predicate": { "kind": "dock_drop_resolve_source_is", "source": "float_zone" },
      "timeout_frames": 120
    },

    { "type": "pointer_up" },
    { "type": "wait_until", "predicate": { "kind": "dock_drag_active_is", "active": false }, "timeout_frames": 240 },

    {
      "type": "wait_until",
      "predicate": { "kind": "dock_graph_signature_contains", "needle": "floating(" },
      "timeout_frames": 240
    },
    { "type": "assert", "predicate": { "kind": "dock_graph_canonical_is", "canonical": true } },
    { "type": "assert", "predicate": { "kind": "dock_graph_has_nested_same_axis_splits_is", "has_nested": false } },

    { "type": "capture_bundle", "label": "docking-arbitration-demo-float-zone-floats-in-window" },
    { "type": "wait_frames", "n": 2 }
  ]
}
