{
  "schema_version": 2,
  "meta": {
    "name": "ui-gallery-calendar-mixed-responsive-popover-vs-panel",
    "required_capabilities": ["diag.script_v2", "diag.screenshot_png"],
    "env_defaults": { "FRET_UI_GALLERY_FIXED_TODAY": "2026-05-15" }
  },
  "steps": [
    { "type": "reset_diagnostics" },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-nav-search" }
      },
      "timeout_frames": 1800
    },
    { "type": "press_key", "key": "escape" },
    { "type": "wait_frames", "n": 2 },
    { "type": "set_window_inner_size", "width_px": 1280.0, "height_px": 720.0 },
    { "type": "wait_frames", "n": 15 },

    { "type": "click", "target": { "kind": "test_id", "id": "ui-gallery-nav-search" } },
    { "type": "press_key", "key": "a", "modifiers": { "ctrl": true } },
    { "type": "press_key", "key": "backspace" },
    { "type": "type_text", "text": "calendar" },
    {
      "type": "wait_until",
      "timeout_frames": 1800,
      "predicate": { "kind": "exists", "target": { "kind": "test_id", "id": "ui-gallery-nav-calendar" } }
    },
    { "type": "click", "target": { "kind": "test_id", "id": "ui-gallery-nav-calendar" } },
    {
      "type": "wait_until",
      "timeout_frames": 1800,
      "predicate": { "kind": "exists", "target": { "kind": "test_id", "id": "ui-gallery-page-calendar" } }
    },

    {
      "type": "scroll_into_view",
      "container": { "kind": "test_id", "id": "ui-gallery-content-scroll" },
      "target": {
        "kind": "test_id",
        "id": "ui-gallery.calendar.responsive.panel.month:2026-05-01"
      },
      "delta_y": -200.0,
      "require_fully_within_container": true,
      "require_fully_within_window": true,
      "padding_px": 16.0,
      "timeout_frames": 1800
    },

    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": {
          "kind": "test_id",
          "id": "ui-gallery.calendar.responsive.panel.month:2026-06-01"
        }
      },
      "timeout_frames": 600
    },
    {
      "type": "assert",
      "predicate": {
        "kind": "bounds_overlapping_x",
        "a": { "kind": "test_id", "id": "ui-gallery.calendar.responsive.panel.month:2026-05-01" },
        "b": { "kind": "test_id", "id": "ui-gallery.calendar.responsive.panel.month:2026-06-01" },
        "eps_px": 1.0
      }
    },
    {
      "type": "assert",
      "predicate": {
        "kind": "bounds_non_overlapping",
        "a": { "kind": "test_id", "id": "ui-gallery.calendar.responsive.panel.month:2026-05-01" },
        "b": { "kind": "test_id", "id": "ui-gallery.calendar.responsive.panel.month:2026-06-01" },
        "eps_px": 1.0
      }
    },
    { "type": "capture_screenshot", "label": "ui-gallery-calendar-mixed-responsive-panel" },

    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": {
          "kind": "test_id",
          "id": "ui-gallery-calendar-responsive-popover-trigger"
        }
      },
      "timeout_frames": 600
    },
    {
      "type": "click",
      "target": { "kind": "test_id", "id": "ui-gallery-calendar-responsive-popover-trigger" }
    },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-calendar-responsive-popover-content" }
      },
      "timeout_frames": 600
    },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": {
          "kind": "test_id",
          "id": "ui-gallery.calendar.responsive.popover.month:2026-05-01"
        }
      },
      "timeout_frames": 600
    },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": {
          "kind": "test_id",
          "id": "ui-gallery.calendar.responsive.popover.month:2026-06-01"
        }
      },
      "timeout_frames": 600
    },
    {
      "type": "assert",
      "predicate": {
        "kind": "bounds_overlapping_y",
        "a": { "kind": "test_id", "id": "ui-gallery.calendar.responsive.popover.month:2026-05-01" },
        "b": { "kind": "test_id", "id": "ui-gallery.calendar.responsive.popover.month:2026-06-01" },
        "eps_px": 1.0
      }
    },
    {
      "type": "assert",
      "predicate": {
        "kind": "bounds_non_overlapping",
        "a": { "kind": "test_id", "id": "ui-gallery.calendar.responsive.popover.month:2026-05-01" },
        "b": { "kind": "test_id", "id": "ui-gallery.calendar.responsive.popover.month:2026-06-01" },
        "eps_px": 1.0
      }
    },
    { "type": "capture_screenshot", "label": "ui-gallery-calendar-mixed-responsive-popover" },

    { "type": "capture_bundle", "label": "ui-gallery-calendar-mixed-responsive-popover-vs-panel" }
  ]
}
