{
  "schema_version": 2,
  "meta": {
    "name": "UI Gallery: bundled mixed-script fallback conformance (no system fonts)",
    "tags": ["ui-gallery", "text", "fonts", "fallback", "conformance"],
    "target_hints": ["fret-ui-gallery"],
    "env_defaults": {
      "FRET_TEXT_SYSTEM_FONTS": "0",
      "FRET_UI_GALLERY_BOOTSTRAP_FONTS": "1"
    }
  },
  "steps": [
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-nav-scroll" }
      },
      "timeout_frames": 240
    },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-nav-search" }
      },
      "timeout_frames": 240
    },

    { "type": "click", "target": { "kind": "test_id", "id": "ui-gallery-nav-search" } },
    { "type": "press_key", "key": "a", "modifiers": { "ctrl": true } },
    { "type": "press_key", "key": "backspace" },
    { "type": "type_text", "text": "mixed script fallback" },
    { "type": "wait_frames", "n": 2 },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "bounds_within_window",
        "target": { "kind": "test_id", "id": "ui-gallery-nav-text-mixed-script-fallback" },
        "padding_px": 8.0,
        "eps_px": 1.0
      },
      "timeout_frames": 300
    },
    {
      "type": "click",
      "target": { "kind": "test_id", "id": "ui-gallery-nav-text-mixed-script-fallback" }
    },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": {
          "kind": "test_id",
          "id": "ui-gallery-text-mixed-script-fallback-root"
        }
      },
      "timeout_frames": 240
    },
    { "type": "wait_frames", "n": 10 },

    { "type": "assert", "predicate": { "kind": "render_text_font_trace_captured_when_missing_glyphs" } },
    { "type": "assert", "predicate": { "kind": "render_text_missing_glyphs_is", "missing_glyphs": 0 } },
    {
      "type": "capture_bundle",
      "label": "ui-gallery-text-mixed-script-bundled-fallback-conformance"
    }
  ]
}
