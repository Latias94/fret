    { "type": "click", "target": { "kind": "test_id", "id": "ui-gallery-theme-preset-trigger" } },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-theme-preset-item-zinc-light" }
      },
      "timeout_frames": 240
    },
    { "type": "capture_bundle", "label": "ui-gallery-theme-select-before-hover" },
    {
      "type": "move_pointer",
      "target": { "kind": "test_id", "id": "ui-gallery-theme-preset-item-zinc-light" }
    },
    { "type": "wait_frames", "n": 2 },
    { "type": "capture_bundle", "label": "ui-gallery-theme-select-after-hover" }
  ]
}

