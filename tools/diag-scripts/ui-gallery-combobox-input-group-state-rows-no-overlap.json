{
  "schema_version": 2,
  "meta": {
    "name": "ui-gallery-combobox-input-group-state-rows-no-overlap",
    "required_capabilities": ["diag.script_v2", "diag.screenshot_png"]
  },
  "steps": [
    { "type": "reset_diagnostics" },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-nav-search" }
      },
      "timeout_frames": 600
    },
    { "type": "press_key", "key": "escape" },
    { "type": "wait_frames", "n": 2 },
    { "type": "set_window_inner_size", "width_px": 1024.0, "height_px": 768.0 },
    { "type": "wait_frames", "n": 15 },

    { "type": "click", "target": { "kind": "test_id", "id": "ui-gallery-nav-search" } },
    { "type": "press_key", "key": "a", "modifiers": { "ctrl": true } },
    { "type": "press_key", "key": "backspace" },
    { "type": "type_text", "text": "combobox" },
    { "type": "wait_frames", "n": 2 },
    {
      "type": "click_stable",
      "target": { "kind": "test_id", "id": "ui-gallery-nav-combobox" },
      "stable_frames": 3,
      "max_move_px": 2.0,
      "timeout_frames": 600
    },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-page-combobox" }
      },
      "timeout_frames": 600
    },
    { "type": "wait_frames", "n": 10 },

    {
      "type": "scroll_into_view",
      "container": { "kind": "test_id", "id": "ui-gallery-content-scroll" },
      "target": { "kind": "test_id", "id": "ui-gallery-combobox-input-group-trigger" },
      "delta_y": -160.0,
      "require_fully_within_container": true,
      "require_fully_within_window": true,
      "padding_px": 24.0,
      "timeout_frames": 900
    },
    { "type": "wait_frames", "n": 8 },

    {
      "type": "click",
      "target": { "kind": "test_id", "id": "ui-gallery-combobox-input-group-trigger" }
    },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-combobox-input-group-input" }
      },
      "timeout_frames": 240
    },
    { "type": "type_text", "text": "op" },
    { "type": "wait_frames", "n": 8 },
    { "type": "press_key", "key": "backspace" },
    { "type": "press_key", "key": "backspace" },
    { "type": "wait_frames", "n": 8 },
    { "type": "press_key", "key": "escape" },
    { "type": "wait_frames", "n": 10 },

    {
      "type": "scroll_into_view",
      "container": { "kind": "test_id", "id": "ui-gallery-content-scroll" },
      "target": { "kind": "test_id", "id": "ui-gallery-combobox-input-group-query" },
      "delta_y": -160.0,
      "require_fully_within_container": true,
      "require_fully_within_window": true,
      "padding_px": 24.0,
      "timeout_frames": 900
    },
    {
      "type": "wait_bounds_stable",
      "target": { "kind": "test_id", "id": "ui-gallery-combobox-input-group-query" },
      "timeout_frames": 240,
      "stable_frames": 3,
      "max_move_px": 1.0
    },

    {
      "type": "capture_screenshot",
      "label": "ui-gallery-combobox-input-group-state-rows"
    },
    { "type": "capture_bundle", "label": "ui-gallery-combobox-input-group-state-rows" },

    {
      "type": "assert",
      "predicate": {
        "kind": "bounds_non_overlapping",
        "a": { "kind": "test_id", "id": "ui-gallery-combobox-input-group-selected" },
        "b": { "kind": "test_id", "id": "ui-gallery-combobox-input-group-query" },
        "eps_px": 0.5
      }
    },
    {
      "type": "assert",
      "predicate": { "kind": "render_text_missing_glyphs_is", "missing_glyphs": 0 }
    }
  ]
}
