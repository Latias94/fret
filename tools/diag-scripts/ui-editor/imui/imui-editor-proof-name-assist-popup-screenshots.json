{
  "schema_version": 2,
  "meta": {
    "name": "imui-editor-proof-name-assist-popup-screenshots",
    "required_capabilities": ["diag.script_v2", "diag.screenshot_png"],
    "tags": [
      "screenshots",
      "ui_editor",
      "imui",
      "text_assist",
      "popup",
      "regression"
    ],
    "target_hints": [
      "Uses the review-only imui_editor_proof_demo layout and filters the inspector down to the assist rows.",
      "Pins TextAssistField anchored-popup geometry, in-window clamping, and active-row state for the editor name-assist proof."
    ],
    "env_defaults": {
      "FRET_IMUI_EDITOR_PROOF_SINGLE_WINDOW": "1",
      "FRET_IMUI_EDITOR_PRESET": "default",
      "FRET_IMUI_EDITOR_PROOF_LAYOUT": "editor_review"
    }
  },
  "window": "lowest_id",
  "steps": [
    { "type": "reset_diagnostics" },
    { "type": "press_key", "key": "escape" },
    { "type": "wait_frames", "n": 4 },
    { "type": "set_window_inner_size", "width_px": 1440.0, "height_px": 1100.0 },
    { "type": "wait_frames", "n": 8 },

    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "imui-editor-proof.editor.search" }
      },
      "timeout_frames": 600
    },
    {
      "type": "click_stable",
      "target": { "kind": "test_id", "id": "imui-editor-proof.editor.search" }
    },
    { "type": "press_key", "key": "a", "modifiers": { "ctrl": true } },
    { "type": "press_key", "key": "backspace" },
    { "type": "wait_frames", "n": 1 },
    { "type": "type_text", "text": "assist" },
    { "type": "wait_frames", "n": 4 },

    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "imui-editor-proof.editor.object.name-assist" }
      },
      "timeout_frames": 600
    },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": {
          "kind": "test_id",
          "id": "imui-editor-proof.editor.object.name-assist.state"
        }
      },
      "timeout_frames": 240
    },

    {
      "type": "click_stable",
      "target": { "kind": "test_id", "id": "imui-editor-proof.editor.object.name-assist" }
    },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "focus_is",
        "target": { "kind": "test_id", "id": "imui-editor-proof.editor.object.name-assist" }
      },
      "timeout_frames": 240
    },
    {
      "type": "set_text_value",
      "target": { "kind": "test_id", "id": "imui-editor-proof.editor.object.name-assist" },
      "text": "c"
    },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "value_equals",
        "target": { "kind": "test_id", "id": "imui-editor-proof.editor.object.name-assist" },
        "text": "c"
      },
      "timeout_frames": 240
    },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": {
          "kind": "test_id",
          "id": "imui-editor-proof.editor.object.name-assist.list"
        }
      },
      "timeout_frames": 240
    },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "focus_is",
        "target": { "kind": "test_id", "id": "imui-editor-proof.editor.object.name-assist" }
      },
      "timeout_frames": 240
    },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "label_contains",
        "target": {
          "kind": "test_id",
          "id": "imui-editor-proof.editor.object.name-assist.state"
        },
        "text": "Expanded"
      },
      "timeout_frames": 240
    },
    {
      "type": "assert",
      "predicate": {
        "kind": "bounds_within_window",
        "target": {
          "kind": "test_id",
          "id": "imui-editor-proof.editor.object.name-assist.list"
        },
        "padding_px": 8.0
      }
    },
    {
      "type": "wait_overlay_placement_trace",
      "query": {
        "kind": "placed_rect",
        "overlay_root_name": "editor.text_assist",
        "anchor_test_id": "imui-editor-proof.editor.object.name-assist",
        "content_test_id": "imui-editor-proof.editor.object.name-assist.list",
        "chosen_side": "bottom"
      },
      "timeout_frames": 240
    },

    { "type": "press_key", "key": "arrow_down" },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "label_contains",
        "target": {
          "kind": "test_id",
          "id": "imui-editor-proof.editor.object.name-assist.active"
        },
        "text": "Cylinder"
      },
      "timeout_frames": 240
    },
    { "type": "wait_frames", "n": 2 },
    {
      "type": "capture_layout_sidecar",
      "label": "imui-editor-proof-name-assist-popup-open.layout"
    },
    {
      "type": "capture_bundle",
      "label": "imui-editor-proof-name-assist-popup-open"
    },
    {
      "type": "capture_screenshot",
      "label": "imui-editor-proof-name-assist-popup-open"
    },

    { "type": "press_key", "key": "escape" },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "not_exists",
        "target": {
          "kind": "test_id",
          "id": "imui-editor-proof.editor.object.name-assist.list"
        }
      },
      "timeout_frames": 240
    },
    {
      "type": "capture_bundle",
      "label": "imui-editor-proof-name-assist-popup-closed"
    }
  ]
}
