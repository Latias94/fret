{
  "schema_version": 2,
  "meta": {
    "name": "imui-editor-proof-advanced-axis-outcomes",
    "required_capabilities": ["diag.script_v2"],
    "tags": [
      "ui_editor",
      "imui",
      "vec_edit",
      "transform_edit",
      "outcome",
      "commit",
      "cancel",
      "regression"
    ],
    "target_hints": [
      "Uses the Advanced editor section in imui_editor_proof_demo.",
      "Proves Vec3Edit and TransformEdit expose stable axis outcome readouts for typed commit/cancel."
    ],
    "env_defaults": {
      "FRET_IMUI_EDITOR_PROOF_LAYOUT": "editor_review"
    }
  },
  "window": "lowest_id",
  "steps": [
    { "type": "reset_diagnostics" },
    { "type": "press_key", "key": "escape" },
    { "type": "wait_frames", "n": 4 },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "imui-editor-proof.editor.advanced.position.x" }
      },
      "timeout_frames": 600
    },
    {
      "type": "click_stable",
      "target": { "kind": "test_id", "id": "imui-editor-proof.editor.advanced.position.x" },
      "click_count": 2
    },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "focus_is",
        "target": {
          "kind": "test_id",
          "id": "imui-editor-proof.editor.advanced.position.x.typing.input"
        }
      },
      "timeout_frames": 240
    },
    {
      "type": "set_text_value",
      "target": {
        "kind": "test_id",
        "id": "imui-editor-proof.editor.advanced.position.x.typing.input"
      },
      "text": "1.250"
    },
    { "type": "press_key", "key": "enter" },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "label_contains",
        "target": {
          "kind": "test_id",
          "id": "imui-editor-proof.editor.advanced.position.x.value"
        },
        "text": "1.250"
      },
      "timeout_frames": 240
    },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "label_contains",
        "target": {
          "kind": "test_id",
          "id": "imui-editor-proof.editor.advanced.position.outcome"
        },
        "text": "X Committed"
      },
      "timeout_frames": 240
    },

    {
      "type": "click_stable",
      "target": {
        "kind": "test_id",
        "id": "imui-editor-proof.editor.advanced.transform.scale.y"
      },
      "click_count": 2
    },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "focus_is",
        "target": {
          "kind": "test_id",
          "id": "imui-editor-proof.editor.advanced.transform.scale.y.typing.input"
        }
      },
      "timeout_frames": 240
    },
    {
      "type": "set_text_value",
      "target": {
        "kind": "test_id",
        "id": "imui-editor-proof.editor.advanced.transform.scale.y.typing.input"
      },
      "text": "2.750"
    },
    { "type": "press_key", "key": "escape" },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "label_contains",
        "target": {
          "kind": "test_id",
          "id": "imui-editor-proof.editor.advanced.transform.scale.y.value"
        },
        "text": "1.000"
      },
      "timeout_frames": 240
    },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "label_contains",
        "target": {
          "kind": "test_id",
          "id": "imui-editor-proof.editor.advanced.transform.outcome"
        },
        "text": "Scale.Y Canceled"
      },
      "timeout_frames": 240
    },

    {
      "type": "capture_bundle",
      "label": "imui-editor-proof-advanced-axis-outcomes"
    }
  ]
}
