{
  "schema_version": 2,
  "meta": {
    "name": "imui-editor-proof-enum-select-selected-row-reveal",
    "required_capabilities": ["diag.script_v2", "diag.screenshot_png"],
    "tags": [
      "ui_editor",
      "imui",
      "enum_select",
      "popup",
      "scroll",
      "regression"
    ],
    "target_hints": [
      "Uses the review-only imui_editor_proof_demo layout and the material inspector shading-model select.",
      "Verifies reopen keeps the selected row visible inside the popup viewport instead of restarting long lists at the top."
    ],
    "env_defaults": {
      "FRET_IMUI_EDITOR_PROOF_SINGLE_WINDOW": "1",
      "FRET_IMUI_EDITOR_PRESET": "default",
      "FRET_IMUI_EDITOR_PROOF_LAYOUT": "editor_review"
    }
  },
  "window": "lowest_id",
  "steps": [
    { "type": "reset_diagnostics" },
    { "type": "press_key", "key": "escape" },
    { "type": "wait_frames", "n": 4 },
    { "type": "set_window_inner_size", "width_px": 1440.0, "height_px": 1100.0 },
    { "type": "wait_frames", "n": 8 },

    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "imui-editor-proof.editor.inspector" }
      },
      "timeout_frames": 600
    },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": {
          "kind": "test_id",
          "id": "imui-editor-proof.editor.material.shading-model"
        }
      },
      "timeout_frames": 600
    },
    {
      "type": "scroll_into_view",
      "container": { "kind": "test_id", "id": "imui-editor-proof.editor.inspector" },
      "target": {
        "kind": "test_id",
        "id": "imui-editor-proof.editor.material.shading-model"
      },
      "delta_x": 0.0,
      "delta_y": -120.0,
      "require_fully_within_window": true,
      "padding_px": 12.0,
      "timeout_frames": 600
    },

    {
      "type": "click_stable",
      "target": {
        "kind": "test_id",
        "id": "imui-editor-proof.editor.material.shading-model"
      }
    },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": {
          "kind": "test_id",
          "id": "imui-editor-proof.editor.material.shading-model.list.viewport"
        }
      },
      "timeout_frames": 240
    },
    {
      "type": "click_stable",
      "target": {
        "kind": "test_id",
        "id": "imui-editor-proof.editor.material.shading-model"
      }
    },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "not_exists",
        "target": {
          "kind": "test_id",
          "id": "imui-editor-proof.editor.material.shading-model.list.viewport"
        }
      },
      "timeout_frames": 240
    },

    {
      "type": "click_stable",
      "target": {
        "kind": "test_id",
        "id": "imui-editor-proof.editor.material.shading-model"
      }
    },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": {
          "kind": "test_id",
          "id": "imui-editor-proof.editor.material.shading-model.list.viewport"
        }
      },
      "timeout_frames": 240
    },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "bounds_overlapping",
        "a": {
          "kind": "test_id",
          "id": "imui-editor-proof.editor.material.shading-model.list.viewport"
        },
        "b": {
          "kind": "test_id",
          "id": "imui-editor-proof.editor.material.shading-model.list.item.cloth"
        },
        "eps_px": 1.0
      },
      "timeout_frames": 240
    },
    {
      "type": "capture_layout_sidecar",
      "label": "imui-editor-proof-enum-select-selected-row-reveal.layout"
    },
    {
      "type": "capture_bundle",
      "label": "imui-editor-proof-enum-select-selected-row-reveal"
    },
    {
      "type": "capture_screenshot",
      "label": "imui-editor-proof-enum-select-selected-row-reveal"
    }
  ]
}
