{
  "schema_version": 2,
  "meta": {
    "name": "imui-interaction-showcase-layout-screenshot",
    "required_capabilities": ["diag.script_v2", "diag.screenshot_png"],
    "tags": ["imui", "showcase", "layout", "screenshot", "ui_editor"],
    "target_hints": [
      "Captures a bounded screenshot + layout sidecar for the IMUI interaction showcase shell.",
      "Use this when the showcase looks visually wrong even though it still compiles and passes source-policy checks."
    ]
  },
  "window": "lowest_id",
  "steps": [
    { "type": "reset_diagnostics" },
    { "type": "press_key", "key": "escape" },
    { "type": "wait_frames", "n": 4 },
    { "type": "set_window_inner_size", "width_px": 1360.0, "height_px": 900.0 },
    { "type": "wait_frames", "n": 20 },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "imui-interaction-showcase.root" }
      },
      "timeout_frames": 600
    },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "imui-interaction-showcase.header" }
      },
      "timeout_frames": 600
    },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "bounds_within_window",
        "target": { "kind": "test_id", "id": "imui-interaction-showcase.header" },
        "padding_px": 4.0,
        "eps_px": 0.5
      },
      "timeout_frames": 600
    },
    { "type": "wait_frames", "n": 8 },
    {
      "type": "capture_layout_sidecar",
      "label": "imui-interaction-showcase.layout"
    },
    {
      "type": "capture_bundle",
      "label": "imui-interaction-showcase"
    },
    {
      "type": "capture_screenshot",
      "label": "imui-interaction-showcase"
    }
  ]
}
