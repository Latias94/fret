{
  "schema_version": 2,
  "meta": {
    "name": "imui-editor-proof-text-numeric-baseline-policy",
    "required_capabilities": ["diag.script_v2"],
    "tags": ["ui_editor", "imui", "numeric_input", "drag_value", "slider", "search", "regression"],
    "target_hints": [
      "Uses the full imui_editor_proof_demo layout.",
      "Proves affixed numeric typed entry replaces the current value on first edit and that the editor search box clears on Escape."
    ],
    "env_defaults": {
      "FRET_IMUI_EDITOR_PROOF_LAYOUT": "full"
    }
  },
  "window": "lowest_id",
  "steps": [
    { "type": "reset_diagnostics" },
    { "type": "press_key", "key": "escape" },
    { "type": "wait_frames", "n": 4 },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "imui-editor-proof.authoring.declarative.value" }
      },
      "timeout_frames": 600
    },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "imui-editor-proof.editor.search" }
      },
      "timeout_frames": 600
    },

    {
      "type": "click_stable",
      "target": { "kind": "test_id", "id": "imui-editor-proof.authoring.declarative.value" },
      "click_count": 2
    },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "focus_is",
        "target": {
          "kind": "test_id",
          "id": "imui-editor-proof.authoring.declarative.value.typing.input"
        }
      },
      "timeout_frames": 240
    },
    {
      "type": "set_text_value",
      "target": {
        "kind": "test_id",
        "id": "imui-editor-proof.authoring.declarative.value.typing.input"
      },
      "text": "1.250"
    },
    { "type": "wait_frames", "n": 1 },
    { "type": "press_key", "key": "enter" },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "label_contains",
        "target": { "kind": "test_id", "id": "imui-editor-proof.authoring.declarative.value.value" },
        "text": "1.250"
      },
      "timeout_frames": 240
    },
    {
      "type": "click_stable",
      "target": { "kind": "test_id", "id": "imui-editor-proof.authoring.declarative.value" },
      "click_count": 2
    },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "focus_is",
        "target": {
          "kind": "test_id",
          "id": "imui-editor-proof.authoring.declarative.value.typing.input"
        }
      },
      "timeout_frames": 240
    },
    { "type": "type_text", "text": "2" },
    { "type": "wait_frames", "n": 1 },
    { "type": "press_key", "key": "enter" },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "label_contains",
        "target": { "kind": "test_id", "id": "imui-editor-proof.authoring.declarative.value.value" },
        "text": "2.000"
      },
      "timeout_frames": 240
    },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "label_contains",
        "target": { "kind": "test_id", "id": "imui-editor-proof.authoring.declarative.value.prefix" },
        "text": "$"
      },
      "timeout_frames": 240
    },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "label_contains",
        "target": { "kind": "test_id", "id": "imui-editor-proof.authoring.declarative.value.suffix" },
        "text": "ms"
      },
      "timeout_frames": 240
    },

    {
      "type": "click_stable",
      "target": { "kind": "test_id", "id": "imui-editor-proof.authoring.declarative.blend" },
      "click_count": 2
    },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "focus_is",
        "target": {
          "kind": "test_id",
          "id": "imui-editor-proof.authoring.declarative.blend.typing.input"
        }
      },
      "timeout_frames": 240
    },
    {
      "type": "set_text_value",
      "target": {
        "kind": "test_id",
        "id": "imui-editor-proof.authoring.declarative.blend.typing.input"
      },
      "text": "35"
    },
    { "type": "wait_frames", "n": 1 },
    { "type": "press_key", "key": "enter" },
    {
      "type": "click_stable",
      "target": { "kind": "test_id", "id": "imui-editor-proof.authoring.declarative.blend" },
      "click_count": 2
    },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "focus_is",
        "target": {
          "kind": "test_id",
          "id": "imui-editor-proof.authoring.declarative.blend.typing.input"
        }
      },
      "timeout_frames": 240
    },
    { "type": "type_text", "text": "75" },
    { "type": "wait_frames", "n": 1 },
    { "type": "press_key", "key": "enter" },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "label_contains",
        "target": {
          "kind": "test_id",
          "id": "imui-editor-proof.authoring.declarative.blend.value_display"
        },
        "text": "75%"
      },
      "timeout_frames": 240
    },

    {
      "type": "click_stable",
      "target": { "kind": "test_id", "id": "imui-editor-proof.editor.search" }
    },
    { "type": "press_key", "key": "a", "modifiers": { "ctrl": true } },
    { "type": "press_key", "key": "backspace" },
    { "type": "wait_frames", "n": 1 },
    { "type": "type_text", "text": "material" },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "imui-editor-proof.editor.search.clear" }
      },
      "timeout_frames": 240
    },
    { "type": "press_key", "key": "escape" },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "not_exists",
        "target": { "kind": "test_id", "id": "imui-editor-proof.editor.search.clear" }
      },
      "timeout_frames": 240
    },

    {
      "type": "capture_bundle",
      "label": "imui-editor-proof-text-numeric-baseline-policy"
    }
  ]
}
