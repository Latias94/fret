{
  "schema_version": 2,
  "meta": {
    "name": "imui-editor-proof-name-assist-history",
    "required_capabilities": ["diag.script_v2"],
    "tags": ["ui_editor", "imui", "text_assist", "history", "regression"],
    "target_hints": [
      "Uses the Object group in imui_editor_proof_demo.",
      "Proves TextField assistive semantics, expanded/collapsed state readouts, Arrow navigation, and Enter accept for the editor name-history proof surface."
    ],
    "env_defaults": {
      "FRET_IMUI_EDITOR_PROOF_LAYOUT": "full"
    }
  },
  "window": "lowest_id",
  "steps": [
    { "type": "reset_diagnostics" },
    { "type": "press_key", "key": "escape" },
    { "type": "wait_frames", "n": 4 },

    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "imui-editor-proof.editor.object.name-assist" }
      },
      "timeout_frames": 600
    },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "label_contains",
        "target": {
          "kind": "test_id",
          "id": "imui-editor-proof.editor.object.name-assist.state"
        },
        "text": "Collapsed"
      },
      "timeout_frames": 240
    },

    {
      "type": "click_stable",
      "target": { "kind": "test_id", "id": "imui-editor-proof.editor.object.name-assist" }
    },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "focus_is",
        "target": { "kind": "test_id", "id": "imui-editor-proof.editor.object.name-assist" }
      },
      "timeout_frames": 240
    },
    {
      "type": "set_text_value",
      "target": { "kind": "test_id", "id": "imui-editor-proof.editor.object.name-assist" },
      "text": "c"
    },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "value_equals",
        "target": { "kind": "test_id", "id": "imui-editor-proof.editor.object.name-assist" },
        "text": "c"
      },
      "timeout_frames": 240
    },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": {
          "kind": "test_id",
          "id": "imui-editor-proof.editor.object.name-assist.list"
        }
      },
      "timeout_frames": 240
    },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "label_contains",
        "target": {
          "kind": "test_id",
          "id": "imui-editor-proof.editor.object.name-assist.state"
        },
        "text": "Expanded"
      },
      "timeout_frames": 240
    },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "label_contains",
        "target": {
          "kind": "test_id",
          "id": "imui-editor-proof.editor.object.name-assist.active"
        },
        "text": "Cube"
      },
      "timeout_frames": 240
    },

    { "type": "press_key", "key": "arrow_down" },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "label_contains",
        "target": {
          "kind": "test_id",
          "id": "imui-editor-proof.editor.object.name-assist.active"
        },
        "text": "Cylinder"
      },
      "timeout_frames": 240
    },
    { "type": "wait_frames", "n": 2 },
    {
      "type": "capture_bundle",
      "label": "imui-editor-proof-name-assist-expanded"
    },

    { "type": "press_key", "key": "enter" },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "value_equals",
        "target": { "kind": "test_id", "id": "imui-editor-proof.editor.object.name-assist" },
        "text": "Cylinder"
      },
      "timeout_frames": 240
    },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "label_contains",
        "target": {
          "kind": "test_id",
          "id": "imui-editor-proof.editor.object.name-assist.accepted"
        },
        "text": "Cylinder"
      },
      "timeout_frames": 240
    },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "label_contains",
        "target": {
          "kind": "test_id",
          "id": "imui-editor-proof.editor.object.name-assist.state"
        },
        "text": "Collapsed"
      },
      "timeout_frames": 240
    },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "not_exists",
        "target": {
          "kind": "test_id",
          "id": "imui-editor-proof.editor.object.name-assist.list"
        }
      },
      "timeout_frames": 240
    },
    {
      "type": "capture_bundle",
      "label": "imui-editor-proof-name-assist-accepted"
    }
  ]
}
