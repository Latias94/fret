      "predicate": {
        "kind": "focus_is",
        "target": {
          "kind": "test_id",
          "id": "imui-editor-proof.editor.drag-value-demo.typing.input"
        }
      },
      "timeout_frames": 240
    },
    {
      "type": "set_text_value",
      "target": {
        "kind": "test_id",
        "id": "imui-editor-proof.editor.drag-value-demo.typing.input"
      },
      "text": "0.630"
    },
    { "type": "press_key", "key": "enter" },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "label_contains",
        "target": { "kind": "test_id", "id": "imui-editor-proof.editor.drag-value-demo.value" },
        "text": "0.625"
      },
      "timeout_frames": 240
    },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "label_contains",
        "target": {
          "kind": "test_id",
          "id": "imui-editor-proof.editor.drag-value-demo.outcome"
        },
        "text": "Commit"
      },
      "timeout_frames": 240
    },
    { "type": "wait_frames", "n": 4 },

    {
      "type": "click_stable",
      "target": { "kind": "test_id", "id": "imui-editor-proof.editor.drag-value-demo" },
      "click_count": 2
    },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "focus_is",
        "target": {
          "kind": "test_id",
          "id": "imui-editor-proof.editor.drag-value-demo.typing.input"
        }
      },
      "timeout_frames": 240
    },
    {
      "type": "set_text_value",
      "target": {
        "kind": "test_id",
        "id": "imui-editor-proof.editor.drag-value-demo.typing.input"
      },
      "text": "1.250"
    },
    { "type": "press_key", "key": "enter" },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "label_contains",
        "target": { "kind": "test_id", "id": "imui-editor-proof.editor.drag-value-demo.value" },
        "text": "1.000"
      },
      "timeout_frames": 240
    },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "label_contains",
        "target": {
          "kind": "test_id",
          "id": "imui-editor-proof.editor.drag-value-demo.outcome"
        },
        "text": "Commit"
      },
      "timeout_frames": 240
    },
    { "type": "wait_frames", "n": 4 },

    {
      "type": "click_stable",
      "target": { "kind": "test_id", "id": "imui-editor-proof.editor.drag-value-demo" },
      "click_count": 2
    },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "focus_is",
        "target": {
          "kind": "test_id",
          "id": "imui-editor-proof.editor.drag-value-demo.typing.input"
        }
      },
      "timeout_frames": 240
    },
    {
      "type": "set_text_value",
      "target": {
        "kind": "test_id",
        "id": "imui-editor-proof.editor.drag-value-demo.typing.input"
      },
      "text": "0.333"
    },
    { "type": "press_key", "key": "escape" },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "label_contains",
        "target": { "kind": "test_id", "id": "imui-editor-proof.editor.drag-value-demo.value" },
        "text": "1.000"
      },
      "timeout_frames": 240
    },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "label_contains",
        "target": {
          "kind": "test_id",
          "id": "imui-editor-proof.editor.drag-value-demo.outcome"
        },
        "text": "Cancel"
      },
      "timeout_frames": 240
    },

    {
      "type": "capture_bundle",
      "label": "imui-editor-proof-drag-value-outcomes"
    }
  ]
}
