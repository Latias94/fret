{
  "schema_version": 2,
  "meta": {
    "name": "imui-editor-proof-drag-value-outcomes",
    "required_capabilities": ["diag.script_v2"],
    "tags": ["ui_editor", "imui", "drag_value", "outcome", "commit", "cancel", "regression"],
    "target_hints": [
      "Uses the review-only editor inspector layout in imui_editor_proof_demo.",
      "Proves DragValue exposes explicit commit/cancel outcomes plus shared clamp/step policy across scrub and typed-edit paths, including Escape cancel during an active scrub session.",
      "The active scrub assertion is tied to the current ImGui-like dense preset: 0.035 scrub speed, 2px threshold, and 0.025 step quantization."
    ],
    "env_defaults": {
      "FRET_IMUI_EDITOR_PROOF_LAYOUT": "editor_review"
    }
  },
  "window": "lowest_id",
  "steps": [
    { "type": "reset_diagnostics" },
    { "type": "press_key", "key": "escape" },
    { "type": "wait_frames", "n": 4 },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "imui-editor-proof.editor.drag-value-demo" }
      },
      "timeout_frames": 600
    },
    {
      "type": "click_stable",
      "target": { "kind": "test_id", "id": "imui-editor-proof.editor.drag-value-demo" },
      "click_count": 2
    },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "focus_is",
        "target": {
          "kind": "test_id",
          "id": "imui-editor-proof.editor.drag-value-demo.typing.input"
        }
      },
      "timeout_frames": 240
    },
    {
      "type": "set_text_value",
      "target": {
        "kind": "test_id",
        "id": "imui-editor-proof.editor.drag-value-demo.typing.input"
      },
      "text": "0.800"
    },
    { "type": "press_key", "key": "enter" },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "label_contains",
        "target": { "kind": "test_id", "id": "imui-editor-proof.editor.drag-value-demo.value" },
        "text": "0.800"
      },
      "timeout_frames": 240
    },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "label_contains",
        "target": {
          "kind": "test_id",
          "id": "imui-editor-proof.editor.drag-value-demo.outcome"
        },
        "text": "Commit"
      },
      "timeout_frames": 240
    },
    { "type": "wait_frames", "n": 4 },
    {
      "type": "pointer_down",
      "target": { "kind": "test_id", "id": "imui-editor-proof.editor.drag-value-demo" }
    },
    { "type": "pointer_move", "delta_x": 40.0, "delta_y": 0.0, "steps": 20 },
    { "type": "pointer_up" },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "label_contains",
        "target": { "kind": "test_id", "id": "imui-editor-proof.editor.drag-value-demo.value" },
        "text": "1.000"
      },
      "timeout_frames": 240
    },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "label_contains",
        "target": {
          "kind": "test_id",
          "id": "imui-editor-proof.editor.drag-value-demo.outcome"
        },
        "text": "Commit"
      },
      "timeout_frames": 240
    },
    { "type": "wait_frames", "n": 4 },

    {
      "type": "pointer_down",
      "target": { "kind": "test_id", "id": "imui-editor-proof.editor.drag-value-demo" }
    },
    { "type": "wait_until", "predicate": { "kind": "event_kind_seen", "event_kind": "pointer.down" }, "timeout_frames": 120 },
    { "type": "pointer_move", "delta_x": -10.0, "delta_y": 0.0, "steps": 10 },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "label_contains",
        "target": { "kind": "test_id", "id": "imui-editor-proof.editor.drag-value-demo.value" },
        "text": "0.725"
      },
      "timeout_frames": 240
    },
    { "type": "press_key", "key": "escape" },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "label_contains",
        "target": { "kind": "test_id", "id": "imui-editor-proof.editor.drag-value-demo.value" },
        "text": "1.000"
      },
      "timeout_frames": 240
    },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "label_contains",
        "target": {
          "kind": "test_id",
          "id": "imui-editor-proof.editor.drag-value-demo.outcome"
        },
        "text": "Cancel"
      },
      "timeout_frames": 240
    },
    { "type": "pointer_up" },
    { "type": "wait_frames", "n": 4 },

    {
      "type": "click_stable",
      "target": { "kind": "test_id", "id": "imui-editor-proof.editor.drag-value-demo" },
      "click_count": 2
