{
  "schema_version": 2,
  "meta": {
    "name": "imui-shadcn-adapter-table-column-width-resize",
    "required_capabilities": ["diag.script_v2", "diag.screenshot_png"],
    "tags": [
      "imui",
      "adapter",
      "table",
      "resize",
      "column_width",
      "response",
      "gate",
      "ui_editor"
    ],
    "target_hints": [
      "Promoted runtime gate for the app-owned resizable inspector table proof in imui_shadcn_adapter_demo.",
      "Drags a stable table header resize handle until the demo-owned width summary reaches the field column max width.",
      "Uses drag_pointer_until because the immediate-mode resize response is consumed during render while the pointer is still dragging."
    ]
  },
  "window": "lowest_id",
  "steps": [
    { "type": "reset_diagnostics" },
    { "type": "press_key", "key": "escape" },
    { "type": "wait_frames", "n": 4 },
    { "type": "set_window_inner_size", "width_px": 1100.0, "height_px": 760.0 },
    { "type": "wait_frames", "n": 16 },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "imui-shadcn-demo.root" }
      },
      "timeout_frames": 600
    },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "imui-shadcn-demo.inspector.table" }
      },
      "timeout_frames": 600
    },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "label_contains",
        "target": { "kind": "test_id", "id": "imui-shadcn-demo.inspector.widths" },
        "text": "Widths: field 104px"
      },
      "timeout_frames": 600
    },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": {
          "kind": "test_id",
          "id": "imui-shadcn-demo.inspector.table.header.cell.inspector-field.resize"
        }
      },
      "timeout_frames": 600
    },
    {
      "type": "wait_bounds_stable",
      "target": {
        "kind": "test_id",
        "id": "imui-shadcn-demo.inspector.table.header.cell.inspector-field.resize"
      },
      "stable_frames": 3,
      "max_move_px": 0.5,
      "timeout_frames": 240
    },
    {
      "type": "capture_layout_sidecar",
      "label": "imui-shadcn-adapter.table-column-width.before"
    },
    {
      "type": "capture_bundle",
      "label": "imui-shadcn-adapter.table-column-width.before"
    },
    {
      "type": "drag_pointer_until",
      "target": {
        "kind": "test_id",
        "id": "imui-shadcn-demo.inspector.table.header.cell.inspector-field.resize"
      },
      "delta_x": 120.0,
      "delta_y": 0.0,
      "steps": 12,
      "predicate": {
        "kind": "label_contains",
        "target": { "kind": "test_id", "id": "imui-shadcn-demo.inspector.widths" },
        "text": "field 180px"
      },
      "timeout_frames": 240
    },
    { "type": "wait_frames", "n": 4 },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "label_contains",
        "target": { "kind": "test_id", "id": "imui-shadcn-demo.inspector.widths" },
        "text": "Widths: field 180px"
      },
      "timeout_frames": 240
    },
    {
      "type": "capture_layout_sidecar",
      "label": "imui-shadcn-adapter.table-column-width.after"
    },
    {
      "type": "capture_bundle",
      "label": "imui-shadcn-adapter.table-column-width.after"
    },
    {
      "type": "capture_screenshot",
      "label": "imui-shadcn-adapter.table-column-width.after"
    }
  ]
}
