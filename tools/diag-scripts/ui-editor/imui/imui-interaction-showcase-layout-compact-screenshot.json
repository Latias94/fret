{
  "schema_version": 2,
  "meta": {
    "name": "imui-interaction-showcase-layout-compact-screenshot",
    "required_capabilities": ["diag.script_v2", "diag.screenshot_png"],
    "tags": ["imui", "showcase", "layout", "compact", "screenshot", "ui_editor"],
    "target_hints": [
      "Captures the default-window compact showcase layout with bounded screenshot and layout evidence.",
      "Use this to keep the default IMUI showcase surface reviewable instead of only looking correct on roomy windows."
    ]
  },
  "window": "lowest_id",
  "steps": [
    { "type": "reset_diagnostics" },
    { "type": "press_key", "key": "escape" },
    { "type": "wait_frames", "n": 4 },
    { "type": "set_window_inner_size", "width_px": 1180.0, "height_px": 760.0 },
    { "type": "wait_frames", "n": 20 },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "imui-interaction-showcase.root" }
      },
      "timeout_frames": 600
    },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "imui-interaction-showcase.scroll.viewport" }
      },
      "timeout_frames": 600
    },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "bounds_within_window",
        "target": { "kind": "test_id", "id": "imui-interaction-showcase.header" },
        "padding_px": 4.0,
        "eps_px": 0.5
      },
      "timeout_frames": 600
    },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "bounds_within_window",
        "target": { "kind": "test_id", "id": "imui-showcase.menu.file" },
        "padding_px": 4.0,
        "eps_px": 0.5
      },
      "timeout_frames": 600
    },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "bounds_within_window",
        "target": { "kind": "test_id", "id": "imui-showcase.tabs.scene" },
        "padding_px": 4.0,
        "eps_px": 0.5
      },
      "timeout_frames": 600
    },
    { "type": "wait_frames", "n": 8 },
    {
      "type": "capture_layout_sidecar",
      "label": "imui-interaction-showcase.compact-layout"
    },
    {
      "type": "capture_bundle",
      "label": "imui-interaction-showcase.compact"
    },
    {
      "type": "capture_screenshot",
      "label": "imui-interaction-showcase.compact"
    }
  ]
}
