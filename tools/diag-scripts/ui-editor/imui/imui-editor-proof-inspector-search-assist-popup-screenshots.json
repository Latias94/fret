{
  "schema_version": 2,
  "meta": {
    "name": "imui-editor-proof-inspector-search-assist-popup-screenshots",
    "required_capabilities": ["diag.script_v2", "diag.screenshot_png"],
    "tags": [
      "screenshots",
      "ui_editor",
      "imui",
      "inspector",
      "search",
      "text_assist",
      "popup",
      "regression"
    ],
    "target_hints": [
      "Uses the review-only imui_editor_proof_demo layout.",
      "Pins InspectorPanel search-history popup geometry, focus retention, Enter accept, and material-filter follow-through."
    ],
    "env_defaults": {
      "FRET_IMUI_EDITOR_PROOF_SINGLE_WINDOW": "1",
      "FRET_IMUI_EDITOR_PRESET": "default",
      "FRET_IMUI_EDITOR_PROOF_LAYOUT": "editor_review"
    }
  },
  "window": "lowest_id",
  "steps": [
    { "type": "reset_diagnostics" },
    { "type": "press_key", "key": "escape" },
    { "type": "wait_frames", "n": 4 },
    { "type": "set_window_inner_size", "width_px": 1440.0, "height_px": 1100.0 },
    { "type": "wait_frames", "n": 8 },

    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "imui-editor-proof.editor.search" }
      },
      "timeout_frames": 600
    },
    {
      "type": "click_stable",
      "target": { "kind": "test_id", "id": "imui-editor-proof.editor.search" }
    },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "focus_is",
        "target": { "kind": "test_id", "id": "imui-editor-proof.editor.search" }
      },
      "timeout_frames": 240
    },
    {
      "type": "set_text_value",
      "target": { "kind": "test_id", "id": "imui-editor-proof.editor.search" },
      "text": "mat"
    },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "value_equals",
        "target": { "kind": "test_id", "id": "imui-editor-proof.editor.search" },
        "text": "mat"
      },
      "timeout_frames": 240
    },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": {
          "kind": "test_id",
          "id": "imui-editor-proof.editor.search.list"
        }
      },
      "timeout_frames": 240
    },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "focus_is",
        "target": { "kind": "test_id", "id": "imui-editor-proof.editor.search" }
      },
      "timeout_frames": 240
    },
    {
      "type": "assert",
      "predicate": {
        "kind": "bounds_within_window",
        "target": {
          "kind": "test_id",
          "id": "imui-editor-proof.editor.search.list"
        },
        "padding_px": 8.0
      }
    },
    {
      "type": "wait_overlay_placement_trace",
      "query": {
        "kind": "placed_rect",
        "overlay_root_name": "editor.text_assist",
        "anchor_test_id": "imui-editor-proof.editor.search",
        "content_test_id": "imui-editor-proof.editor.search.list",
        "chosen_side": "bottom"
      },
      "timeout_frames": 240
    },
    { "type": "wait_frames", "n": 2 },
    {
      "type": "capture_layout_sidecar",
      "label": "imui-editor-proof-inspector-search-assist-popup-open.layout"
    },
    {
      "type": "capture_bundle",
      "label": "imui-editor-proof-inspector-search-assist-popup-open"
    },
    {
      "type": "capture_screenshot",
      "label": "imui-editor-proof-inspector-search-assist-popup-open"
    },

    { "type": "press_key", "key": "enter" },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "value_equals",
        "target": { "kind": "test_id", "id": "imui-editor-proof.editor.search" },
        "text": "Material"
      },
      "timeout_frames": 240
    },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "not_exists",
        "target": {
          "kind": "test_id",
          "id": "imui-editor-proof.editor.search.list"
        }
      },
      "timeout_frames": 240
    },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": {
          "kind": "test_id",
          "id": "imui-editor-proof.editor.material.base-color"
        }
      },
      "timeout_frames": 240
    },
    {
      "type": "capture_bundle",
      "label": "imui-editor-proof-inspector-search-assist-popup-accepted"
    }
  ]
}
