{
  "schema_version": 2,
  "steps": [
    { "type": "press_key", "key": "escape" },
    { "type": "wait_frames", "n": 2 },

    { "type": "set_window_inner_size", "width_px": 1280.0, "height_px": 720.0 },
    { "type": "wait_frames", "n": 2 },

    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-hit-test-only-probe-region" }
      },
      "timeout_frames": 240
    },

    { "type": "reset_diagnostics" },

    {
      "type": "move_pointer",
      "target": { "kind": "test_id", "id": "ui-gallery-hit-test-only-probe-region" }
    },
    { "type": "wait_frames", "n": 1 },

    {
      "type": "move_pointer_sweep",
      "target": { "kind": "test_id", "id": "ui-gallery-hit-test-only-probe-region" },
      "delta_x": 700.0,
      "delta_y": 180.0,
      "steps": 320
    },
    { "type": "wait_frames", "n": 2 },

    {
      "type": "move_pointer_sweep",
      "target": { "kind": "test_id", "id": "ui-gallery-hit-test-only-probe-region" },
      "delta_x": -700.0,
      "delta_y": -180.0,
      "steps": 320
    },
    { "type": "wait_frames", "n": 2 },

    {
      "type": "capture_bundle",
      "label": "ui-gallery-hit-test-only-paint-cache-probe-sweep"
    },

    { "type": "press_key", "key": "escape" },
    { "type": "wait_frames", "n": 2 }
  ]
}
