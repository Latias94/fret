{
  "schema_version": 1,
  "steps": [
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-nav-search" }
      },
      "timeout_frames": 240
    },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-nav-scroll" }
      },
      "timeout_frames": 240
    },

    { "type": "click", "target": { "kind": "test_id", "id": "ui-gallery-nav-search" } },
    { "type": "press_key", "key": "a", "modifiers": { "ctrl": true } },
    { "type": "press_key", "key": "backspace" },
    { "type": "type_text", "text": "chrome_torture" },
    { "type": "wait_frames", "n": 2 },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "bounds_within_window",
        "target": { "kind": "test_id", "id": "ui-gallery-nav-chrome-torture" },
        "padding_px": 8.0,
        "eps_px": 1.0
      },
      "timeout_frames": 240
    },
    { "type": "click", "target": { "kind": "test_id", "id": "ui-gallery-nav-chrome-torture" } },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-page-chrome-torture" }
      },
      "timeout_frames": 240
    },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "bounds_within_window",
        "target": { "kind": "test_id", "id": "ui-gallery-page-chrome-torture" },
        "padding_px": 0.0,
        "eps_px": 1.0
      },
      "timeout_frames": 240
    },

    { "type": "wait_frames", "n": 30 },
    { "type": "capture_screenshot", "label": "ui-gallery-chrome-torture-layout" },
    { "type": "capture_bundle", "label": "ui-gallery-chrome-torture-layout" },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "bounds_non_overlapping",
        "a": { "kind": "test_id", "id": "ui-gallery-dropdown-trigger" },
        "b": { "kind": "test_id", "id": "ui-gallery-chrome-btn-1" },
        "eps_px": 0.1
      },
      "timeout_frames": 240
    },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "bounds_non_overlapping",
        "a": { "kind": "test_id", "id": "ui-gallery-context-trigger" },
        "b": { "kind": "test_id", "id": "ui-gallery-chrome-btn-3" },
        "eps_px": 0.1
      },
      "timeout_frames": 240
    }
  ]
}
