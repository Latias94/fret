{
  "schema_version": 2,
  "meta": {
    "name": "Docking arbitration demo: modal closes on dock drag + viewport capture stays correct",
    "tags": ["docking", "modal", "gate"],
    "required_capabilities": ["diag.script_v2"],
    "target_hints": [
      "Opens a popover and asserts docking drag closes it (capture), then opens a dialog and asserts underlay click does not leak through."
    ]
  },
  "steps": [
    { "type": "press_key", "key": "escape" },
    { "type": "wait_frames", "n": 5 },
    { "type": "set_window_inner_size", "width_px": 1600.0, "height_px": 900.0 },
    { "type": "wait_frames", "n": 10 },
    {
      "type": "wait_until",
      "predicate": { "kind": "exists", "target": { "kind": "test_id", "id": "dock-arb-dock-space" } },
      "timeout_frames": 240
    },

    {
      "type": "wait_until",
      "predicate": {
        "kind": "bounds_within_window",
        "target": { "kind": "test_id", "id": "dock-arb-popover-trigger" },
        "padding_px": 4.0
      },
      "timeout_frames": 240
    },
    { "type": "click", "target": { "kind": "test_id", "id": "dock-arb-popover-trigger" } },
    {
      "type": "wait_until",
      "predicate": { "kind": "exists", "target": { "kind": "test_id", "id": "dock-arb-popover-open" } },
      "timeout_frames": 120
    },

    {
      "type": "pointer_down",
      "window": { "kind": "current" },
      "target": { "kind": "test_id", "id": "dock-arb-tab-drag-anchor-left" },
      "button": "left"
    },
    {
      "type": "pointer_move",
      "window": { "kind": "current" },
      "delta_x": 24.0,
      "delta_y": 0.0,
      "steps": 12
    },
    {
      "type": "wait_until",
      "window": { "kind": "current" },
      "predicate": { "kind": "dock_drag_active_is", "active": true },
      "timeout_frames": 120
    },
    { "type": "pointer_up", "window": { "kind": "current" } },
    {
      "type": "wait_until",
      "window": { "kind": "current" },
      "predicate": { "kind": "dock_drag_active_is", "active": false },
      "timeout_frames": 240
    },
    {
      "type": "wait_until",
      "predicate": { "kind": "exists", "target": { "kind": "test_id", "id": "dock-arb-popover-closed" } },
      "timeout_frames": 120
    },

    {
      "type": "wait_until",
      "predicate": {
        "kind": "bounds_within_window",
        "target": { "kind": "test_id", "id": "dock-arb-viewport-left" },
        "padding_px": 0.0,
        "eps_px": 2.0
      },
      "timeout_frames": 240
    },
    {
      "type": "pointer_down",
      "window": { "kind": "current" },
      "target": { "kind": "test_id", "id": "dock-arb-viewport-left" },
      "button": "left"
    },
    {
      "type": "pointer_move",
      "window": { "kind": "current" },
      "delta_x": 12.0,
      "delta_y": 6.0,
      "steps": 8
    },
    { "type": "wait_frames", "n": 2 },
    {
      "type": "pointer_move",
      "window": { "kind": "current" },
      "delta_x": 128.0,
      "delta_y": 44.0,
      "steps": 18
    },
    { "type": "wait_frames", "n": 2 },
    { "type": "pointer_up", "window": { "kind": "current" } },

    {
      "type": "wait_until",
      "predicate": {
        "kind": "bounds_within_window",
        "target": { "kind": "test_id", "id": "dock-arb-dialog-trigger" },
        "padding_px": 4.0
      },
      "timeout_frames": 240
    },
    { "type": "click", "target": { "kind": "test_id", "id": "dock-arb-dialog-trigger" } },
    {
      "type": "wait_until",
      "predicate": { "kind": "exists", "target": { "kind": "test_id", "id": "dock-arb-dialog-open" } },
      "timeout_frames": 120
    },

    {
      "type": "click",
      "target": { "kind": "test_id", "id": "dock-arb-underlay-probe" }
    },
    { "type": "wait_frames", "n": 2 },

    { "type": "press_key", "key": "escape" },
    { "type": "wait_frames", "n": 2 },
    {
      "type": "wait_until",
      "predicate": { "kind": "exists", "target": { "kind": "test_id", "id": "dock-arb-dialog-closed" } },
      "timeout_frames": 120
    },

    { "type": "capture_bundle", "label": "docking-arbitration-demo-modal-dock-drag-viewport-capture" }
  ]
}
