{
  "schema_version": 2,
  "meta": {
    "name": "Docking arbitration demo: drag a torn-off tab back to the main window (large OS window move, DPI/monitor stress)",
    "tags": ["docking", "multiwindow", "drag", "dpi", "gate"],
    "required_capabilities": ["diag.script_v2", "diag.multi_window"],
    "env_defaults": {
      "FRET_DOCK_ALLOW_MULTI_WINDOW_TEAR_OFF": "1"
    },
    "target_hints": [
      "This gate is a stress variant of the multi-window drag-back flow.",
      "After tear-off creates a floating OS window, the script moves that floating window far along +X (cross-monitor if present).",
      "Expected behavior: cross-window drag routing remains correct and the tab can still be docked back into the main window (no coordinate/DPI drift regressions).",
      "Evidence: the script captures bundles both right after tear-off and after the large outer move; use `fretboard-dev diag dock-routing <bundle_dir>` to inspect dock-drag routing (including scale_factor_x1000 fields when available).",
      "Note: if the host only has a single monitor, the OS may clamp the outer position; the gate still exercises large-coordinate paths and must pass."
    ]
  },
  "steps": [
    { "type": "press_key", "window": { "kind": "first_seen" }, "key": "escape" },
    { "type": "wait_frames", "n": 2 },

    { "type": "set_window_outer_position", "window": { "kind": "first_seen" }, "x_px": 120.0, "y_px": 120.0 },
    { "type": "set_window_inner_size", "window": { "kind": "first_seen" }, "width_px": 1600.0, "height_px": 900.0 },
    { "type": "wait_frames", "n": 2 },

    {
      "type": "wait_until",
      "window": { "kind": "first_seen" },
      "predicate": {
        "kind": "bounds_min_size",
        "target": { "kind": "test_id", "id": "dock-arb-viewport-right" },
        "min_w_px": 700.0,
        "min_h_px": 500.0,
        "eps_px": 1.0
      },
      "timeout_frames": 240
    },

    {
      "type": "wait_bounds_stable",
      "target": { "kind": "test_id", "id": "dock-arb-tab-drag-anchor-right" },
      "stable_frames": 12,
      "max_move_px": 0.5,
      "timeout_frames": 240
    },

    {
      "type": "wait_until",
      "window": { "kind": "first_seen" },
      "predicate": { "kind": "exists", "target": { "kind": "test_id", "id": "dock-arb-tab-drag-anchor-right" } },
      "timeout_frames": 240
    },

    {
      "type": "drag_pointer_until",
      "window": { "kind": "first_seen" },
      "target": { "kind": "test_id", "id": "dock-arb-tab-drag-anchor-right" },
      "release_on_success": false,
      "delta_x": 2400.0,
      "delta_y": 0.0,
      "steps": 140,
      "predicate": { "kind": "known_window_count_ge", "n": 2 },
      "timeout_frames": 600
    },
    {
      "type": "wait_until",
      "predicate": { "kind": "known_window_count_ge", "n": 2 },
      "timeout_frames": 240,
      "timeout_ms": 15000
    },
    { "type": "wait_frames", "n": 10 },
    {
      "type": "wait_until",
      "predicate": { "kind": "dock_drag_active_is", "active": true },
      "timeout_frames": 240,
      "timeout_ms": 15000
    },
    { "type": "capture_bundle", "label": "multiwindow-drag-back-large-move-after-tearoff" },

    { "type": "raise_window", "window": { "kind": "last_seen" } },
    {
      "type": "set_window_outer_position",
      "window": { "kind": "last_seen" },
      "x_px": 3800.0,
      "y_px": 120.0
    },
    {
      "type": "set_window_inner_size",
      "window": { "kind": "last_seen" },
      "width_px": 900.0,
      "height_px": 700.0
    },
    { "type": "wait_frames", "n": 4 },
    { "type": "capture_bundle", "label": "multiwindow-drag-back-large-move-after-outer-move" },

    { "type": "raise_window", "window": { "kind": "first_seen" } },
    {
      "type": "move_pointer",
      "window": { "kind": "first_seen" },
      "target": { "kind": "test_id", "id": "dock-arb-dock-space" }
    },
    { "type": "wait_frames", "n": 2 },
    {
      "type": "wait_until",
      "window": { "kind": "first_seen" },
      "predicate": {
        "kind": "bounds_min_size",
        "target": { "kind": "test_id", "id": "dock-arb-hint-outer-right" },
        "min_w_px": 20.0,
        "min_h_px": 20.0
      },
      "timeout_frames": 240
    },
    {
      "type": "move_pointer",
      "window": { "kind": "first_seen" },
      "target": { "kind": "test_id", "id": "dock-arb-hint-outer-right" }
    },
    { "type": "wait_frames", "n": 2 },
    {
      "type": "wait_until",
      "predicate": { "kind": "dock_drag_current_window_is", "window": { "kind": "first_seen" } },
      "timeout_frames": 240
    },
    { "type": "wait_frames", "n": 2 },
    { "type": "pointer_up", "window": { "kind": "first_seen" } },
    { "type": "wait_frames", "n": 2 },

    {
      "type": "wait_until",
      "predicate": { "kind": "known_window_count_is", "n": 1 },
      "timeout_frames": 600
    },

    {
      "type": "wait_until",
      "window": { "kind": "first_seen" },
      "predicate": { "kind": "dock_graph_canonical_is", "canonical": true },
      "timeout_frames": 240
    },
    {
      "type": "assert",
      "window": { "kind": "first_seen" },
      "predicate": {
        "kind": "dock_graph_signature_contains",
        "needle": "demo.viewport.left"
      }
    },
    {
      "type": "assert",
      "window": { "kind": "first_seen" },
      "predicate": { "kind": "dock_graph_signature_contains", "needle": "demo.viewport.right" }
    },
    {
      "type": "assert",
      "window": { "kind": "first_seen" },
      "predicate": { "kind": "dock_graph_signature_contains", "needle": "demo.controls" }
    },
    {
      "type": "assert",
      "window": { "kind": "first_seen" },
      "predicate": { "kind": "dock_graph_signature_contains", "needle": "floatings=[]" }
    },
    { "type": "capture_bundle", "label": "docking-arbitration-demo-multiwindow-drag-tab-back-to-main-large-outer-move" }
  ]
}
