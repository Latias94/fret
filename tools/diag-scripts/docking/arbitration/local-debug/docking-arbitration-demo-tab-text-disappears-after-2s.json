{
  "schema_version": 2,
  "meta": {
    "name": "LOCAL DEBUG: docking tab text disappears after ~2s (while drag active)",
    "tags": ["docking", "multiwindow", "local_debug", "screenshots"],
    "required_capabilities": ["diag.script_v2", "diag.multi_window", "diag.screenshot_png"],
    "env_defaults": {
      "FRET_DOCK_ALLOW_MULTI_WINDOW_TEAR_OFF": "1"
    },
    "target_hints": [
      "This script is a local debugging aid for a visual issue: tab label text disappears after ~2 seconds.",
      "It captures screenshots and bundles before/after waiting ~2 seconds while a dock drag is active."
    ]
  },
  "steps": [
    { "type": "press_key", "window": { "kind": "first_seen" }, "key": "escape" },
    { "type": "wait_frames", "n": 2 },

    { "type": "set_window_outer_position", "window": { "kind": "first_seen" }, "x_px": 120.0, "y_px": 120.0 },
    { "type": "set_window_inner_size", "window": { "kind": "first_seen" }, "width_px": 1600.0, "height_px": 900.0 },
    { "type": "wait_frames", "n": 2 },

    {
      "type": "wait_until",
      "window": { "kind": "first_seen" },
      "predicate": { "kind": "exists", "target": { "kind": "test_id", "id": "dock-arb-tab-drag-anchor-left" } },
      "timeout_frames": 240
    },

    { "type": "raise_window", "window": { "kind": "first_seen" } },
    { "type": "wait_frames", "n": 2 },
    { "type": "capture_screenshot", "label": "tab-text-baseline-main" },
    { "type": "capture_bundle", "label": "tab-text-baseline-main" },

    {
      "type": "wait_bounds_stable",
      "window": { "kind": "first_seen" },
      "target": { "kind": "test_id", "id": "dock-arb-tab-drag-anchor-left" },
      "stable_frames": 12,
      "max_move_px": 0.5,
      "timeout_frames": 240
    },
    {
      "type": "drag_pointer",
      "window": { "kind": "first_seen" },
      "target": { "kind": "test_id", "id": "dock-arb-tab-drag-anchor-left" },
      "delta_x": -2400.0,
      "delta_y": 0.0,
      "steps": 160
    },
    { "type": "wait_until", "predicate": { "kind": "known_window_count_ge", "n": 2 }, "timeout_frames": 240 },
    { "type": "wait_frames", "n": 30 },

    { "type": "raise_window", "window": { "kind": "last_seen" } },
    { "type": "wait_frames", "n": 4 },
    {
      "type": "wait_until",
      "window": { "kind": "last_seen" },
      "predicate": { "kind": "exists", "target": { "kind": "test_id", "id": "dock-arb-tab-drag-anchor-left" } },
      "timeout_frames": 240
    },
    { "type": "capture_screenshot", "label": "tab-text-baseline-float" },

    { "type": "pointer_down", "window": { "kind": "last_seen" }, "target": { "kind": "test_id", "id": "dock-arb-tab-drag-anchor-left" } },
    { "type": "pointer_move", "window": { "kind": "last_seen" }, "delta_x": 20.0, "delta_y": 0.0, "steps": 12 },
    { "type": "wait_until", "predicate": { "kind": "dock_drag_active_is", "active": true }, "timeout_frames": 120 },
    { "type": "wait_frames", "n": 2 },

    { "type": "raise_window", "window": { "kind": "first_seen" } },
    { "type": "set_cursor_in_window_logical", "window": { "kind": "first_seen" }, "x_px": 220.0, "y_px": 60.0 },
    { "type": "wait_frames", "window": { "kind": "first_seen" }, "n": 2 },
    { "type": "capture_screenshot", "label": "tab-text-during-drag-main-t0" },

    { "type": "wait_frames", "window": { "kind": "first_seen" }, "n": 120 },
    { "type": "capture_screenshot", "label": "tab-text-during-drag-main-t2s" },
    { "type": "capture_bundle", "label": "tab-text-during-drag-after-2s" },

    { "type": "press_key", "window": { "kind": "first_seen" }, "key": "escape" },
    { "type": "wait_frames", "n": 2 },
    { "type": "pointer_up", "window": { "kind": "first_seen" } },
    { "type": "wait_until", "predicate": { "kind": "dock_drag_active_is", "active": false }, "timeout_frames": 240 },

    { "type": "wait_until", "predicate": { "kind": "known_window_count_is", "n": 1 }, "timeout_frames": 600 },
    { "type": "capture_bundle", "label": "tab-text-after-close" }
  ]
}
