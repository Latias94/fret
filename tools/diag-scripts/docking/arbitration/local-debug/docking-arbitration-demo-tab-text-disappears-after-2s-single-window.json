{
  "schema_version": 2,
  "meta": {
    "name": "LOCAL DEBUG: docking tab text disappears after ~2s (single-window drag)",
    "tags": ["docking", "local_debug", "screenshots"],
    "required_capabilities": ["diag.script_v2", "diag.screenshot_png"],
    "target_hints": [
      "Starts a dock tab drag in a single window (no tear-off).",
      "Captures screenshots before/after waiting ~2 seconds while the drag is active."
    ]
  },
  "steps": [
    { "type": "press_key", "window": { "kind": "first_seen" }, "key": "escape" },
    { "type": "wait_frames", "n": 2 },

    { "type": "set_window_outer_position", "window": { "kind": "first_seen" }, "x_px": 120.0, "y_px": 120.0 },
    { "type": "set_window_inner_size", "window": { "kind": "first_seen" }, "width_px": 1600.0, "height_px": 900.0 },
    { "type": "wait_frames", "n": 2 },

    {
      "type": "wait_until",
      "window": { "kind": "first_seen" },
      "predicate": { "kind": "exists", "target": { "kind": "test_id", "id": "dock-arb-tab-drag-anchor-right" } },
      "timeout_frames": 240
    },

    { "type": "capture_screenshot", "label": "tab-text-idle-t0" },
    { "type": "wait_frames", "n": 120 },
    { "type": "capture_screenshot", "label": "tab-text-idle-t2s" },

    { "type": "pointer_down", "window": { "kind": "first_seen" }, "target": { "kind": "test_id", "id": "dock-arb-tab-drag-anchor-right" } },
    { "type": "pointer_move", "window": { "kind": "first_seen" }, "delta_x": 20.0, "delta_y": 0.0, "steps": 12 },
    { "type": "wait_until", "predicate": { "kind": "dock_drag_active_is", "active": true }, "timeout_frames": 120 },

    { "type": "capture_screenshot", "label": "tab-text-during-drag-t0" },
    { "type": "wait_frames", "n": 120 },
    { "type": "capture_screenshot", "label": "tab-text-during-drag-t2s" },
    { "type": "capture_bundle", "label": "tab-text-during-drag-after-2s" },

    { "type": "press_key", "window": { "kind": "first_seen" }, "key": "escape" },
    { "type": "wait_frames", "n": 2 },
    { "type": "pointer_up", "window": { "kind": "first_seen" } },
    { "type": "wait_until", "predicate": { "kind": "dock_drag_active_is", "active": false }, "timeout_frames": 240 },

    { "type": "capture_bundle", "label": "tab-text-after-cancel" }
  ]
}
