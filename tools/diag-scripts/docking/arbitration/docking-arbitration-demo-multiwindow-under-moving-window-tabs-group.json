{
  "schema_version": 2,
  "meta": {
    "name": "Docking arbitration demo: peek-behind hover routing works for tabs-group drags",
    "tags": ["docking", "multiwindow", "drag", "hover", "gate"],
    "required_capabilities": ["diag.script_v2", "diag.multi_window"],
    "env_defaults": {
      "FRET_DOCK_ALLOW_MULTI_WINDOW_TEAR_OFF": "1",
      "FRET_DOCK_TEAROFF_TRANSPARENT_PAYLOAD": "1"
    },
    "target_hints": [
      "This gate overlaps two OS windows and starts a cross-window tabs-group dock drag in the topmost window.",
      "Expected (transparent payload): hover routing peeks behind the moving window so docking previews/resolve can target the overlapped window.",
      "It differs from the basic under-moving-window gate by starting the drag on empty tab-bar space (tabs-group drag), not on a specific tab (panel drag)."
    ]
  },
  "steps": [
    { "type": "press_key", "window": { "kind": "first_seen" }, "key": "escape" },
    { "type": "wait_frames", "n": 2 },
    {
      "type": "wait_until",
      "predicate": { "kind": "platform_ui_window_hover_detection_is", "quality": "reliable" },
      "timeout_frames": 240
    },

    { "type": "set_window_outer_position", "window": { "kind": "first_seen" }, "x_px": 120.0, "y_px": 120.0 },
    { "type": "set_window_inner_size", "window": { "kind": "first_seen" }, "width_px": 1600.0, "height_px": 900.0 },
    { "type": "wait_frames", "n": 2 },

    {
      "type": "wait_until",
      "window": { "kind": "first_seen" },
      "predicate": { "kind": "exists", "target": { "kind": "test_id", "id": "dock-arb-tab-drag-anchor-right" } },
      "timeout_frames": 240
    },

    {
      "type": "drag_pointer",
      "window": { "kind": "current" },
      "target": { "kind": "test_id", "id": "dock-arb-tab-drag-anchor-right" },
      "delta_x": 2400.0,
      "delta_y": 0.0,
      "steps": 140
    },
    { "type": "wait_until", "predicate": { "kind": "known_window_count_ge", "n": 2 }, "timeout_frames": 240 },
    { "type": "wait_frames", "n": 30 },

    { "type": "raise_window", "window": { "kind": "first_seen_other" } },
    { "type": "set_window_outer_position", "window": { "kind": "first_seen_other" }, "x_px": 200.0, "y_px": 200.0 },
    { "type": "set_window_inner_size", "window": { "kind": "first_seen_other" }, "width_px": 1200.0, "height_px": 800.0 },
    { "type": "wait_frames", "n": 10 },

    { "type": "raise_window", "window": { "kind": "first_seen_other" } },
    { "type": "wait_frames", "n": 2 },

    {
      "type": "wait_until",
      "window": { "kind": "first_seen_other" },
      "predicate": { "kind": "exists", "target": { "kind": "test_id", "id": "dock-arb-tabs-group-drag-anchor-right" } },
      "timeout_frames": 240
    },

    { "type": "pointer_down", "window": { "kind": "first_seen_other" }, "target": { "kind": "test_id", "id": "dock-arb-tabs-group-drag-anchor-right" } },
    { "type": "pointer_move", "window": { "kind": "first_seen_other" }, "delta_x": 20.0, "delta_y": 0.0, "steps": 12 },
    { "type": "wait_until", "window": { "kind": "first_seen" }, "predicate": { "kind": "dock_drag_active_is", "active": true }, "timeout_frames": 120 },
    { "type": "wait_until", "window": { "kind": "first_seen" }, "predicate": { "kind": "dock_drag_kind_is", "drag_kind": "dock_tabs" }, "timeout_frames": 120 },
    {
      "type": "wait_until",
      "window": { "kind": "first_seen" },
      "predicate": { "kind": "dock_drag_window_under_cursor_source_is", "source": "platform" },
      "timeout_frames": 120
    },

    {
      "type": "wait_until",
      "window": { "kind": "first_seen" },
      "predicate": { "kind": "dock_drag_current_window_is", "window": { "kind": "first_seen" } },
      "timeout_frames": 240
    },
    {
      "type": "wait_until",
      "window": { "kind": "first_seen" },
      "predicate": { "kind": "dock_drag_moving_window_is", "window": { "kind": "first_seen_other" } },
      "timeout_frames": 240
    },
    {
      "type": "wait_until",
      "window": { "kind": "first_seen" },
      "predicate": { "kind": "dock_drag_window_under_moving_window_source_is", "source": "platform" },
      "timeout_frames": 240
    },
    {
      "type": "wait_until",
      "window": { "kind": "first_seen" },
      "predicate": { "kind": "dock_drag_window_under_moving_window_is", "window": { "kind": "first_seen" } },
      "timeout_frames": 240
    },

    { "type": "capture_bundle", "label": "docking-arbitration-demo-multiwindow-under-moving-window-tabs-group" }
  ]
}
