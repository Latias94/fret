{
  "schema_version": 2,
  "meta": {
    "name": "Docking arbitration demo (Wayland): tear-off degrades to in-window floating",
    "tags": ["docking", "degradation", "linux", "wayland", "gate"],
    "required_capabilities": ["diag.script_v2"],
    "env_defaults": {
      "FRET_DOCK_ALLOW_MULTI_WINDOW_TEAR_OFF": "1"
    },
    "target_hints": [
      "This is a Linux Wayland-specific degradation gate.",
      "Wayland compositors do not provide a reliable window-under-cursor contract, so OS-window tear-off must be disabled and docking should degrade to in-window floating instead (ADR 0054 / ADR 0083).",
      "Expected: `ui.window_hover_detection` reports `none` and attempting a tear-off gesture does not create a second OS window."
    ]
  },
  "steps": [
    { "type": "press_key", "key": "escape" },
    { "type": "wait_frames", "n": 2 },

    {
      "type": "wait_until",
      "predicate": { "kind": "platform_ui_window_hover_detection_is", "quality": "none" },
      "timeout_frames": 240
    },

    { "type": "set_window_outer_position", "x_px": 120.0, "y_px": 120.0 },
    { "type": "set_window_inner_size", "width_px": 1600.0, "height_px": 900.0 },
    { "type": "wait_frames", "n": 2 },

    {
      "type": "wait_until",
      "predicate": { "kind": "exists", "target": { "kind": "test_id", "id": "dock-arb-tab-drag-anchor-right" } },
      "timeout_frames": 240
    },

    {
      "type": "drag_pointer",
      "target": { "kind": "test_id", "id": "dock-arb-tab-drag-anchor-right" },
      "delta_x": 2400.0,
      "delta_y": 0.0,
      "steps": 140
    },
    { "type": "wait_frames", "n": 60 },

    { "type": "assert", "predicate": { "kind": "known_window_count_is", "n": 1 } },
    { "type": "capture_bundle", "label": "docking-arbitration-demo-wayland-degrade-no-os-tearoff" },
    { "type": "wait_frames", "n": 2 }
  ]
}
