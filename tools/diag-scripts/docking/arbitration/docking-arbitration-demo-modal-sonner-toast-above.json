{
  "schema_version": 2,
  "meta": {
    "name": "Docking arbitration demo: modal keeps sonner toast above",
    "tags": ["docking", "modal", "toast", "gate"],
    "required_capabilities": ["diag.script_v2"]
  },
  "steps": [
    { "type": "press_key", "key": "escape" },
    { "type": "wait_frames", "n": 5 },
    { "type": "set_window_inner_size", "width_px": 1600.0, "height_px": 900.0 },
    { "type": "wait_frames", "n": 10 },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "dock-arb-dock-space" }
      },
      "timeout_frames": 240
    },

    {
      "type": "wait_until",
      "predicate": {
        "kind": "bounds_within_window",
        "target": { "kind": "test_id", "id": "dock-arb-dialog-trigger" },
        "padding_px": 4.0
      },
      "timeout_frames": 240
    },
    { "type": "click", "target": { "kind": "test_id", "id": "dock-arb-dialog-trigger" } },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "dock-arb-dialog-open" }
      },
      "timeout_frames": 240
    },

    { "type": "click", "target": { "kind": "test_id", "id": "dock-arb-sonner-trigger" } },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "dock-arb-sonner-toast" }
      },
      "timeout_frames": 240
    },

    {
      "type": "capture_bundle",
      "label": "docking-arbitration-demo-modal-sonner-toast-above"
    }
  ]
}
