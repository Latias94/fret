{
  "schema_version": 2,
  "meta": {
    "name": "Docking arbitration demo: drop-zone mask can disallow the left edge (policy gate)",
    "tags": ["docking", "nary", "gate"],
    "required_capabilities": ["diag.script_v2"]
  },
  "steps": [
    { "type": "press_key", "key": "escape" },
    { "type": "wait_frames", "n": 5 },
    {
      "type": "wait_until",
      "predicate": { "kind": "exists", "target": { "kind": "test_id", "id": "dock-arb-tab-drag-anchor-right" } },
      "timeout_frames": 240
    },
    {
      "type": "wait_until",
      "predicate": { "kind": "exists", "target": { "kind": "test_id", "id": "dock-arb-toggle-drop-mask-left-edge" } },
      "timeout_frames": 240
    },
    { "type": "click", "target": { "kind": "test_id", "id": "dock-arb-toggle-drop-mask-left-edge" }, "button": "left" },
    {
      "type": "wait_until",
      "predicate": { "kind": "exists", "target": { "kind": "test_id", "id": "dock-arb-drop-mask-left-disallowed" } },
      "timeout_frames": 120
    },
    {
      "type": "wait_until",
      "window": { "kind": "current" },
      "predicate": { "kind": "dock_graph_canonical_is", "canonical": true },
      "timeout_frames": 240
    },
    {
      "type": "pointer_down",
      "window": { "kind": "current" },
      "target": { "kind": "test_id", "id": "dock-arb-tab-drag-anchor-right" },
      "button": "left"
    },
    {
      "type": "set_cursor_in_window_logical",
      "window": { "kind": "current" },
      "x_px": 538.0,
      "y_px": 14.0
    },
    {
      "type": "pointer_move",
      "window": { "kind": "current" },
      "delta_x": -520.0,
      "delta_y": 346.0,
      "steps": 32
    },
    {
      "type": "set_cursor_in_window_logical",
      "window": { "kind": "current" },
      "x_px": 18.0,
      "y_px": 360.0
    },
    {
      "type": "wait_until",
      "window": { "kind": "current" },
      "predicate": { "kind": "dock_drag_active_is", "active": true },
      "timeout_frames": 120
    },
    {
      "type": "wait_until",
      "window": { "kind": "current" },
      "predicate": { "kind": "dock_drop_resolve_source_is", "source": "outer_hint_rect" },
      "timeout_frames": 60
    },
    {
      "type": "wait_until",
      "window": { "kind": "current" },
      "predicate": { "kind": "dock_drop_resolved_is_some", "some": false },
      "timeout_frames": 60
    },
    { "type": "pointer_up", "window": { "kind": "current" }, "button": "left" },
    {
      "type": "wait_until",
      "window": { "kind": "current" },
      "predicate": { "kind": "dock_drag_active_is", "active": false },
      "timeout_frames": 240
    },
    {
      "type": "assert",
      "window": { "kind": "current" },
      "predicate": { "kind": "dock_graph_canonical_is", "canonical": true }
    },
    {
      "type": "assert",
      "window": { "kind": "current" },
      "predicate": {
        "kind": "dock_graph_signature_is",
        "signature": "dock(root=split(v,[split(h,[tabs([demo.viewport.left]),tabs([demo.viewport.right])]),tabs([demo.controls])]);floatings=[])"
      }
    },
    {
      "type": "capture_bundle",
      "label": "docking-arbitration-demo-nary-drop-zone-mask-disallow-left-edge"
    }
  ]
}
