{
  "schema_version": 2,
  "meta": {
    "name": "Docking arbitration demo: split viewports respond to input (smoke)",
    "tags": ["docking", "gate"],
    "required_capabilities": ["diag.script_v2"]
  },
  "steps": [
    { "type": "press_key", "key": "escape" },
    { "type": "wait_frames", "n": 5 },
    {
      "type": "wait_until",
      "predicate": { "kind": "exists", "target": { "kind": "test_id", "id": "dock-arb-dock-space" } },
      "timeout_frames": 240
    },
    {
      "type": "wait_until",
      "window": { "kind": "current" },
      "predicate": {
        "kind": "bounds_within_window",
        "target": { "kind": "test_id", "id": "dock-arb-viewport-left" },
        "padding_px": 0.0,
        "eps_px": 2.0
      },
      "timeout_frames": 240
    },
    {
      "type": "wait_until",
      "window": { "kind": "current" },
      "predicate": {
        "kind": "bounds_within_window",
        "target": { "kind": "test_id", "id": "dock-arb-viewport-right" },
        "padding_px": 0.0,
        "eps_px": 2.0
      },
      "timeout_frames": 240
    },
    {
      "type": "drag_pointer",
      "window": { "kind": "current" },
      "target": { "kind": "test_id", "id": "dock-arb-viewport-left" },
      "delta_x": 160.0,
      "delta_y": 60.0,
      "steps": 18
    },
    { "type": "wait_frames", "n": 2 },
    {
      "type": "drag_pointer",
      "window": { "kind": "current" },
      "target": { "kind": "test_id", "id": "dock-arb-viewport-right" },
      "delta_x": -160.0,
      "delta_y": 40.0,
      "steps": 18
    },
    { "type": "capture_bundle", "label": "docking-arbitration-demo-split-viewports" }
  ]
}
