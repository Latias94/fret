{
  "schema_version": 2,
  "meta": {
    "name": "Docking arbitration demo: tab bar drop-at-end resolves insert_index == tab_count (two tabs)",
    "tags": ["docking", "tabbar", "gate"],
    "required_capabilities": ["diag.script_v2"],
    "target_hints": [
      "This script first merges two viewports into a single tab stack, then asserts drop-at-end resolves insert_index == 2.",
      "It cancels the final drag (Escape) to avoid mutating layout beyond the setup step."
    ]
  },
  "steps": [
    { "type": "set_window_inner_size", "width_px": 1600.0, "height_px": 900.0 },
    { "type": "wait_frames", "n": 10 },

    { "type": "press_key", "key": "escape" },
    { "type": "wait_frames", "n": 5 },
    {
      "type": "wait_until",
      "predicate": { "kind": "exists", "target": { "kind": "test_id", "id": "dock-arb-dock-space" } },
      "timeout_frames": 240
    },
    {
      "type": "wait_until",
      "predicate": { "kind": "exists", "target": { "kind": "test_id", "id": "dock-arb-tab-drag-anchor-left" } },
      "timeout_frames": 240
    },
    {
      "type": "wait_until",
      "predicate": { "kind": "exists", "target": { "kind": "test_id", "id": "dock-arb-tab-drag-anchor-right" } },
      "timeout_frames": 240
    },
    {
      "type": "wait_until",
      "predicate": { "kind": "exists", "target": { "kind": "test_id", "id": "dock-arb-tab-drop-end-anchor-left" } },
      "timeout_frames": 240
    },
    {
      "type": "wait_until",
      "predicate": { "kind": "dock_graph_signature_fingerprint64_is", "fingerprint64": 7509174212363425732 }
    },

    {
      "type": "pointer_down",
      "window": { "kind": "current" },
      "target": { "kind": "test_id", "id": "dock-arb-tab-drag-anchor-right" },
      "button": "left"
    },
    { "type": "pointer_move", "window": { "kind": "current" }, "delta_x": 20.0, "delta_y": 0.0, "steps": 12 },
    { "type": "wait_until", "window": { "kind": "current" }, "predicate": { "kind": "dock_drag_active_is", "active": true }, "timeout_frames": 120 },
    {
      "type": "move_pointer",
      "window": { "kind": "current" },
      "target": { "kind": "test_id", "id": "dock-arb-tab-drag-anchor-left" }
    },
    { "type": "wait_frames", "n": 2 },
    {
      "type": "wait_until",
      "window": { "kind": "current" },
      "predicate": { "kind": "dock_drop_resolve_source_is", "source": "tab_bar" },
      "timeout_frames": 120
    },
    { "type": "pointer_up", "window": { "kind": "current" } },
    { "type": "wait_until", "window": { "kind": "current" }, "predicate": { "kind": "dock_drag_active_is", "active": false }, "timeout_frames": 240 },
    { "type": "wait_frames", "n": 10 },

    {
      "type": "pointer_down",
      "window": { "kind": "current" },
      "target": { "kind": "test_id", "id": "dock-arb-tab-drag-anchor-right" },
      "button": "left"
    },
    { "type": "pointer_move", "window": { "kind": "current" }, "delta_x": 20.0, "delta_y": 0.0, "steps": 12 },
    { "type": "wait_until", "window": { "kind": "current" }, "predicate": { "kind": "dock_drag_active_is", "active": true }, "timeout_frames": 120 },

    { "type": "move_pointer", "window": { "kind": "current" }, "target": { "kind": "test_id", "id": "dock-arb-tab-drop-end-anchor-left" } },
    { "type": "wait_frames", "n": 2 },
    {
      "type": "wait_until",
      "window": { "kind": "current" },
      "predicate": { "kind": "dock_drop_resolve_source_is", "source": "tab_bar" },
      "timeout_frames": 120
    },
    {
      "type": "wait_until",
      "window": { "kind": "current" },
      "predicate": { "kind": "dock_drop_resolved_is_some", "some": true },
      "timeout_frames": 120
    },
    {
      "type": "wait_until",
      "window": { "kind": "current" },
      "predicate": { "kind": "dock_drop_resolved_zone_is", "zone": "center" },
      "timeout_frames": 120
    },
    {
      "type": "wait_until",
      "window": { "kind": "current" },
      "predicate": { "kind": "dock_drop_resolved_insert_index_is", "index": 2 },
      "timeout_frames": 120
    },

    { "type": "press_key", "key": "escape" },
    { "type": "wait_frames", "n": 2 },
    { "type": "pointer_up", "window": { "kind": "current" } },
    { "type": "wait_until", "window": { "kind": "current" }, "predicate": { "kind": "dock_drag_active_is", "active": false }, "timeout_frames": 240 },

    { "type": "capture_bundle", "label": "docking-arbitration-demo-tab-bar-drop-end-insert-index-two-tabs" }
  ]
}
