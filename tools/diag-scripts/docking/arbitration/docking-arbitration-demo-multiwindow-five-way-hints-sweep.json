{
  "schema_version": 2,
  "meta": {
    "name": "Docking arbitration demo: multi-window five-way hint sweep (inner pad)",
    "tags": ["docking", "multiwindow", "tearoff", "hints", "gate"],
    "required_capabilities": ["diag.script_v2", "diag.multi_window"],
    "env_defaults": {
      "FRET_DOCK_ALLOW_MULTI_WINDOW_TEAR_OFF": "1"
    },
    "target_hints": [
      "Tears off a tab into a dock-floating OS window.",
      "Starts a cross-window drag and sweeps the inner 5-way docking hint pad in the main window (top/left/right/bottom/center).",
      "Asserts that each hint can be selected deterministically via `dock_drop_resolved_zone_is`."
    ]
  },
  "steps": [
    { "type": "press_key", "window": { "kind": "first_seen" }, "key": "escape" },
    { "type": "wait_frames", "n": 2 },

    { "type": "set_window_outer_position", "window": { "kind": "first_seen" }, "x_px": 120.0, "y_px": 120.0 },
    { "type": "set_window_inner_size", "window": { "kind": "first_seen" }, "width_px": 1600.0, "height_px": 900.0 },
    { "type": "wait_frames", "n": 2 },

    {
      "type": "wait_until",
      "window": { "kind": "first_seen" },
      "predicate": { "kind": "exists", "target": { "kind": "test_id", "id": "dock-arb-tab-drag-anchor-left" } },
      "timeout_frames": 240
    },
    {
      "type": "wait_until",
      "window": { "kind": "first_seen" },
      "predicate": { "kind": "exists", "target": { "kind": "test_id", "id": "dock-arb-hint-inner-center" } },
      "timeout_frames": 240
    },

    {
      "type": "drag_pointer",
      "window": { "kind": "first_seen" },
      "target": { "kind": "test_id", "id": "dock-arb-tab-drag-anchor-left" },
      "delta_x": -2400.0,
      "delta_y": 0.0,
      "steps": 160
    },
    { "type": "wait_frames", "n": 10 },
    { "type": "wait_until", "predicate": { "kind": "known_window_count_ge", "n": 2 }, "timeout_frames": 240 },
    { "type": "wait_frames", "n": 30 },

    { "type": "raise_window", "window": { "kind": "last_seen_other" } },
    { "type": "wait_frames", "n": 4 },
    {
      "type": "wait_until",
      "window": { "kind": "last_seen_other" },
      "predicate": { "kind": "exists", "target": { "kind": "test_id", "id": "dock-arb-tab-drag-anchor-left" } },
      "timeout_frames": 240
    },

    { "type": "pointer_down", "window": { "kind": "last_seen_other" }, "target": { "kind": "test_id", "id": "dock-arb-tab-drag-anchor-left" } },
    { "type": "pointer_move", "window": { "kind": "last_seen_other" }, "delta_x": 20.0, "delta_y": 0.0, "steps": 12 },
    { "type": "wait_until", "predicate": { "kind": "dock_drag_active_is", "active": true }, "timeout_frames": 120 },

    { "type": "raise_window", "window": { "kind": "first_seen" } },
    { "type": "wait_frames", "window": { "kind": "first_seen" }, "n": 2 },

    { "type": "move_pointer", "window": { "kind": "first_seen" }, "target": { "kind": "test_id", "id": "dock-arb-hint-inner-top" } },
    { "type": "wait_until", "window": { "kind": "first_seen" }, "predicate": { "kind": "dock_drop_resolved_zone_is", "zone": "top" }, "timeout_frames": 240 },

    { "type": "move_pointer", "window": { "kind": "first_seen" }, "target": { "kind": "test_id", "id": "dock-arb-hint-inner-left" } },
    { "type": "wait_until", "window": { "kind": "first_seen" }, "predicate": { "kind": "dock_drop_resolved_zone_is", "zone": "left" }, "timeout_frames": 240 },

    { "type": "move_pointer", "window": { "kind": "first_seen" }, "target": { "kind": "test_id", "id": "dock-arb-hint-inner-right" } },
    { "type": "wait_until", "window": { "kind": "first_seen" }, "predicate": { "kind": "dock_drop_resolved_zone_is", "zone": "right" }, "timeout_frames": 240 },

    { "type": "move_pointer", "window": { "kind": "first_seen" }, "target": { "kind": "test_id", "id": "dock-arb-hint-inner-bottom" } },
    { "type": "wait_until", "window": { "kind": "first_seen" }, "predicate": { "kind": "dock_drop_resolved_zone_is", "zone": "bottom" }, "timeout_frames": 240 },

    { "type": "move_pointer", "window": { "kind": "first_seen" }, "target": { "kind": "test_id", "id": "dock-arb-hint-inner-center" } },
    { "type": "wait_until", "window": { "kind": "first_seen" }, "predicate": { "kind": "dock_drop_resolved_zone_is", "zone": "center" }, "timeout_frames": 240 },

    { "type": "pointer_up", "window": { "kind": "first_seen" } },
    { "type": "wait_until", "predicate": { "kind": "dock_drop_resolved_is_some", "some": true }, "timeout_frames": 240 },
    { "type": "wait_until", "predicate": { "kind": "dock_drag_active_is", "active": false }, "timeout_frames": 240 },
    { "type": "wait_until", "predicate": { "kind": "known_window_count_is", "n": 1 }, "timeout_frames": 600 },

    { "type": "capture_bundle", "label": "five-way-hints-after-close" }
  ]
}

