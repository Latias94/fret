{
  "schema_version": 2,
  "meta": {
    "name": "Docking arbitration demo: floating title drag docks back to main",
    "tags": ["docking", "floating", "gate"],
    "required_capabilities": ["diag.script_v2"],
    "target_hints": [
      "Create an in-window floating container via float-zone, then drag its title bar onto docking hint rectangles.",
      "Expected behavior: while dragging, docking hint routing is published and on drop the floating container merges back into the main dock tree (ImGui-style)."
    ]
  },
  "steps": [
    { "type": "press_key", "key": "escape" },
    { "type": "wait_frames", "n": 2 },

    { "type": "set_window_outer_position", "x_px": 120.0, "y_px": 120.0 },
    { "type": "set_window_inner_size", "width_px": 1600.0, "height_px": 900.0 },
    { "type": "wait_frames", "n": 2 },

    {
      "type": "wait_until",
      "predicate": { "kind": "exists", "target": { "kind": "test_id", "id": "dock-arb-dock-space" } },
      "timeout_frames": 240
    },
    {
      "type": "wait_until",
      "predicate": { "kind": "exists", "target": { "kind": "test_id", "id": "dock-arb-tab-drag-anchor-right" } },
      "timeout_frames": 240
    },
    {
      "type": "wait_until",
      "predicate": { "kind": "exists", "target": { "kind": "test_id", "id": "dock-arb-tab-drag-anchor-left" } },
      "timeout_frames": 240
    },
    {
      "type": "wait_until",
      "predicate": { "kind": "exists", "target": { "kind": "test_id", "id": "dock-arb-float-zone-anchor" } },
      "timeout_frames": 240
    },
    {
      "type": "wait_until",
      "predicate": { "kind": "exists", "target": { "kind": "test_id", "id": "dock-arb-hint-inner-center" } },
      "timeout_frames": 240
    },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "dock_graph_signature_is",
        "signature": "dock(root=split(v,[split(h,[tabs([demo.viewport.left]),tabs([demo.viewport.right])]),tabs([demo.controls])]);floatings=[])"
      },
      "timeout_frames": 240
    },

    {
      "type": "drag_to",
      "from": { "kind": "test_id", "id": "dock-arb-tab-drag-anchor-right" },
      "to": { "kind": "test_id", "id": "dock-arb-float-zone-anchor" },
      "steps": 48,
      "timeout_frames": 240
    },
    { "type": "wait_until", "predicate": { "kind": "dock_drag_active_is", "active": false }, "timeout_frames": 240 },
    { "type": "wait_until", "predicate": { "kind": "dock_graph_signature_contains", "needle": "floating(" }, "timeout_frames": 240 },

    {
      "type": "wait_until",
      "predicate": {
        "kind": "bounds_within_window",
        "target": { "kind": "test_id", "id": "dock-arb-floating-title-bar-anchor" },
        "padding_px": 4.0
      },
      "timeout_frames": 240
    },

    {
      "type": "drag_to",
      "from": { "kind": "test_id", "id": "dock-arb-floating-title-bar-anchor" },
      "to": { "kind": "test_id", "id": "dock-arb-tab-drag-anchor-left" },
      "steps": 72,
      "timeout_frames": 240
    },

    {
      "type": "wait_until",
      "predicate": { "kind": "dock_graph_signature_contains", "needle": "floatings=[]" },
      "timeout_frames": 240
    },
    {
      "type": "assert",
      "predicate": {
        "kind": "dock_graph_signature_contains",
        "needle": "demo.viewport.left"
      }
    },
    { "type": "assert", "predicate": { "kind": "dock_graph_signature_contains", "needle": "demo.viewport.right" } },
    { "type": "assert", "predicate": { "kind": "dock_graph_signature_contains", "needle": "demo.controls" } },
    { "type": "assert", "predicate": { "kind": "dock_graph_canonical_is", "canonical": true } },
    { "type": "assert", "predicate": { "kind": "dock_graph_has_nested_same_axis_splits_is", "has_nested": false } },

    { "type": "capture_bundle", "label": "docking-arbitration-demo-floating-title-drag-docks-to-main" }
  ]
}
