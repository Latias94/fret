{
  "schema_version": 2,
  "meta": {
    "name": "Docking arbitration demo: large preset transparent payload enables peek-behind under overlap",
    "tags": ["docking", "multiwindow", "large", "hover", "transparent_payload", "gate"],
    "required_capabilities": ["diag.script_v2", "diag.multi_window"],
    "env_defaults": {
      "FRET_DOCK_ARB_PRESET": "large",
      "FRET_DOCK_ALLOW_MULTI_WINDOW_TEAR_OFF": "1",
      "FRET_DOCK_TEAROFF_TRANSPARENT_PAYLOAD": "1"
    },
    "target_hints": [
      "Large preset variant of the transparent payload gate: overlaps two OS windows and asserts that hover routing selects the window under the moving window while the moving dock window is semi-transparent (ImGui `ConfigDockingTransparentPayload`).",
      "Expected: `dock_drag_transparent_payload_applied_is` becomes true during the drag and `dock_drag_current_window_is` targets the window under the moving window in the overlap region.",
      "Cursor overrides use window-client logical coordinates to stay stable under DPI scaling."
    ]
  },
  "steps": [
    { "type": "press_key", "window": { "kind": "first_seen" }, "key": "escape" },
    { "type": "wait_frames", "n": 2 },
    {
      "type": "wait_until",
      "predicate": { "kind": "platform_ui_window_hover_detection_is", "quality": "reliable" },
      "timeout_frames": 240
    },

    { "type": "set_window_outer_position", "window": { "kind": "first_seen" }, "x_px": 120.0, "y_px": 120.0 },
    { "type": "set_window_inner_size", "window": { "kind": "first_seen" }, "width_px": 1600.0, "height_px": 900.0 },
    { "type": "wait_frames", "n": 2 },

    {
      "type": "wait_until",
      "window": { "kind": "first_seen" },
      "predicate": { "kind": "exists", "target": { "kind": "test_id", "id": "dock-arb-viewport-extra-0" } },
      "timeout_frames": 240
    },

    {
      "type": "drag_pointer",
      "window": { "kind": "current" },
      "target": { "kind": "test_id", "id": "dock-arb-tab-drag-anchor-right" },
      "delta_x": 2400.0,
      "delta_y": 0.0,
      "steps": 140
    },
    { "type": "wait_until", "predicate": { "kind": "known_window_count_ge", "n": 2 }, "timeout_frames": 240 },
    { "type": "wait_frames", "n": 30 },

    { "type": "raise_window", "window": { "kind": "last_seen" } },
    { "type": "set_window_outer_position", "window": { "kind": "last_seen" }, "x_px": 200.0, "y_px": 200.0 },
    { "type": "set_window_inner_size", "window": { "kind": "last_seen" }, "width_px": 1200.0, "height_px": 800.0 },
    { "type": "wait_frames", "n": 10 },

    { "type": "set_cursor_in_window_logical", "window": { "kind": "first_seen" }, "x_px": 320.0, "y_px": 320.0 },
    { "type": "wait_frames", "n": 2 },

    { "type": "raise_window", "window": { "kind": "last_seen" } },
    { "type": "wait_frames", "n": 2 },

    { "type": "pointer_down", "window": { "kind": "last_seen" }, "target": { "kind": "test_id", "id": "dock-arb-tab-drag-anchor-right" } },
    { "type": "pointer_move", "window": { "kind": "last_seen" }, "delta_x": 20.0, "delta_y": 0.0, "steps": 12 },
    { "type": "wait_until", "window": { "kind": "last_seen" }, "predicate": { "kind": "dock_drag_active_is", "active": true }, "timeout_frames": 120 },
    { "type": "wait_until", "window": { "kind": "last_seen" }, "predicate": { "kind": "dock_drag_transparent_payload_applied_is", "applied": true }, "timeout_frames": 120 },
    { "type": "wait_until", "window": { "kind": "last_seen" }, "predicate": { "kind": "dock_drag_transparent_payload_hit_test_passthrough_applied_is", "applied": true }, "timeout_frames": 120 },
    { "type": "wait_until", "window": { "kind": "last_seen" }, "predicate": { "kind": "dock_drag_window_under_cursor_source_is", "source": "platform" }, "timeout_frames": 120 },

    {
      "type": "wait_until",
      "window": { "kind": "last_seen" },
      "predicate": { "kind": "dock_drag_moving_window_is", "window": { "kind": "last_seen" } },
      "timeout_frames": 240
    },
    {
      "type": "wait_until",
      "window": { "kind": "last_seen" },
      "predicate": { "kind": "dock_drag_window_under_moving_window_source_is", "source": "platform" },
      "timeout_frames": 240
    },
    {
      "type": "wait_until",
      "window": { "kind": "last_seen" },
      "predicate": { "kind": "dock_drag_window_under_moving_window_is", "window": { "kind": "first_seen" } },
      "timeout_frames": 240
    },

    {
      "type": "wait_until",
      "window": { "kind": "last_seen" },
      "predicate": { "kind": "dock_drag_current_window_is", "window": { "kind": "first_seen" } },
      "timeout_frames": 240
    },

    { "type": "raise_window", "window": { "kind": "first_seen" } },
    { "type": "wait_frames", "n": 2 },
    {
      "type": "wait_until",
      "window": { "kind": "first_seen" },
      "predicate": { "kind": "dock_drag_current_window_is", "window": { "kind": "first_seen" } },
      "timeout_frames": 240
    },

    { "type": "raise_window", "window": { "kind": "last_seen" } },
    { "type": "wait_frames", "n": 2 },
    {
      "type": "wait_until",
      "window": { "kind": "last_seen" },
      "predicate": { "kind": "dock_drag_current_window_is", "window": { "kind": "first_seen" } },
      "timeout_frames": 240
    },

    { "type": "pointer_up" },
    { "type": "wait_until", "window": { "kind": "last_seen" }, "predicate": { "kind": "dock_drag_active_is", "active": false }, "timeout_frames": 240 },

    {
      "type": "assert",
      "window": { "kind": "first_seen" },
      "predicate": {
        "kind": "dock_graph_signature_is",
        "signature": "dock(root=split(v,[split(h,[tabs([demo.viewport.left]),tabs([demo.viewport.extra#0]),tabs([demo.viewport.extra#1])]),split(h,[tabs([demo.viewport.extra#2]),tabs([demo.viewport.extra#3]),tabs([demo.viewport.extra#4]),tabs([demo.viewport.extra#5])]),split(h,[tabs([demo.viewport.extra#6]),tabs([demo.viewport.extra#7]),tabs([demo.viewport.extra#8]),tabs([demo.viewport.extra#9])]),tabs([demo.controls])]);floatings=[])"
      }
    },
    {
      "type": "assert",
      "window": { "kind": "last_seen" },
      "predicate": {
        "kind": "dock_graph_signature_is",
        "signature": "dock(root=tabs([demo.viewport.right]);floatings=[])"
      }
    },

    { "type": "capture_bundle", "label": "docking-arbitration-demo-multiwindow-large-transparent-payload-zorder-switch" },
    { "type": "wait_frames", "n": 2 }
  ]
}
