{
  "schema_version": 2,
  "meta": {
    "name": "Docking arbitration demo: chained tear-off (opt-in) + merge back to main",
    "tags": ["docking", "multiwindow", "tearoff", "drag", "gate"],
    "required_capabilities": ["diag.script_v2", "diag.multi_window"],
    "env_defaults": {
      "FRET_DOCK_ALLOW_MULTI_WINDOW_TEAR_OFF": "1"
    },
    "target_hints": [
      "This script exercises an opt-in behavior: creating multiple DockFloating OS windows without merging the first one back.",
      "It tears off two distinct tabs (left + right) from the main window, then drags them back one-by-one and asserts the dock graph is canonical, has no floatings, and still contains the baseline panels.",
      "Note: cursor overrides are expressed in window-client physical pixels."
    ]
  },
  "steps": [
    { "type": "press_key", "window": { "kind": "first_seen" }, "key": "escape" },
    { "type": "wait_frames", "n": 2 },

    { "type": "set_window_outer_position", "window": { "kind": "first_seen" }, "x_px": 120.0, "y_px": 120.0 },
    { "type": "set_window_inner_size", "window": { "kind": "first_seen" }, "width_px": 1600.0, "height_px": 900.0 },
    { "type": "wait_frames", "n": 2 },

    {
      "type": "wait_until",
      "window": { "kind": "first_seen" },
      "predicate": { "kind": "exists", "target": { "kind": "test_id", "id": "dock-arb-tab-drag-anchor-left" } },
      "timeout_frames": 240
    },
    {
      "type": "wait_until",
      "window": { "kind": "first_seen" },
      "predicate": { "kind": "exists", "target": { "kind": "test_id", "id": "dock-arb-tab-drag-anchor-right" } },
      "timeout_frames": 240
    },

    {
      "type": "wait_until",
      "window": { "kind": "first_seen" },
      "predicate": { "kind": "dock_graph_canonical_is", "canonical": true },
      "timeout_frames": 240
    },
    {
      "type": "assert",
      "window": { "kind": "first_seen" },
      "predicate": {
        "kind": "dock_graph_signature_fingerprint64_is",
        "fingerprint64": 7509174212363425732
      }
    },

    {
      "type": "drag_pointer",
      "window": { "kind": "first_seen" },
      "target": { "kind": "test_id", "id": "dock-arb-tab-drag-anchor-left" },
      "release_on_success": false,
      "delta_x": -2400.0,
      "delta_y": 0.0,
      "steps": 160
    },
    { "type": "wait_frames", "n": 10 },
    { "type": "wait_until", "predicate": { "kind": "known_window_count_ge", "n": 2 }, "timeout_frames": 240 },
    { "type": "wait_frames", "n": 30 },
    { "type": "raise_window", "window": { "kind": "last_seen_other" } },
    { "type": "set_window_outer_position", "window": { "kind": "last_seen_other" }, "x_px": 1560.0, "y_px": 180.0 },
    { "type": "set_window_inner_size", "window": { "kind": "last_seen_other" }, "width_px": 900.0, "height_px": 650.0 },
    { "type": "wait_frames", "n": 10 },
    {
      "type": "wait_until",
      "window": { "kind": "last_seen_other" },
      "predicate": { "kind": "exists", "target": { "kind": "test_id", "id": "dock-arb-dock-space" } },
      "timeout_frames": 240
    },
    { "type": "wait_frames", "n": 2 },

    { "type": "raise_window", "window": { "kind": "first_seen" } },
    { "type": "wait_frames", "window": { "kind": "first_seen" }, "n": 2 },

    {
      "type": "drag_pointer",
      "window": { "kind": "first_seen" },
      "target": { "kind": "test_id", "id": "dock-arb-tab-drag-anchor-right" },
      "release_on_success": false,
      "delta_x": 2400.0,
      "delta_y": 0.0,
      "steps": 160
    },
    { "type": "wait_frames", "n": 10 },
    { "type": "wait_until", "predicate": { "kind": "known_window_count_ge", "n": 3 }, "timeout_frames": 240 },
    { "type": "wait_frames", "n": 30 },
    { "type": "raise_window", "window": { "kind": "last_seen_other" } },
    { "type": "set_window_outer_position", "window": { "kind": "last_seen_other" }, "x_px": 180.0, "y_px": 180.0 },
    { "type": "set_window_inner_size", "window": { "kind": "last_seen_other" }, "width_px": 900.0, "height_px": 650.0 },
    { "type": "wait_frames", "n": 10 },
    {
      "type": "wait_until",
      "window": { "kind": "last_seen_other" },
      "predicate": { "kind": "exists", "target": { "kind": "test_id", "id": "dock-arb-dock-space" } },
      "timeout_frames": 240
    },
    { "type": "wait_frames", "n": 2 },

    { "type": "raise_window", "window": { "kind": "last_seen_other" } },
    { "type": "set_cursor_in_window", "window": { "kind": "last_seen_other" }, "x_px": 640.0, "y_px": 260.0 },
    { "type": "wait_frames", "n": 2 },
    {
      "type": "wait_until",
      "window": { "kind": "last_seen_other" },
      "predicate": { "kind": "exists", "target": { "kind": "test_id", "id": "dock-arb-tab-drag-anchor-right" } },
      "timeout_frames": 240
    },
    {
      "type": "pointer_down",
      "window": { "kind": "last_seen_other" },
      "target": { "kind": "test_id", "id": "dock-arb-tab-drag-anchor-right" }
    },
    {
      "type": "pointer_move",
      "window": { "kind": "last_seen_other" },
      "delta_x": 120.0,
      "delta_y": 0.0,
      "steps": 24
    },
    {
      "type": "wait_until",
      "window": { "kind": "last_seen_other" },
      "predicate": { "kind": "dock_drag_active_is", "active": true },
      "timeout_frames": 120
    },
    { "type": "wait_frames", "window": { "kind": "last_seen_other" }, "n": 2 },

    { "type": "raise_window", "window": { "kind": "first_seen" } },
    { "type": "wait_frames", "window": { "kind": "first_seen" }, "n": 2 },
    { "type": "wait_frames", "window": { "kind": "first_seen" }, "n": 2 },
    {
      "type": "move_pointer",
      "window": { "kind": "first_seen" },
      "target": { "kind": "test_id", "id": "dock-arb-dock-space" }
    },
    { "type": "wait_frames", "n": 2 },
    {
      "type": "move_pointer",
      "window": { "kind": "first_seen" },
      "target": { "kind": "test_id", "id": "dock-arb-hint-inner-top" }
    },
    { "type": "wait_frames", "n": 2 },
    {
      "type": "wait_until",
      "window": { "kind": "first_seen" },
      "predicate": { "kind": "dock_drag_current_window_is", "window": { "kind": "first_seen" } },
      "timeout_frames": 240
    },
    { "type": "pointer_up", "window": { "kind": "first_seen" } },
    { "type": "wait_until", "predicate": { "kind": "dock_drop_resolved_is_some", "some": true }, "timeout_frames": 240 },
    { "type": "assert", "window": { "kind": "first_seen" }, "predicate": { "kind": "dock_drop_resolved_zone_is", "zone": "top" } },
    {
      "type": "wait_until",
      "predicate": { "kind": "dock_drag_active_is", "active": false },
      "timeout_frames": 240
    },
    { "type": "capture_bundle", "label": "docking-arbitration-demo-multiwindow-chained-tearoff-two-tabs-merge-drop1" },
    { "type": "wait_frames", "n": 20 },
    {
      "type": "wait_until",
      "predicate": { "kind": "known_window_count_is", "n": 2 },
      "timeout_frames": 600
    },
    { "type": "wait_frames", "n": 2 },
    {
      "type": "capture_bundle",
      "label": "docking-arbitration-demo-multiwindow-chained-tearoff-two-tabs-merge-after-close1"
    },
    {
      "type": "wait_until",
      "window": { "kind": "first_seen" },
      "predicate": { "kind": "dock_graph_signature_contains", "needle": "demo.viewport.right" },
      "timeout_frames": 240
    },
    {
      "type": "wait_until",
      "window": { "kind": "last_seen" },
      "predicate": { "kind": "dock_graph_signature_contains", "needle": "demo.viewport.left" },
      "timeout_frames": 240
    },

    {
      "type": "wait_until",
      "window": { "kind": "first_seen_other" },
      "predicate": { "kind": "exists", "target": { "kind": "test_id", "id": "dock-arb-dock-space" } },
      "timeout_frames": 240
    },
    { "type": "set_window_outer_position", "window": { "kind": "first_seen_other" }, "x_px": 180.0, "y_px": 540.0 },
    { "type": "wait_frames", "n": 10 },

    { "type": "raise_window", "window": { "kind": "first_seen_other" } },
    { "type": "set_cursor_in_window", "window": { "kind": "first_seen_other" }, "x_px": 640.0, "y_px": 260.0 },
    { "type": "wait_frames", "n": 2 },
    {
      "type": "wait_until",
      "window": { "kind": "first_seen_other" },
      "predicate": { "kind": "exists", "target": { "kind": "test_id", "id": "dock-arb-tab-drag-anchor-left" } },
      "timeout_frames": 240
    },
    {
      "type": "pointer_down",
      "window": { "kind": "first_seen_other" },
      "target": { "kind": "test_id", "id": "dock-arb-tab-drag-anchor-left" }
    },
    { "type": "pointer_move", "window": { "kind": "first_seen_other" }, "delta_x": 120.0, "delta_y": 0.0, "steps": 24 },
    {
      "type": "wait_until",
      "window": { "kind": "first_seen_other" },
      "predicate": { "kind": "dock_drag_active_is", "active": true },
      "timeout_frames": 120
    },
    { "type": "wait_frames", "n": 2 },

    { "type": "raise_window", "window": { "kind": "first_seen" } },
    { "type": "wait_frames", "window": { "kind": "first_seen" }, "n": 2 },
    { "type": "wait_frames", "window": { "kind": "first_seen" }, "n": 2 },
    {
      "type": "move_pointer",
      "window": { "kind": "first_seen" },
      "target": { "kind": "test_id", "id": "dock-arb-viewport-right" }
    },
    { "type": "wait_frames", "n": 2 },
    {
      "type": "move_pointer",
      "window": { "kind": "first_seen" },
      "target": { "kind": "test_id", "id": "dock-arb-hint-inner-left" }
    },
    { "type": "wait_frames", "n": 2 },
    { "type": "wait_until", "window": { "kind": "first_seen" }, "predicate": { "kind": "dock_drag_current_window_is", "window": { "kind": "first_seen" } }, "timeout_frames": 240 },
    { "type": "pointer_up", "window": { "kind": "first_seen" } },
    { "type": "wait_until", "predicate": { "kind": "dock_drop_resolved_is_some", "some": true }, "timeout_frames": 240 },
    { "type": "assert", "window": { "kind": "first_seen" }, "predicate": { "kind": "dock_drop_resolved_zone_is", "zone": "left" } },
    {
      "type": "wait_until",
      "predicate": { "kind": "dock_drag_active_is", "active": false },
      "timeout_frames": 240
    },
    { "type": "capture_bundle", "label": "docking-arbitration-demo-multiwindow-chained-tearoff-two-tabs-merge-drop2" },
    {
      "type": "wait_until",
      "predicate": { "kind": "known_window_count_is", "n": 1 },
      "timeout_frames": 600
    },
    { "type": "wait_frames", "n": 2 },
    {
      "type": "capture_bundle",
      "label": "docking-arbitration-demo-multiwindow-chained-tearoff-two-tabs-merge-after-close2"
    },

    {
      "type": "wait_until",
      "window": { "kind": "first_seen" },
      "predicate": { "kind": "dock_graph_signature_contains", "needle": "demo.viewport.right" },
      "timeout_frames": 240
    },
    {
      "type": "wait_until",
      "window": { "kind": "first_seen" },
      "predicate": { "kind": "dock_graph_signature_contains", "needle": "demo.viewport.left" },
      "timeout_frames": 240
    },
    { "type": "wait_until", "window": { "kind": "first_seen" }, "predicate": { "kind": "dock_graph_canonical_is", "canonical": true }, "timeout_frames": 240 },
    {
      "type": "assert",
      "window": { "kind": "first_seen" },
      "predicate": { "kind": "dock_graph_signature_contains", "needle": "demo.viewport.left" }
    },
    {
      "type": "assert",
      "window": { "kind": "first_seen" },
      "predicate": { "kind": "dock_graph_signature_contains", "needle": "demo.viewport.right" }
    },
    {
      "type": "assert",
      "window": { "kind": "first_seen" },
      "predicate": { "kind": "dock_graph_signature_contains", "needle": "demo.controls" }
    },
    {
      "type": "assert",
      "window": { "kind": "first_seen" },
      "predicate": { "kind": "dock_graph_signature_contains", "needle": "floatings=[]" }
    },

    { "type": "capture_bundle", "label": "docking-arbitration-demo-multiwindow-chained-tearoff-two-tabs-merge" },
    { "type": "wait_frames", "n": 2 }
  ]
}
