{
  "meta": {
    "required_capabilities": [
      "diag.script_v2"
    ]
  },
  "schema_version": 2,
  "steps": [
    {
      "type": "wait_until",
      "timeout_frames": 600,
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-nav-search" }
      }
    },
    {
      "type": "click",
      "button": "left",
      "target": { "kind": "test_id", "id": "ui-gallery-nav-search" }
    },
    {
      "type": "press_key",
      "key": "a",
      "repeat": false,
      "modifiers": { "ctrl": true, "alt": false, "meta": false, "shift": false }
    },
    {
      "type": "press_key",
      "key": "backspace",
      "repeat": false,
      "modifiers": { "ctrl": false, "alt": false, "meta": false, "shift": false }
    },
    { "type": "type_text", "text": "select" },
    { "type": "wait_frames", "n": 2 },
    {
      "type": "click",
      "button": "left",
      "target": { "kind": "test_id", "id": "ui-gallery-nav-select" }
    },
    {
      "type": "wait_until",
      "timeout_frames": 600,
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-page-select" }
      }
    },
    {
      "type": "wait_until",
      "timeout_frames": 600,
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-select-demo-tabs-trigger-code" }
      }
    },
    {
      "type": "wait_until",
      "timeout_frames": 600,
      "predicate": {
        "kind": "bounds_min_size",
        "target": { "kind": "test_id", "id": "ui-gallery-select-demo-tabs-shared-indicator" },
        "min_w_px": 40.0,
        "min_h_px": 20.0,
        "eps_px": 0.5
      }
    },
    {
      "type": "click",
      "button": "left",
      "target": { "kind": "test_id", "id": "ui-gallery-select-demo-tabs-trigger-code" }
    },
    { "type": "wait_frames", "n": 12 },
    {
      "type": "assert",
      "predicate": {
        "kind": "bounds_overlapping",
        "a": { "kind": "test_id", "id": "ui-gallery-select-demo-tabs-shared-indicator" },
        "b": { "kind": "test_id", "id": "ui-gallery-select-demo-tabs-trigger-code" },
        "eps_px": 1.0
      }
    },
    {
      "type": "capture_bundle",
      "label": "ui-gallery-select-demo-tabs-indicator-follows-selection"
    }
  ]
}

