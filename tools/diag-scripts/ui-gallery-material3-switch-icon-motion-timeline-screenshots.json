{
  "schema_version": 2,
  "meta": {
    "name": "ui-gallery-material3-switch-icon-motion-timeline-screenshots",
    "required_capabilities": ["diag.script_v2", "diag.screenshot_png"],
    "tags": ["ui_gallery", "material3", "switch", "icons", "motion", "timeline", "screenshots"]
  },
  "steps": [
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-nav-search" }
      },
      "timeout_frames": 600
    },
    { "type": "click", "target": { "kind": "test_id", "id": "ui-gallery-nav-search" } },
    { "type": "press_key", "key": "a", "modifiers": { "ctrl": true } },
    { "type": "press_key", "key": "backspace" },
    { "type": "type_text", "text": "switch" },
    { "type": "wait_frames", "n": 2 },
    {
      "type": "ensure_visible",
      "target": { "kind": "test_id", "id": "ui-gallery-nav-material3-switch" },
      "within_window": true,
      "padding_px": 8.0,
      "timeout_frames": 600
    },
    { "type": "click", "target": { "kind": "test_id", "id": "ui-gallery-nav-material3-switch" } },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-page-material3-switch" }
      },
      "timeout_frames": 600
    },
    { "type": "wait_frames", "n": 20 },

    {
      "type": "wait_until",
      "predicate": {
        "kind": "checked_is",
        "target": { "kind": "test_id", "id": "ui-gallery-material3-switch-icons-both" },
        "checked": false
      },
      "timeout_frames": 600
    },

    { "type": "capture_screenshot", "label": "m3-switch-icons-both-00-off" },
    { "type": "click", "target": { "kind": "test_id", "id": "ui-gallery-material3-switch-icons-both" } },
    { "type": "capture_screenshot", "label": "m3-switch-icons-both-10-on-frame0" },
    { "type": "wait_frames", "n": 1 },
    { "type": "capture_screenshot", "label": "m3-switch-icons-both-11-on-frame1" },
    { "type": "wait_frames", "n": 1 },
    { "type": "capture_screenshot", "label": "m3-switch-icons-both-12-on-frame2" },
    { "type": "wait_frames", "n": 1 },
    { "type": "capture_screenshot", "label": "m3-switch-icons-both-13-on-frame3" },
    { "type": "wait_frames", "n": 1 },
    { "type": "capture_screenshot", "label": "m3-switch-icons-both-14-on-frame4" },
    { "type": "wait_frames", "n": 6 },
    { "type": "capture_screenshot", "label": "m3-switch-icons-both-15-on-rest" },

    {
      "type": "wait_until",
      "predicate": {
        "kind": "checked_is",
        "target": { "kind": "test_id", "id": "ui-gallery-material3-switch-icons-both" },
        "checked": true
      },
      "timeout_frames": 600
    },

    { "type": "click", "target": { "kind": "test_id", "id": "ui-gallery-material3-switch-icons-both" } },
    { "type": "capture_screenshot", "label": "m3-switch-icons-both-20-off-frame0" },
    { "type": "wait_frames", "n": 1 },
    { "type": "capture_screenshot", "label": "m3-switch-icons-both-21-off-frame1" },
    { "type": "wait_frames", "n": 1 },
    { "type": "capture_screenshot", "label": "m3-switch-icons-both-22-off-frame2" },
    { "type": "wait_frames", "n": 1 },
    { "type": "capture_screenshot", "label": "m3-switch-icons-both-23-off-frame3" },
    { "type": "wait_frames", "n": 1 },
    { "type": "capture_screenshot", "label": "m3-switch-icons-both-24-off-frame4" },
    { "type": "wait_frames", "n": 6 },
    { "type": "capture_screenshot", "label": "m3-switch-icons-both-25-off-rest" },

    {
      "type": "wait_until",
      "predicate": {
        "kind": "checked_is",
        "target": { "kind": "test_id", "id": "ui-gallery-material3-switch-icons-selected-only" },
        "checked": false
      },
      "timeout_frames": 600
    },

    { "type": "capture_screenshot", "label": "m3-switch-icons-selected-only-00-off" },
    { "type": "click", "target": { "kind": "test_id", "id": "ui-gallery-material3-switch-icons-selected-only" } },

    { "type": "capture_screenshot", "label": "m3-switch-icons-selected-only-10-on-frame0" },
    { "type": "wait_frames", "n": 1 },
    { "type": "capture_screenshot", "label": "m3-switch-icons-selected-only-11-on-frame1" },
    { "type": "wait_frames", "n": 1 },
    { "type": "capture_screenshot", "label": "m3-switch-icons-selected-only-12-on-frame2" },
    { "type": "wait_frames", "n": 1 },
    { "type": "capture_screenshot", "label": "m3-switch-icons-selected-only-13-on-frame3" },
    { "type": "wait_frames", "n": 1 },
    { "type": "capture_screenshot", "label": "m3-switch-icons-selected-only-14-on-frame4" },
    { "type": "wait_frames", "n": 6 },
    { "type": "capture_screenshot", "label": "m3-switch-icons-selected-only-15-on-rest" },

    {
      "type": "wait_until",
      "predicate": {
        "kind": "checked_is",
        "target": { "kind": "test_id", "id": "ui-gallery-material3-switch-icons-selected-only" },
        "checked": true
      },
      "timeout_frames": 600
    },

    { "type": "click", "target": { "kind": "test_id", "id": "ui-gallery-material3-switch-icons-selected-only" } },
    { "type": "capture_screenshot", "label": "m3-switch-icons-selected-only-20-off-frame0" },
    { "type": "wait_frames", "n": 1 },
    { "type": "capture_screenshot", "label": "m3-switch-icons-selected-only-21-off-frame1" },
    { "type": "wait_frames", "n": 1 },
    { "type": "capture_screenshot", "label": "m3-switch-icons-selected-only-22-off-frame2" },
    { "type": "wait_frames", "n": 1 },
    { "type": "capture_screenshot", "label": "m3-switch-icons-selected-only-23-off-frame3" },
    { "type": "wait_frames", "n": 1 },
    { "type": "capture_screenshot", "label": "m3-switch-icons-selected-only-24-off-frame4" },
    { "type": "wait_frames", "n": 6 },
    { "type": "capture_screenshot", "label": "m3-switch-icons-selected-only-25-off-rest" },

    { "type": "capture_bundle", "label": "ui-gallery-material3-switch-icon-motion-timeline" }
  ]
}

