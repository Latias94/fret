{
  "schema_version": 2,
  "meta": {
    "notes": [
      "Liquid glass lens corner screenshots (Fake only, Warp v1 only, Custom v2 only).",
      "Relies on stable defaults in LiquidGlassState::init: fake=true, warp_v1=true, warp_v2=false, custom_v2=false."
    ]
  },
  "steps": [
    { "type": "set_window_inner_size", "width_px": 1280.0, "height_px": 720.0 },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "liquid-glass-switch-show-custom-v2" }
      },
      "timeout_frames": 600
    },

    { "type": "reset_diagnostics" },

    { "type": "click_stable", "target": { "kind": "test_id", "id": "liquid-glass-switch-show-warp-v1" }, "stable_frames": 6, "max_move_px": 0.5, "timeout_frames": 600 },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "liquid-glass-lens-fake" }
      },
      "timeout_frames": 600
    },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "not_exists",
        "target": { "kind": "test_id", "id": "liquid-glass-lens-warp-v1" }
      },
      "timeout_frames": 600
    },
    { "type": "wait_frames", "n": 30 },
    { "type": "capture_screenshot", "label": "liquid-glass-lens-fake-corners" },

    { "type": "click_stable", "target": { "kind": "test_id", "id": "liquid-glass-switch-show-fake" }, "stable_frames": 6, "max_move_px": 0.5, "timeout_frames": 600 },
    { "type": "click_stable", "target": { "kind": "test_id", "id": "liquid-glass-switch-show-warp-v1" }, "stable_frames": 6, "max_move_px": 0.5, "timeout_frames": 600 },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "liquid-glass-lens-warp-v1" }
      },
      "timeout_frames": 600
    },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "not_exists",
        "target": { "kind": "test_id", "id": "liquid-glass-lens-fake" }
      },
      "timeout_frames": 600
    },
    { "type": "wait_frames", "n": 30 },
    { "type": "capture_screenshot", "label": "liquid-glass-lens-warp-v1-corners" },

    { "type": "click_stable", "target": { "kind": "test_id", "id": "liquid-glass-switch-show-warp-v1" }, "stable_frames": 6, "max_move_px": 0.5, "timeout_frames": 600 },
    { "type": "click_stable", "target": { "kind": "test_id", "id": "liquid-glass-switch-show-custom-v2" }, "stable_frames": 6, "max_move_px": 0.5, "timeout_frames": 600 },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "liquid-glass-lens-custom-v2" }
      },
      "timeout_frames": 600
    },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "not_exists",
        "target": { "kind": "test_id", "id": "liquid-glass-lens-warp-v1" }
      },
      "timeout_frames": 600
    },
    { "type": "wait_frames", "n": 30 },
    { "type": "capture_screenshot", "label": "liquid-glass-lens-custom-v2-corners" },

    { "type": "wait_frames", "n": 2 }
  ]
}
