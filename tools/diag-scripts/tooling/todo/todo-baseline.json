{
  "schema_version": 2,
  "steps": [
    {
      "button": "left",
      "target": {
        "id": "todo_demo.draft",
        "kind": "test_id"
      },
      "type": "click"
    },
    {
      "text": "自动化任务",
      "type": "type_text"
    },
    {
      "n": 2,
      "type": "wait_frames"
    },
    {
      "key": "enter",
      "modifiers": {
        "alt": false,
        "ctrl": false,
        "meta": false,
        "shift": false
      },
      "repeat": false,
      "type": "press_key"
    },
    {
      "predicate": {
        "kind": "exists",
        "target": {
          "id": "todo_demo.row.4",
          "kind": "test_id"
        }
      },
      "timeout_frames": 60,
      "type": "wait_until"
    },
    {
      "label": "todo-after-add",
      "type": "capture_bundle"
    },
    {
      "button": "left",
      "target": {
        "id": "todo_demo.done.4",
        "kind": "test_id"
      },
      "type": "click"
    },
    {
      "n": 2,
      "type": "wait_frames"
    },
    {
      "label": "todo-after-toggle-done",
      "type": "capture_bundle"
    },
    {
      "button": "left",
      "target": {
        "id": "todo_demo.remove.4",
        "kind": "test_id"
      },
      "type": "click"
    },
    {
      "n": 2,
      "type": "wait_frames"
    },
    {
      "label": "todo-after-remove",
      "type": "capture_bundle"
    }
  ]
}
