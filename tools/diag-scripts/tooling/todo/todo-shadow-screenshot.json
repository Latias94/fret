{
  "schema_version": 2,
  "meta": {
    "name": "Todo demo shadow screenshot",
    "tags": ["todo_demo", "shadow", "screenshot"],
    "required_capabilities": ["diag.script_v2", "diag.screenshot_png"]
  },
  "steps": [
    { "type": "reset_diagnostics" },
    { "type": "set_window_inner_size", "width_px": 680.0, "height_px": 760.0 },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "todo_demo.root" }
      },
      "timeout_frames": 600
    },
    { "type": "wait_frames", "n": 12 },
    { "type": "capture_bundle", "label": "todo-demo-shadow" },
    { "type": "capture_screenshot", "label": "todo-demo-shadow" }
  ]
}
