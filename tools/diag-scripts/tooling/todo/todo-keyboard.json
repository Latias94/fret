{
  "schema_version": 1,
  "steps": [
    { "type": "click", "target": { "kind": "test_id", "id": "todo_demo.draft" } },
    { "type": "type_text", "text": "键盘任务" },
    { "type": "wait_frames", "n": 2 },
    { "type": "press_key", "key": "enter" },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "todo_demo.row.4" }
      },
      "timeout_frames": 60
    },
    { "type": "wait_frames", "n": 2 },
    { "type": "capture_bundle", "label": "todo-before-toggle" },
    { "type": "capture_screenshot", "label": "todo-before-toggle" },
    { "type": "click", "target": { "kind": "test_id", "id": "todo_demo.done.4" } },
    { "type": "wait_frames", "n": 2 },
    { "type": "capture_bundle", "label": "todo-after-toggle" },
    { "type": "capture_screenshot", "label": "todo-after-toggle" },
    { "type": "click", "target": { "kind": "test_id", "id": "todo_demo.remove.4" } },
    { "type": "wait_frames", "n": 2 },
    { "type": "capture_bundle", "label": "todo-after-delete" },
    { "type": "capture_screenshot", "label": "todo-after-delete" }
  ]
}
