{
  "schema_version": 2,
  "meta": {
    "name": "todo: memory steady (wgpu high frequency report)",
    "tags": ["todo", "memory", "steady", "wgpu", "highfreq"],
    "required_capabilities": ["diag.script_v2"],
    "target_hints": [
      "Same as todo-memory-steady, but samples wgpu allocator/hub stats every 60 frames.",
      "This can perturb Metal/driver allocations; use for attribution deep-dives, not for stable baselines."
    ],
    "env_defaults": {
      "FRET_DIAG_WGPU_ALLOCATOR_REPORT": 1,
      "FRET_DIAG_WGPU_ALLOCATOR_REPORT_EVERY_N_FRAMES": 60,
      "FRET_DIAG_WGPU_REPORT": 1,
      "FRET_DIAG_WGPU_REPORT_EVERY_N_FRAMES": 60
    }
  },
  "steps": [
    { "type": "reset_diagnostics" },
    { "type": "wait_frames", "n": 10 },

    { "type": "click", "target": { "kind": "test_id", "id": "todo_demo.draft" } },
    { "type": "type_text", "text": "steady-state memory sample" },
    { "type": "wait_frames", "n": 2 },
    { "type": "press_key", "key": "enter" },
    {
      "type": "wait_until",
      "predicate": { "kind": "exists", "target": { "kind": "test_id", "id": "todo_demo.row.4" } },
      "timeout_frames": 120
    },

    { "type": "reset_diagnostics" },
    { "type": "wait_frames", "n": 600 },
    { "type": "capture_bundle", "label": "todo-memory-steady" }
  ]
}
