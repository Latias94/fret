{
  "schema_version": 2,
  "meta": {
    "name": "Todo resize drag jitter steady",
    "tags": ["todo_demo", "resize", "drag_jitter", "steady"],
    "required_capabilities": ["diag.script_v2", "diag.screenshot_png"]
  },
  "steps": [
    { "type": "set_window_inner_size", "width_px": 980.0, "height_px": 720.0 },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "todo_demo.root" }
      },
      "timeout_frames": 600
    },
    { "type": "wait_frames", "n": 12 },
    { "type": "reset_diagnostics" },

    { "type": "set_window_inner_size", "width_px": 980.0, "height_px": 720.0 },
    { "type": "wait_frames", "n": 1 },
    {
      "type": "assert",
      "predicate": {
        "kind": "bounds_within_window",
        "target": { "kind": "test_id", "id": "todo_demo.root" },
        "padding_px": 0.0,
        "eps_px": 1.0
      }
    },
