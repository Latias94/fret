{
  "schema_version": 2,
  "meta": {
    "name": "hello_world_compare: layout-model memory steady",
    "tags": [
      "hello-world",
      "compare",
      "layout-model",
      "memory",
      "steady"
    ],
    "required_capabilities": [
      "diag.script_v2"
    ],
    "target_hints": [
      "Captures a steady-state bundle while the compare demo mutates layout-affecting state each frame."
    ],
    "env_defaults": {
      "FRET_DIAG_WGPU_ALLOCATOR_REPORT": 1,
      "FRET_DIAG_WGPU_ALLOCATOR_REPORT_EVERY_N_FRAMES": 600,
      "FRET_DIAG_WGPU_REPORT": 1,
      "FRET_DIAG_WGPU_REPORT_EVERY_N_FRAMES": 600,
      "FRET_HELLO_WORLD_COMPARE_ACTIVE_MODE": "layout-model"
    }
  },
  "steps": [
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": {
          "kind": "test_id",
          "id": "hello_world_compare.root"
        }
      },
      "timeout_frames": 600
    },
    {
      "type": "reset_diagnostics"
    },
    {
      "type": "wait_frames",
      "n": 10
    },
    {
      "type": "reset_diagnostics"
    },
    {
      "type": "wait_frames",
      "n": 600
    },
    {
      "type": "capture_bundle",
      "label": "hello-world-compare-active-memory-steady"
    }
  ]
}
