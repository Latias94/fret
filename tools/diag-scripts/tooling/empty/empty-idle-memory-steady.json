{
  "schema_version": 2,
  "meta": {
    "name": "empty: idle memory steady",
    "tags": ["empty", "memory", "steady"],
    "required_capabilities": ["diag.script_v2"],
    "target_hints": ["Captures a steady-state bundle after a short warmup window."]
