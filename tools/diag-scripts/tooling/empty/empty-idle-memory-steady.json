{
  "schema_version": 2,
  "meta": {
    "name": "empty: idle memory steady",
    "tags": ["empty", "memory", "steady"],
    "required_capabilities": ["diag.script_v2"],
    "target_hints": ["Captures a steady-state bundle after a short warmup window."],
    "env_defaults": {
      "FRET_DIAG_WGPU_ALLOCATOR_REPORT": 1,
      "FRET_DIAG_WGPU_ALLOCATOR_REPORT_EVERY_N_FRAMES": 600,
      "FRET_DIAG_WGPU_REPORT": 1,
      "FRET_DIAG_WGPU_REPORT_EVERY_N_FRAMES": 600
    }
  },
  "steps": [
    { "type": "reset_diagnostics" },
    { "type": "wait_frames", "n": 10 },

    { "type": "reset_diagnostics" },
    { "type": "wait_frames", "n": 600 },
    { "type": "capture_bundle", "label": "empty-idle-memory-steady" }
  ]
}
