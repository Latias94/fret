{
  "schema_version": 2,
  "meta": {
    "name": "empty: idle memory steady (surface latency 1)",
    "tags": ["empty", "memory", "steady", "attribution"],
    "required_capabilities": ["diag.script_v2"],
    "target_hints": [
      "Captures a steady-state bundle after a short warmup window.",
      "Overrides SurfaceConfiguration.desired_maximum_frame_latency to 1 to probe swapchain/backbuffer pressure."
    ],
    "env_defaults": {
      "FRET_DIAG_WGPU_ALLOCATOR_REPORT": 1,
      "FRET_DIAG_WGPU_ALLOCATOR_REPORT_EVERY_N_FRAMES": 600,
      "FRET_DIAG_WGPU_REPORT": 1,
      "FRET_DIAG_WGPU_REPORT_EVERY_N_FRAMES": 600,
      "FRET_RENDER_WGPU_SURFACE_DESIRED_MAX_FRAME_LATENCY": 1
    }
  },
  "steps": [
    { "type": "reset_diagnostics" },
    { "type": "wait_frames", "n": 10 },

    { "type": "reset_diagnostics" },
    { "type": "wait_frames", "n": 600 },
    { "type": "capture_bundle", "label": "empty-idle-memory-steady-latency1" }
  ]
}

