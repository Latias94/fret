{
  "meta": {
    "name": "ui-gallery-material3-time-picker-chrome-fill",
    "required_capabilities": ["diag.script_v2"]
  },
  "schema_version": 2,
  "steps": [
    { "type": "reset_diagnostics" },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-nav-search" }
      },
      "timeout_frames": 600
    },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-nav-scroll" }
      },
      "timeout_frames": 600
    },
    { "type": "press_key", "key": "escape" },
    { "type": "wait_frames", "n": 2 },

    { "type": "set_window_inner_size", "width_px": 1280.0, "height_px": 720.0 },
    { "type": "wait_frames", "n": 15 },

    { "type": "click", "target": { "kind": "test_id", "id": "ui-gallery-nav-search" } },
    { "type": "press_key", "key": "a", "modifiers": { "ctrl": true } },
    { "type": "press_key", "key": "backspace" },
    { "type": "type_text", "text": "material3 time picker" },
    { "type": "wait_frames", "n": 2 },

    {
      "type": "scroll_into_view",
      "container": { "kind": "test_id", "id": "ui-gallery-nav-scroll" },
      "target": { "kind": "test_id", "id": "ui-gallery-nav-material3-time-picker" },
      "delta_y": -240.0,
      "timeout_frames": 600
    },
    {
      "type": "click",
      "target": { "kind": "test_id", "id": "ui-gallery-nav-material3-time-picker" }
    },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-page-material3-time-picker" }
      },
      "timeout_frames": 600
    },

    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-material3-time-picker-open" }
      },
      "timeout_frames": 600
    },
    { "type": "click", "target": { "kind": "test_id", "id": "ui-gallery-material3-time-picker-open" } },
    { "type": "wait_frames", "n": 20 },

    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-material3-time-picker-scrim" }
      },
      "timeout_frames": 600
    },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-material3-time-picker-scrim.chrome" }
      },
      "timeout_frames": 600
    },
    {
      "type": "assert",
      "predicate": {
        "kind": "bounds_approx_equal",
        "a": { "kind": "test_id", "id": "ui-gallery-material3-time-picker-scrim" },
        "b": { "kind": "test_id", "id": "ui-gallery-material3-time-picker-scrim.chrome" },
        "eps_px": 1.0
      }
    },

    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "time-picker-clock-dial" }
      },
      "timeout_frames": 600
    },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "time-picker-clock-dial.chrome" }
      },
      "timeout_frames": 600
    },
    {
      "type": "assert",
      "predicate": {
        "kind": "bounds_approx_equal",
        "a": { "kind": "test_id", "id": "time-picker-clock-dial" },
        "b": { "kind": "test_id", "id": "time-picker-clock-dial.chrome" },
        "eps_px": 1.0
      }
    },

    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "time-picker-hour-selector" }
      },
      "timeout_frames": 600
    },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "time-picker-hour-selector.chrome" }
      },
      "timeout_frames": 600
    },
    {
      "type": "assert",
      "predicate": {
        "kind": "bounds_approx_equal",
        "a": { "kind": "test_id", "id": "time-picker-hour-selector" },
        "b": { "kind": "test_id", "id": "time-picker-hour-selector.chrome" },
        "eps_px": 1.0
      }
    },

    {
      "type": "capture_bundle",
      "label": "ui-gallery-material3-time-picker-chrome-fill"
    }
  ]
}

