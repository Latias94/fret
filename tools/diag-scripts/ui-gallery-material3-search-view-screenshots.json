{
  "schema_version": 2,
  "steps": [
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-page-material3-state-matrix" }
      },
      "timeout_frames": 600
    },
    { "type": "wait_frames", "n": 30 },

    {
      "type": "ensure_visible",
      "target": { "kind": "test_id", "id": "ui-gallery-material3-search-view" },
      "within_window": true,
      "padding_px": 8.0,
      "timeout_frames": 600
    },
    { "type": "click", "target": { "kind": "test_id", "id": "ui-gallery-material3-search-view" } },

    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-material3-search-view-panel" }
      },
      "timeout_frames": 600
    },
    { "type": "wait_frames", "n": 20 },

    { "type": "capture_bundle", "label": "ui-gallery-material3-search-view-open" },
    { "type": "capture_screenshot", "label": "ui-gallery-material3-search-view-open" },

    { "type": "press_key", "key": "escape" },
    { "type": "wait_frames", "n": 20 },

    { "type": "capture_bundle", "label": "ui-gallery-material3-search-view-closed" },
    { "type": "capture_screenshot", "label": "ui-gallery-material3-search-view-closed" }
  ]
}

