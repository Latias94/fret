{
  "schema_version": 2,
  "meta": {
    "name": "Cookbook: theme_switching_basics screenshots",
    "tags": ["cookbook", "theme_switching_basics", "theme", "smoke", "screenshots"],
    "required_capabilities": ["diag.script_v2", "diag.screenshot_png"],
    "target_hints": [
      "Waits for the example root to exist.",
      "Captures Light and Dark screenshots + bundle."
    ]
  },
  "steps": [
    { "type": "reset_diagnostics" },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "cookbook.theme_switching_basics.root" }
      },
      "timeout_frames": 600
    },
    { "type": "wait_frames", "n": 10 },
    { "type": "capture_screenshot", "label": "cookbook-theme-switching-basics-light" },
    { "type": "click_stable", "target": { "kind": "test_id", "id": "cookbook.theme_switching_basics.toggle" } },
    { "type": "wait_frames", "n": 20 },
    { "type": "capture_screenshot", "label": "cookbook-theme-switching-basics-dark" },
    { "type": "capture_bundle", "label": "cookbook-theme-switching-basics-screenshots" }
  ]
}

