{
  "schema_version": 2,
  "meta": {
    "name": "cookbook-canvas-pan-zoom-basics-smoke",
    "required_capabilities": ["diag.script_v2", "diag.screenshot_png"],
    "tags": ["cookbook", "canvas", "pan_zoom", "smoke"]
  },
  "steps": [
    { "type": "reset_diagnostics" },
    { "type": "set_window_inner_size", "width_px": 1120.0, "height_px": 780.0 },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "cookbook.canvas_pan_zoom_basics.root" }
      },
      "timeout_frames": 240
    },
    { "type": "wait_frames", "n": 10 },
    { "type": "capture_screenshot", "label": "cookbook-canvas-pan-zoom-basics-before" },
    {
      "type": "drag_pointer",
      "target": { "kind": "test_id", "id": "cookbook.canvas_pan_zoom_basics.canvas" },
      "button": "middle",
      "delta_x": 180.0,
      "delta_y": 120.0,
      "steps": 12
    },
    { "type": "wait_frames", "n": 5 },
    {
      "type": "wheel",
      "target": { "kind": "test_id", "id": "cookbook.canvas_pan_zoom_basics.canvas" },
      "delta_x": 0.0,
      "delta_y": -240.0
    },
    { "type": "wait_frames", "n": 5 },
    {
      "type": "drag_pointer",
      "target": { "kind": "test_id", "id": "cookbook.canvas_pan_zoom_basics.canvas" },
      "button": "left",
      "delta_x": 140.0,
      "delta_y": 0.0,
      "steps": 10
    },
    { "type": "wait_frames", "n": 10 },
    { "type": "capture_screenshot", "label": "cookbook-canvas-pan-zoom-basics-after" },
    { "type": "capture_bundle", "label": "cookbook-canvas-pan-zoom-basics-smoke" }
  ]
}

