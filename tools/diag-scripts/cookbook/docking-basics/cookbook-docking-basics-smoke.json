{
  "schema_version": 2,
  "meta": {
    "name": "cookbook-docking-basics-smoke",
    "required_capabilities": ["diag.script_v2", "diag.screenshot_png"],
    "tags": ["cookbook", "docking", "interop", "smoke"]
  },
  "steps": [
    { "type": "reset_diagnostics" },
    { "type": "set_window_inner_size", "width_px": 1120.0, "height_px": 780.0 },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "cookbook.docking_basics.root" }
      },
      "timeout_frames": 240
    },
    { "type": "wait_frames", "n": 10 },
    { "type": "click", "target": { "kind": "test_id", "id": "cookbook.docking_basics.activate_hierarchy" } },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "semantics_numeric_approx_eq",
        "target": { "kind": "test_id", "id": "cookbook.docking_basics.active_left" },
        "field": "value",
        "value": 0.0,
        "eps": 0.01
      },
      "timeout_frames": 240
    },
    { "type": "click", "target": { "kind": "test_id", "id": "cookbook.docking_basics.activate_inspector" } },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "semantics_numeric_approx_eq",
        "target": { "kind": "test_id", "id": "cookbook.docking_basics.active_left" },
        "field": "value",
        "value": 1.0,
        "eps": 0.01
      },
      "timeout_frames": 240
    },
    { "type": "click", "target": { "kind": "test_id", "id": "cookbook.docking_basics.activate_editor" } },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "semantics_numeric_approx_eq",
        "target": { "kind": "test_id", "id": "cookbook.docking_basics.active_right" },
        "field": "value",
        "value": 0.0,
        "eps": 0.01
      },
      "timeout_frames": 240
    },
    { "type": "click", "target": { "kind": "test_id", "id": "cookbook.docking_basics.activate_console" } },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "semantics_numeric_approx_eq",
        "target": { "kind": "test_id", "id": "cookbook.docking_basics.active_right" },
        "field": "value",
        "value": 1.0,
        "eps": 0.01
      },
      "timeout_frames": 240
    },
    { "type": "capture_screenshot", "label": "cookbook-docking-basics-smoke" },
    { "type": "capture_bundle", "label": "cookbook-docking-basics-smoke" }
  ]
}
