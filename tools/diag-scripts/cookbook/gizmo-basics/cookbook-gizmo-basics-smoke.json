{
  "schema_version": 2,
  "meta": {
    "name": "cookbook-gizmo-basics-smoke",
    "required_capabilities": ["diag.script_v2", "diag.screenshot_png"],
    "tags": ["cookbook", "gizmo", "viewport", "smoke"],
    "target_hints": [
      "Waits for the root to exist.",
      "Performs a simple pointer drag + wheel interaction over the viewport.",
      "Verifies the position-length numeric semantics are present (reset returns to ~0).",
      "Captures a screenshot + bundle."
    ]
  },
  "steps": [
    { "type": "reset_diagnostics" },
    { "type": "set_window_inner_size", "width_px": 1120.0, "height_px": 780.0 },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "cookbook.gizmo_basics.root" }
      },
      "timeout_frames": 600
    },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "semantics_numeric_approx_eq",
        "target": { "kind": "test_id", "id": "cookbook.gizmo_basics.pos_len" },
        "field": "value",
        "value": 0.0,
        "eps": 0.0001
      },
      "timeout_frames": 240
    },
    { "type": "move_pointer", "target": { "kind": "test_id", "id": "cookbook.gizmo_basics.viewport" } },
    {
      "type": "drag_pointer",
      "target": { "kind": "test_id", "id": "cookbook.gizmo_basics.viewport" },
      "button": "left",
      "delta_x": 180.0,
      "delta_y": 20.0,
      "steps": 12
    },
    {
      "type": "wheel",
      "target": { "kind": "test_id", "id": "cookbook.gizmo_basics.viewport" },
      "delta_y": -240.0
    },
    { "type": "wait_frames", "n": 10 },
    { "type": "click_stable", "target": { "kind": "test_id", "id": "cookbook.gizmo_basics.reset" } },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "semantics_numeric_approx_eq",
        "target": { "kind": "test_id", "id": "cookbook.gizmo_basics.pos_len" },
        "field": "value",
        "value": 0.0,
        "eps": 0.0001
      },
      "timeout_frames": 240
    },
    { "type": "wait_frames", "n": 10 },
    { "type": "capture_screenshot", "label": "cookbook-gizmo-basics-smoke" },
    { "type": "capture_bundle", "label": "cookbook-gizmo-basics-smoke" }
  ]
}
