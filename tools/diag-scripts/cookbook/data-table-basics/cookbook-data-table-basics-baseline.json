{
  "schema_version": 2,
  "meta": {
    "name": "cookbook data table: baseline",
    "tags": ["cookbook", "cookbook.data_table_basics", "table", "screenshots"],
    "required_capabilities": ["diag.script_v2", "diag.screenshot_png"],
    "target_hints": [
      "Waits for the root + table slot to exist.",
      "Captures a baseline screenshot + bundle."
    ]
  },
  "steps": [
    { "type": "reset_diagnostics" },
    { "type": "set_window_inner_size", "width_px": 1180.0, "height_px": 820.0 },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "cookbook.data_table_basics.root" }
      },
      "timeout_frames": 600
    },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "cookbook.data_table_basics.table" }
      },
      "timeout_frames": 600
    },
    { "type": "wait_frames", "n": 30 },
    { "type": "capture_screenshot", "label": "cookbook-data-table-basics-baseline" },
    { "type": "capture_bundle", "label": "cookbook-data-table-basics-baseline" }
  ]
}

