{
  "schema_version": 2,
  "meta": {
    "name": "cookbook drop shadow: baseline",
    "tags": ["cookbook", "cookbook.drop_shadow_basics", "renderer", "screenshots"],
    "required_capabilities": ["diag.script_v2", "diag.screenshot_png"],
    "target_hints": [
      "Waits for the root to exist, then captures a baseline screenshot + bundle."
    ]
  },
  "steps": [
    { "type": "reset_diagnostics" },
    { "type": "set_window_inner_size", "width_px": 1280.0, "height_px": 860.0 },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "cookbook.drop_shadow_basics.root" }
      },
      "timeout_frames": 600
    },
    { "type": "wait_frames", "n": 30 },
    { "type": "capture_screenshot", "label": "cookbook-drop-shadow-basics-baseline" },
    { "type": "capture_bundle", "label": "cookbook-drop-shadow-basics-baseline" }
  ]
}

