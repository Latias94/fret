{
  "schema_version": 2,
  "meta": {
    "name": "Cookbook: query basics baseline",
    "tags": ["cookbook", "cookbook.query_basics", "query", "screenshots", "smoke"],
    "required_capabilities": ["diag.script_v2", "diag.screenshot_png"],
    "target_hints": [
      "Waits for the root to exist.",
      "Waits for the query to reach Success and show stable demo text.",
      "Captures a baseline screenshot + bundle."
    ]
  },
  "steps": [
    { "type": "reset_diagnostics" },
    { "type": "set_window_inner_size", "width_px": 720.0, "height_px": 420.0 },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "cookbook.query_basics.root" }
      },
      "timeout_frames": 600
    },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "label_contains",
        "target": { "kind": "test_id", "id": "cookbook.query_basics.status.badge" },
        "text": "Success"
      },
      "timeout_frames": 600
    },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "label_contains",
        "target": { "kind": "test_id", "id": "cookbook.query_basics.data.line" },
        "text": "Hello from fret-query."
      },
      "timeout_frames": 240
    },
    { "type": "capture_screenshot", "label": "cookbook-query-basics-baseline" },
    { "type": "capture_bundle", "label": "cookbook-query-basics-baseline" }
  ]
}

