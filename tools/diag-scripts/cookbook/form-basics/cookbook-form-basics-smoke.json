{
  "schema_version": 2,
  "meta": {
    "name": "cookbook-form-basics-smoke",
    "required_capabilities": ["diag.script_v2", "diag.screenshot_png"],
    "tags": ["cookbook", "form_basics", "validation", "smoke"]
  },
  "steps": [
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "cookbook.form_basics.root" }
      },
      "timeout_frames": 240
    },
    { "type": "click", "target": { "kind": "test_id", "id": "cookbook.form_basics.name" } },
    {
      "type": "type_text_into",
      "target": { "kind": "test_id", "id": "cookbook.form_basics.name" },
      "text": "Jane Doe"
    },
    { "type": "click", "target": { "kind": "test_id", "id": "cookbook.form_basics.email" } },
    {
      "type": "type_text_into",
      "target": { "kind": "test_id", "id": "cookbook.form_basics.email" },
      "text": "jane@example.com"
    },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "semantics_numeric_approx_eq",
        "target": { "kind": "test_id", "id": "cookbook.form_basics.valid" },
        "field": "value",
        "value": 1.0,
        "eps": 0.01
      },
      "timeout_frames": 240
    },
    { "type": "click", "target": { "kind": "test_id", "id": "cookbook.form_basics.reset" } },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "semantics_numeric_approx_eq",
        "target": { "kind": "test_id", "id": "cookbook.form_basics.valid" },
        "field": "value",
        "value": 0.0,
        "eps": 0.01
      },
      "timeout_frames": 240
    },
    { "type": "capture_screenshot", "label": "cookbook-form-basics-smoke" },
    { "type": "capture_bundle", "label": "cookbook-form-basics-smoke" }
  ]
}

