{
  "schema_version": 2,
  "meta": {
    "name": "cookbook-toast-basics-smoke",
    "required_capabilities": ["diag.script_v2", "diag.screenshot_png"],
    "tags": ["cookbook", "toast_basics", "sonner", "smoke"]
  },
  "steps": [
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "cookbook.toast_basics.root" }
      },
      "timeout_frames": 240
    },
    {
      "type": "click",
      "target": { "kind": "test_id", "id": "cookbook.toast_basics.default" }
    },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "toast-entry-1" }
      },
      "timeout_frames": 240
    },
    { "type": "capture_screenshot", "label": "cookbook-toast-basics-smoke" },
    { "type": "capture_bundle", "label": "cookbook-toast-basics-smoke" }
  ]
}

