{
  "schema_version": 2,
  "steps": [
    { "type": "press_key", "key": "escape" },
    { "type": "wait_frames", "n": 2 },

    { "type": "set_window_inner_size", "width_px": 1280.0, "height_px": 720.0 },

    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "node_graph.canvas" }
      },
      "timeout_frames": 600
    },

    { "type": "wait_frames", "n": 8 },
    { "type": "reset_diagnostics" },
    { "type": "wait_frames", "n": 60 },

    { "type": "capture_screenshot", "label": "node-graph-wire-paint-cookbook-workflow-clean" },

    { "type": "press_key", "key": "p", "modifiers": { "ctrl": true, "shift": true } },
    { "type": "wait_frames", "n": 12 },
    { "type": "capture_screenshot", "label": "node-graph-wire-paint-cookbook-schematic-contrast" },

    { "type": "press_key", "key": "p", "modifiers": { "ctrl": true, "shift": true } },
    { "type": "wait_frames", "n": 12 },
    { "type": "capture_screenshot", "label": "node-graph-wire-paint-cookbook-graph-dark" },

    { "type": "capture_bundle", "label": "node-graph-wire-paint-cookbook-screenshots" }
  ]
}

