{
  "schema_version": 2,
  "meta": {
    "name": "cookbook-virtual-list-basics-smoke",
    "required_capabilities": ["diag.script_v2", "diag.screenshot_png"],
    "tags": ["cookbook", "virtual_list", "scroll", "reorder", "smoke"]
  },
  "steps": [
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "cookbook.virtual_list_basics.root" }
      },
      "timeout_frames": 240
    },
    {
      "type": "click",
      "target": { "kind": "test_id", "id": "cookbook.virtual_list_basics.scroll_target" }
    },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "cookbook.virtual_list_basics.row_target" }
      },
      "timeout_frames": 240
    },
    { "type": "click", "target": { "kind": "test_id", "id": "cookbook.virtual_list_basics.rotate" } },
    {
      "type": "click",
      "target": { "kind": "test_id", "id": "cookbook.virtual_list_basics.scroll_target" }
    },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "cookbook.virtual_list_basics.row_target" }
      },
      "timeout_frames": 240
    },
    { "type": "capture_screenshot", "label": "cookbook-virtual-list-basics-smoke" },
    { "type": "capture_bundle", "label": "cookbook-virtual-list-basics-smoke" }
  ]
}

