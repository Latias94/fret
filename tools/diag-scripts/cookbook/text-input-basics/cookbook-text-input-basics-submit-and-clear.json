{
  "schema_version": 2,
  "meta": {
    "name": "cookbook-text-input-basics-submit-and-clear",
    "required_capabilities": ["diag.script_v2", "diag.screenshot_png"],
    "tags": ["cookbook", "text_input", "input", "commands", "smoke"]
  },
  "steps": [
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "cookbook.text_input_basics.root" }
      },
      "timeout_frames": 240
    },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "semantics_numeric_approx_eq",
        "target": { "kind": "test_id", "id": "cookbook.text_input_basics.len" },
        "field": "value",
        "value": 0.0,
        "eps": 0.01
      },
      "timeout_frames": 240
    },
    { "type": "click", "target": { "kind": "test_id", "id": "cookbook.text_input_basics.input" } },
    {
      "type": "type_text_into",
      "target": { "kind": "test_id", "id": "cookbook.text_input_basics.input" },
      "text": "abc"
    },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "semantics_numeric_approx_eq",
        "target": { "kind": "test_id", "id": "cookbook.text_input_basics.len" },
        "field": "value",
        "value": 3.0,
        "eps": 0.01
      },
      "timeout_frames": 240
    },
    { "type": "press_key", "key": "enter" },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "semantics_numeric_approx_eq",
        "target": { "kind": "test_id", "id": "cookbook.text_input_basics.submitted_count" },
        "field": "value",
        "value": 1.0,
        "eps": 0.01
      },
      "timeout_frames": 240
    },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "semantics_numeric_approx_eq",
        "target": { "kind": "test_id", "id": "cookbook.text_input_basics.len" },
        "field": "value",
        "value": 0.0,
        "eps": 0.01
      },
      "timeout_frames": 240
    },
    {
      "type": "type_text_into",
      "target": { "kind": "test_id", "id": "cookbook.text_input_basics.input" },
      "text": "hi"
    },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "semantics_numeric_approx_eq",
        "target": { "kind": "test_id", "id": "cookbook.text_input_basics.len" },
        "field": "value",
        "value": 2.0,
        "eps": 0.01
      },
      "timeout_frames": 240
    },
    { "type": "press_key", "key": "escape" },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "semantics_numeric_approx_eq",
        "target": { "kind": "test_id", "id": "cookbook.text_input_basics.len" },
        "field": "value",
        "value": 0.0,
        "eps": 0.01
      },
      "timeout_frames": 240
    },
    { "type": "capture_screenshot", "label": "cookbook-text-input-basics-submit-and-clear" },
    { "type": "capture_bundle", "label": "cookbook-text-input-basics-submit-and-clear" }
  ]
}

