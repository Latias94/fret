{
  "schema_version": 2,
  "meta": {
    "name": "ui-gallery-combobox-basic-open-neutral-dark-screenshot",
    "required_capabilities": ["diag.script_v2", "diag.screenshot_png"]
  },
  "steps": [
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-theme-preset-trigger" }
      },
      "timeout_frames": 600
    },
    {
      "type": "click",
      "target": { "kind": "test_id", "id": "ui-gallery-theme-preset-trigger" }
    },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "select-scroll-viewport" }
      },
      "timeout_frames": 240
    },
    {
      "type": "click",
      "target": { "kind": "test_id", "id": "ui-gallery-theme-preset-item-neutral-dark" }
    },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "not_exists",
        "target": { "kind": "test_id", "id": "select-scroll-viewport" }
      },
      "timeout_frames": 240
    },
    {
      "type": "press_key",
      "key": "escape",
      "repeat": false,
      "modifiers": { "alt": false, "ctrl": false, "meta": false, "shift": false }
    },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-page-combobox" }
      },
      "timeout_frames": 600
    },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-combobox-basic-trigger" }
      },
      "timeout_frames": 600
    },
    {
      "type": "click",
      "target": { "kind": "test_id", "id": "ui-gallery-combobox-basic-trigger" },
      "button": "left"
    },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-combobox-basic-input" }
      },
      "timeout_frames": 240
    },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-combobox-basic-listbox" }
      },
      "timeout_frames": 240
    },
    {
      "type": "wait_bounds_stable",
      "target": { "kind": "test_id", "id": "ui-gallery-combobox-basic-listbox" },
      "timeout_frames": 180,
      "stable_frames": 2,
      "max_move_px": 1.0
    },
    {
      "type": "capture_screenshot",
      "label": "ui-gallery-combobox-basic-neutral-dark-open"
    },
    {
      "type": "capture_bundle",
      "label": "ui-gallery-combobox-basic-neutral-dark-open"
    }
  ]
}
