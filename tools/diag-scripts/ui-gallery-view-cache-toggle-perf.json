{
  "schema_version": 1,
  "steps": [
    {
      "type": "move_pointer",
      "target": { "kind": "test_id", "id": "ui-gallery-nav-view-cache" }
    },
    {
      "type": "click",
      "target": { "kind": "test_id", "id": "ui-gallery-nav-view-cache" }
    },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-view-cache-root" }
      },
      "timeout_frames": 360
    },

    { "type": "click", "target": { "kind": "test_id", "id": "ui-gallery-view-cache-enabled" } },
    { "type": "wait_frames", "n": 2 },
    {
      "type": "click",
      "target": { "kind": "test_id", "id": "ui-gallery-view-cache-bump-counter" }
    },
    { "type": "wait_frames", "n": 2 },
    {
      "type": "click",
      "target": { "kind": "test_id", "id": "ui-gallery-view-cache-popover-trigger" }
    },
    { "type": "wait_frames", "n": 10 },
    { "type": "press_key", "key": "escape" },
    { "type": "wait_frames", "n": 2 },

    { "type": "capture_bundle", "label": "ui-gallery-view-cache-toggle-perf" }
  ]
}
