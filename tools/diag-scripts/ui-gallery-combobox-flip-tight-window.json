{
  "schema_version": 2,
  "meta": {
    "required_capabilities": [
      "diag.script_v2",
      "diag.overlay_placement_trace"
    ]
  },
  "steps": [
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": {
          "kind": "test_id",
          "id": "ui-gallery-nav-search"
        }
      },
      "timeout_frames": 600
    },
    {
      "type": "press_key",
      "key": "escape",
      "modifiers": {
        "shift": false,
        "ctrl": false,
        "alt": false,
        "meta": false
      },
      "repeat": false
    },
    {
      "type": "wait_frames",
      "n": 2
    },
    {
      "type": "click",
      "target": {
        "kind": "test_id",
        "id": "ui-gallery-nav-search"
      },
      "button": "left"
    },
    {
      "type": "press_key",
      "key": "a",
      "modifiers": {
        "shift": false,
        "ctrl": true,
        "alt": false,
        "meta": false
      },
      "repeat": false
    },
    {
      "type": "press_key",
      "key": "backspace",
      "modifiers": {
        "shift": false,
        "ctrl": false,
        "alt": false,
        "meta": false
      },
      "repeat": false
    },
    {
      "type": "type_text",
      "text": "combobox"
    },
    {
      "type": "wait_frames",
      "n": 2
    },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": {
          "kind": "test_id",
          "id": "ui-gallery-nav-combobox"
        }
      },
      "timeout_frames": 600
    },
    {
      "type": "click",
      "target": {
        "kind": "test_id",
        "id": "ui-gallery-nav-combobox"
      },
      "button": "left"
    },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": {
          "kind": "test_id",
          "id": "ui-gallery-page-combobox"
        }
      },
      "timeout_frames": 600
    },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": {
          "kind": "test_id",
          "id": "ui-gallery-combobox-demo-trigger"
        }
      },
      "timeout_frames": 600
    },
    {
      "type": "set_window_inner_size",
      "width_px": 420.0,
      "height_px": 240.0
    },
    {
      "type": "scroll_into_view",
      "container": {
        "kind": "test_id",
        "id": "ui-gallery-page-combobox"
      },
      "target": {
        "kind": "test_id",
        "id": "ui-gallery-combobox-rtl-trigger"
      },
      "delta_x": 0.0,
      "delta_y": -720.0,
      "require_fully_within_container": false,
      "require_fully_within_window": true,
      "padding_px": 2.0,
      "padding_insets_px": null,
      "timeout_frames": 240
    },
    {
      "type": "click_stable",
      "target": {
        "kind": "test_id",
        "id": "ui-gallery-combobox-rtl-trigger"
      },
      "button": "left",
      "stable_frames": 2,
      "max_move_px": 1.0,
      "timeout_frames": 180
    },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": {
          "kind": "test_id",
          "id": "ui-gallery-combobox-rtl-input"
        }
      },
      "timeout_frames": 240
    },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": {
          "kind": "test_id",
          "id": "ui-gallery-combobox-rtl-listbox"
        }
      },
      "timeout_frames": 240
    },
    {
      "type": "wait_overlay_placement_trace",
      "query": {
        "kind": "anchored_panel",
        "anchor_test_id": "ui-gallery-combobox-rtl-trigger",
        "content_test_id": "ui-gallery-combobox-rtl-listbox",
        "flipped": true
      },
      "timeout_frames": 240
    },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "bounds_within_window",
        "target": {
          "kind": "test_id",
          "id": "ui-gallery-combobox-rtl-listbox"
        },
        "padding_px": 2.0,
        "eps_px": 0.5
      },
      "timeout_frames": 240
    },
    {
      "type": "capture_bundle",
      "label": "ui-gallery-combobox-flip-tight-window"
    }
  ]
}
