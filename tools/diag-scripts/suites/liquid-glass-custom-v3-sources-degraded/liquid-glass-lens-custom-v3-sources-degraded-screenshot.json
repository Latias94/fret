{
  "schema_version": 2,
  "meta": {
    "env_defaults": {
      "FRET_DIAG_RENDERER_PERF": 1,
      "FRET_RENDER_WGPU_INTERMEDIATE_BUDGET_BYTES": 33554432
    },
    "notes": [
      "Liquid glass CustomV3 screenshot forcing an intermediate budget that keeps CustomV3 active, but degrades renderer sources.",
      "Intended to deterministically exercise CustomEffectV3 sources degradation signals (raw aliasing + pyramid degraded to 1)."
    ]
  },
  "steps": [
    { "type": "set_window_inner_size", "width_px": 1280.0, "height_px": 720.0 },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "liquid-glass-switch-show-custom-v3" }
      },
      "timeout_frames": 600
    },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "liquid-glass-button-reset-stage" }
      },
      "timeout_frames": 600
    },
    { "type": "click_stable", "target": { "kind": "test_id", "id": "liquid-glass-button-reset-stage" }, "stable_frames": 6, "max_move_px": 0.5, "timeout_frames": 600 },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "checked_is",
        "target": { "kind": "test_id", "id": "liquid-glass-switch-use-backdrop" },
        "checked": true
      },
      "timeout_frames": 600
    },

    { "type": "click_stable", "target": { "kind": "test_id", "id": "liquid-glass-switch-show-fake" }, "stable_frames": 6, "max_move_px": 0.5, "timeout_frames": 600 },
    { "type": "click_stable", "target": { "kind": "test_id", "id": "liquid-glass-switch-show-warp-v1" }, "stable_frames": 6, "max_move_px": 0.5, "timeout_frames": 600 },

    { "type": "click_stable", "target": { "kind": "test_id", "id": "liquid-glass-switch-show-custom-v3" }, "stable_frames": 6, "max_move_px": 0.5, "timeout_frames": 600 },

    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "liquid-glass-lens-custom-v3" }
      },
      "timeout_frames": 600
    },

    { "type": "wait_frames", "n": 12 },
    { "type": "reset_diagnostics" },

    { "type": "wait_frames", "n": 120 },
    { "type": "capture_screenshot", "label": "liquid-glass-lens-custom-v3-sources-degraded" },
    { "type": "capture_bundle", "label": "liquid-glass-lens-custom-v3-sources-degraded" }
  ]
}
