{
  "schema_version": 2,
  "meta": {
    "notes": [
      "Liquid glass CustomV3 bevel lighting screenshot.",
      "Opens the inspector and sets bevel sliders to deterministic values."
    ]
  },
  "steps": [
    { "type": "set_window_inner_size", "width_px": 1280.0, "height_px": 720.0 },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "liquid-glass-switch-show-custom-v3" }
      },
      "timeout_frames": 600
    },

    { "type": "click_stable", "target": { "kind": "test_id", "id": "liquid-glass-switch-show-fake" }, "stable_frames": 6, "max_move_px": 0.5, "timeout_frames": 600 },
    { "type": "click_stable", "target": { "kind": "test_id", "id": "liquid-glass-switch-show-warp-v1" }, "stable_frames": 6, "max_move_px": 0.5, "timeout_frames": 600 },

    { "type": "click_stable", "target": { "kind": "test_id", "id": "liquid-glass-switch-show-custom-v3" }, "stable_frames": 6, "max_move_px": 0.5, "timeout_frames": 600 },
    { "type": "click_stable", "target": { "kind": "test_id", "id": "liquid-glass-switch-show-inspector" }, "stable_frames": 6, "max_move_px": 0.5, "timeout_frames": 600 },

    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "liquid-glass-slider-custom-v3-bevel-strength" }
      },
      "timeout_frames": 600
    },

    {
      "type": "set_slider_value",
      "target": { "kind": "test_id", "id": "liquid-glass-slider-custom-v3-bevel-angle-deg" },
      "value": 45.0,
      "min": 0.0,
      "max": 360.0,
      "epsilon": 1.0,
      "timeout_frames": 240,
      "drag_steps": 10
    },
    {
      "type": "set_slider_value",
      "target": { "kind": "test_id", "id": "liquid-glass-slider-custom-v3-bevel-secondary" },
      "value": 1.0,
      "min": 0.0,
      "max": 1.0,
      "epsilon": 0.02,
      "timeout_frames": 240,
      "drag_steps": 10
    },
    {
      "type": "set_slider_value",
      "target": { "kind": "test_id", "id": "liquid-glass-slider-custom-v3-bevel-strength" },
      "value": 1.0,
      "min": 0.0,
      "max": 1.0,
      "epsilon": 0.02,
      "timeout_frames": 240,
      "drag_steps": 10
    },

    { "type": "wait_frames", "n": 30 },
    { "type": "reset_diagnostics" },

    { "type": "wait_frames", "n": 120 },
    { "type": "capture_screenshot", "label": "liquid-glass-lens-custom-v3-bevel" },
    { "type": "capture_bundle", "label": "liquid-glass-lens-custom-v3-bevel" }
  ]
}
