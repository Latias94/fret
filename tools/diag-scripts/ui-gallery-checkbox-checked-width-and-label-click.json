{
  "schema_version": 2,
  "meta": {
    "name": "ui-gallery-checkbox-checked-width-and-label-click",
    "required_capabilities": ["diag.script_v2", "diag.screenshot_png"],
    "tags": ["ui_gallery", "shadcn", "checkbox", "layout", "label", "regression"]
  },
  "steps": [
    { "type": "reset_diagnostics" },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-nav-search" }
      },
      "timeout_frames": 600
    },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-nav-scroll" }
      },
      "timeout_frames": 600
    },

    { "type": "press_key", "key": "escape" },
    { "type": "wait_frames", "n": 2 },

    { "type": "set_window_inner_size", "width_px": 320.0, "height_px": 720.0 },
    { "type": "wait_frames", "n": 20 },

    { "type": "click", "target": { "kind": "test_id", "id": "ui-gallery-nav-search" } },
    { "type": "press_key", "key": "a", "modifiers": { "ctrl": true } },
    { "type": "press_key", "key": "backspace" },
    { "type": "type_text", "text": "checkbox" },
    { "type": "wait_frames", "n": 2 },

    {
      "type": "scroll_into_view",
      "container": { "kind": "test_id", "id": "ui-gallery-nav-scroll" },
      "target": { "kind": "test_id", "id": "ui-gallery-nav-checkbox" },
      "delta_y": -240.0,
      "timeout_frames": 600
    },
    { "type": "click", "target": { "kind": "test_id", "id": "ui-gallery-nav-checkbox" } },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-page-checkbox" }
      },
      "timeout_frames": 600
    },

    {
      "type": "scroll_into_view",
      "container": { "kind": "test_id", "id": "ui-gallery-content-viewport" },
      "target": { "kind": "test_id", "id": "ui-gallery-checkbox-controlled" },
      "delta_y": -240.0,
      "timeout_frames": 600
    },
    { "type": "wait_frames", "n": 5 },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "checked_is",
        "target": { "kind": "test_id", "id": "ui-gallery-checkbox-controlled" },
        "checked": true
      },
      "timeout_frames": 600
    },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "bounds_min_size",
        "target": { "kind": "test_id", "id": "ui-gallery-checkbox-controlled" },
        "min_w_px": 16.0,
        "min_h_px": 16.0,
        "eps_px": 0.25
      },
      "timeout_frames": 600
    },

    {
      "type": "click",
      "target": { "kind": "test_id", "id": "ui-gallery-checkbox-controlled-label" }
    },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "checked_is",
        "target": { "kind": "test_id", "id": "ui-gallery-checkbox-controlled" },
        "checked": false
      },
      "timeout_frames": 600
    },

    { "type": "capture_bundle", "label": "ui-gallery-checkbox-checked-width-and-label-click" },
    { "type": "capture_screenshot", "label": "ui-gallery-checkbox-checked-width-and-label-click" }
  ]
}
