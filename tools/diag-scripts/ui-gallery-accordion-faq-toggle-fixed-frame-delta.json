{
  "schema_version": 2,
  "steps": [
    { "type": "reset_diagnostics" },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-nav-search" }
      },
      "timeout_frames": 240
    },
    { "type": "click", "target": { "kind": "test_id", "id": "ui-gallery-nav-search" } },
    { "type": "press_key", "key": "a", "modifiers": { "ctrl": true } },
    { "type": "press_key", "key": "backspace" },
    { "type": "type_text", "text": "accordion" },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-nav-accordion" }
      },
      "timeout_frames": 240
    },
    { "type": "click", "target": { "kind": "test_id", "id": "ui-gallery-nav-accordion" } },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-page-accordion" }
      },
      "timeout_frames": 240
    },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-accordion-demo-returns-trigger" }
      },
      "timeout_frames": 240
    },

    { "type": "wait_frames", "n": 10 },
    { "type": "capture_bundle", "label": "ui-gallery-accordion-faq-toggle-before" },
    { "type": "capture_screenshot", "label": "ui-gallery-accordion-faq-toggle-before" },

    {
      "type": "click_stable",
      "target": { "kind": "test_id", "id": "ui-gallery-accordion-demo-returns-trigger" }
    },
    { "type": "wait_frames", "n": 20 },
    { "type": "capture_bundle", "label": "ui-gallery-accordion-faq-toggle-after" },
    { "type": "capture_screenshot", "label": "ui-gallery-accordion-faq-toggle-after" },

    {
      "type": "capture_bundle",
      "label": "ui-gallery-accordion-faq-toggle-fixed-frame-delta"
    }
  ]
}
