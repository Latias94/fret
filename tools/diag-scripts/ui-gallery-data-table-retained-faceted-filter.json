{
  "schema_version": 2,
  "steps": [
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-nav-search" }
      },
      "timeout_frames": 240
    },
    { "type": "click", "target": { "kind": "test_id", "id": "ui-gallery-nav-search" } },
    { "type": "type_text", "text": "datatable (torture)" },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-nav-data-table-torture" }
      },
      "timeout_frames": 240
    },
    { "type": "click", "target": { "kind": "test_id", "id": "ui-gallery-nav-data-table-torture" } },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-data-table-torture-root" }
      },
      "timeout_frames": 240
    },

    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": {
          "kind": "role_and_name",
          "role": "text",
          "name": "StatusFilter: <none>"
        }
      },
      "timeout_frames": 240
    },

    {
      "type": "click",
      "target": { "kind": "role_and_name", "role": "button", "name": "Status" }
    },
    { "type": "wait_frames", "n": 2 },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "role_and_name", "role": "menu_item_checkbox", "name": "Running" }
      },
      "timeout_frames": 240
    },
    { "type": "click", "target": { "kind": "role_and_name", "role": "menu_item_checkbox", "name": "Running" } },
    { "type": "wait_frames", "n": 2 },
    { "type": "click", "target": { "kind": "role_and_name", "role": "menu_item_checkbox", "name": "Idle" } },
    { "type": "wait_frames", "n": 2 },

    {
      "type": "assert",
      "predicate": {
        "kind": "exists",
        "target": {
          "kind": "role_and_name",
          "role": "text",
          "name": "StatusFilter: Running, Idle"
        }
      }
    },

    { "type": "capture_bundle", "label": "ui-gallery-data-table-retained-faceted-filter" }
  ]
}

