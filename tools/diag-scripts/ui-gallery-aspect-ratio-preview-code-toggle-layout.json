{
  "schema_version": 2,
  "meta": {
    "name": "ui-gallery-aspect-ratio-preview-code-toggle-layout",
    "required_capabilities": ["diag.script_v2"]
  },
  "steps": [
    { "type": "press_key", "key": "escape" },
    { "type": "wait_frames", "n": 2 },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-nav-search" }
      },
      "timeout_frames": 600
    },
    { "type": "click", "target": { "kind": "test_id", "id": "ui-gallery-nav-search" } },
    { "type": "press_key", "key": "a", "modifiers": { "ctrl": true } },
    { "type": "press_key", "key": "backspace" },
    { "type": "type_text", "text": "aspect ratio" },
    { "type": "wait_frames", "n": 2 },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-nav-aspect-ratio" }
      },
      "timeout_frames": 600
    },
    {
      "type": "scroll_into_view",
      "container": { "kind": "test_id", "id": "ui-gallery-nav-scroll" },
      "target": { "kind": "test_id", "id": "ui-gallery-nav-aspect-ratio" },
      "delta_y": -240.0,
      "timeout_frames": 600
    },
    { "type": "click", "target": { "kind": "test_id", "id": "ui-gallery-nav-aspect-ratio" } },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-page-aspect-ratio" }
      },
      "timeout_frames": 600
    },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "docsec-demo-tabs-trigger-code" }
      },
      "timeout_frames": 600
    },

    { "type": "click", "target": { "kind": "test_id", "id": "docsec-demo-tabs-trigger-code" } },
    { "type": "wait_frames", "n": 8 },
    { "type": "capture_bundle", "label": "ui-gallery-aspect-ratio-code-tab" },

    {
      "type": "click",
      "target": { "kind": "test_id", "id": "docsec-demo-tabs-trigger-preview" }
    },
    { "type": "wait_frames", "n": 8 },
    {
      "type": "wait_bounds_stable",
      "target": { "kind": "test_id", "id": "docsec-demo-content" },
      "stable_frames": 10,
      "timeout_frames": 600
    },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "bounds_max_size",
        "target": { "kind": "test_id", "id": "docsec-demo-content" },
        "max_w_px": 2000.0,
        "max_h_px": 520.0
      },
      "timeout_frames": 600
    },
    { "type": "capture_bundle", "label": "ui-gallery-aspect-ratio-preview-tab-after-code" }
  ]
}
