{
  "schema_version": 2,
  "steps": [
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-nav-search" }
      },
      "timeout_frames": 600
    },
    { "type": "click", "target": { "kind": "test_id", "id": "ui-gallery-nav-search" } },
    { "type": "press_key", "key": "a", "modifiers": { "ctrl": true } },
    { "type": "press_key", "key": "backspace" },
    { "type": "type_text", "text": "dialog" },
    { "type": "wait_frames", "n": 2 },
    {
      "type": "ensure_visible",
      "target": { "kind": "test_id", "id": "ui-gallery-nav-material3-dialog" },
      "within_window": true,
      "padding_px": 8.0,
      "timeout_frames": 600
    },
    { "type": "click", "target": { "kind": "test_id", "id": "ui-gallery-nav-material3-dialog" } },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-page-material3-dialog" }
      },
      "timeout_frames": 600
    },
    { "type": "wait_frames", "n": 30 },

    {
      "type": "ensure_visible",
      "target": { "kind": "test_id", "id": "ui-gallery-material3-dialog-open" },
      "within_window": true,
      "padding_px": 8.0,
      "timeout_frames": 600
    },
    { "type": "capture_screenshot", "label": "m3-dialog-select-00-page" },

    { "type": "click", "target": { "kind": "test_id", "id": "ui-gallery-material3-dialog-open" } },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-material3-dialog-action-cancel" }
      },
      "timeout_frames": 600
    },
    { "type": "wait_frames", "n": 10 },
    { "type": "capture_screenshot", "label": "m3-dialog-select-10-dialog-open" },

    {
      "type": "ensure_visible",
      "target": { "kind": "test_id", "id": "ui-gallery-material3-dialog-select" },
      "within_window": true,
      "padding_px": 8.0,
      "timeout_frames": 600
    },
    { "type": "move_pointer", "target": { "kind": "test_id", "id": "ui-gallery-material3-dialog-select" } },
    { "type": "click", "target": { "kind": "test_id", "id": "ui-gallery-material3-dialog-select" } },
    { "type": "wait_frames", "n": 2 },
    { "type": "capture_bundle", "label": "after-select-click" },
    { "type": "press_key", "key": "arrow_down" },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": {
          "kind": "test_id",
          "id": "ui-gallery-material3-dialog-select-listbox"
        }
      },
      "timeout_frames": 600
    },
    { "type": "wait_frames", "n": 10 },
    { "type": "capture_screenshot", "label": "m3-dialog-select-20-select-open" },
    { "type": "press_key", "key": "escape" },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "not_exists",
        "target": {
          "kind": "test_id",
          "id": "ui-gallery-material3-dialog-select-listbox"
        }
      },
      "timeout_frames": 600
    },

    {
      "type": "ensure_visible",
      "target": { "kind": "test_id", "id": "ui-gallery-material3-dialog-select-bottom" },
      "within_window": true,
      "padding_px": 8.0,
      "timeout_frames": 600
    },
    { "type": "move_pointer", "target": { "kind": "test_id", "id": "ui-gallery-material3-dialog-select-bottom" } },
    { "type": "click", "target": { "kind": "test_id", "id": "ui-gallery-material3-dialog-select-bottom" } },
    { "type": "wait_frames", "n": 2 },
    { "type": "capture_bundle", "label": "after-select-bottom-click" },
    { "type": "press_key", "key": "arrow_down" },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": {
          "kind": "test_id",
          "id": "ui-gallery-material3-dialog-select-bottom-listbox"
        }
      },
      "timeout_frames": 600
    },
    { "type": "wait_frames", "n": 10 },
    { "type": "capture_screenshot", "label": "m3-dialog-select-30-bottom-select-open" },

    { "type": "capture_bundle", "label": "ui-gallery-material3-select-dialog-overlay-screenshots" }
  ]
}
