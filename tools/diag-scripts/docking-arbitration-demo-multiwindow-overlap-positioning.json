{
  "schema_version": 2,
  "meta": {
    "name": "Docking arbitration demo: tear-off then overlap windows (manual repro helper)",
    "tags": ["docking", "multiwindow", "overlap"],
    "required_capabilities": ["diag.script_v2"],
    "target_hints": [
      "Intended for desktop runners with multi-window tear-off enabled.",
      "This script is a setup helper (not a strict parity gate yet): it creates a DockFloating window via tear-off, then moves it to overlap the source window."
    ]
  },
  "steps": [
    { "type": "press_key", "key": "escape" },
    { "type": "wait_frames", "n": 2 },

    { "type": "set_window_outer_position", "x_px": 120.0, "y_px": 120.0 },
    { "type": "set_window_inner_size", "width_px": 1600.0, "height_px": 900.0 },
    { "type": "wait_frames", "n": 2 },

    {
      "type": "wait_until",
      "predicate": { "kind": "exists", "target": { "kind": "test_id", "id": "dock-arb-tab-drag-anchor-right" } },
      "timeout_frames": 240
    },

    {
      "type": "drag_pointer",
      "target": { "kind": "test_id", "id": "dock-arb-tab-drag-anchor-right" },
      "delta_x": 2400.0,
      "delta_y": 0.0,
      "steps": 140
    },
    { "type": "wait_frames", "n": 90 },

    {
      "type": "set_window_outer_position",
      "window": { "kind": "last_seen_other" },
      "x_px": 180.0,
      "y_px": 180.0
    },
    { "type": "wait_frames", "n": 10 },

    { "type": "capture_bundle", "label": "docking-arbitration-demo-multiwindow-overlap-positioning" },
    { "type": "wait_frames", "n": 2 }
  ]
}

