{
  "schema_version": 2,
  "meta": {
    "name": "UI Gallery: Text mixed-script fallback screenshot",
    "tags": ["ui-gallery", "text", "fonts", "fallback", "cjk", "emoji", "screenshot"],
    "required_capabilities": ["diag.script_v2", "diag.screenshot_png"]
  },
  "steps": [
    { "type": "reset_diagnostics" },
    {
      "type": "wait_until",
      "predicate": { "kind": "exists", "target": { "kind": "test_id", "id": "ui-gallery-nav-scroll" } },
      "timeout_frames": 600
    },
    {
      "type": "wait_until",
      "predicate": { "kind": "exists", "target": { "kind": "test_id", "id": "ui-gallery-nav-search" } },
      "timeout_frames": 600
    },
    { "type": "press_key", "key": "escape" },
    { "type": "wait_frames", "n": 2 },
    { "type": "set_window_inner_size", "width_px": 1280.0, "height_px": 720.0 },
    { "type": "wait_frames", "n": 15 },
    { "type": "click", "target": { "kind": "test_id", "id": "ui-gallery-nav-search" } },
    { "type": "press_key", "key": "a", "modifiers": { "ctrl": true } },
    { "type": "press_key", "key": "backspace" },
    { "type": "type_text", "text": "text_mixed_script_fallback" },
    { "type": "wait_frames", "n": 2 },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "bounds_within_window",
        "target": { "kind": "test_id", "id": "ui-gallery-nav-text-mixed-script-fallback" },
        "padding_px": 8.0,
        "eps_px": 1.0
      },
      "timeout_frames": 600
    },
    { "type": "click", "target": { "kind": "test_id", "id": "ui-gallery-nav-text-mixed-script-fallback" } },
    {
      "type": "wait_until",
      "predicate": { "kind": "focus_is", "target": { "kind": "test_id", "id": "ui-gallery-nav-text-mixed-script-fallback" } },
      "timeout_frames": 60
    },
    { "type": "press_key", "key": "enter" },
    {
      "type": "wait_until",
      "predicate": { "kind": "exists", "target": { "kind": "test_id", "id": "ui-gallery-page-text-mixed-script-fallback" } },
      "timeout_frames": 600
    },
    {
      "type": "wait_until",
      "predicate": { "kind": "exists", "target": { "kind": "test_id", "id": "ui-gallery-text-mixed-script-fallback-root" } },
      "timeout_frames": 600
    },
    {
      "type": "wait_until",
      "predicate": { "kind": "exists", "target": { "kind": "test_id", "id": "ui-gallery-text-mixed-script-fallback-mixed" } },
      "timeout_frames": 600
    },
    { "type": "wait_frames", "n": 30 },
    { "type": "capture_screenshot", "label": "ui-gallery-text-mixed-script-fallback" }
  ]
}

