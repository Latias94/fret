{
  "schema_version": 2,
  "steps": [
    { "type": "reset_diagnostics" },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-nav-search" }
      },
      "timeout_frames": 240
    },
    { "type": "click", "target": { "kind": "test_id", "id": "ui-gallery-nav-search" } },
    { "type": "press_key", "key": "a", "modifiers": { "ctrl": true } },
    { "type": "press_key", "key": "backspace" },
    { "type": "type_text", "text": "navigation menu" },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-nav-navigation-menu" }
      },
      "timeout_frames": 240
    },
    {
      "type": "click",
      "target": { "kind": "test_id", "id": "ui-gallery-nav-navigation-menu" }
    },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": {
          "kind": "test_id",
          "id": "ui-gallery-navigation-menu-demo-trigger-getting-started"
        }
      },
      "timeout_frames": 240
    },

    {
      "type": "move_pointer",
      "target": {
        "kind": "test_id",
        "id": "ui-gallery-navigation-menu-demo-trigger-getting-started"
      }
    },
    { "type": "wait_frames", "n": 14 },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-navigation-menu-demo-viewport" }
      },
      "timeout_frames": 240
    },

    { "type": "wait_frames", "n": 8 },
    { "type": "capture_bundle", "label": "ui-gallery-navigation-menu-viewport-before" },
    { "type": "capture_screenshot", "label": "ui-gallery-navigation-menu-viewport-before" },

    {
      "type": "move_pointer",
      "target": {
        "kind": "test_id",
        "id": "ui-gallery-navigation-menu-demo-trigger-components"
      }
    },
    { "type": "wait_frames", "n": 16 },
    { "type": "capture_bundle", "label": "ui-gallery-navigation-menu-viewport-after" },
    { "type": "capture_screenshot", "label": "ui-gallery-navigation-menu-viewport-after" },

    {
      "type": "capture_bundle",
      "label": "ui-gallery-navigation-menu-viewport-fixed-frame-delta"
    }
  ]
}
