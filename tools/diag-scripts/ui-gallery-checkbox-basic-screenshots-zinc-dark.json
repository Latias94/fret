{
  "schema_version": 2,
  "meta": {
    "name": "UI gallery: Checkbox basic screenshots (zinc dark)",
    "tags": ["ui-gallery", "shadcn", "checkbox", "zinc-dark", "screenshots"],
    "required_capabilities": ["diag.script_v2", "diag.screenshot_png"],
    "target_hints": [
      "Sets theme preset to zinc/dark.",
      "Navigates to the Checkbox page.",
      "Captures screenshots of the basic checkbox before and after toggling."
    ]
  },
  "steps": [
    { "type": "reset_diagnostics" },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-theme-preset-trigger" }
      },
      "timeout_frames": 600
    },
    { "type": "click", "target": { "kind": "test_id", "id": "ui-gallery-theme-preset-trigger" } },
    {
      "type": "click_stable",
      "target": {
        "kind": "test_id",
        "id": "ui-gallery-theme-preset-item-zinc-dark"
      }
    },
    { "type": "wait_frames", "n": 2 },
    { "type": "press_key", "key": "escape" },
    { "type": "wait_frames", "n": 2 },

    {
      "type": "type_text_into",
      "target": { "kind": "test_id", "id": "ui-gallery-nav-search" },
      "text": "checkbox",
      "clear_before_type": true,
      "timeout_frames": 600
    },
    { "type": "wait_frames", "n": 2 },
    {
      "type": "scroll_into_view",
      "container": { "kind": "test_id", "id": "ui-gallery-nav-scroll" },
      "target": { "kind": "test_id", "id": "ui-gallery-nav-checkbox" },
      "delta_y": -240.0,
      "timeout_frames": 600
    },
    { "type": "click_stable", "target": { "kind": "test_id", "id": "ui-gallery-nav-checkbox" } },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-page-checkbox" }
      },
      "timeout_frames": 600
    },

    {
      "type": "scroll_into_view",
      "container": { "kind": "test_id", "id": "ui-gallery-content-scroll" },
      "target": { "kind": "test_id", "id": "ui-gallery-checkbox-basic" },
      "delta_y": -120.0,
      "require_fully_within_container": true,
      "require_fully_within_window": true,
      "padding_px": 16.0,
      "timeout_frames": 600
    },
    { "type": "wait_frames", "n": 2 },
    { "type": "capture_screenshot", "label": "ui-gallery-checkbox-basic-zinc-dark.before" },
    { "type": "click_stable", "target": { "kind": "test_id", "id": "ui-gallery-checkbox-basic" } },
    { "type": "wait_frames", "n": 2 },
    { "type": "capture_screenshot", "label": "ui-gallery-checkbox-basic-zinc-dark.after" },
    { "type": "capture_bundle", "label": "ui-gallery-checkbox-basic-zinc-dark" }
  ]
}

