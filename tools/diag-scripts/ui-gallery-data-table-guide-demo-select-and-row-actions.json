{
  "meta": {
    "required_capabilities": ["diag.script_v2", "diag.screenshot_png"]
  },
  "schema_version": 2,
  "steps": [
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-nav-search" }
      },
      "timeout_frames": 240
    },
    { "type": "click", "target": { "kind": "test_id", "id": "ui-gallery-nav-search" } },
    { "type": "press_key", "key": "a", "modifiers": { "ctrl": true } },
    { "type": "press_key", "key": "backspace" },
    { "type": "type_text", "text": "datatable" },
    { "type": "wait_frames", "n": 2 },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-nav-data-table" }
      },
      "timeout_frames": 240
    },
    { "type": "click", "target": { "kind": "test_id", "id": "ui-gallery-nav-data-table" } },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-data-table-root" }
      },
      "timeout_frames": 240
    },
    { "type": "wait_frames", "n": 30 },
    {
      "type": "capture_screenshot",
      "label": "ui-gallery-data-table-guide-demo-layout"
    },

    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-data-table-select-all" }
      },
      "timeout_frames": 240
    },
    { "type": "click", "target": { "kind": "test_id", "id": "ui-gallery-data-table-select-all" } },
    { "type": "wait_frames", "n": 2 },

    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-data-table-row-actions-open-1" }
      },
      "timeout_frames": 240
    },
    {
      "type": "click",
      "target": { "kind": "test_id", "id": "ui-gallery-data-table-row-actions-open-1" }
    },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": {
          "kind": "test_id",
          "id": "ui-gallery-data-table-row-actions-item-edit-1"
        }
      },
      "timeout_frames": 240
    },

    {
      "type": "capture_bundle",
      "label": "ui-gallery-data-table-guide-demo-select-and-row-actions"
    }
  ]
}
