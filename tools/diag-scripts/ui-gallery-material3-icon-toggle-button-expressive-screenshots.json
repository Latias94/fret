{
  "schema_version": 2,
  "meta": {
    "name": "ui-gallery-material3-icon-toggle-button-expressive-screenshots",
    "required_capabilities": ["diag.script_v2", "diag.screenshot_png"],
    "tags": ["ui_gallery", "material3", "icon_button", "toggle", "expressive", "screenshots"]
  },
  "steps": [
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-nav-search" }
      },
      "timeout_frames": 600
    },
    { "type": "click", "target": { "kind": "test_id", "id": "ui-gallery-nav-search" } },
    { "type": "press_key", "key": "a", "modifiers": { "ctrl": true } },
    { "type": "press_key", "key": "backspace" },
    { "type": "type_text", "text": "icon button" },
    { "type": "wait_frames", "n": 2 },
    {
      "type": "ensure_visible",
      "target": { "kind": "test_id", "id": "ui-gallery-nav-material3-icon-button" },
      "within_window": true,
      "padding_px": 8.0,
      "timeout_frames": 600
    },
    {
      "type": "click",
      "target": { "kind": "test_id", "id": "ui-gallery-nav-material3-icon-button" }
    },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-page-material3-icon-button" }
      },
      "timeout_frames": 600
    },
    { "type": "wait_frames", "n": 20 },

    { "type": "capture_bundle", "label": "m3-icon-button-toggle-00-standard-idle" },
    { "type": "capture_screenshot", "label": "m3-icon-button-toggle-00-standard-idle" },

    {
      "type": "click",
      "target": {
        "kind": "role_and_name",
        "role": "switch",
        "name": "Enable Material 3 Expressive variant"
      }
    },
    { "type": "wait_frames", "n": 10 },
    { "type": "capture_bundle", "label": "m3-icon-button-toggle-10-expressive-idle" },
    { "type": "capture_screenshot", "label": "m3-icon-button-toggle-10-expressive-idle" },

    {
      "type": "click",
      "target": { "kind": "role_and_name", "role": "button", "name": "Toggle off" }
    },
    { "type": "wait_frames", "n": 4 },
    { "type": "capture_bundle", "label": "m3-icon-button-toggle-20-click-toggle-off" },
    { "type": "capture_screenshot", "label": "m3-icon-button-toggle-20-click-toggle-off" },

    {
      "type": "click",
      "target": { "kind": "role_and_name", "role": "button", "name": "Toggle on" }
    },
    { "type": "wait_frames", "n": 4 },
    { "type": "capture_bundle", "label": "m3-icon-button-toggle-30-click-toggle-on" },
    { "type": "capture_screenshot", "label": "m3-icon-button-toggle-30-click-toggle-on" },

    { "type": "capture_bundle", "label": "ui-gallery-material3-icon-toggle-button-expressive" }
  ]
}
