{
  "schema_version": 2,
  "steps": [
    { "type": "press_key", "key": "escape" },
    { "type": "wait_frames", "n": 2 },

    { "type": "set_window_inner_size", "width_px": 1280.0, "height_px": 720.0 },
    { "type": "wait_frames", "n": 2 },

    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-overlay-underlay" }
      },
      "timeout_frames": 240
    },

    { "type": "reset_diagnostics" },

    { "type": "move_pointer", "target": { "kind": "test_id", "id": "ui-gallery-overlay-underlay" } },
    { "type": "wait_frames", "n": 1 },

    {
      "type": "drag_pointer",
      "target": { "kind": "test_id", "id": "ui-gallery-overlay-underlay" },
      "button": "middle",
      "delta_x": 900.0,
      "delta_y": 420.0,
      "steps": 300
    },
    { "type": "wait_frames", "n": 1 },
    {
      "type": "drag_pointer",
      "target": { "kind": "test_id", "id": "ui-gallery-overlay-underlay" },
      "button": "middle",
      "delta_x": -900.0,
      "delta_y": -420.0,
      "steps": 300
    },
    { "type": "wait_frames", "n": 2 },

    { "type": "capture_bundle", "label": "ui-gallery-hit-test-drag-sweep-steady" },

    { "type": "press_key", "key": "escape" },
    { "type": "wait_frames", "n": 2 }
  ]
}

