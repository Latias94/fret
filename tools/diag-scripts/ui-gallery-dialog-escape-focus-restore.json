{
  "schema_version": 1,
  "steps": [
    {
      "type": "click",
      "target": { "kind": "test_id", "id": "ui-gallery-dialog-trigger" }
    },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-dialog-close" }
      },
      "timeout_frames": 60
    },
    { "type": "press_key", "key": "escape" },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "focus_is",
        "target": { "kind": "test_id", "id": "ui-gallery-dialog-trigger" }
      },
      "timeout_frames": 60
    },
    { "type": "capture_bundle", "label": "ui-gallery-dialog-escape-focus-restore" }
  ]
}
