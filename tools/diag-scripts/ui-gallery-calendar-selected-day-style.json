{
  "schema_version": 2,
  "meta": {
    "name": "UI Gallery: Calendar selected day is square and styled",
    "tags": ["ui-gallery", "calendar", "shadcn"],
    "required_capabilities": ["diag.script_v2", "diag.screenshot_png"]
  },
  "steps": [
    { "type": "reset_diagnostics" },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-nav-search" }
      },
      "timeout_frames": 600
    },
    { "type": "press_key", "key": "escape" },
    { "type": "wait_frames", "n": 2 },
    { "type": "set_window_inner_size", "width_px": 1280.0, "height_px": 720.0 },
    { "type": "wait_frames", "n": 15 },

    { "type": "click", "target": { "kind": "test_id", "id": "ui-gallery-nav-search" } },
    { "type": "press_key", "key": "a", "modifiers": { "ctrl": true } },
    { "type": "press_key", "key": "backspace" },
    { "type": "type_text", "text": "calendar" },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-nav-calendar" }
      },
      "timeout_frames": 600
    },
    { "type": "click", "target": { "kind": "test_id", "id": "ui-gallery-nav-calendar" } },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-page-calendar" }
      },
      "timeout_frames": 600
    },

    {
      "type": "scroll_into_view",
      "container": { "kind": "test_id", "id": "ui-gallery-content-scroll" },
      "target": { "kind": "test_id", "id": "ui-gallery.calendar.basic:2025-02-12" },
      "delta_y": -240.0,
      "require_fully_within_container": true,
      "require_fully_within_window": true,
      "padding_px": 16.0,
      "padding_insets_px": {
        "left_px": 16.0,
        "top_px": 16.0,
        "right_px": 16.0,
        "bottom_px": 40.0
      },
      "timeout_frames": 1800
    },
    {
      "type": "assert",
      "predicate": {
        "kind": "selected_is",
        "target": { "kind": "test_id", "id": "ui-gallery.calendar.basic:2025-02-12" },
        "selected": true
      }
    },
    {
      "type": "assert",
      "predicate": {
        "kind": "bounds_min_size",
        "target": { "kind": "test_id", "id": "ui-gallery.calendar.basic:2025-02-12" },
        "min_w_px": 31.0,
        "min_h_px": 31.0,
        "eps_px": 1.0
      }
    },
    {
      "type": "assert",
      "predicate": {
        "kind": "bounds_max_size",
        "target": { "kind": "test_id", "id": "ui-gallery.calendar.basic:2025-02-12" },
        "max_w_px": 33.0,
        "max_h_px": 33.0,
        "eps_px": 1.0
      }
    },

    { "type": "wait_frames", "n": 10 },
    { "type": "capture_bundle", "label": "ui-gallery-calendar-selected-day-style" },
    { "type": "capture_screenshot", "label": "ui-gallery-calendar-selected-day-style" }
  ]
}
