{
  "schema_version": 2,
  "meta": {
    "name": "ui-gallery-combobox-notes-zinc-light-screenshot",
    "required_capabilities": ["diag.script_v2", "diag.screenshot_png"]
  },
  "steps": [
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-nav-search" }
      },
      "timeout_frames": 600
    },
    {
      "type": "press_key",
      "key": "escape",
      "repeat": false,
      "modifiers": { "alt": false, "ctrl": false, "meta": false, "shift": false }
    },
    { "type": "wait_frames", "n": 2 },
    {
      "type": "click",
      "target": { "kind": "test_id", "id": "ui-gallery-nav-search" },
      "button": "left"
    },
    {
      "type": "press_key",
      "key": "a",
      "repeat": false,
      "modifiers": { "alt": false, "ctrl": true, "meta": false, "shift": false }
    },
    {
      "type": "press_key",
      "key": "backspace",
      "repeat": false,
      "modifiers": { "alt": false, "ctrl": false, "meta": false, "shift": false }
    },
    { "type": "type_text", "text": "combobox" },
    { "type": "wait_frames", "n": 2 },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-nav-combobox" }
      },
      "timeout_frames": 600
    },
    {
      "type": "click",
      "target": { "kind": "test_id", "id": "ui-gallery-nav-combobox" },
      "button": "left"
    },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-page-combobox" }
      },
      "timeout_frames": 600
    },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-theme-preset-trigger" }
      },
      "timeout_frames": 600
    },
    {
      "type": "click",
      "target": { "kind": "test_id", "id": "ui-gallery-theme-preset-trigger" }
    },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "select-scroll-viewport" }
      },
      "timeout_frames": 240
    },
    {
      "type": "click",
      "target": { "kind": "test_id", "id": "ui-gallery-theme-preset-item-zinc-light" }
    },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "not_exists",
        "target": { "kind": "test_id", "id": "select-scroll-viewport" }
      },
      "timeout_frames": 240
    },
    { "type": "wait_frames", "n": 6 },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-combobox-notes-title" }
      },
      "timeout_frames": 600
    },
    {
      "type": "scroll_into_view",
      "container": { "kind": "test_id", "id": "ui-gallery-content-scroll" },
      "target": { "kind": "test_id", "id": "ui-gallery-combobox-notes-content" },
      "delta_x": 0.0,
      "delta_y": -240.0,
      "padding_px": 2.0,
      "padding_insets_px": null,
      "require_fully_within_container": false,
      "require_fully_within_window": true,
      "timeout_frames": 240
    },
    {
      "type": "wait_bounds_stable",
      "target": { "kind": "test_id", "id": "ui-gallery-combobox-notes-content" },
      "timeout_frames": 180,
      "stable_frames": 2,
      "max_move_px": 1.0
    },
    { "type": "wait_frames", "n": 12 },
    { "type": "capture_screenshot", "label": "ui-gallery-combobox-notes-zinc-light" },
    { "type": "capture_bundle", "label": "ui-gallery-combobox-notes-zinc-light" }
  ]
}
