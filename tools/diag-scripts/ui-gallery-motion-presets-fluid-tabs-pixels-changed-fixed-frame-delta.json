{
  "schema_version": 2,
  "meta": {
    "name": "ui-gallery-motion-presets-fluid-tabs-pixels-changed-fixed-frame-delta",
    "required_capabilities": ["diag.script_v2", "diag.screenshot_png"]
  },
  "steps": [
    { "type": "reset_diagnostics" },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-nav-search" }
      },
      "timeout_frames": 240
    },
    {
      "type": "click",
      "target": { "kind": "test_id", "id": "ui-gallery-nav-search" }
    },
    { "type": "press_key", "key": "a", "modifiers": { "ctrl": true } },
    { "type": "press_key", "key": "backspace" },
    { "type": "type_text", "text": "motion presets" },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-nav-motion-presets" }
      },
      "timeout_frames": 240
    },
    { "type": "click", "target": { "kind": "test_id", "id": "ui-gallery-nav-motion-presets" } },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": {
          "kind": "test_id",
          "id": "ui-gallery-motion-presets-fluid-tabs-trigger-accounts"
        }
      },
      "timeout_frames": 240
    },
    { "type": "wait_frames", "n": 8 },
    { "type": "capture_bundle", "label": "ui-gallery-motion-presets-fluid-tabs-before" },
    { "type": "capture_screenshot", "label": "ui-gallery-motion-presets-fluid-tabs-before" },

    {
      "type": "click_stable",
      "target": {
        "kind": "test_id",
        "id": "ui-gallery-motion-presets-fluid-tabs-trigger-deposits"
      },
      "stable_frames": 4,
      "max_move_px": 0.5,
      "timeout_frames": 240
    },
    { "type": "wait_frames", "n": 24 },
    { "type": "capture_bundle", "label": "ui-gallery-motion-presets-fluid-tabs-after" },
    { "type": "capture_screenshot", "label": "ui-gallery-motion-presets-fluid-tabs-after" },

    {
      "type": "capture_bundle",
      "label": "ui-gallery-motion-presets-fluid-tabs-pixels-changed-fixed-frame-delta"
    }
  ]
}
