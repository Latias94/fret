{
  "schema_version": 2,
  "meta": {
    "name": "ui-gallery-tooltip-demo-open-arrow-screenshot",
    "required_capabilities": ["diag.script_v2", "diag.screenshot_png"],
    "tags": ["ui_gallery", "shadcn", "tooltip", "screenshot"]
  },
  "steps": [
    { "type": "reset_diagnostics" },
    { "type": "set_window_inner_size", "width_px": 1280.0, "height_px": 720.0 },
    { "type": "wait_frames", "n": 20 },

    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-nav-search" }
      },
      "timeout_frames": 600
    },
    { "type": "press_key", "key": "escape" },
    { "type": "wait_frames", "n": 2 },

    {
      "type": "click_stable",
      "target": { "kind": "test_id", "id": "ui-gallery-nav-search" },
      "button": "left",
      "stable_frames": 10,
      "max_move_px": 0.5,
      "timeout_frames": 600
    },
    { "type": "press_key", "key": "a", "modifiers": { "ctrl": true } },
    { "type": "press_key", "key": "backspace" },
    { "type": "type_text", "text": "tooltip" },
    { "type": "wait_frames", "n": 2 },

    {
      "type": "wait_until",
      "predicate": {
        "kind": "bounds_within_window",
        "target": { "kind": "test_id", "id": "ui-gallery-nav-tooltip" },
        "padding_px": 8.0,
        "eps_px": 1.0
      },
      "timeout_frames": 600
    },
    {
      "type": "click_stable",
      "target": { "kind": "test_id", "id": "ui-gallery-nav-tooltip" },
      "button": "left",
      "stable_frames": 10,
      "max_move_px": 0.5,
      "timeout_frames": 600
    },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-page-tooltip" }
      },
      "timeout_frames": 600
    },

    {
      "type": "scroll_into_view",
      "container": { "kind": "test_id", "id": "ui-gallery-content-scroll" },
      "target": { "kind": "test_id", "id": "ui-gallery-tooltip-demo-trigger" },
      "delta_y": -240.0,
      "require_fully_within_window": true,
      "padding_px": 12.0,
      "timeout_frames": 1200
    },
    {
      "type": "move_pointer",
      "target": { "kind": "test_id", "id": "ui-gallery-tooltip-demo-trigger" }
    },

    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-tooltip-demo-panel" }
      },
      "timeout_frames": 600
    },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-tooltip-demo-arrow" }
      },
      "timeout_frames": 600
    },
    {
      "type": "wait_bounds_stable",
      "target": { "kind": "test_id", "id": "ui-gallery-tooltip-demo-panel" },
      "stable_frames": 30,
      "max_move_px": 0.75,
      "timeout_frames": 1200
    },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "bounds_overlapping",
        "a": { "kind": "test_id", "id": "ui-gallery-tooltip-demo-panel" },
        "b": { "kind": "test_id", "id": "ui-gallery-tooltip-demo-arrow" },
        "eps_px": 0.75
      },
      "timeout_frames": 600
    },

    {
      "type": "capture_bundle",
      "label": "ui-gallery-tooltip-demo-open-arrow-screenshot"
    },
    {
      "type": "capture_screenshot",
      "label": "ui-gallery-tooltip-demo-open-arrow-screenshot"
    }
  ]
}
