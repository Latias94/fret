{
  "schema_version": 2,
  "meta": {
    "name": "ui-gallery-text-measure-overlay-wrap-modes-screenshots",
    "required_capabilities": ["diag.script_v2", "diag.screenshot_png"],
    "tags": ["ui_gallery", "text", "wrap", "intrinsic", "measure_overlay", "screenshots"]
  },
  "steps": [
    { "type": "reset_diagnostics" },
    { "type": "press_key", "key": "escape" },
    { "type": "wait_frames", "n": 2 },

    {
      "type": "wait_until",
      "predicate": { "kind": "exists", "target": { "kind": "test_id", "id": "ui-gallery-nav-search" } },
      "timeout_frames": 600
    },

    { "type": "click", "target": { "kind": "test_id", "id": "ui-gallery-nav-search" } },
    { "type": "press_key", "key": "a", "modifiers": { "ctrl": true } },
    { "type": "press_key", "key": "backspace" },
    { "type": "type_text", "text": "text_measure_overlay" },
    { "type": "wait_frames", "n": 2 },

    { "type": "click", "target": { "kind": "test_id", "id": "ui-gallery-nav-text-measure-overlay" } },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-page-text-measure-overlay" }
      },
      "timeout_frames": 600
    },

    { "type": "wait_until", "predicate": { "kind": "font_catalog_populated" }, "timeout_frames": 1800 },
    { "type": "wait_until", "predicate": { "kind": "system_font_rescan_idle" }, "timeout_frames": 1800 },
    {
      "type": "wait_until",
      "predicate": { "kind": "text_font_stack_key_stable", "stable_frames": 120 },
      "timeout_frames": 900
    },

    { "type": "set_window_inner_size", "width_px": 1280.0, "height_px": 720.0 },
    { "type": "wait_frames", "n": 10 },
    { "type": "capture_screenshot", "label": "measure-overlay-wide-1280", "timeout_frames": 240 },

    { "type": "set_window_inner_size", "width_px": 520.0, "height_px": 720.0 },
    { "type": "wait_frames", "n": 15 },
    { "type": "capture_screenshot", "label": "measure-overlay-narrow-520", "timeout_frames": 240 },

    { "type": "set_window_inner_size", "width_px": 360.0, "height_px": 720.0 },
    { "type": "wait_frames", "n": 15 },
    { "type": "capture_screenshot", "label": "measure-overlay-narrow-360", "timeout_frames": 240 },

    { "type": "capture_bundle", "label": "ui-gallery-text-measure-overlay-wrap-modes-screenshots" },
    { "type": "wait_frames", "n": 2 }
  ]
}

