{
  "schema_version": 2,
  "meta": {
    "name": "ui-gallery-material3-switch-focus-chroming-screenshots",
    "required_capabilities": ["diag.script_v2", "diag.screenshot_png"],
    "tags": ["ui_gallery", "material3", "switch", "focus", "chroming", "screenshots"]
  },
  "steps": [
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-nav-search" }
      },
      "timeout_frames": 600
    },
    { "type": "click", "target": { "kind": "test_id", "id": "ui-gallery-nav-search" } },
    { "type": "press_key", "key": "a", "modifiers": { "ctrl": true } },
    { "type": "press_key", "key": "backspace" },
    { "type": "type_text", "text": "switch" },
    { "type": "wait_frames", "n": 2 },
    {
      "type": "ensure_visible",
      "target": { "kind": "test_id", "id": "ui-gallery-nav-material3-switch" },
      "within_window": true,
      "padding_px": 8.0,
      "timeout_frames": 600
    },
    { "type": "click", "target": { "kind": "test_id", "id": "ui-gallery-nav-material3-switch" } },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-page-material3-switch" }
      },
      "timeout_frames": 600
    },
    { "type": "wait_frames", "n": 20 },

    { "type": "capture_bundle", "label": "m3-switch-00-idle" },
    { "type": "capture_screenshot", "label": "m3-switch-00-idle" },

    {
      "type": "click",
      "target": { "kind": "test_id", "id": "ui-gallery-material3-switch" }
    },
    { "type": "wait_frames", "n": 10 },
    { "type": "capture_bundle", "label": "m3-switch-10-clicked-focused" },
    { "type": "capture_screenshot", "label": "m3-switch-10-clicked-focused" },

    {
      "type": "capture_bundle",
      "label": "ui-gallery-material3-switch-focus-chroming-screenshots"
    }
  ]
}
