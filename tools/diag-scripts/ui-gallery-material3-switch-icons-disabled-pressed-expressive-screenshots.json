      "timeout_frames": 600
    },
    { "type": "wait_frames", "n": 20 },

    {
      "type": "wait_until",
      "predicate": {
        "kind": "role_is",
        "target": { "kind": "test_id", "id": "ui-gallery-material3-switch" },
        "role": "switch"
      },
      "timeout_frames": 600
    },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "checked_is",
        "target": { "kind": "test_id", "id": "ui-gallery-material3-switch" },
        "checked": false
      },
      "timeout_frames": 600
    },
    { "type": "capture_bundle", "label": "m3-switch-edge-00-standard-idle" },
    { "type": "capture_screenshot", "label": "m3-switch-edge-00-standard-idle" },

    { "type": "pointer_down", "target": { "kind": "test_id", "id": "ui-gallery-material3-switch" } },
    { "type": "wait_frames", "n": 6 },
    { "type": "capture_bundle", "label": "m3-switch-edge-05-standard-pressed" },
