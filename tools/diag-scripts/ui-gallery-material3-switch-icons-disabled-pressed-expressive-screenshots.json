    { "type": "capture_screenshot", "label": "m3-switch-icons-selected-only-10-selected" },

    {
      "type": "wait_until",
      "predicate": {
        "kind": "checked_is",
        "target": { "kind": "test_id", "id": "ui-gallery-material3-switch-icons-selected-only-disabled" },
        "checked": true
      },
      "timeout_frames": 600
