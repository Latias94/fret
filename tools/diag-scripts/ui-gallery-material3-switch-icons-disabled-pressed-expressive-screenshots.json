{
  "schema_version": 2,
  "meta": {
    "name": "ui-gallery-material3-switch-icons-disabled-pressed-expressive-screenshots",
    "required_capabilities": ["diag.script_v2", "diag.screenshot_png"],
    "tags": ["ui_gallery", "material3", "switch", "icons", "disabled", "pressed", "expressive", "screenshots"]
  },
  "steps": [
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-nav-search" }
