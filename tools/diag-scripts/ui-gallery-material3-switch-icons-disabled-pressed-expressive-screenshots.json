    {
      "type": "move_pointer",
      "target": { "kind": "test_id", "id": "ui-gallery-nav-search" }
    },
    { "type": "wait_frames", "n": 1 },
    { "type": "pointer_up" },
    { "type": "wait_frames", "n": 6 },

    {
      "type": "click",
      "target": { "kind": "test_id", "id": "ui-gallery-material3-design-variant-toggle" }
