    { "type": "click", "target": { "kind": "test_id", "id": "ui-gallery-material3-switch-icons-both-disabled" } },
    { "type": "wait_frames", "n": 6 },
    {
      "type": "assert",
      "predicate": {
        "kind": "checked_is",
        "target": { "kind": "test_id", "id": "ui-gallery-material3-switch-icons-both-disabled" },
        "checked": true
      }
    },

    { "type": "click", "target": { "kind": "test_id", "id": "ui-gallery-material3-switch-icons-both" } },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "checked_is",
        "target": { "kind": "test_id", "id": "ui-gallery-material3-switch-icons-both" },
        "checked": false
      },
      "timeout_frames": 600
    },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "checked_is",
        "target": { "kind": "test_id", "id": "ui-gallery-material3-switch-icons-both-disabled" },
