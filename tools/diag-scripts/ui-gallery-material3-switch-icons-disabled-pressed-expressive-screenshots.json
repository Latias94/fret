    { "type": "capture_bundle", "label": "m3-switch-icons-selected-only-20-disabled-selected" },
    { "type": "capture_screenshot", "label": "m3-switch-icons-selected-only-20-disabled-selected" },
    { "type": "click", "target": { "kind": "test_id", "id": "ui-gallery-material3-switch-icons-selected-only-disabled" } },
    { "type": "wait_frames", "n": 6 },
    {
      "type": "assert",
      "predicate": {
