    },
    { "type": "wait_frames", "n": 1 },
    { "type": "pointer_up" },
    { "type": "wait_frames", "n": 4 },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "checked_is",
        "target": { "kind": "test_id", "id": "ui-gallery-material3-switch-icons-both" },
        "checked": false
      },
      "timeout_frames": 600
    },

    { "type": "click", "target": { "kind": "test_id", "id": "ui-gallery-material3-switch-icons-both" } },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "checked_is",
        "target": { "kind": "test_id", "id": "ui-gallery-material3-switch-icons-both" },
        "checked": true
