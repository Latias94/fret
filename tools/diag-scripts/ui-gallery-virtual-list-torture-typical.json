{
  "schema_version": 2,
  "steps": [
    { "type": "press_key", "key": "escape" },
    { "type": "wait_frames", "n": 2 },

    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-nav-scroll" }
      },
      "timeout_frames": 240
    },

    { "type": "wheel", "target": { "kind": "test_id", "id": "ui-gallery-nav-scroll" }, "delta_y": 720.0 },
    { "type": "wheel", "target": { "kind": "test_id", "id": "ui-gallery-nav-scroll" }, "delta_y": 720.0 },
    { "type": "wheel", "target": { "kind": "test_id", "id": "ui-gallery-nav-scroll" }, "delta_y": 720.0 },
    { "type": "wheel", "target": { "kind": "test_id", "id": "ui-gallery-nav-scroll" }, "delta_y": 720.0 },
    { "type": "wheel", "target": { "kind": "test_id", "id": "ui-gallery-nav-scroll" }, "delta_y": 720.0 },
    { "type": "wheel", "target": { "kind": "test_id", "id": "ui-gallery-nav-scroll" }, "delta_y": 720.0 },
    { "type": "wheel", "target": { "kind": "test_id", "id": "ui-gallery-nav-scroll" }, "delta_y": 720.0 },
    { "type": "wheel", "target": { "kind": "test_id", "id": "ui-gallery-nav-scroll" }, "delta_y": 720.0 },
    { "type": "wheel", "target": { "kind": "test_id", "id": "ui-gallery-nav-scroll" }, "delta_y": 720.0 },
    { "type": "wheel", "target": { "kind": "test_id", "id": "ui-gallery-nav-scroll" }, "delta_y": 720.0 },
    { "type": "wait_frames", "n": 2 },

    {
      "type": "scroll_into_view",
      "container": { "kind": "test_id", "id": "ui-gallery-nav-scroll" },
      "target": { "kind": "test_id", "id": "ui-gallery-nav-virtual-list-torture" },
      "delta_y": -720.0,
      "timeout_frames": 600
    },
    { "type": "click", "target": { "kind": "test_id", "id": "ui-gallery-nav-virtual-list-torture" } },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-virtual-list-root" }
      },
      "timeout_frames": 360
    },

    { "type": "set_window_inner_size", "width_px": 1280.0, "height_px": 720.0 },
    { "type": "wait_frames", "n": 2 },

    {
      "type": "wait_until",
      "predicate": { "kind": "font_catalog_populated" },
      "timeout_frames": 1800
    },
    {
      "type": "wait_until",
      "predicate": { "kind": "system_font_rescan_idle" },
      "timeout_frames": 1800
    },
    {
      "type": "wait_until",
      "predicate": { "kind": "text_font_stack_key_stable", "stable_frames": 120 },
      "timeout_frames": 600
    },

    { "type": "reset_diagnostics" },

    { "type": "click", "target": { "kind": "test_id", "id": "ui-gallery-virtual-list-jump-button" } },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "visible_in_window",
        "target": { "kind": "test_id", "id": "ui-gallery-virtual-list-row-9000-label" }
      },
      "timeout_frames": 360
    },
    { "type": "click", "target": { "kind": "test_id", "id": "ui-gallery-virtual-list-bottom-button" } },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-virtual-list-row-9999-label" }
      },
      "timeout_frames": 360
    },

    { "type": "move_pointer", "target": { "kind": "test_id", "id": "ui-gallery-virtual-list-root" } },
    { "type": "wait_frames", "n": 1 },
    {
      "type": "move_pointer_sweep",
      "target": { "kind": "test_id", "id": "ui-gallery-virtual-list-root" },
      "delta_x": 900.0,
      "delta_y": 420.0,
      "steps": 300
    },
    { "type": "wait_frames", "n": 2 },
    {
      "type": "capture_bundle",
      "label": "ui-gallery-virtual-list-bottom-typical",
      "max_snapshots": 180
    },
    { "type": "wait_frames", "n": 2 }
  ]
}
