{
  "schema_version": 2,
  "steps": [
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-nav-scroll" }
      },
      "timeout_frames": 240
    },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-nav-search" }
      },
      "timeout_frames": 240
    },

    { "type": "click", "target": { "kind": "test_id", "id": "ui-gallery-nav-search" } },
    { "type": "press_key", "key": "a", "modifiers": { "ctrl": true } },
    { "type": "press_key", "key": "backspace" },
    { "type": "type_text", "text": "bidi" },
    { "type": "wait_frames", "n": 2 },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "bounds_within_window",
        "target": {
          "kind": "test_id",
          "id": "ui-gallery-nav-text-bidi-rtl-conformance"
        },
        "padding_px": 8.0,
        "eps_px": 1.0
      },
      "timeout_frames": 300
    },
    {
      "type": "click",
      "target": { "kind": "test_id", "id": "ui-gallery-nav-text-bidi-rtl-conformance" }
    },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": {
          "kind": "test_id",
          "id": "ui-gallery-text-bidi-rtl-conformance-root"
        }
      },
      "timeout_frames": 240
    },
    { "type": "wait_frames", "n": 10 },

    { "type": "click", "target": { "kind": "test_id", "id": "ui-gallery-text-bidi-sample-btn-1" } },
    { "type": "wait_frames", "n": 10 },
    { "type": "assert", "predicate": { "kind": "render_text_font_trace_captured_when_missing_glyphs" } },
    { "type": "assert", "predicate": { "kind": "render_text_missing_glyphs_is", "missing_glyphs": 0 } },
    { "type": "capture_bundle", "label": "ui-gallery-text-bidi-font-fallback-cjk" },
    { "type": "capture_screenshot", "label": "ui-gallery-text-bidi-font-fallback-cjk" },

    { "type": "click", "target": { "kind": "test_id", "id": "ui-gallery-text-bidi-sample-btn-2" } },
    { "type": "wait_frames", "n": 10 },
    { "type": "assert", "predicate": { "kind": "render_text_font_trace_captured_when_missing_glyphs" } },
    { "type": "assert", "predicate": { "kind": "render_text_missing_glyphs_is", "missing_glyphs": 0 } },
    { "type": "capture_bundle", "label": "ui-gallery-text-bidi-font-fallback-mixed-ltr-cjk" },
    { "type": "capture_screenshot", "label": "ui-gallery-text-bidi-font-fallback-mixed-ltr-cjk" },

    { "type": "click", "target": { "kind": "test_id", "id": "ui-gallery-text-bidi-sample-btn-8" } },
    { "type": "wait_frames", "n": 10 },
    { "type": "assert", "predicate": { "kind": "render_text_font_trace_captured_when_missing_glyphs" } },
    { "type": "assert", "predicate": { "kind": "render_text_missing_glyphs_is", "missing_glyphs": 0 } },
    { "type": "capture_bundle", "label": "ui-gallery-text-bidi-font-fallback-emoji-rtl" },
    { "type": "capture_screenshot", "label": "ui-gallery-text-bidi-font-fallback-emoji-rtl" }
  ]
}
