{
  "schema_version": 2,
  "meta": {
    "name": "UI gallery: Settings / Menu bar surfaces select shadow screenshots (zinc light)",
    "tags": ["ui-gallery", "settings", "shadcn", "select", "screenshots", "zinc-light"],
    "required_capabilities": ["diag.script_v2", "diag.screenshot_png"],
    "target_hints": [
      "Sets theme preset to zinc/light.",
      "Opens UI gallery settings sheet.",
      "Opens both Menu bar surfaces Select controls and captures screenshots/bundles to detect shadow clipping."
    ]
  },
  "steps": [
    { "type": "reset_diagnostics" },
    { "type": "press_key", "key": "escape" },
    { "type": "wait_frames", "n": 2 },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-theme-preset-trigger" }
      },
      "timeout_frames": 600
    },
    { "type": "click", "target": { "kind": "test_id", "id": "ui-gallery-theme-preset-trigger" } },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-theme-preset-item-zinc-light" }
      },
      "timeout_frames": 600
    },
    { "type": "click_stable", "target": { "kind": "test_id", "id": "ui-gallery-theme-preset-item-zinc-light" } },
    { "type": "wait_frames", "n": 2 },
    { "type": "press_key", "key": "escape" },
    { "type": "wait_frames", "n": 4 },
    {
      "type": "wait_until",
      "predicate": { "kind": "exists", "target": { "kind": "test_id", "id": "ui-gallery-settings-open" } },
      "timeout_frames": 600
    },
    { "type": "click", "target": { "kind": "test_id", "id": "ui-gallery-settings-open" } },
    { "type": "wait_frames", "n": 8 },

    {
      "type": "wait_until",
      "predicate": { "kind": "exists", "target": { "kind": "test_id", "id": "ui-gallery-settings-os-menubar" } },
      "timeout_frames": 600
    },
    { "type": "click_stable", "target": { "kind": "test_id", "id": "ui-gallery-settings-os-menubar" } },
    {
      "type": "wait_until",
      "predicate": { "kind": "exists", "target": { "kind": "test_id", "id": "ui-gallery-settings-os-menubar-auto" } },
      "timeout_frames": 600
    },
    { "type": "wait_frames", "n": 4 },
    { "type": "capture_bundle", "label": "ui-gallery-settings-menubar-surfaces-os-menubar-select-open-zinc-light" },
    { "type": "capture_screenshot", "label": "ui-gallery-settings-menubar-surfaces-os-menubar-select-open-zinc-light" },
    { "type": "press_key", "key": "escape" },
    { "type": "wait_frames", "n": 6 },

    { "type": "click_stable", "target": { "kind": "test_id", "id": "ui-gallery-settings-in-window-menubar" } },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-settings-in-window-menubar-auto" }
      },
      "timeout_frames": 600
    },
    { "type": "wait_frames", "n": 4 },
    { "type": "capture_bundle", "label": "ui-gallery-settings-menubar-surfaces-in-window-select-open-zinc-light" },
    { "type": "capture_screenshot", "label": "ui-gallery-settings-menubar-surfaces-in-window-select-open-zinc-light" }
  ]
}
