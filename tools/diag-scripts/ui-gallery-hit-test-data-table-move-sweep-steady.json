{
  "schema_version": 2,
  "steps": [
    { "type": "press_key", "key": "escape" },
    { "type": "wait_frames", "n": 2 },

    { "type": "set_window_inner_size", "width_px": 1280.0, "height_px": 960.0 },
    { "type": "wait_frames", "n": 2 },

    { "type": "click", "target": { "kind": "test_id", "id": "ui-gallery-nav-data-table-torture" } },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "focus_is",
        "target": { "kind": "test_id", "id": "ui-gallery-nav-data-table-torture" }
      },
      "timeout_frames": 240
    },
    { "type": "press_key", "key": "enter" },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-data-table-torture-root" }
      },
      "timeout_frames": 240
    },
    { "type": "wait_frames", "n": 2 },

    { "type": "reset_diagnostics" },

    { "type": "move_pointer", "target": { "kind": "test_id", "id": "ui-gallery-data-table-torture-root" } },
    { "type": "wait_frames", "n": 1 },

    {
      "type": "move_pointer_sweep",
      "target": { "kind": "test_id", "id": "ui-gallery-data-table-torture-root" },
      "delta_x": 900.0,
      "delta_y": 360.0,
      "steps": 200
    },
    { "type": "wait_frames", "n": 2 },
    {
      "type": "move_pointer_sweep",
      "target": { "kind": "test_id", "id": "ui-gallery-data-table-torture-root" },
      "delta_x": -900.0,
      "delta_y": -360.0,
      "steps": 200
    },
    { "type": "wait_frames", "n": 2 },

    { "type": "capture_bundle", "label": "ui-gallery-hit-test-data-table-move-sweep-steady" },

    { "type": "press_key", "key": "escape" },
    { "type": "wait_frames", "n": 2 }
  ]
}
