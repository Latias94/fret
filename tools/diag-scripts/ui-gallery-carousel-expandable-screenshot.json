{
  "schema_version": 2,
  "meta": {
    "name": "UI gallery: carousel expandable screenshots",
    "tags": ["ui-gallery", "carousel", "expandable", "screenshot"],
    "required_capabilities": ["diag.script_v2", "diag.screenshot_png"]
  },
  "steps": [
    { "type": "reset_diagnostics" },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-nav-search" }
      },
      "timeout_frames": 600
    },
    { "type": "press_key", "key": "escape" },
    { "type": "wait_frames", "n": 2 },

    { "type": "set_window_inner_size", "width_px": 1280.0, "height_px": 720.0 },
    { "type": "wait_frames", "n": 10 },

    { "type": "click", "target": { "kind": "test_id", "id": "ui-gallery-nav-search" } },
    { "type": "press_key", "key": "a", "modifiers": { "ctrl": true } },
    { "type": "press_key", "key": "backspace" },
    { "type": "type_text", "text": "carousel" },
    { "type": "wait_frames", "n": 2 },
    { "type": "click", "target": { "kind": "test_id", "id": "ui-gallery-nav-carousel" } },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-page-carousel" }
      },
      "timeout_frames": 600
    },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-carousel-expandable" }
      },
      "timeout_frames": 600
    },
    {
      "type": "scroll_into_view",
      "container": { "kind": "test_id", "id": "ui-gallery-content-scroll" },
      "target": { "kind": "test_id", "id": "ui-gallery-carousel-expandable" },
      "delta_y": -120.0,
      "require_fully_within_container": true,
      "require_fully_within_window": true,
      "padding_px": 16.0,
      "timeout_frames": 600
    },

    { "type": "wait_frames", "n": 24 },
    { "type": "capture_bundle", "label": "ui-gallery-carousel-expandable-before" },
    { "type": "capture_screenshot", "label": "ui-gallery-carousel-expandable-before" },

    {
      "type": "click_stable",
      "target": { "kind": "test_id", "id": "ui-gallery-carousel-expandable-item-1" }
    },
    { "type": "wait_frames", "n": 40 },
    { "type": "capture_bundle", "label": "ui-gallery-carousel-expandable-after" },
    { "type": "capture_screenshot", "label": "ui-gallery-carousel-expandable-after" }
  ]
}
