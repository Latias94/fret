{
  "schema_version": 2,
  "meta": {
    "name": "ui-gallery-material3-slider-set-value-expressive-screenshots",
    "required_capabilities": ["diag.script_v2", "diag.screenshot_png"],
    "tags": ["ui_gallery", "material3", "slider", "expressive", "set_slider_value", "screenshots"]
  },
  "steps": [
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-nav-search" }
      },
      "timeout_frames": 600
    },
    { "type": "click", "target": { "kind": "test_id", "id": "ui-gallery-nav-search" } },
    { "type": "press_key", "key": "a", "modifiers": { "ctrl": true } },
    { "type": "press_key", "key": "backspace" },
    { "type": "type_text", "text": "slider" },
    { "type": "wait_frames", "n": 2 },
    {
      "type": "ensure_visible",
      "target": { "kind": "test_id", "id": "ui-gallery-nav-material3-slider" },
      "within_window": true,
      "padding_px": 8.0,
      "timeout_frames": 600
    },
    { "type": "click", "target": { "kind": "test_id", "id": "ui-gallery-nav-material3-slider" } },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-page-material3-slider" }
      },
      "timeout_frames": 600
    },
    { "type": "wait_frames", "n": 20 },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "role_is",
        "target": { "kind": "test_id", "id": "ui-gallery-material3-slider" },
        "role": "slider"
      },
      "timeout_frames": 600
    },
    {
      "type": "ensure_visible",
      "target": { "kind": "test_id", "id": "ui-gallery-material3-slider" },
      "within_window": true,
      "padding_px": 8.0,
      "timeout_frames": 600
    },
    { "type": "capture_bundle", "label": "m3-slider-00-standard-idle" },
    { "type": "capture_screenshot", "label": "m3-slider-00-standard-idle" },
    {
      "type": "set_slider_value",
      "target": { "kind": "test_id", "id": "ui-gallery-material3-slider" },
      "value": 0.8,
      "min": 0.0,
      "max": 1.0,
      "epsilon": 0.02,
      "timeout_frames": 240,
      "drag_steps": 8
    },
    { "type": "wait_frames", "n": 2 },
    { "type": "capture_bundle", "label": "m3-slider-10-standard-set-0p8" },
    { "type": "capture_screenshot", "label": "m3-slider-10-standard-set-0p8" },
    {
      "type": "click",
      "target": { "kind": "test_id", "id": "ui-gallery-material3-design-variant-toggle" }
    },
    { "type": "wait_frames", "n": 10 },
    { "type": "capture_bundle", "label": "m3-slider-20-expressive-idle" },
    { "type": "capture_screenshot", "label": "m3-slider-20-expressive-idle" },
    {
      "type": "set_slider_value",
      "target": { "kind": "test_id", "id": "ui-gallery-material3-slider" },
      "value": 0.2,
      "min": 0.0,
      "max": 1.0,
      "epsilon": 0.02,
      "timeout_frames": 240,
      "drag_steps": 8
    },
    { "type": "wait_frames", "n": 2 },
    { "type": "capture_bundle", "label": "m3-slider-30-expressive-set-0p2" },
    { "type": "capture_screenshot", "label": "m3-slider-30-expressive-set-0p2" },
    { "type": "capture_bundle", "label": "ui-gallery-material3-slider-set-value-expressive" }
  ]
}

