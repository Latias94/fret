{
  "schema_version": 2,
  "meta": {
    "name": "ui-gallery-material3-switch-icon-color-crossfade-timeline-screenshots",
    "required_capabilities": ["diag.script_v2", "diag.screenshot_png"],
    "tags": ["ui_gallery", "material3", "switch", "icons", "color", "crossfade", "timeline", "screenshots"]
  },
  "steps": [
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-nav-search" }
      },
      "timeout_frames": 600
    },
    { "type": "click", "target": { "kind": "test_id", "id": "ui-gallery-nav-search" } },
    { "type": "press_key", "key": "a", "modifiers": { "ctrl": true } },
    { "type": "press_key", "key": "backspace" },
    { "type": "type_text", "text": "switch" },
    { "type": "wait_frames", "n": 2 },
    {
      "type": "ensure_visible",
      "target": { "kind": "test_id", "id": "ui-gallery-nav-material3-switch" },
      "within_window": true,
      "padding_px": 8.0,
      "timeout_frames": 600
    },
    { "type": "click", "target": { "kind": "test_id", "id": "ui-gallery-nav-material3-switch" } },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-page-material3-switch" }
      },
      "timeout_frames": 600
    },
    { "type": "wait_frames", "n": 20 },

    {
      "type": "wait_until",
      "predicate": {
        "kind": "checked_is",
        "target": { "kind": "test_id", "id": "ui-gallery-material3-switch-icons-both" },
        "checked": false
      },
      "timeout_frames": 600
    },

    { "type": "capture_screenshot", "label": "m3-switch-icons-both-color-00-off" },
    { "type": "move_pointer", "target": { "kind": "test_id", "id": "ui-gallery-material3-switch-icons-both" } },
    { "type": "capture_screenshot", "label": "m3-switch-icons-both-color-10-hover-frame0" },
    { "type": "wait_frames", "n": 1 },
    { "type": "capture_screenshot", "label": "m3-switch-icons-both-color-11-hover-frame1" },
    { "type": "wait_frames", "n": 1 },
    { "type": "capture_screenshot", "label": "m3-switch-icons-both-color-12-hover-frame2" },
    { "type": "wait_frames", "n": 2 },
    { "type": "capture_screenshot", "label": "m3-switch-icons-both-color-13-hover-rest" },

    { "type": "pointer_down", "target": { "kind": "test_id", "id": "ui-gallery-material3-switch-icons-both" } },
    { "type": "capture_screenshot", "label": "m3-switch-icons-both-color-20-pressed-frame0" },
    { "type": "wait_frames", "n": 1 },
    { "type": "capture_screenshot", "label": "m3-switch-icons-both-color-21-pressed-frame1" },
    { "type": "wait_frames", "n": 2 },
    { "type": "capture_screenshot", "label": "m3-switch-icons-both-color-22-pressed-rest" },
    { "type": "pointer_up" },

    { "type": "capture_bundle", "label": "ui-gallery-material3-switch-icon-color-crossfade-timeline" }
  ]
}

