{
  "schema_version": 2,
  "meta": {
    "notes": [
      "Liquid glass CustomV3 pair screenshot with BackdropSourceGroup enabled.",
      "This exercises the ADR 0305 ceiling: multiple CustomV3 surfaces sharing a stable raw snapshot + pyramid."
    ]
  },
  "steps": [
    { "type": "set_window_inner_size", "width_px": 1280.0, "height_px": 720.0 },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "liquid-glass-switch-custom-v3-source-group" }
      },
      "timeout_frames": 600
    },

    { "type": "click_stable", "target": { "kind": "test_id", "id": "liquid-glass-switch-show-fake" }, "stable_frames": 6, "max_move_px": 0.5, "timeout_frames": 600 },
    { "type": "click_stable", "target": { "kind": "test_id", "id": "liquid-glass-switch-show-warp-v1" }, "stable_frames": 6, "max_move_px": 0.5, "timeout_frames": 600 },
    { "type": "click_stable", "target": { "kind": "test_id", "id": "liquid-glass-switch-show-warp-v2" }, "stable_frames": 6, "max_move_px": 0.5, "timeout_frames": 600 },
    { "type": "click_stable", "target": { "kind": "test_id", "id": "liquid-glass-switch-show-custom-v2" }, "stable_frames": 6, "max_move_px": 0.5, "timeout_frames": 600 },

    { "type": "click_stable", "target": { "kind": "test_id", "id": "liquid-glass-switch-show-custom-v3" }, "stable_frames": 6, "max_move_px": 0.5, "timeout_frames": 600 },
    { "type": "click_stable", "target": { "kind": "test_id", "id": "liquid-glass-switch-custom-v3-pair" }, "stable_frames": 6, "max_move_px": 0.5, "timeout_frames": 600 },
    { "type": "click_stable", "target": { "kind": "test_id", "id": "liquid-glass-switch-custom-v3-source-group" }, "stable_frames": 6, "max_move_px": 0.5, "timeout_frames": 600 },

    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "liquid-glass-lens-custom-v3" }
      },
      "timeout_frames": 600
    },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "liquid-glass-lens-custom-v3-b" }
      },
      "timeout_frames": 600
    },

    { "type": "wait_frames", "n": 12 },
    { "type": "reset_diagnostics" },

    { "type": "wait_frames", "n": 120 },
    { "type": "capture_screenshot", "label": "liquid-glass-lens-custom-v3-source-group" },
    { "type": "capture_bundle", "label": "liquid-glass-lens-custom-v3-source-group" }
  ]
}

