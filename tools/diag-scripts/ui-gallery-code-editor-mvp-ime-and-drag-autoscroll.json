{
  "schema_version": 2,
  "steps": [
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-nav-search" }
      },
      "timeout_frames": 240
    },
    { "type": "click", "target": { "kind": "test_id", "id": "ui-gallery-nav-search" } },
    { "type": "press_key", "key": "a", "modifiers": { "ctrl": true } },
    { "type": "press_key", "key": "backspace" },
    { "type": "type_text", "text": "code_editor_mvp" },
    { "type": "wait_frames", "n": 2 },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "bounds_within_window",
        "target": { "kind": "test_id", "id": "ui-gallery-nav-code-editor-mvp" },
        "padding_px": 8.0,
        "eps_px": 1.0
      },
      "timeout_frames": 240
    },
    { "type": "click", "target": { "kind": "test_id", "id": "ui-gallery-nav-code-editor-mvp" } },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-code-editor-root" }
      },
      "timeout_frames": 240
    },
    { "type": "wait_frames", "n": 10 },
    { "type": "click", "target": { "kind": "test_id", "id": "ui-gallery-code-editor-mvp-viewport" } },
    { "type": "wait_frames", "n": 2 },

    { "type": "type_text", "text": "diag-autoscroll" },
    { "type": "press_key", "key": "enter" },
    { "type": "wait_frames", "n": 2 },

    { "type": "reset_diagnostics" },
    {
      "type": "drag_pointer",
      "target": { "kind": "test_id", "id": "ui-gallery-code-editor-mvp-viewport" },
      "delta_x": 0.0,
      "delta_y": -1200.0,
      "steps": 180
    },
    { "type": "wait_frames", "n": 10 },
    {
      "type": "drag_pointer",
      "target": { "kind": "test_id", "id": "ui-gallery-code-editor-mvp-viewport" },
      "delta_x": 0.0,
      "delta_y": 1200.0,
      "steps": 180
    },
    { "type": "wait_frames", "n": 10 },
    { "type": "capture_bundle", "label": "ui-gallery-code-editor-mvp-drag-autoscroll" },

    { "type": "click", "target": { "kind": "test_id", "id": "ui-gallery-code-editor-mvp-viewport" } },
    { "type": "wait_frames", "n": 2 },
    { "type": "capture_bundle", "label": "ui-gallery-code-editor-mvp-ime-before" },
    { "type": "reset_diagnostics" },
    { "type": "wait_frames", "n": 360 },
    { "type": "capture_bundle", "label": "ui-gallery-code-editor-mvp-ime-after" }
  ]
}
