{
  "schema_version": 2,
  "steps": [
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-nav-search" }
      },
      "timeout_frames": 240
    },
    { "type": "click", "target": { "kind": "test_id", "id": "ui-gallery-nav-search" } },
    { "type": "press_key", "key": "a", "modifiers": { "ctrl": true } },
    { "type": "press_key", "key": "backspace" },
    { "type": "type_text", "text": "ai suggestions" },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-nav-ai-suggestions-demo" }
      },
      "timeout_frames": 240
    },
    {
      "type": "click",
      "target": { "kind": "test_id", "id": "ui-gallery-nav-ai-suggestions-demo" }
    },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-ai-suggestions-root" }
      },
      "timeout_frames": 240
    },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "bounds_within_window",
        "target": { "kind": "test_id", "id": "ui-ai-suggestion-architecture" },
        "padding_px": 8.0,
        "eps_px": 1.0
      },
      "timeout_frames": 300
    },
    {
      "type": "click_stable",
      "target": { "kind": "test_id", "id": "ui-ai-suggestion-architecture" }
    },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-ai-suggestions-clicked-marker" }
      },
      "timeout_frames": 240
    },
    { "type": "wait_frames", "n": 10 },
    { "type": "capture_bundle", "label": "ui-gallery-ai-suggestions-demo-click" }
  ]
}
