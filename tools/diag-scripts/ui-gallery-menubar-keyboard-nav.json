{
  "schema_version": 1,
  "steps": [
    {
      "type": "click",
      "target": { "kind": "test_id", "id": "ui-gallery-nav-menus" }
    },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-menubar-file" }
      },
      "timeout_frames": 240
    },
    { "type": "press_key", "key": "f10" },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "focus_is",
        "target": { "kind": "test_id", "id": "ui-gallery-menubar-file" }
      },
      "timeout_frames": 120
    },
    { "type": "press_key", "key": "down" },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-menubar-open" }
      },
      "timeout_frames": 60
    },
    { "type": "press_key", "key": "escape" },
    { "type": "wait_frames", "n": 5 },
    { "type": "capture_bundle", "label": "ui-gallery-menubar-file-escape" }
  ]
}
