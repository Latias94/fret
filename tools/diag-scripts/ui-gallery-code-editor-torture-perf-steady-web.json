{
  "schema_version": 2,
  "steps": [
    { "type": "press_key", "key": "escape" },
    { "type": "wait_frames", "n": 2 },

    { "type": "set_window_inner_size", "width_px": 1280.0, "height_px": 720.0 },
    { "type": "wait_frames", "n": 2 },

    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-code-editor-torture-root" }
      },
      "timeout_frames": 1200
    },

    {
      "type": "wait_until",
      "predicate": { "kind": "font_catalog_populated" },
      "timeout_frames": 1800
    },

    { "type": "wait_frames", "n": 300 },

    { "type": "reset_diagnostics" },
    { "type": "wait_frames", "n": 240 },

    {
      "type": "capture_bundle",
      "label": "ui-gallery-code-editor-torture-perf-steady-web"
    },
    { "type": "wait_frames", "n": 2 }
  ]
}
