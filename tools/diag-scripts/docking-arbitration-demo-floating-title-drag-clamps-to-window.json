{
  "schema_version": 2,
  "meta": {
    "name": "Docking arbitration demo: floating title drag clamps to window bounds",
    "tags": ["docking", "floating", "gate"],
    "required_capabilities": ["diag.script_v2"],
    "target_hints": [
      "Create an in-window floating container via float-zone, then drag its title bar far outside the window.",
      "Expected behavior: the floating rect is clamped to window bounds (ImGui-style hand feel) and the drag is observed by diagnostics."
    ]
  },
  "steps": [
    { "type": "press_key", "key": "escape" },
    { "type": "wait_frames", "n": 2 },

    { "type": "set_window_outer_position", "x_px": 120.0, "y_px": 120.0 },
    { "type": "set_window_inner_size", "width_px": 1600.0, "height_px": 900.0 },
    { "type": "wait_frames", "n": 2 },

    {
      "type": "wait_until",
      "predicate": { "kind": "exists", "target": { "kind": "test_id", "id": "dock-arb-dock-space" } },
      "timeout_frames": 240
    },
    {
      "type": "wait_until",
      "predicate": { "kind": "exists", "target": { "kind": "test_id", "id": "dock-arb-tab-drag-anchor-right" } },
      "timeout_frames": 240
    },
    {
      "type": "wait_until",
      "predicate": { "kind": "exists", "target": { "kind": "test_id", "id": "dock-arb-float-zone-anchor" } },
      "timeout_frames": 240
    },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "dock_graph_signature_is",
        "signature": "dock(root=split(v,[split(h,[tabs([demo.viewport.left]),tabs([demo.viewport.right])]),tabs([demo.controls])]);floatings=[])"
      },
      "timeout_frames": 240
    },

    {
      "type": "drag_to",
      "from": { "kind": "test_id", "id": "dock-arb-tab-drag-anchor-right" },
      "to": { "kind": "test_id", "id": "dock-arb-float-zone-anchor" },
      "steps": 48,
      "timeout_frames": 240
    },
    { "type": "wait_until", "predicate": { "kind": "dock_drag_active_is", "active": false }, "timeout_frames": 240 },
    { "type": "wait_until", "predicate": { "kind": "dock_graph_signature_contains", "needle": "floating(" }, "timeout_frames": 240 },

    {
      "type": "wait_until",
      "predicate": {
        "kind": "bounds_within_window",
        "target": { "kind": "test_id", "id": "dock-arb-floating-title-bar-anchor" },
        "padding_px": 4.0
      },
      "timeout_frames": 240
    },

    { "type": "pointer_down", "target": { "kind": "test_id", "id": "dock-arb-floating-title-bar-anchor" } },
    { "type": "pointer_move", "delta_x": 4.0, "delta_y": 0.0, "steps": 2 },
    { "type": "wait_until", "predicate": { "kind": "dock_floating_drag_active_is", "active": true }, "timeout_frames": 120 },
    { "type": "pointer_move", "delta_x": -4000.0, "delta_y": -4000.0, "steps": 80 },
    { "type": "pointer_up" },
    { "type": "wait_until", "predicate": { "kind": "dock_floating_drag_active_is", "active": false }, "timeout_frames": 120 },
    { "type": "wait_frames", "n": 2 },

    {
      "type": "assert",
      "predicate": {
        "kind": "bounds_within_window",
        "target": { "kind": "test_id", "id": "dock-arb-floating-title-bar-anchor" },
        "padding_px": 4.0
      }
    },
    { "type": "assert", "predicate": { "kind": "dock_graph_canonical_is", "canonical": true } },
    { "type": "assert", "predicate": { "kind": "dock_graph_has_nested_same_axis_splits_is", "has_nested": false } },

    { "type": "capture_bundle", "label": "docking-arbitration-demo-floating-title-drag-clamps-to-window" },
    { "type": "wait_frames", "n": 2 }
  ]
}
