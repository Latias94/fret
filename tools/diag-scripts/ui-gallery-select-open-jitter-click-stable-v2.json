      "target": { "kind": "test_id", "id": "ui-gallery-select-item-banana" },
      "stable_frames": 2,
      "max_move_px": 1.0,
      "timeout_frames": 180
    },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "not_exists",
        "target": { "kind": "test_id", "id": "select-scroll-viewport" }
