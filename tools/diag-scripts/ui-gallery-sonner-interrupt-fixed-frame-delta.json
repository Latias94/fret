{
  "schema_version": 2,
  "steps": [
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-nav-search" }
      },
      "timeout_frames": 240
    },
    { "type": "click", "target": { "kind": "test_id", "id": "ui-gallery-nav-search" } },
    { "type": "press_key", "key": "a", "modifiers": { "ctrl": true } },
    { "type": "press_key", "key": "backspace" },
    { "type": "type_text", "text": "sonner" },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-nav-sonner" }
      },
      "timeout_frames": 240
    },
    { "type": "click", "target": { "kind": "test_id", "id": "ui-gallery-nav-sonner" } },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-page-sonner" }
      },
      "timeout_frames": 240
    },

    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-sonner-demo-show" }
      },
      "timeout_frames": 240
    },

    { "type": "click", "target": { "kind": "test_id", "id": "ui-gallery-sonner-demo-show" } },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "toast-entry-1" }
      },
      "timeout_frames": 240
    },

    {
      "type": "click_stable",
      "target": { "kind": "role_and_name", "role": "button", "name": "Close toast" },
      "stable_frames": 6,
      "max_move_px": 1.0,
      "timeout_frames": 240
    },
    { "type": "wait_frames", "n": 1 },

    { "type": "click", "target": { "kind": "test_id", "id": "ui-gallery-sonner-demo-show" } },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "toast-entry-2" }
      },
      "timeout_frames": 240
    },
    {
      "type": "assert",
      "predicate": { "kind": "exists", "target": { "kind": "test_id", "id": "toast-entry-1" } }
    },

    {
      "type": "wait_until",
      "predicate": {
        "kind": "not_exists",
        "target": { "kind": "test_id", "id": "toast-entry-1" }
      },
      "timeout_frames": 240
    },

    { "type": "capture_bundle", "label": "ui-gallery-sonner-interrupt-fixed-frame-delta" }
  ]
}
