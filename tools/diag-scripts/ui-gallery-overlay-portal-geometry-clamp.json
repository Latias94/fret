{
  "schema_version": 1,
  "steps": [
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-nav-scroll" }
      },
      "timeout_frames": 240
    },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-nav-search" }
      },
      "timeout_frames": 240
    },

    { "type": "click", "target": { "kind": "test_id", "id": "ui-gallery-nav-search" } },
    { "type": "press_key", "key": "a", "modifiers": { "ctrl": true } },
    { "type": "press_key", "key": "backspace" },
    { "type": "type_text", "text": "overlay" },
    { "type": "wait_frames", "n": 2 },
    {
      "type": "wheel",
      "target": { "kind": "test_id", "id": "ui-gallery-nav-scroll" },
      "delta_y": 2000.0
    },
    { "type": "wait_frames", "n": 2 },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "bounds_within_window",
        "target": { "kind": "test_id", "id": "ui-gallery-nav-overlay" },
        "padding_px": 8.0,
        "eps_px": 1.0
      },
      "timeout_frames": 240
    },
    { "type": "click", "target": { "kind": "test_id", "id": "ui-gallery-nav-overlay" } },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-page-overlay" }
      },
      "timeout_frames": 240
    },
    { "type": "wait_frames", "n": 30 },

    { "type": "click", "target": { "kind": "test_id", "id": "ui-gallery-portal-geometry-trigger" } },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-portal-geometry-popover-content" }
      },
      "timeout_frames": 240
    },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "bounds_within_window",
        "target": { "kind": "test_id", "id": "ui-gallery-portal-geometry-popover-content" },
        "padding_px": 0.0,
        "eps_px": 1.0
      },
      "timeout_frames": 240
    },
    { "type": "capture_bundle", "label": "ui-gallery-overlay-portal-geometry-open" },
    { "type": "capture_screenshot", "label": "ui-gallery-overlay-portal-geometry-open" },

    {
      "type": "wheel",
      "target": { "kind": "test_id", "id": "ui-gallery-portal-geometry-scroll-area" },
      "delta_y": 600.0
    },
    { "type": "wait_frames", "n": 10 },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "bounds_within_window",
        "target": { "kind": "test_id", "id": "ui-gallery-portal-geometry-popover-content" },
        "padding_px": 0.0,
        "eps_px": 1.0
      },
      "timeout_frames": 240
    },
    { "type": "capture_bundle", "label": "ui-gallery-overlay-portal-geometry-after-scroll" },
    { "type": "capture_screenshot", "label": "ui-gallery-overlay-portal-geometry-after-scroll" },

    { "type": "click", "target": { "kind": "test_id", "id": "ui-gallery-portal-geometry-popover-close" } },
    { "type": "wait_frames", "n": 10 }
  ]
}
