{
  "meta": {
    "name": "ui-gallery-control-chrome-button-group-flex1-item-fill",
    "required_capabilities": ["diag.script_v2"]
  },
  "schema_version": 2,
  "steps": [
    { "type": "reset_diagnostics" },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-nav-search" }
      },
      "timeout_frames": 600
    },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-nav-scroll" }
      },
      "timeout_frames": 600
    },
    { "type": "press_key", "key": "escape" },
    { "type": "wait_frames", "n": 2 },
    { "type": "set_window_inner_size", "width_px": 1280.0, "height_px": 720.0 },
    { "type": "wait_frames", "n": 15 },

    { "type": "click", "target": { "kind": "test_id", "id": "ui-gallery-nav-search" } },
    { "type": "press_key", "key": "a", "modifiers": { "ctrl": true } },
    { "type": "press_key", "key": "backspace" },
    { "type": "type_text", "text": "button group" },
    { "type": "wait_frames", "n": 2 },

    {
      "type": "scroll_into_view",
      "container": { "kind": "test_id", "id": "ui-gallery-nav-scroll" },
      "target": { "kind": "test_id", "id": "ui-gallery-nav-button-group" },
      "delta_y": -240.0,
      "timeout_frames": 600
    },
    { "type": "click", "target": { "kind": "test_id", "id": "ui-gallery-nav-button-group" } },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-page-button-group" }
      },
      "timeout_frames": 600
    },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-button-group-flex1" }
      },
      "timeout_frames": 600
    },

    {
      "type": "wait_until",
      "predicate": {
        "kind": "bounds_min_size",
        "target": { "kind": "test_id", "id": "ui-gallery-button-group-flex1-overview" },
        "min_w_px": 120.0,
        "min_h_px": 0.0,
        "eps_px": 1.0
      },
      "timeout_frames": 240
    },
    {
      "type": "assert",
      "predicate": {
        "kind": "bounds_approx_equal",
        "a": { "kind": "test_id", "id": "ui-gallery-button-group-flex1-overview" },
        "b": { "kind": "test_id", "id": "ui-gallery-button-group-flex1-overview.chrome" },
        "eps_px": 1.0
      }
    },
    {
      "type": "assert",
      "predicate": {
        "kind": "bounds_approx_equal",
        "a": { "kind": "test_id", "id": "ui-gallery-button-group-flex1-analytics" },
        "b": { "kind": "test_id", "id": "ui-gallery-button-group-flex1-analytics.chrome" },
        "eps_px": 1.0
      }
    },
    {
      "type": "assert",
      "predicate": {
        "kind": "bounds_approx_equal",
        "a": { "kind": "test_id", "id": "ui-gallery-button-group-flex1-reports" },
        "b": { "kind": "test_id", "id": "ui-gallery-button-group-flex1-reports.chrome" },
        "eps_px": 1.0
      }
    },

    {
      "type": "capture_bundle",
      "label": "ui-gallery-control-chrome-button-group-flex1-item-fill"
    }
  ]
}
