{
  "schema_version": 2,
  "meta": {
    "env_defaults": {
      "FRET_DIAG_RENDERER_PERF": 1,
      "FRET_RENDER_WGPU_INTERMEDIATE_BUDGET_BYTES": 134217728
    },
    "notes": [
      "Liquid glass CustomV3 pair screenshot without BackdropSourceGroup (two independent scopes).",
      "This intentionally exercises the frame-local CustomV3 pyramid reuse cache miss behavior: each scope builds its own pyramid, so cache misses should dominate (expected hint: renderer.custom_effect_v3_pyramid_cache_miss_heavy)."
    ]
  },
  "steps": [
    { "type": "set_window_inner_size", "width_px": 1280.0, "height_px": 720.0 },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "liquid-glass-switch-custom-v3-source-group" }
      },
      "timeout_frames": 600
    },
    {
      "type": "click_stable",
      "target": { "kind": "test_id", "id": "liquid-glass-switch-show-fake" },
      "stable_frames": 6,
      "max_move_px": 0.5,
      "timeout_frames": 600
    },
    {
      "type": "click_stable",
      "target": { "kind": "test_id", "id": "liquid-glass-switch-show-warp-v1" },
      "stable_frames": 6,
      "max_move_px": 0.5,
      "timeout_frames": 600
    },
    {
      "type": "click_stable",
      "target": { "kind": "test_id", "id": "liquid-glass-switch-show-custom-v3" },
      "stable_frames": 6,
      "max_move_px": 0.5,
      "timeout_frames": 600
    },
    {
      "type": "click_stable",
      "target": { "kind": "test_id", "id": "liquid-glass-switch-custom-v3-pair" },
      "stable_frames": 6,
      "max_move_px": 0.5,
      "timeout_frames": 600
    },
    {
      "type": "click_stable",
      "target": { "kind": "test_id", "id": "liquid-glass-switch-show-inspector" },
      "stable_frames": 6,
      "max_move_px": 0.5,
      "timeout_frames": 600
    },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "liquid-glass-slider-custom-v3-bevel-strength" }
      },
      "timeout_frames": 600
    },
    {
      "type": "set_slider_value",
      "target": { "kind": "test_id", "id": "liquid-glass-slider-custom-v3-bevel-angle-deg" },
      "value": 45.0,
      "min": 0.0,
      "max": 360.0,
      "epsilon": 1.0,
      "timeout_frames": 240,
      "drag_steps": 10
    },
    {
      "type": "set_slider_value",
      "target": { "kind": "test_id", "id": "liquid-glass-slider-custom-v3-bevel-secondary" },
      "value": 1.0,
      "min": 0.0,
      "max": 1.0,
      "epsilon": 0.02,
      "timeout_frames": 240,
      "drag_steps": 10
    },
    {
      "type": "set_slider_value",
      "target": { "kind": "test_id", "id": "liquid-glass-slider-custom-v3-bevel-strength" },
      "value": 1.0,
      "min": 0.0,
      "max": 1.0,
      "epsilon": 0.02,
      "timeout_frames": 240,
      "drag_steps": 10
    },
    {
      "type": "click_stable",
      "target": { "kind": "test_id", "id": "liquid-glass-switch-show-inspector" },
      "stable_frames": 6,
      "max_move_px": 0.5,
      "timeout_frames": 600
    },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "liquid-glass-lens-custom-v3" }
      },
      "timeout_frames": 600
    },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "liquid-glass-lens-custom-v3-b" }
      },
      "timeout_frames": 600
    },
    { "type": "wait_frames", "n": 12 },
    { "type": "reset_diagnostics" },
    { "type": "wait_frames", "n": 120 },
    { "type": "capture_screenshot", "label": "liquid-glass-lens-custom-v3-pair-no-group" },
    { "type": "capture_bundle", "label": "liquid-glass-lens-custom-v3-pair-no-group" }
  ]
}

