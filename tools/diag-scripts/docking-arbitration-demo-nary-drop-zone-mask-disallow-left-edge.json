{
  "schema_version": 2,
  "meta": {
    "name": "Docking arbitration demo: drop-zone mask can disallow the left edge (policy gate)",
    "tags": ["docking", "nary", "gate"],
    "required_capabilities": ["diag.script_v2"]
  },
  "steps": [
    { "type": "press_key", "key": "escape" },
    { "type": "wait_frames", "n": 5 },
    {
      "type": "wait_until",
      "predicate": { "kind": "exists", "target": { "kind": "test_id", "id": "dock-arb-tab-drag-anchor-right" } },
      "timeout_frames": 240
    },
    {
      "type": "wait_until",
      "predicate": { "kind": "exists", "target": { "kind": "test_id", "id": "dock-arb-toggle-drop-mask-left-edge" } },
      "timeout_frames": 240
    },
    { "type": "click", "target": { "kind": "test_id", "id": "dock-arb-toggle-drop-mask-left-edge" }, "button": "left" },
    {
      "type": "wait_until",
      "predicate": { "kind": "exists", "target": { "kind": "test_id", "id": "dock-arb-drop-mask-left-disallowed" } },
      "timeout_frames": 120
    },
    {
      "type": "wait_until",
      "predicate": { "kind": "dock_graph_canonical_is", "canonical": true },
      "timeout_frames": 240
    },
    {
      "type": "drag_pointer",
      "target": { "kind": "test_id", "id": "dock-arb-tab-drag-anchor-right" },
      "delta_x": -720.0,
      "delta_y": 346.0,
      "steps": 32
    },
    {
      "type": "wait_until",
      "predicate": { "kind": "dock_drop_resolve_source_is", "source": "outer_hint_rect" },
      "timeout_frames": 60
    },
    {
      "type": "wait_until",
      "predicate": { "kind": "dock_drop_resolved_is_some", "some": false },
      "timeout_frames": 60
    },
    {
      "type": "assert",
      "predicate": { "kind": "dock_graph_canonical_is", "canonical": true }
    },
    {
      "type": "capture_bundle",
      "label": "docking-arbitration-demo-nary-drop-zone-mask-disallow-left-edge"
    }
  ]
}
