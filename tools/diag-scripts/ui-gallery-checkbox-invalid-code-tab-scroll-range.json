{
  "schema_version": 2,
  "meta": {
    "name": "ui-gallery-checkbox-invalid-code-tab-scroll-range",
    "required_capabilities": ["diag.script_v2", "diag.screenshot_png"],
    "tags": ["ui_gallery", "shadcn", "checkbox", "tabs", "scroll", "regression"]
  },
  "steps": [
    { "type": "reset_diagnostics" },
    { "type": "press_key", "key": "escape" },
    { "type": "wait_frames", "n": 2 },
    { "type": "set_window_inner_size", "width_px": 1280.0, "height_px": 720.0 },
    { "type": "wait_frames", "n": 20 },

    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-nav-search" }
      },
      "timeout_frames": 600
    },
    {
      "type": "type_text_into",
      "target": { "kind": "test_id", "id": "ui-gallery-nav-search" },
      "text": "checkbox",
      "clear_before_type": true,
      "timeout_frames": 600
    },
    { "type": "wait_frames", "n": 4 },

    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-nav-checkbox" }
      },
      "timeout_frames": 600
    },
    {
      "type": "scroll_into_view",
      "container": { "kind": "test_id", "id": "ui-gallery-nav-scroll" },
      "target": { "kind": "test_id", "id": "ui-gallery-nav-checkbox" },
      "delta_y": -120.0,
      "require_fully_within_container": true,
      "require_fully_within_window": false,
      "padding_px": 0.0,
      "padding_insets_px": { "left_px": 0.0, "top_px": 24.0, "right_px": 0.0, "bottom_px": 24.0 },
      "timeout_frames": 600
    },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "bounds_within_window",
        "target": { "kind": "test_id", "id": "ui-gallery-nav-checkbox" },
        "padding_px": 0.0,
        "padding_insets_px": { "left_px": 0.0, "top_px": 24.0, "right_px": 0.0, "bottom_px": 24.0 },
        "eps_px": 1.0
      },
      "timeout_frames": 600
    },
    { "type": "click", "target": { "kind": "test_id", "id": "ui-gallery-nav-checkbox" } },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-page-checkbox" }
      },
      "timeout_frames": 600
    },

    {
      "type": "scroll_into_view",
      "container": { "kind": "test_id", "id": "ui-gallery-content-viewport" },
      "target": { "kind": "test_id", "id": "docsec-invalid-state-tabs-trigger-code" },
      "delta_y": -120.0,
      "require_fully_within_window": true,
      "padding_px": 24.0,
      "timeout_frames": 600
    },
    {
      "type": "click_stable",
      "target": { "kind": "test_id", "id": "docsec-invalid-state-tabs-trigger-code" },
      "stable_frames": 2,
      "max_move_px": 2.0,
      "timeout_frames": 900
    },
    { "type": "wait_frames", "n": 15 },
    { "type": "capture_bundle", "label": "ui-gallery-checkbox-invalid-code-tab-scroll-range.after-tab_switch" },

    {
      "type": "scroll_into_view",
      "container": { "kind": "test_id", "id": "ui-gallery-content-viewport" },
      "target": { "kind": "test_id", "id": "ui-gallery-checkbox-notes" },
      "delta_y": -120.0,
      "require_fully_within_window": true,
      "padding_px": 24.0,
      "timeout_frames": 900
    },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "bounds_within_window",
        "target": { "kind": "test_id", "id": "ui-gallery-checkbox-notes" },
        "padding_px": 24.0,
        "eps_px": 1.0
      },
      "timeout_frames": 900
    },
    { "type": "capture_screenshot", "label": "ui-gallery-checkbox-invalid-code-tab-scroll-range.notes_visible" },
    { "type": "capture_bundle", "label": "ui-gallery-checkbox-invalid-code-tab-scroll-range" }
  ]
}
