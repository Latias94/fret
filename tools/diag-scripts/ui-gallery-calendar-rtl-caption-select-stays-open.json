{
  "schema_version": 2,
  "meta": {
    "name": "UI Gallery: Calendar RTL caption selects do not auto-dismiss",
    "tags": ["ui-gallery", "calendar", "rtl", "select", "shadcn"],
    "required_capabilities": ["diag.script_v2"]
  },
  "steps": [
    { "type": "reset_diagnostics" },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-nav-search" }
      },
      "timeout_frames": 600
    },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-nav-scroll" }
      },
      "timeout_frames": 600
    },
    { "type": "press_key", "key": "escape" },
    { "type": "wait_frames", "n": 2 },
    { "type": "set_window_inner_size", "width_px": 1280.0, "height_px": 720.0 },
    { "type": "wait_frames", "n": 15 },

    {
      "type": "type_text_into",
      "target": { "kind": "test_id", "id": "ui-gallery-nav-search" },
      "text": "calendar",
      "clear_before_type": true,
      "timeout_frames": 600
    },
    { "type": "wait_frames", "n": 2 },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "bounds_within_window",
        "target": { "kind": "test_id", "id": "ui-gallery-nav-calendar" },
        "padding_px": 8.0,
        "eps_px": 1.0
      },
      "timeout_frames": 1800
    },
    {
      "type": "click",
      "target": { "kind": "test_id", "id": "ui-gallery-nav-calendar" }
    },
    {
      "type": "wait_until",
      "predicate": {
        "kind": "exists",
        "target": { "kind": "test_id", "id": "ui-gallery-page-calendar" }
      },
      "timeout_frames": 600
    },

    {
      "type": "scroll_into_view",
      "container": { "kind": "test_id", "id": "ui-gallery-content-scroll" },
      "target": {
        "kind": "test_id",
        "id": "ui-gallery.calendar.rtl.caption-month-trigger"
      },
      "delta_y": 240.0,
      "require_fully_within_window": true,
      "padding_px": 12.0,
      "timeout_frames": 1800
    },
    {
      "type": "wait_bounds_stable",
      "target": {
        "kind": "test_id",
        "id": "ui-gallery.calendar.rtl.caption-month-trigger"
      },
      "stable_frames": 6,
      "max_move_px": 1.0,
      "timeout_frames": 600
    },
    {
      "type": "pointer_down",
      "target": {
        "kind": "test_id",
        "id": "ui-gallery.calendar.rtl.caption-month-trigger"
      },
      "button": "left"
    },
    { "type": "wait_frames", "n": 2 },
    { "type": "pointer_up", "button": "left" },
    {
      "type": "wait_until",
      "predicate": { "kind": "exists", "target": { "kind": "test_id", "id": "select-scroll-viewport" } },
      "timeout_frames": 600
    },
    { "type": "wait_frames", "n": 15 },
    { "type": "assert", "predicate": { "kind": "exists", "target": { "kind": "test_id", "id": "select-scroll-viewport" } } },
    { "type": "press_key", "key": "escape" },
    {
      "type": "wait_until",
      "predicate": { "kind": "not_exists", "target": { "kind": "test_id", "id": "select-scroll-viewport" } },
      "timeout_frames": 600
    },

    {
      "type": "scroll_into_view",
      "container": { "kind": "test_id", "id": "ui-gallery-content-scroll" },
      "target": {
        "kind": "test_id",
        "id": "ui-gallery.calendar.rtl.caption-year-trigger"
      },
      "delta_y": 120.0,
      "require_fully_within_window": true,
      "padding_px": 12.0,
      "timeout_frames": 1800
    },
    {
      "type": "wait_bounds_stable",
      "target": {
        "kind": "test_id",
        "id": "ui-gallery.calendar.rtl.caption-year-trigger"
      },
      "stable_frames": 6,
      "max_move_px": 1.0,
      "timeout_frames": 600
    },
    {
      "type": "pointer_down",
      "target": {
        "kind": "test_id",
        "id": "ui-gallery.calendar.rtl.caption-year-trigger"
      },
      "button": "left"
    },
    { "type": "wait_frames", "n": 2 },
    { "type": "pointer_up", "button": "left" },
    {
      "type": "wait_until",
      "predicate": { "kind": "exists", "target": { "kind": "test_id", "id": "select-scroll-viewport" } },
      "timeout_frames": 600
    },
    { "type": "wait_frames", "n": 15 },
    { "type": "assert", "predicate": { "kind": "exists", "target": { "kind": "test_id", "id": "select-scroll-viewport" } } },

    { "type": "capture_bundle", "label": "ui-gallery-calendar-rtl-caption-select-stays-open" }
  ]
}
