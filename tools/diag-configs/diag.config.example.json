{
  "schema_version": 1,
  "enabled": true,
  "out_dir": "target/fret-diag",
  "paths": {
    "trigger_path": "trigger.touch",
    "ready_path": "ready.touch",
    "exit_path": "exit.touch",
    "script_path": "script.json",
    "script_trigger_path": "script.touch",
    "script_result_path": "script.result.json",
    "script_result_trigger_path": "script.result.touch",
    "pick_trigger_path": "pick.touch",
    "pick_result_path": "pick.result.json",
    "pick_result_trigger_path": "pick.result.touch",
    "inspect_path": "inspect.json",
    "inspect_trigger_path": "inspect.touch",
    "screenshot_request_path": "screenshots.request.json",
    "screenshot_trigger_path": "screenshots.touch",
    "screenshot_result_path": "screenshots.result.json",
    "screenshot_result_trigger_path": "screenshots.result.touch"
  },
  "max_events": 2000,
  "max_snapshots": 300,
  "script_dump_max_snapshots": 10,
  "capture_semantics": true,
  "max_semantics_nodes": 50000,
  "semantics_test_ids_only": false,
  "screenshots_enabled": false,
  "screenshot_on_dump": false,
  "redact_text": true,
  "max_debug_string_bytes": 2048,
  "max_gating_trace_entries": 200,
  "script_keepalive": true,
  "script_auto_dump": true,
  "pick_auto_dump": true,
  "frame_clock_fixed_delta_ms": null,
  "devtools_embed_bundle": null
}
