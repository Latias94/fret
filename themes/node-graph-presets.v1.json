        "optional": true,
        "node_corner_radius_px": 6.0,
        "node_header_height_px": 24.0,
        "pin_radius_px": 4.0,
        "wire_width_px": 1.5,
        "grid_minor_width_px": 1.0,
        "grid_major_width_px": 1.0
      },
      "interaction_state_matrix": {
        "node": {
          "base": { "use": ["node.body_background", "node.border"] },
          "hover": { "use": ["states.hover"] },
          "selected": { "use": ["node.ring_selected", "node.border_selected"] },
          "focused": { "use": ["node.ring_focused"] },
          "disabled": { "use": ["states.disabled"] },
          "invalid": { "use": ["states.invalid"] },
          "convertible": { "use": ["states.convertible"] }
        },
        "pin": {
          "base": { "use": ["port.by_port_kind.*"] },
          "hover": { "use": ["states.hover"] },
          "selected": { "use": ["states.hover"] },
          "focused": { "use": ["states.hover"] },
          "disabled": { "use": ["states.disabled"] },
          "invalid": { "use": ["states.invalid"] },
          "convertible": { "use": ["states.convertible"] }
        },
        "wire": {
          "base": { "use": ["wire.data_color", "wire.exec_color"] },
          "hover": { "use": ["states.hover"] },
          "selected": { "use": ["node.ring_selected"] },
          "focused": { "use": ["node.ring_focused"] },
          "disabled": { "use": ["states.disabled"] },
          "invalid": { "use": ["wire.dash_invalid", "states.invalid"] },
          "convertible": { "use": ["wire.dash_preview", "states.convertible"] }
        }
      },
      "example_compositions": [
        {
          "name": "example_1",
          "description": "A 'source' kind node with 'data' ports connected to a 'compute' kind node. A 'preview' port connected via dashed 'wire_preview'."
        },
        {
          "name": "example_2",
          "description": "Node A is selected (blue ring), Node B is focused (solid blue stroke). Hovering over a 'data' pin on Node C highlights it, and a dragged wire shows an 'invalid' red dashed line to an incompatible 'exec' pin."
        }
      ],
      "a11y_notes": {
        "target_contrast": "AA preferred",
        "risks": [
          "Header backgrounds may lack contrast with white node body; rely on border separation."
        ]
      }
    },
