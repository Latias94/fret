  "repro": {
    "summary": "Scaffold an external-style hello app, then run it through the public native `fretboard dev` surface; keep a self-hosted smoke that resolves and runs `fretboard` itself through the new Cargo-target selector.",
    "commands": [
      "cargo run -p fretboard -- new hello --name hello-world --path /tmp/fretboard-dev-hello --no-check",
      "cd /tmp/fretboard-dev-hello && cargo run -p fretboard -- dev native --manifest-path ./Cargo.toml",
      "cargo run -p fretboard -- dev native --manifest-path crates/fretboard/Cargo.toml --bin fretboard -- --help",
      "cargo run -p fretboard -- dev web --manifest-path apps/fret-demo-web/Cargo.toml --no-open --port 8091"
    ]
  },
