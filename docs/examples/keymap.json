    },
    {
      "command": "edit.paste",
      "platform": "macos",
      "when": "focus.is_text_input",
      "keys": { "mods": ["meta"], "key": "KeyV" }
    },
    {
      "command": "edit.select_all",
      "platform": "windows",
      "when": "focus.is_text_input",
      "keys": { "mods": ["ctrl"], "key": "KeyA" }
