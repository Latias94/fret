{
  "schema_version": 1,
  "notes": "Baseline wrap conformance fixtures for the renderer wrapper. These goldens are expected to change when upgrading line breaking (text-line-breaking-v1 M1/M2).",
  "cases": [
    {
      "id": "ascii_words_word_wrap",
      "text": "hello world hello world hello world",
      "font_family": "Fira Mono",
      "wrap": "word",
      "max_width_px": 60.0,
      "expected_line_ranges": [[0, 6], [6, 12], [12, 18], [18, 24], [24, 30], [30, 35]]
    },
    {
      "id": "ascii_words_grapheme_wrap",
      "text": "hello world hello world hello world",
      "font_family": "Fira Mono",
